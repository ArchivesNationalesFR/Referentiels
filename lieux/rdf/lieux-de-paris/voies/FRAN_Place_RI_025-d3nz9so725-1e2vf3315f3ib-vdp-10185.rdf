   <rico:Place rdf:about="place/FRAN_RI_025-d3nz9so725-1e2vf3315f3ib-vdp-10185">
      <skos:prefLabel xml:lang="fr">rue Debelleyme (3e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Debelleyme</skos:altLabel>
      <rico:name>rue Debelleyme (3e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Debelleyme (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz9so725-1e2vf3315f3ib-vdp-10185"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nz9so725-1e2vf3315f3ib-rue%20Debelleyme"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nz9so725-1e2vf3315f3ib"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/10185_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Précédemment rue Neuve Saint-François et rue Saint-François, entre la rue de Turenne et la rue Vieille du Temple ; rue de l'Echaudé au Marais, entre la rue Vieille du Temple et la rue de Poitou ; rue de Limoges, entre les rues de Poitou et de Bretagne ; rue de Périgueux ou du Périgord, entre les rues de Bretagne et de Turenne. [Origine du nom de la voie :] Louis Marie Debelleyme (1787-1862), magistrat et préfet de police, a longtemps habité ce quartier.</rico:history>
