   <rico:Activity rdf:about="activity/alignement-vdp-10185_1833-05-16_1911-12-22">
      <rico:generalDescription xml:lang="fr">Non retenus au PSMV du Marais : Ordonnance du 16 mai 1833, entre la rue de Turenne et la rue Vieille du Temple. Ordonnance du 31 mars 1835, entre la rue Vieille du Temple et la rue de Bretagne. Décret du 22 décembre 1911, pan coupé, côté impair, à l'angle de la rue de Bretagne, côté impair. Non retenus au POS et non repris au PLU : Ordonnance du 31 mars 1835, entre la rue de Bretagne et la rue de Turenne, 111.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nz9so725-1e2vf3315f3ib-vdp-10185"/>
