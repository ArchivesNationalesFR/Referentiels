   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nzdr8d1r--1o5u2mt1ra93k-vdp-14077_1938-02-16_1948-01-20">
      <rico:generalDescription xml:lang="fr">Non retenus au POS et non repris au PLU : Arrêté du 16 février 1938. Arrêté du 20 janvier 1948 (relatif à la rue Carducci), pan coupé à l'angle de cette dernière voie, côté impair. L'arrêté du 20 janvier 1948 (relatif à la rue des Solitaires) rapporte les alignements de la rue de la Villette au droit du n° 50 et approuve : 1° : pan coupé de 8 m sur le n° 48 ; 2° : un pan coupé de 20 m à l'angle de la rue des Solitaires, côté impair.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nzdr8d1r--1o5u2mt1ra93k-vdp-14077"/>
      <rico:hadSubevent rdf:resource="activity/alignement-FRAN_RI_025-d3nzdr8d1r--1o5u2mt1ra93k-vdp-14077_1938-02-16_1948-01-20_1938-02-16"/>
      <rico:hadSubevent rdf:resource="activity/alignement-FRAN_RI_025-d3nzdr8d1r--1o5u2mt1ra93k-vdp-14077_1938-02-16_1948-01-20_1948-01-20"/>
   </rico:Activity>
   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nzdr8d1r--1o5u2mt1ra93k-vdp-14077_1938-02-16_1948-01-20_1948-01-20">
