   <rico:Place rdf:about="place/FRAN_RI_025-d3nzdr8d1r--1o5u2mt1ra93k-vdp-14077">
      <rdfs:label xml:lang="fr">rue de la Villette (19e arrondissement, Paris, France ; id : 14077)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue de la Villette (19e arrondissement, Paris, France ; id : 14077)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de la Villette</skos:altLabel>
      <rico:name>rue de la Villette (19e arrondissement, Paris, France ; id : 14077)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Villette (rue de la)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzdr8d1r--1o5u2mt1ra93k-vdp-14077"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzdr8d1r--1o5u2mt1ra93k-rue%20de%20la%20Villette"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzdr8d1r--1o5u2mt1ra93k"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/14077_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Elle est tracée sur le plan de Roussel (1730). La partie comprise entre les rues de Belleville et Fessart porte sur le plan cadastral de 1812 le nom de rue des Sonneries. Avant 1865, la rue de la Villette se prolongeait jusqu'à la rue Compans. Un tronçon a été intégré à la rue d'Hautpoul par décret impérial du 2 octobre 1865, un autre intégré au parc des Buttes Chaumont. | Origine du nom : Ancien chemin conduisant de Belleville à la Villette.</rico:history>
