   <rico:Place rdf:about="place/FRAN_RI_025-d3nzbrwmo1-1aercz4pqof6k-vdp-11868">
      <skos:prefLabel xml:lang="fr">rue de Lille (7e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de Lille</skos:altLabel>
      <rico:name>rue de Lille (7e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Lille (rue de)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzbrwmo1-1aercz4pqof6k-vdp-11868"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzbrwmo1-1aercz4pqof6k-rue%20de%20Lille"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzbrwmo1-1aercz4pqof6k"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/11868_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Ouverte dans le Grand Pré aux Clercs. Elle fut dénommée rue de Bourbon jusqu'en 1792 et de 1815 à 1830 ; rue de Lille, de 1792 à 1815 et après 1830. [Origine du nom de la voie :] Substitué en 1792 à celui de Bourbon, en l'honneur de la défense de Lille.</rico:history>
