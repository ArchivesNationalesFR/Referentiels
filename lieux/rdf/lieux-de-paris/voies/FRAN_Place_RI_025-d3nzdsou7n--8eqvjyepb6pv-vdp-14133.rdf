   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nzdsou7n--8eqvjyepb6pv-vdp-14133_1843-05-04_1968-02-05">
      <rico:generalDescription xml:lang="fr">Non retenus au POS et non repris au PLU : Arrêté des 4 mai 1843 et 10 mai 1855, sauf pour la partie d'une longueur de 110 m, dans la traversée du chemin de fer d'Orléans, dont le tracé a été modifié lors de l'agrandissement de la gare aux marchandises d'Ivry, déclaré d'utilité publique par un décret du 6 mai 1874. Arrêté du 5 février 1968 (relatif à la rue du Chevaleret), pan coupé à l'angle de la rue du Loiret.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nzdsou7n--8eqvjyepb6pv-vdp-14133"/>
