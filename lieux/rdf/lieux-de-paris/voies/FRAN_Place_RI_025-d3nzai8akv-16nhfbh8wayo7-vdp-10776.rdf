   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nzai8akv-16nhfbh8wayo7-vdp-10776_1843-08-02_1914-03-12">
      <rico:generalDescription xml:lang="fr">Non retenus au POS et non repris au PLU : Décret du 12 mars 1914, côté impair, entre les rues de Montfaucon et Princesse. Ordonnance du 2 août 1843 : 1° côté impair entre les rues des Canettes et Bonaparte ; 2° côté pair, au droit des nos 2 et 4 et entre les rues des Ciseaux et Bonaparte. Ordonnance du 30 avril 1844 (relatif à la rue des Ciseaux), pan coupé sur le n° 20. Décret du 8 décembre 1894 (UP) : 1° côté impair, entre les rues Princesse et des Canettes ; 2° côté pair, du n° 6 inclus à la rue des Ciseaux. Décret du 28 juillet 1866 (UP), partie M, sauf du côté pair, entre les rues Bonaparte et de Rennes.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nzai8akv-16nhfbh8wayo7-vdp-10776"/>
      <rico:hadSubevent rdf:resource="activity/alignement-FRAN_RI_025-d3nzai8akv-16nhfbh8wayo7-vdp-10776_1843-08-02_1914-03-12_1843-08-02"/>
      <rico:hadSubevent rdf:resource="activity/alignement-FRAN_RI_025-d3nzai8akv-16nhfbh8wayo7-vdp-10776_1843-08-02_1914-03-12_1844-04-30"/>
      <rico:hadSubevent rdf:resource="activity/alignement-FRAN_RI_025-d3nzai8akv-16nhfbh8wayo7-vdp-10776_1843-08-02_1914-03-12_1866-07-28"/>
      <rico:hadSubevent rdf:resource="activity/alignement-FRAN_RI_025-d3nzai8akv-16nhfbh8wayo7-vdp-10776_1843-08-02_1914-03-12_1894-12-08"/>
      <rico:hadSubevent rdf:resource="activity/alignement-FRAN_RI_025-d3nzai8akv-16nhfbh8wayo7-vdp-10776_1843-08-02_1914-03-12_1914-03-12"/>
   </rico:Activity>
   <rico:Activity rdf:about="activity/numerotage-FRAN_RI_025-d3nzai8akv-16nhfbh8wayo7-vdp-10776_1877-08-09_1900-05-15">
      <rico:generalDescription xml:lang="fr">Arrêté du 9 août 1877, entre la rue de Rennes et le carrefour de la Croix Rouge. Arrêté du 15 mai 1900, côté pair.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/num%C3%A9rotage%20de%20voie%20urbaine"/>
