      <anf-onto:startingOnStreet xml:lang="fr">place d'Acadie.</anf-onto:startingOnStreet>
      <anf-onto:endingAtPoint xml:lang="fr">place Michel Debré, 1 et rue du Dragon, 1.</anf-onto:endingAtPoint>
