      <rico:textualValue xml:lang="fr">place Émile Mâle</rico:textualValue>
      <rico:history xml:lang="fr">Emile Mâle (Commentry, 1862-Chaalis, 1954), historien d’art français. Membre de l’Académie française en 1927.</rico:history>
