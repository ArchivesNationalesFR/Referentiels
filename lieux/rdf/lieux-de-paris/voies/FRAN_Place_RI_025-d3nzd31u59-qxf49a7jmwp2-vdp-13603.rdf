   <rico:Place rdf:about="place/FRAN_RI_025-d3nzd31u59-qxf49a7jmwp2-vdp-13603">
      <skos:prefLabel xml:lang="fr">rue Saint-Guillaume (7e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Saint-Guillaume</skos:altLabel>
      <rico:name>rue Saint-Guillaume (7e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Saint-Guillaume (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzd31u59-qxf49a7jmwp2-vdp-13603"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzd31u59-qxf49a7jmwp2-rue%20Saint-Guillaume"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzd31u59-qxf49a7jmwp2"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/13603_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Elle commençait autrefois à la rue des Saints-Pères : le tronçon situé entre les rues des Saints-Pères et du Pré aux Clercs a été dénommé rue Perronet par décret du 2 octobre 1865. Sur le plan de Gomboust, de 1652, la partie comprise entre la rue des Saints-Pères et la rue Saint-Dominique (absorbée depuis par le boulevard Saint-Germain) est appelée déjà rue Saint-Guillaume ; c'était plus anciennement la rue de la Butte. La partie comprise entre la rue Saint-Dominique et la rue de Grenelle a été dénommée rue Neuve des Rosiers sous Louis XIII, plus tard, rue des Rosiers. C'était plus anciennement : le chemin du Cimetière Saint-Père (1502), le chemin qui va de Saint-Père à la Maladrerie (1529), la rue du Plessis (1595 à 1628).</rico:history>
      <rico:isOrWasAffectedBy rdf:resource="activity/alignement-vdp-13603_1844-04-30"/>
      <rico:hasExtent rdf:resource="extent/vdp-13603_numero_impair"/>
      <rico:hasExtent rdf:resource="extent/vdp-13603_largeur"/>
      <rico:hasExtent rdf:resource="extent/vdp-13603_numero_pair"/>
      <rico:hasExtent rdf:resource="extent/vdp-13603_longueur"/>
      <anf-onto:startingAtPoint xml:lang="fr">rue Perronet, 11, et rue du Pré aux Clercs, 18.</anf-onto:startingAtPoint>
      <anf-onto:streetEndsOrEndedAtPoint>
         <rico:Place rdf:nodeID="N7c05c518ffef4e9bae44effdde07d42e">
            <rico:name xml:lang="fr">rue de Grenelle, 32.</rico:name>
