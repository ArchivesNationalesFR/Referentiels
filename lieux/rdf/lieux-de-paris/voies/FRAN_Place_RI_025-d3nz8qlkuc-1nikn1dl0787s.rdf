   <rico:PlaceName rdf:about="placeName/FRAN_RI_025-d3nz8qlkuc-1nikn1dl0787s-place%20du%20Bataillon%20Fran%C3%A7ais%20de%20L%27O.N.U.%20en%20Cor%C3%A9e">
      <rico:textualValue xml:lang="fr">place du Bataillon Français de L’O.N.U. en Corée</rico:textualValue>
      <rico:history xml:lang="fr">Bataillon créé par le gouvernement français le 24 août 1950. Il était composé de volontaires, presque tous combattants de la guerre de 1939-1945 ou de la guerre d’Indochine, qui s’illustrèrent pendant la guerre de Corée (1951-1953).</rico:history>
      <rico:isOrWasPlaceNameOf rdf:resource="place/FRAN_RI_025-d3nz8qlkuc-1nikn1dl0787s"/>
      <rico:resultsOrResultedFrom rdf:resource="activity/denomination-FRAN_RI_025-d3nz8qlkuc-1nikn1dl0787s_1984-10-12"/>
   </rico:PlaceName>
