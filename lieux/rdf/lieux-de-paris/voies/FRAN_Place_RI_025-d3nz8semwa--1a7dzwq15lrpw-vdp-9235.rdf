   <rico:Activity rdf:about="activity/alignement-vdp-9235_1826-06-21_1924-04-25">
      <rico:generalDescription xml:lang="fr">Non retenus au POS et non repris au PLU : Ordonnance du 21 juin 1826. Un décret du 25 avril 1924, a approuvé deux pans coupés de 5 m du côté impair, à l'angle de la rue Notre-Dame de Recouvrance, côté pair, et à l'angle de la rue de la Ville Neuve, côté impair.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
