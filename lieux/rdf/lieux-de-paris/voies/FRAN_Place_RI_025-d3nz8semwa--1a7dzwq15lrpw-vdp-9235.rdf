      <rico:hasExtent rdf:resource="extent/vdp-9235_numero_pair"/>
      <rico:hasExtent rdf:resource="extent/vdp-9235_numero_impair"/>
      <anf-onto:startingAtPoint xml:lang="fr">rue Poissonnière, 14.</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">boulevard de Bonne Nouvelle, 5 bis, et rue de Cléry, 97.</anf-onto:endingAtPoint>
      <rico:isOrWasContainedBy rdf:resource="place/FRAN_RI_023-d3nyvfot96-v4utuwrppfm3"/>
