   <rico:Place rdf:about="place/FRAN_RI_025-d3nz8hdj7f-zgl2bnn8s6u2-vdp-8931">
      <rdfs:label xml:lang="fr">rue Amélie (7e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue Amélie (7e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Amélie</skos:altLabel>
      <rico:name>rue Amélie (7e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Amélie (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz8hdj7f-zgl2bnn8s6u2-vdp-8931"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nz8hdj7f-zgl2bnn8s6u2-rue%20Am%C3%A9lie"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nz8hdj7f-zgl2bnn8s6u2"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/8931_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Les clauses insérées dans les lettres patentes du 6 septembre 1772 n'ayant pas été exécutées, un jugement du Tribunal de première instance de l'année 1826 déclara cette rue voie privée et, en 1832, un arrêté préfectoral la fit clore à ses deux extrémités. Le 13 octobre 1859, une ordonnance du Préfet de police autorisa la circulation du public dans la rue Amélie. | Origine du nom : Amélie, prénom de la fille de M. Pihan de Laforest, l'un des anciens propriétaires riverains.</rico:history>
