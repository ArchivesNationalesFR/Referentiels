   <rico:Place rdf:about="place/FRAN_RI_025-d3nzdj66tj-1273odzusayz2-vdp-13858">
      <skos:prefLabel xml:lang="fr">rue des Tournelles (3e-4e arrondissements, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue des Tournelles</skos:altLabel>
      <rico:name>rue des Tournelles (3e-4e arrondissements, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Tournelles (rue des)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzdj66tj-1273odzusayz2-vdp-13858"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzdj66tj-1273odzusayz2-rue%20des%20Tournelles"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzdj66tj-1273odzusayz2"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/13858_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">L'arrêté du 15 juillet 1839, réunissait la petite rue Neuve Saint-Gilles (ouverte en 1637), comprise entre la rue Saint-Gilles et le boulevard Beaumarchais, à la rue des Tournelles, comprise entre les rues Saint-Antoine et Saint-Gilles. L'ancienne rue des Tournelles, portait, en 1546, le nom de rue Jean Beausire. [Origine du nom de la voie :] Longeait le palais des Tournelles.</rico:history>
