   <rico:Place rdf:about="place/FRAN_RI_025-d3nzdokgfk-1anooamvc83ng-vdp-14012">
      <skos:prefLabel xml:lang="fr">rue de la Verrerie (4e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de la Verrerie</skos:altLabel>
      <rico:name>rue de la Verrerie (4e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Verrerie (rue de la)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzdokgfk-1anooamvc83ng-vdp-14012"/>
