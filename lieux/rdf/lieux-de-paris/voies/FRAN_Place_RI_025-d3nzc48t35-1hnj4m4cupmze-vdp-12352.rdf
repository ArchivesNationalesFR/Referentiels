   <rico:Place rdf:about="place/FRAN_RI_025-d3nzc48t35-1hnj4m4cupmze-vdp-12352">
      <rdfs:label xml:lang="fr">rue de Montmorency (3e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue de Montmorency (3e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de Montmorency</skos:altLabel>
      <rico:name>rue de Montmorency (3e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Montmorency (rue de)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzc48t35-1hnj4m4cupmze-vdp-12352"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzc48t35-1hnj4m4cupmze-rue%20de%20Montmorency"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzc48t35-1hnj4m4cupmze"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/12352_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">La partie située entre les rues Saint-Martin et Beaubourg était dénommée, dès le XIVe siècle, rue du Seigneur de Montmorency. La partie située entre les rues Beaubourg et du Temple était, en 1328, la ruelle au Villain. Elle s'est nommée rue Cour au Villain. Lacaille écrit rue Courtauvillain et rue ou ruelle Auvillain ; elle a pris également le nom de rue de Montmorency en 1768. Elle s'est appelée rue de la Réunion de 1793 à 1806. En 1808 elle reprit son ancien nom. | Origine du nom : Les seigneurs de Montmorency avaient leur hôtel dans cette voie aux XIIIe et XIVe siècles.</rico:history>
      <rico:isOrWasAffectedBy rdf:resource="activity/alignement-FRAN_RI_025-d3nzc48t35-1hnj4m4cupmze-vdp-12352_1829-01-14_1970-12-29"/>
