   <rico:Place rdf:about="place/FRAN_RI_025-d3nzaifazz-aznshgj1es0q-vdp-10779">
      <rdfs:label xml:lang="fr">rue de Fourcy (4e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue de Fourcy (4e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de Fourcy</skos:altLabel>
      <rico:name>rue de Fourcy (4e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Fourcy (rue de)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzaifazz-aznshgj1es0q-vdp-10779"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzaifazz-aznshgj1es0q-rue%20de%20Fourcy"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzaifazz-aznshgj1es0q"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/10779_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Cette voie existait en 1313 à l'état d'impasse et fut prolongée jusqu'à la rue de Jouy. Elle a porté les noms de ruelle puis de rue Sans chef, de cul-de-sac Sancier ou Censée. | Origine du nom : Henri de Fourcy, dont l'hôtel était situé dans le voisinage, était prévôt des marchands lorsqu'elle fut percée (vers 1690).</rico:history>
