   <rico:Place rdf:about="place/FRAN_RI_025-d3nzcefau5--exr7ba0ld9ug-vdp-12713">
      <skos:prefLabel xml:lang="fr">rue Pavée (4e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Pavée</skos:altLabel>
      <rico:name>rue Pavée (4e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Pavée (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzcefau5--exr7ba0ld9ug-vdp-12713"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzcefau5--exr7ba0ld9ug-rue%20Pav%C3%A9e"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzcefau5--exr7ba0ld9ug"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/12713_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">La partie B existait en 1235 sous le nom de rue du Petit Marivaux : c'était, en 1406, la rue du Petit Marais, plus tard la rue Marivas ou Marivaux ; vers le milieu du XVe siècle, la rue Pavée. En 1838, elle fut prolongée jusqu'à la rue Saint-Antoine. Lors de l'ouverture de la rue de Rivoli, une partie de la voie a été supprimée et le tronçon A a été élargi à 11 m du côté impair. [Origine du nom de la voie :] Ce fut l'une des premières rues pavées dans le quartier.</rico:history>
      <rico:isOrWasRegulatedBy rdf:resource="rule/arrete-vdp-12713"/>
      <rico:isOrWasAffectedBy rdf:resource="activity/alignement-vdp-12713_1838-10-14"/>
      <rico:hasExtent rdf:resource="extent/vdp-12713_numero_pair"/>
      <rico:hasExtent rdf:resource="extent/vdp-12713_numero_impair"/>
      <rico:hasExtent rdf:resource="extent/vdp-12713_largeur"/>
      <rico:hasExtent rdf:resource="extent/vdp-12713_longueur"/>
      <anf-onto:endingAtPoint xml:lang="fr">rue des Francs Bourgeois, 25.</anf-onto:endingAtPoint>
      <anf-onto:streetStartsOrStartedAtPoint>
         <rico:Place rdf:nodeID="Nb58d896baa914a28a5d9dad8e0926fd3">
            <rico:name xml:lang="fr">rue de Rivoli, 10.</rico:name>
