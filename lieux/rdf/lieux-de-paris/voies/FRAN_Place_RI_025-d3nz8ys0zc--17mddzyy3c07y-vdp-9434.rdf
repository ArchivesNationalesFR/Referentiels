   <rico:Place rdf:about="place/FRAN_RI_025-d3nz8ys0zc--17mddzyy3c07y-vdp-9434">
      <rdfs:label xml:lang="fr">quai de Bourbon (4e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">quai de Bourbon (4e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">quai de Bourbon</skos:altLabel>
      <rico:name>quai de Bourbon (4e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Bourbon (quai de)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz8ys0zc--17mddzyy3c07y-vdp-9434"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nz8ys0zc--17mddzyy3c07y-quai%20de%20Bourbon"/>
