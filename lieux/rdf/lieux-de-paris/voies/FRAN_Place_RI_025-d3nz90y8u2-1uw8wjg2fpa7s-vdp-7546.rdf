      <anf-onto:streetStatus xml:lang="fr">voie caduque d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/7546_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:endDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1868-08-10</rico:endDate>
      <rico:history xml:lang="fr">La dénomination rue Brunel a été annulée par décret impérial du 10 août 1868, la voie n'étant pas encore ouverte. L'arrêté préfectoral du 30 août 1884 a attribué le nom rue Nicolas Chuquet à la partie de son emprise ouverte en 1883.</rico:history>
