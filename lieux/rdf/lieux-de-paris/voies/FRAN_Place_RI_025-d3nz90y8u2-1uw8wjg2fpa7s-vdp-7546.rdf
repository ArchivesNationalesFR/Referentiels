   <rico:Place rdf:about="place/FRAN_RI_025-d3nz90y8u2-1uw8wjg2fpa7s-vdp-7546">
      <rdfs:label xml:lang="fr">rue Brunel (17e arrondissement, Paris, France ; id : 7546)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue Brunel (17e arrondissement, Paris, France ; id : 7546)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Brunel</skos:altLabel>
      <rico:name>rue Brunel (17e arrondissement, Paris, France ; id : 7546)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Brunel (rue)</skos:hiddenLabel>
