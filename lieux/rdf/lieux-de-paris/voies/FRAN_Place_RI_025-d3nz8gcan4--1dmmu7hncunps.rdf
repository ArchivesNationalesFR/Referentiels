   <rico:PlaceName rdf:about="placeName/FRAN_RI_025-d3nz8gcan4--1dmmu7hncunps-rue%20Alice%20Domon%20et%20L%C3%A9onie%20Duquet">
      <rico:textualValue xml:lang="fr">rue Alice Domon et Léonie Duquet</rico:textualValue>
      <rico:history xml:lang="fr">Alice Domon (soeur Alicia) née en 1937, Renée Duquet (soeur Léonie) née en 1916, religieuses infirmières appartenant à la Congrégation des Missions étrangères, portées disparues en Argentine. Elles luttèrent contre la dictature du Général Jorge Vidéla en mars 1976. Renée Duquet a été identifiée le 29 août 2005 et a été enterrée à Buenos Aires.</rico:history>
      <rico:isOrWasPlaceNameOf rdf:resource="place/FRAN_RI_025-d3nz8gcan4--1dmmu7hncunps"/>
      <rico:resultsOrResultedFrom rdf:resource="activity/denomination-FRAN_RI_025-d3nz8gcan4--1dmmu7hncunps_2006-01-30"/>
   </rico:PlaceName>
