   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nzcc05st-1h3miyy1ie3r0-vdp-12586_1845-08-29_1884-09-23">
      <rico:generalDescription xml:lang="fr">Non retenus au POS et non repris au PLU : Ordonnance du 29 août 1845, au droit des nos 63 à 113 bis. Ordonnance du 23 septembre 1884, entre la rue du Moulin de la Vierge et la rue d'Alésia. Non retenus au PAZ de la Zac "Guilleminot-Vercingétorix" et non repris au PLU : Ordonnance du 29 août 1845, au droit des nos 54 à 116. Décret du 23 septembre 1884, au droit des nos 14 à 52, 118 à 128, 1 à 61 et 115 à 127. Non retenus au PAZ de la Zac "Jean Zay" et non repris au PLU : Ordonnance du 23 septembre 1884, au droit des nos 2 à 12.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nzcc05st-1h3miyy1ie3r0-vdp-12586"/>
