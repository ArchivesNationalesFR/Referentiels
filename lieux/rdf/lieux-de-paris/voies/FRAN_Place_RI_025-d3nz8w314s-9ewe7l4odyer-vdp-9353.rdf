   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nz8w314s-9ewe7l4odyer-vdp-9353_1837-02-28_1938-02-16">
      <rico:generalDescription xml:lang="fr">Non retenus au POS et non repris au PLU : Ordonnance du 28 février 1837, côté impair, entre la place d'Estienne d'Orves et la rue de la Trinité et, côté pair, entre la rue Mansart et la place Blanche. Arrêté du 16 février 1938, le surplus de la voie et pans coupés de 10 m, côté pair : 1° à l'angle de la rue Mansart, côté pair ; 2° aux angles de la rue de Douai.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nz8w314s-9ewe7l4odyer-vdp-9353"/>
