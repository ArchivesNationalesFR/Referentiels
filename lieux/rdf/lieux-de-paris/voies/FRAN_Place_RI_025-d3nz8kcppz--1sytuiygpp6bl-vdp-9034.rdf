   <rico:Place rdf:about="place/FRAN_RI_025-d3nz8kcppz--1sytuiygpp6bl-vdp-9034">
      <rdfs:label xml:lang="fr">rue d'Arcole (4e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue d'Arcole (4e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue d'Arcole</skos:altLabel>
      <rico:name>rue d'Arcole (4e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Arcole (rue d')</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz8kcppz--1sytuiygpp6bl-vdp-9034"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nz8kcppz--1sytuiygpp6bl-rue%20d%27Arcole"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nz8kcppz--1sytuiygpp6bl"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/9034_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">L'ancienne rue d'Arcole avait été formée par la réunion de deux rues existant déjà au XIIIe siècle ; la rue du Chevet Saint-Landry (précédemment rue de la Couronne) et la rue Saint-Pierre aux Boeufs ou Saint-Père à Beus ; la rue d'Arcole actuelle a englobé vers 1865 le passage Sainte-Marine. | Origine du nom : Située en face du pont d'Arcole.</rico:history>
