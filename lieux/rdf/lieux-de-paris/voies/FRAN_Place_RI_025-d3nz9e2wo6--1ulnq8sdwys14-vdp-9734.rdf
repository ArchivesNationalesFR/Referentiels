      <rico:hasExtent rdf:resource="extent/vdp-9734_longueur"/>
      <rico:hasExtent rdf:resource="extent/vdp-9734_largeur"/>
      <rico:hasExtent rdf:resource="extent/vdp-9734_numero_impair"/>
      <anf-onto:startingAtPoint xml:lang="fr">rue du Temple, 113.</anf-onto:startingAtPoint>
      <anf-onto:streetEndsOrEndedAtPoint>
         <rico:Place rdf:nodeID="Naf721f8da2f84f11bd46ac891b95d96a">
            <rico:name xml:lang="fr">rue Saint-Martin, 230.</rico:name>
