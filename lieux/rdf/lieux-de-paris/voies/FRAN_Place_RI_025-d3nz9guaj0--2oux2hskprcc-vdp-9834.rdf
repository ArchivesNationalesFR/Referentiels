   <rico:Place rdf:about="place/FRAN_RI_025-d3nz9guaj0--2oux2hskprcc-vdp-9834">
      <rdfs:label xml:lang="fr">rue Chauvelot (15e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue Chauvelot (15e arrondissement, Paris, France)</skos:prefLabel>
