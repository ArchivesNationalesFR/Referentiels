   <rico:Place rdf:about="place/FRAN_RI_025-d3nzdiob5q-17fcemu65dfth-vdp-979">
      <skos:prefLabel xml:lang="fr">rue de la Tonnellerie (1er arrondissement, Paris, France)</skos:prefLabel>
