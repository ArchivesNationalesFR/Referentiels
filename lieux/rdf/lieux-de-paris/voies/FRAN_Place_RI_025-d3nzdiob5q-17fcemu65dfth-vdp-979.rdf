      <rico:hasOrHadIdentifier rdf:resource="identifier/979_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:endDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1867-02-26</rico:endDate>
      <rico:history xml:lang="fr">Supprimée par l'ouverture de la rue du Pont Neuf. Elle portait ce nom au XIIIe siècle. On l'a aussi appelée des Toilières, de la Toilerie, rue des Grands Piliers des Halles. Une partie a porté le nom de la Bonneterie.</rico:history>
      <rico:isOrWasRegulatedBy rdf:resource="rule/arrete-vdp-979"/>
      <anf-onto:startingOnStreet xml:lang="fr">rue Saint-Honoré</anf-onto:startingOnStreet>
      <anf-onto:endingOnStreet xml:lang="fr">rue de la Fromagerie (supprimée)</anf-onto:endingOnStreet>
      <rico:isOrWasContainedBy rdf:resource="place/FRAN_RI_023-d3nyvg5q7k-1815nk8q1azo8"/>
      <rico:isOrWasContainedBy rdf:resource="place/FRAN_RI_022-d3nyv8f3d4-ok53bz6domv3"/>
