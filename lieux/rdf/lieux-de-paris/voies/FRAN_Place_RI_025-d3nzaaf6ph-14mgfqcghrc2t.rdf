   <rico:Place rdf:about="place/FRAN_RI_025-d3nzaaf6ph-14mgfqcghrc2t">
      <rdfs:label xml:lang="fr">rue Émile Borel (Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue Émile Borel (Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Émile Borel</skos:altLabel>
      <skos:hiddenLabel xml:lang="fr">Emile-Borel (rue)</skos:hiddenLabel>
