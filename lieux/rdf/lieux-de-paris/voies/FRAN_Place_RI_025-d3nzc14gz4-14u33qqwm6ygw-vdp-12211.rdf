   <rico:Place rdf:about="place/FRAN_RI_025-d3nzc14gz4-14u33qqwm6ygw-vdp-12211">
      <skos:prefLabel xml:lang="fr">rue de Ménilmontant (20e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de Ménilmontant</skos:altLabel>
      <rico:name>rue de Ménilmontant (20e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Ménilmontant (rue de)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzc14gz4-14u33qqwm6ygw-vdp-12211"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzc14gz4-14u33qqwm6ygw-rue%20de%20M%C3%A9nilmontant"/>
