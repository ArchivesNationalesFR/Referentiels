   <rico:Place rdf:about="place/FRAN_RI_025-d3nzcfvtid--jeaka2twm5ar-vdp-12757">
      <rdfs:label xml:lang="fr">rue Pernelle (4e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue Pernelle (4e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Pernelle</skos:altLabel>
      <rico:name>rue Pernelle (4e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Pernelle (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzcfvtid--jeaka2twm5ar-vdp-12757"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzcfvtid--jeaka2twm5ar-rue%20Pernelle"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzcfvtid--jeaka2twm5ar"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/12757_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Précédemment petite rue Marivaux, rue de la Lanterne et rue Pernelle. La petite rue Marivaux a été dénommée rue des Prêtres, d'après Corrozet (1532). La rue de la Lanterne a porté les noms de : ruelle Saint-Bon (1250), rue de la Lanterne des Arcis (1440), rue de la Dentelle, d'après Bretez (1739). | Origine du nom : Pernelle, femme de Nicolas Flamel ; voisinage de la rue Nicolas Flamel.</rico:history>
