   <rico:Place rdf:about="place/FRAN_RI_025-d3nz9p27h8-1bf8128ky2l84-vdp-10069">
      <rdfs:label xml:lang="fr">rue des Couronnes (20e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue des Couronnes (20e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue des Couronnes</skos:altLabel>
      <rico:name>rue des Couronnes (20e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Couronnes (rue des)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz9p27h8-1bf8128ky2l84-vdp-10069"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nz9p27h8-1bf8128ky2l84-rue%20des%20Couronnes"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nz9p27h8-1bf8128ky2l84"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/10069_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">La partie A est tracée sur le plan de Roussel (1730). Le tronçon entre la Caroline (actuellement rue Julien Lacroix) et la chaussée de Ménilmontant (actuellement rue de Ménilmontant) a été dénommé rue Julien Lacroix par arrêté préfectoral du 2 avril 1868. | Origine du nom : Lieu-dit dénommé autrefois les Couronnes sous Savies.</rico:history>
