   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nz9p27h8-1bf8128ky2l84-vdp-10069_1837-02-28_1895-02-06">
      <rico:generalDescription xml:lang="fr">Retenus au PAZ de la Zac "Belleville" et non repris au PLU : Ordonnance du 28 février 1837, au droit des nos 1 à 41. Décret du 25 mars 1878, au droit du n° 43. Non retenus au POS et non repris au PLU : Ordonnance du 28 février 1837, partie A, sauf au droit des nos 1 à 41. Décret du 19 janvier 1885, raccordement avec le côté impair de la rue Vilin. Décret du 25 mars 1878, partie B, sauf au droit du n° 43. Décret du 6 février 1895, raccordement avec le côté impair de la rue du Transvaal.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nz9p27h8-1bf8128ky2l84-vdp-10069"/>
