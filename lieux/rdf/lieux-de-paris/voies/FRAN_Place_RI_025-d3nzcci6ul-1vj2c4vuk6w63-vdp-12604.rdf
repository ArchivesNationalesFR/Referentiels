   <rico:Place rdf:about="place/FRAN_RI_025-d3nzcci6ul-1vj2c4vuk6w63-vdp-12604">
      <skos:prefLabel xml:lang="fr">rue Palatine (6e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Palatine</skos:altLabel>
      <rico:name>rue Palatine (6e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Palatine (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzcci6ul-1vj2c4vuk6w63-vdp-12604"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzcci6ul-1vj2c4vuk6w63-rue%20Palatine"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzcci6ul-1vj2c4vuk6w63"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Ouverte lors de la construction de l'église Saint-Sulpice ; elle a été dénommée d'abord rue Neuve Saint-Sulpice puis, rue du Cimetière Saint-Sulpice. [Origine du nom de la voie :] En l'honneur de la princesse palatine Anne de Bavière, veuve de Henri Jules de Bourbon, prince de Condé ; elle avait fait construire à ses frais la fontaine de la rue Garancière.</rico:history>
