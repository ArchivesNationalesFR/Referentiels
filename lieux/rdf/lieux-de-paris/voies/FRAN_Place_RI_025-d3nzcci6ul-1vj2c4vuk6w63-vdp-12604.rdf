   <rico:Activity rdf:about="activity/alignement-vdp-12604_1843-04-03_1895-07-18">
      <rico:generalDescription xml:lang="fr">Non retenus au POS et non repris au PLU : Ordonnance du 3 avril 1843, côté impair. Décret du 18 juillet 1895, côté pair (église Saint-Sulpice), sur une longueur de 31 m, à partir de la rue Garancière. Le plan annexé à ce décret indique un nivellement entre les rues Garancière et Servandoni.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nzcci6ul-1vj2c4vuk6w63-vdp-12604"/>
