      <rico:hasExtent rdf:resource="extent/vdp-12604_numero_impair"/>
      <anf-onto:startingAtPoint xml:lang="fr">rue Garancière, 4.</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">place Saint-Sulpice, 1.</anf-onto:endingAtPoint>
