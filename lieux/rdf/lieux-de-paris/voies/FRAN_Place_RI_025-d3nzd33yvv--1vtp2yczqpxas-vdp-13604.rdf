   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nzd33yvv--1vtp2yczqpxas-vdp-13604_1843-03-26_1949-02-11">
      <rico:generalDescription xml:lang="fr">Non retenus au POS et non repris au PLU : Ordonnance du 26 mars 1843, partie A. Décret du 17 octobre 1857 (UP), partie B. Décret du 30 juillet 1859 (UP) (relatif au boulevard Arago), raccordement du côté pair avec le côté pair de la rue Pascal et entre le boulevard Arago et la rue Pascal. Arrêté du 11 février 1949 (relatif à la rue Broca), pan coupé, côté pair, à l'angle de la rue Broca, côté pair.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
