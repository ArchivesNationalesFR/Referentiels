   <rico:Place rdf:about="place/FRAN_RI_025-d3nzd33yvv--1vtp2yczqpxas-vdp-13604">
      <rdfs:label xml:lang="fr">rue Saint-Hippolyte (13e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue Saint-Hippolyte (13e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Saint-Hippolyte</skos:altLabel>
      <rico:name>rue Saint-Hippolyte (13e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Saint-Hippolyte (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzd33yvv--1vtp2yczqpxas-vdp-13604"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzd33yvv--1vtp2yczqpxas-rue%20Saint-Hippolyte"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzd33yvv--1vtp2yczqpxas"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/13604_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Avant l'ouverture du boulevard Arago, la rue Saint-Hippolyte commençait aux anciennes rues Pierre Assis et des Trois Couronnes. La partie de la rue Saint-Hippolyte, comprise entre ces voies et la rue Broca, indiquée sur le plan de Gomboust (1652), a porté le nom de rue des Teinturiers. | Origine du nom : L'église Saint-Hippolyte était située dans cette rue.</rico:history>
