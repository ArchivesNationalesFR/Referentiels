      <rico:hasExtent rdf:resource="extent/vdp-12366_largeur"/>
      <rico:hasExtent rdf:resource="extent/vdp-12366_longueur"/>
      <anf-onto:startingAtPoint xml:lang="fr">rue de Trévise, 7.</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">rue du Faubourg Montmartre, 18 et rue Geoffroy-Marie, 2.</anf-onto:endingAtPoint>
