   <rico:Place rdf:about="place/FRAN_RI_025-d3nzc4mkfy-jgw6cecr6scw-vdp-12366">
      <skos:prefLabel xml:lang="fr">rue de Montyon (9e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de Montyon</skos:altLabel>
      <rico:name>rue de Montyon (9e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Montyon (rue de)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzc4mkfy-jgw6cecr6scw-vdp-12366"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzc4mkfy-jgw6cecr6scw-rue%20de%20Montyon"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzc4mkfy-jgw6cecr6scw"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/12366_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Cette partie était précédemment comprise dans la rue de la Boule Rouge, anciennement passage de la Boule Rouge ; le passage de la Boule Rouge avait été converti en rue à la suite d'une ordonnance royale du 23 décembre 1816. [Origine du nom de la voie :] Antoine Jean Baptiste Robert Auget, baron de Montyon (1733-1820), philanthrope français ; donna trois millions aux hospices et légua plus d'un million à l'Institut pour fonder des prix.</rico:history>
      <rico:isOrWasRegulatedBy rdf:resource="rule/arrete-vdp-12366"/>
      <rico:isOrWasAffectedBy rdf:resource="activity/alignement-vdp-12366_1833-08-23_1845-10-03"/>
      <rico:isOrWasAffectedBy rdf:resource="activity/denomination-FRAN_RI_025-d3nzc4mkfy-jgw6cecr6scw_1843-05-26"/>
      <rico:isOrWasAffectedBy rdf:resource="activity/ouverture-vdp-12366_1844-08-11"/>
