   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nzbcqdtk-vr86sq5gwxb9-vdp-11224_1845-01-09_1929-10-25">
      <rico:generalDescription xml:lang="fr">Non retenus au POS et non repris au PLU : Décret du 27 décembre 1865, partie A, côté pair. Décret du 21 octobre 1884, pan coupé, côté pair, à l'angle du boulevard Haussmann. L'arrêté du 25 octobre 1929 (relatif à la rue de Provence) rapporte les alignements de la rue du Havre, côté impair, partie A. Ordonnance royale du 9 janvier 1845, partie B.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nzbcqdtk-vr86sq5gwxb9-vdp-11224"/>
