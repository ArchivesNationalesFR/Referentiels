   <rico:Activity rdf:about="activity/ouverture-FRAN_RI_025-d3nzbcqdtk-vr86sq5gwxb9-vdp-11224_1843-09-03_1845-01-09">
      <rico:generalDescription xml:lang="fr">Ordonnance du 9 janvier 1845, partie B. Cette ordonnance confirme deux ordonnances précédentes du 3 septembre 1843 et du 8 décembre 1844.</rico:generalDescription>
