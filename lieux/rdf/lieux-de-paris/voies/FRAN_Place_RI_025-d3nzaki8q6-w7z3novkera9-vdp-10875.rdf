   <rico:Place rdf:about="place/FRAN_RI_025-d3nzaki8q6-w7z3novkera9-vdp-10875">
      <rdfs:label xml:lang="fr">rue de la Gaîté (14e arrondissement, Paris, France ; id : 10875)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue de la Gaîté (14e arrondissement, Paris, France ; id : 10875)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de la Gaîté</skos:altLabel>
      <rico:name>rue de la Gaîté (14e arrondissement, Paris, France ; id : 10875)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Gaîté (rue de la)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzaki8q6-w7z3novkera9-vdp-10875"/>
