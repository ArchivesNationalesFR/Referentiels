   <rico:PlaceName rdf:about="placeName/FRAN_RI_025-d3nzbioezu--h0j4vdfnz4xe-rue%20Jean%20de%20La%20Fontaine">
      <rico:textualValue xml:lang="fr">rue Jean de La Fontaine</rico:textualValue>
      <rico:history xml:lang="fr">Jean de La Fontaine (Château-Thierry, 1621-Paris, 1695); avocat; maitre des eaux et forêts à Château-Thierry pendant 20 ans; poète français et fabuliste; élu à l’Académie Française en 1683, au fauteuil de Colbert.</rico:history>
      <rico:isOrWasPlaceNameOf rdf:resource="place/FRAN_RI_025-d3nzbioezu--h0j4vdfnz4xe"/>
