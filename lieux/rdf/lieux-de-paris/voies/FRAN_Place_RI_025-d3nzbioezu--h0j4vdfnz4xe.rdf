   <rico:Place rdf:about="place/FRAN_RI_025-d3nzbioezu--h0j4vdfnz4xe">
      <rdfs:label xml:lang="fr">rue Jean de La Fontaine (Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue Jean de La Fontaine (Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Jean de La Fontaine</skos:altLabel>
