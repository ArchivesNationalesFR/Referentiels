      <anf-onto:startingAtPoint xml:lang="fr">quai Voltaire, 35, et quai Anatole France, 1.</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">rue de Sèvres, 24.</anf-onto:endingAtPoint>
