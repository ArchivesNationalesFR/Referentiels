   <rico:Place rdf:about="place/FRAN_RI_025-d3nz8obgnr--1944hikuiskl0-vdp-9145">
      <skos:prefLabel xml:lang="fr">rue du Bac (7e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue du Bac</skos:altLabel>
      <rico:name>rue du Bac (7e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Bac (rue du)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz8obgnr--1944hikuiskl0-vdp-9145"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nz8obgnr--1944hikuiskl0-rue%20du%20Bac"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nz8obgnr--1944hikuiskl0"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/9145_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Primitivement, elle fut appelée grand chemin du Bac puis, ruelle du Bac et grande rue du Bac. [Origine du nom de la voie :] Bac établi sur la rivière, en 1550, avant la construction du pont Royal.</rico:history>
