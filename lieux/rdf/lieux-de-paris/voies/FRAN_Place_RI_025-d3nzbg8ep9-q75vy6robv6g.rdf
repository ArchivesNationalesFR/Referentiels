   <rico:PlaceName rdf:about="placeName/FRAN_RI_025-d3nzbg8ep9-q75vy6robv6g-place%20de%20l%27%C3%8Ele%20de%20Sein">
      <rico:textualValue xml:lang="fr">place de l’Île de Sein</rico:textualValue>
      <rico:history xml:lang="fr">Hommage aux 133 hommes constituant la population mâle de l’île de Sein qui quittèrent l’île en juin 1940 pour se rendre en Angleterre et furent les premiers à se rallier au général de Gaulle à la suite de son appel du 18 juin 1940.</rico:history>
