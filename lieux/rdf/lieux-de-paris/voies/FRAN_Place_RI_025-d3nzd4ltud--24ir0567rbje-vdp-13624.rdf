      <anf-onto:startingAtPoint xml:lang="fr">rue du Faubourg Saint-Martin, 127.</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">boulevard de Magenta, 72.</anf-onto:endingAtPoint>
