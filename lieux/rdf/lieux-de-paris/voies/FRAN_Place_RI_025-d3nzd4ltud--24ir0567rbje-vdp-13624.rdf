   <rico:Place rdf:about="place/FRAN_RI_025-d3nzd4ltud--24ir0567rbje-vdp-13624">
      <rdfs:label xml:lang="fr">rue Saint-Laurent (10e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue Saint-Laurent (10e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Saint-Laurent</skos:altLabel>
      <rico:name>rue Saint-Laurent (10e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Saint-Laurent (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzd4ltud--24ir0567rbje-vdp-13624"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzd4ltud--24ir0567rbje-rue%20Saint-Laurent"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzd4ltud--24ir0567rbje"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/13624_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Précédemment rue Neuve Saint-Laurent et antérieurement ruelle Saint-Denis. Elle est indiquée sur le plan de Braun (1530). Avant l'ouverture du boulevard de Magenta, la rue Saint-Laurent finissait rue du Faubourg Saint-Denis ; le décret du 19 novembre 1855 relatif à cette ouverture avait déclaré d'utilité publique la suppression de la partie comprise entre le boulevard de Strasbourg et la rue du Faubourg Saint-Denis. | Origine du nom : Voisinage de l'église Saint-Laurent.</rico:history>
      <rico:isOrWasAffectedBy rdf:resource="activity/alignement-FRAN_RI_025-d3nzd4ltud--24ir0567rbje-vdp-13624_1850-03-22"/>
