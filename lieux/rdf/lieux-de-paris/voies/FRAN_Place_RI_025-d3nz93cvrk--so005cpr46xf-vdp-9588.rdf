   <rico:Place rdf:about="place/FRAN_RI_025-d3nz93cvrk--so005cpr46xf-vdp-9588">
      <rdfs:label xml:lang="fr">rue des Canettes (6e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue des Canettes (6e arrondissement, Paris, France)</skos:prefLabel>
