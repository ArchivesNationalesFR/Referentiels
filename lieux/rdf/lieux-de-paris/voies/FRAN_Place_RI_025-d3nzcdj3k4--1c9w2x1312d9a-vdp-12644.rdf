   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nzcdj3k4--1c9w2x1312d9a-vdp-12644_1838-12-22_1959-09-28">
      <rico:generalDescription xml:lang="fr">Retenus au POS et non repris au PLU : Décret du 13 juin 1913, au droit des nos 11 à 17, 27 à 31 et 37 à 39. Non retenus au POS et non repris au PLU : Ordonnance du 22 décembre 1838 et du 4 juin 1846, côté pair, entre la place de Costa Rica et le n° 60 inclus. Décret du 13 juin 1913, côté impair, entre les places de Costa Rica et de Passy sauf au droit des nos 11 à 17, 27 à 31 et 37 à 39. Ces alignements ne sont pas exécutoires par mesure ordinaire de voirie. Décret du 8 mars 1926, complété par un décret du 25 août 1926, côté pair, depuis le n° 62 inclus jusqu'à la rue de Boulainvilliers. Arrêté du 28 septembre 1959 (relatif à la place de Passy) au droit du n° 69.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nzcdj3k4--1c9w2x1312d9a-vdp-12644"/>
