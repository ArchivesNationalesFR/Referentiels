   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nz8wy9x7-b1xqn5ujzq5k-vdp-9369_1929-07-18_1973-01-10">
      <rico:generalDescription xml:lang="fr">Retenus au POS et non repris au PLU : Arrêté du 10 janvier 1973, pour les nos 41 à 43. Non retenus au POS et non repris au PLU : Arrêté du 10 janvier 1973, entre la rue Molitor et le boulevard Exelmans, sauf du côté impair, entre un point situé à 3,50 m environ de la rue Jouvenet et la limite séparative des nos 61 et 63 sauf pour les nos 41 à 43. Décret du 18 juillet 1929, le surplus.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nz8wy9x7-b1xqn5ujzq5k-vdp-9369"/>
