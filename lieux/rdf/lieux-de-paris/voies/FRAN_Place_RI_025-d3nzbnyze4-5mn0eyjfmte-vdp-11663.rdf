   <rico:Place rdf:about="place/FRAN_RI_025-d3nzbnyze4-5mn0eyjfmte-vdp-11663">
      <skos:prefLabel xml:lang="fr">rue Lamarck (18e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Lamarck</skos:altLabel>
      <rico:name>rue Lamarck (18e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Lamarck (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzbnyze4-5mn0eyjfmte-vdp-11663"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzbnyze4-5mn0eyjfmte-rue%20Lamarck"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzbnyze4-5mn0eyjfmte"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/11663_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Le tronçon situé entre les rues Becquerel et du Mont Cenis était autrefois une partie de la rue de la Bonne. La partie qui était comprise entre les rues Foyatier et Maurice Utrillo a pris en 1930 le nom de rue du Cardinal Dubois. [Origine du nom de la voie :] Jean Baptiste Pierre Antoine de Monet de Lamarck (1744-1829), naturaliste français, initiateur de la théorie du transformisme, auteur d'études sur les fossiles du bassin de Paris.</rico:history>
