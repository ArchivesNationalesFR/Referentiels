      <anf-onto:startingOnStreet xml:lang="fr">rue Maurice Utrillo, 8 et rue du Cardinal Dubois.</anf-onto:startingOnStreet>
      <anf-onto:endingAtPoint xml:lang="fr">avenue de Saint-Ouen, 68 et rue Etex, 34.</anf-onto:endingAtPoint>
