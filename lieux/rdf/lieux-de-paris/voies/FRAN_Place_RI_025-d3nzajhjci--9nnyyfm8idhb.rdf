   <rico:PlaceName rdf:about="placeName/FRAN_RI_025-d3nzajhjci--9nnyyfm8idhb-rue%20des%20Fr%C3%A8res%20d%27Astier%20de%20la%20Vigerie">
      <rico:textualValue xml:lang="fr">rue des Frères d’Astier de la Vigerie</rico:textualValue>
      <rico:history xml:lang="fr">Les frères d’Astier de la Vigerie, compagnons de la libération, s’illustrèrent en prenant part à la défense et à la libération de la France : François (1886-1956), général de l’Armée de l’air qui rejoignit le général de Gaulle en 1942 et devint inspecteur des forces aériennes libres ; Henri (1897-1952), officier français grand résistant, prépara le putsch d’Alger en 1942, puis organisa les `Corps francs` et combattit à leur titre en France ; Emmanuel (1900-1969), homme politique et écrivain fonda le mouvement de résistance et le journal du même nom : Libération.</rico:history>
      <rico:isOrWasPlaceNameOf rdf:resource="place/FRAN_RI_025-d3nzajhjci--9nnyyfm8idhb"/>
      <rico:resultsOrResultedFrom rdf:resource="activity/denomination-FRAN_RI_025-d3nzajhjci--9nnyyfm8idhb_1983-12-26"/>
   </rico:PlaceName>
