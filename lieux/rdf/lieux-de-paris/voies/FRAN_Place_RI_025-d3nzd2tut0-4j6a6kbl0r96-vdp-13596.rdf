   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nzd2tut0-4j6a6kbl0r96-vdp-13596_1824-04-21_1949-01-25">
      <rico:generalDescription xml:lang="fr">Non retenus au POS et non repris au PLU : Ordonnance du 16 avril 1831, côté pair : 1° entre les rues La Fayette et de la Victoire, sauf le raccordement avec la rue La Fayette ; 2° entre les rues de Châteaudun et Saint-Lazare. Ordonnance du 21 avril 1824, au droit du n° 51. Arrêté du 25 janvier 1949, le surplus, ainsi que le raccordement du côté pair avec la rue La Fayette et des pans coupés également du côté pair : 1° à l'angle de la rue de la Victoire, côté impair ; 2° à l'angle de la rue de Châteaudun, côté pair ; 3° à l'angle de la rue Saint-Lazare, côté impair.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nzd2tut0-4j6a6kbl0r96-vdp-13596"/>
      <rico:hadSubevent rdf:resource="activity/alignement-FRAN_RI_025-d3nzd2tut0-4j6a6kbl0r96-vdp-13596_1824-04-21_1949-01-25_1824-04-21"/>
