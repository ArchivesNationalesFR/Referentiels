   <rico:Place rdf:about="place/FRAN_RI_025-d3nzd2tut0-4j6a6kbl0r96-vdp-13596">
      <rdfs:label xml:lang="fr">rue Saint-Georges (9e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue Saint-Georges (9e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Saint-Georges</skos:altLabel>
      <rico:name>rue Saint-Georges (9e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Saint-Georges (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzd2tut0-4j6a6kbl0r96-vdp-13596"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzd2tut0-4j6a6kbl0r96-rue%20Saint-Georges"/>
