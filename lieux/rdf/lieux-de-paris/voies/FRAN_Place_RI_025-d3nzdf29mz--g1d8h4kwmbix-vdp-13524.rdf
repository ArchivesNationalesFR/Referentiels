   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nzdf29mz--g1d8h4kwmbix-vdp-13524_1852-11-08_1855-11-19">
      <rico:generalDescription xml:lang="fr">Non retenus au POS et non repris au PLU : Décret du 19 novembre 1855 (relatif au boulevard de Magenta), côté impair : 1° entre la rue de la Fidélité et la rue Saint-Laurent ; 2° sur une longueur de 4,50 m environ à partir de la rue Saint-Laurent. Décret du 8 novembre 1852 (UP), le surplus.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nzdf29mz--g1d8h4kwmbix-vdp-13524"/>
