   <rico:Place rdf:about="place/FRAN_RI_025-d3nzc4q7pv--h7yuh7yz1kmc-vdp-12369">
      <rdfs:label xml:lang="fr">rue Moreau (12e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue Moreau (12e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Moreau</skos:altLabel>
      <rico:name>rue Moreau (12e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Moreau (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzc4q7pv--h7yuh7yz1kmc-vdp-12369"/>
