      <rico:hasExtent rdf:resource="extent/vdp-13556_largeur"/>
      <rico:hasExtent rdf:resource="extent/vdp-13556_longueur"/>
      <anf-onto:startingAtPoint xml:lang="fr">rue de Richelieu, 75.</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">avenue de l'Opéra, 34, et rue d'Antin, 14.</anf-onto:endingAtPoint>
