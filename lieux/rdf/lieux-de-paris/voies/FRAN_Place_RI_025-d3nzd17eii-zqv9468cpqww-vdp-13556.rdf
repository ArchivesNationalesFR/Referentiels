   <rico:Place rdf:about="place/FRAN_RI_025-d3nzd17eii-zqv9468cpqww-vdp-13556">
      <skos:prefLabel xml:lang="fr">rue Saint-Augustin (2e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Saint-Augustin</skos:altLabel>
      <rico:name>rue Saint-Augustin (2e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Saint-Augustin (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzd17eii-zqv9468cpqww-vdp-13556"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzd17eii-zqv9468cpqww-rue%20Saint-Augustin"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzd17eii-zqv9468cpqww"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/13556_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Précédemment partie de la rue Neuve Saint-Augustin ; celle-ci a porté les noms de rue Saint-Victor et rue Neuve des Vieux Augustins. La partie qui était comprise entre l'avenue de l'Opéra et le boulevard des Capucines a pris, en 1881, le nom de rue Daunou. [Origine du nom de la voie :] Longeait le couvent des religieux Augustins réformés, dit des Petits-Pères.</rico:history>
