      <rico:hasExtent rdf:resource="extent/vdp-9180_numero_impair"/>
      <rico:hasExtent rdf:resource="extent/vdp-9180_longueur"/>
      <anf-onto:startingAtPoint xml:lang="fr">rue de l'Hôtel de Ville, 62.</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">rue François Miron, 14.</anf-onto:endingAtPoint>
      <rico:isOrWasContainedBy rdf:resource="place/FRAN_RI_023-d3nyvgu6c8--18n2bsdc6izgn"/>
