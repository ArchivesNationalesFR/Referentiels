   <rico:Place rdf:about="place/FRAN_RI_025-d3nzdi69w7-1wstm8j35hxug-vdp-13822">
      <skos:prefLabel xml:lang="fr">rue Tiron (4e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Tiron</skos:altLabel>
      <rico:name>rue Tiron (4e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Tiron (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzdi69w7-1wstm8j35hxug-vdp-13822"/>
