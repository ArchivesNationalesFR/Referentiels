   <rico:Place rdf:about="place/FRAN_RI_025-d3nzcf0icl-u8a1i63fhv30-vdp-12732">
      <skos:prefLabel xml:lang="fr">rue de la Pépinière (8e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de la Pépinière</skos:altLabel>
      <rico:name>rue de la Pépinière (8e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Pépinière (rue de la)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzcf0icl-u8a1i63fhv30-vdp-12732"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzcf0icl-u8a1i63fhv30-rue%20de%20la%20P%C3%A9pini%C3%A8re"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzcf0icl-u8a1i63fhv30"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/12732_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Elle est indiquée sur le plan de Saint-Victor (1555). Le tronçon situé entre le boulevard Malesherbes et la rue du Faubourg Saint-Honoré a été dénommé rue Abbatucci (actuellement rue La Boëtie) par décret impérial du 10 août 1868. [Origine du nom de la voie :] Cette voie, dont faisait partie autrefois la rue La Boétie, conduisait à la pépinière royale du Roule.</rico:history>
      <rico:isOrWasAffectedBy rdf:resource="activity/alignement-vdp-12732_1848-02-09_1930-09-04"/>
      <rico:hasExtent rdf:resource="extent/vdp-12732_numero_impair"/>
      <rico:hasExtent rdf:resource="extent/vdp-12732_numero_pair"/>
      <rico:hasExtent rdf:resource="extent/vdp-12732_largeur"/>
      <rico:hasExtent rdf:resource="extent/vdp-12732_longueur"/>
      <anf-onto:startingOnStreet xml:lang="fr">place Gabriel Péri, et rue Pasquier.</anf-onto:startingOnStreet>
      <anf-onto:endingAtPoint xml:lang="fr">place Saint-Augustin, 4.</anf-onto:endingAtPoint>
      <anf-onto:crossesOrCrossed rdf:resource="place/FRAN_RI_023-d3nyvfy1fk--tfn4492ql1ea"/>
      <anf-onto:crossesOrCrossed rdf:resource="place/FRAN_RI_023-d3nyvgbfmz--11ww01vod4uww"/>
