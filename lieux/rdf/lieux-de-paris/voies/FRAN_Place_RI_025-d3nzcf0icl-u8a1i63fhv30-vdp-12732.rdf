   <rico:Activity rdf:about="activity/alignement-vdp-12732_1848-02-09_1930-09-04">
      <rico:generalDescription xml:lang="fr">Non retenus au POS et non repris au PLU : Décret du 30 juin 1859 (UP), côté impair et côté pair, sur une longueur de 6,50 m environ avant le pan coupé circulaire à l'angle de la place Saint-Augustin, dont l'alignement a été approuvé par l'arrêté du 4 septembre 1930. Ordonnance du 9 février 1848, le surplus du côté pair.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
