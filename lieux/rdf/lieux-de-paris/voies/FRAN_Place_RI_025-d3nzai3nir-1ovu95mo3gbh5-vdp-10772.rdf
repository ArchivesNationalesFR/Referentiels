   <rico:Place rdf:about="place/FRAN_RI_025-d3nzai3nir-1ovu95mo3gbh5-vdp-10772">
      <rdfs:label xml:lang="fr">rue du Fouarre (5e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue du Fouarre (5e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue du Fouarre</skos:altLabel>
