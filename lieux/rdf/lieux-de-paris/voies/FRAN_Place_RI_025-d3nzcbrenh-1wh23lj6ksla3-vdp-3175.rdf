      <rico:hasExtent rdf:resource="extent/vdp-3175_longueur"/>
      <rico:hasExtent rdf:resource="extent/vdp-3175_largeur"/>
      <anf-onto:startingAtPoint xml:lang="fr">Boulevard Saint-Marcel, 79</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">rue de la Reine Blanche, 22</anf-onto:endingAtPoint>
