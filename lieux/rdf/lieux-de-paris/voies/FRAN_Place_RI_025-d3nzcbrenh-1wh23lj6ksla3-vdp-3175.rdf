   <rico:Place rdf:about="place/FRAN_RI_025-d3nzcbrenh-1wh23lj6ksla3-vdp-3175">
      <skos:prefLabel xml:lang="fr">rue Ortolan (13e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Ortolan</skos:altLabel>
      <rico:name>rue Ortolan (13e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Ortolan (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzcbrenh-1wh23lj6ksla3-vdp-3175"/>
