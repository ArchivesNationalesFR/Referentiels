   <rico:Place rdf:about="place/FRAN_RI_025-d3nz8dd931-12iq9zppv6ok-vdp-8789">
      <skos:prefLabel xml:lang="fr">rue de l'Abreuvoir (18e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de l'Abreuvoir</skos:altLabel>
      <rico:name>rue de l'Abreuvoir (18e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Abreuvoir (rue de l')</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz8dd931-12iq9zppv6ok-vdp-8789"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nz8dd931-12iq9zppv6ok-rue%20de%20l%27Abreuvoir"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nz8dd931-12iq9zppv6ok"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/8789_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Elle est indiquée à l'état de chemin sur le plan de Jouvin de Rochefort (1672). En 1843, elle était dénommée chemin de l'Abreuvoir. Un décret du 11 août 1867 (UP), rapporté par un autre décret du 25 mars 1899, avait prévu la suppression de la rue de l'Abreuvoir en vue de l'ouverture de la rue Chasseloup-Laubat. [Origine du nom de la voie :] Ancien abreuvoir de Montmartre auquel cette voie conduisait.</rico:history>
      <rico:isOrWasRegulatedBy rdf:resource="rule/arrete-vdp-8789"/>
      <rico:isOrWasAffectedBy rdf:resource="activity/classement-vdp-8789_1863-05-23"/>
      <rico:isOrWasAffectedBy rdf:resource="activity/numerotage-vdp-8789_1874-07-29"/>
      <rico:hasExtent rdf:resource="extent/vdp-8789_largeur"/>
      <rico:hasExtent rdf:resource="extent/vdp-8789_longueur"/>
      <rico:hasExtent rdf:resource="extent/vdp-8789_numero_impair"/>
      <rico:hasExtent rdf:resource="extent/vdp-8789_numero_pair"/>
      <anf-onto:startingAtPoint xml:lang="fr">rue des Saules, 9.</anf-onto:startingAtPoint>
      <anf-onto:endingOnStreet xml:lang="fr">place Dalida.</anf-onto:endingOnStreet>
      <rico:isOrWasContainedBy rdf:resource="place/FRAN_RI_022-d3nyv8luy3-fe1chmhbhkpu"/>
      <rico:hasOrHadPhysicalLocation rdf:resource="physicalLocation/vdp-8789"/>
   </rico:Place>
