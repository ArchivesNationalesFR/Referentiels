   <rico:Activity rdf:about="activity/denomination-FRAN_RI_025-d3nzdf9dq0-nx3dir0dwnhc_1808-06-16">
      <rico:generalDescription xml:lang="fr">dénomination : Un décret du 16 juin 1808, relatif à l'achèvement de cette voie, la désigne sous le nom de rue Neuve de Sully.</rico:generalDescription>
