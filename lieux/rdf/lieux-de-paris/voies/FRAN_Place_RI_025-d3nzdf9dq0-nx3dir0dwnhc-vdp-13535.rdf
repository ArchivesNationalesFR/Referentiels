   <rico:Place rdf:about="place/FRAN_RI_025-d3nzdf9dq0-nx3dir0dwnhc-vdp-13535">
      <rdfs:label xml:lang="fr">rue de Sully (4e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue de Sully (4e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de Sully</skos:altLabel>
      <rico:name>rue de Sully (4e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Sully (rue de)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzdf9dq0-nx3dir0dwnhc-vdp-13535"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzdf9dq0-nx3dir0dwnhc-rue%20de%20Sully"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzdf9dq0-nx3dir0dwnhc"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/13535_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Elle occupe un emplacement qui faisait anciennement partie de la cour du Grand Arsenal. Précédemment rue Neuve de Sully et cour de l'Arsenal. Un arrêté du 26 janvier 1906 a réuni au quai des Célestins une partie de la rue de Sully comprise entre le boulevard Henri IV et la rue du Petit Musc. | Origine du nom : Maximilien de Béthune, baron de Rosny et duc de Sully (1560-1641), ministre de Henri IV, habitait l'Arsenal comme Grand Maître de l'Artillerie.</rico:history>
