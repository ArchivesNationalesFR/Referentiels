   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nzd5mlt5--oyds4h1k7v8u-vdp-13644_1837-02-28">
      <rico:generalDescription xml:lang="fr">Non retenus au PSMV du Marais : Ordonnance du 28 février 1837, entre rue du Temple et rue du Renard. Non retenus au PAZ de la ZAC "Halles" et non repris au PLU : Ordonnance du 28 février 1837, au droit des nos 20 à 36, sauf sur une longueur de 45 m à partir d'un point situé à 30 m de la rue du Renard. Non retenus au POS et non repris au PLU : Ordonnance du 28 février 1837, sauf côté impair sur une longueur de 35 m à partir de la rue Brisemiche et, côté pair, au droit des nos 20 à 36.</rico:generalDescription>
      <rico:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1837-02-28</rico:date>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nzd5mlt5--oyds4h1k7v8u-vdp-13644"/>
   </rico:Activity>
   <rico:Activity rdf:about="activity/declassement-FRAN_RI_025-d3nzd5mlt5--oyds4h1k7v8u-vdp-13644_1975-01-30">
      <rico:generalDescription xml:lang="fr">Arrêté du 30 janvier 1975, à partir de la rue Brisemiche sur une longueur de 35 m et sur une largeur de 4 m, côté impair, 2 m, côté pair.</rico:generalDescription>
      <rico:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1975-01-30</rico:date>
      <rico:hasActivityType rdf:resource="activityType/d%C3%A9classement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nzd5mlt5--oyds4h1k7v8u-vdp-13644"/>
   </rico:Activity>
