      <rico:isOrWasAffectedBy rdf:resource="activity/alignement-vdp-13846_1936-03-10_1937-08-11"/>
      <rico:isOrWasAffectedBy rdf:resource="activity/classement-vdp-13846_1863-05-23"/>
