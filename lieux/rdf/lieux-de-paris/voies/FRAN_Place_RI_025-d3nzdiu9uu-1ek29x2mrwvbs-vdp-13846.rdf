   <rico:Place rdf:about="place/FRAN_RI_025-d3nzdiu9uu-1ek29x2mrwvbs-vdp-13846">
      <skos:prefLabel xml:lang="fr">rue de la Tour (16e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de la Tour</skos:altLabel>
      <rico:name>rue de la Tour (16e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Tour (rue de la)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzdiu9uu-1ek29x2mrwvbs-vdp-13846"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzdiu9uu-1ek29x2mrwvbs-rue%20de%20la%20Tour"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzdiu9uu-1ek29x2mrwvbs"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/13846_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Anciennement partie de la rue du Moulin de la Tour. Elle est indiquée à l'état de chemin sur le plan de Roussel (1730). Un tronçon de la rue de la Tour qui était compris entre les boulevards Flandrin et Lannes a été dénommé en 1896 rue Adolphe Yvon. [Origine du nom de la voie :] Voisinage de l'ancien moulin de la Tour de Passy.</rico:history>
