   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nz963hdt-n8ftw3v28oq9-vdp-9691_1852-12-27">
      <rico:generalDescription xml:lang="fr">Retenus au PAZ de la Zac "Gare de Lyon-Bercy" et non repris au PLU : Décret du 27 décembre 1852, côté impair, du boulevard Diderot, à un point situé 132 m environ au-delà du prolongement du côté pair de la rue Hector Malot. Non retenus au PAZ de la Zac "Chalon" et non repris au PLU : Décret du 27 décembre 1852, côté pair, sur une longueur de 70 m environ au-delà du prolongement du côté pair de la rue Hector Malot. Non retenus au POS et non repris au PLU : Décret du 27 décembre 1852, côté impair, à partir d'un point situé 132 m environ au-delà du prolongement du côté pair de la rue Hector Malot.</rico:generalDescription>
      <rico:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1852-12-27</rico:date>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nz963hdt-n8ftw3v28oq9-vdp-9691"/>
   </rico:Activity>
