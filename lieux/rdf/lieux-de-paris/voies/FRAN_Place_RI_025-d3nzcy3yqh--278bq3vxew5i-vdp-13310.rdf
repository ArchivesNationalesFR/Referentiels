   <rico:Place rdf:about="place/FRAN_RI_025-d3nzcy3yqh--278bq3vxew5i-vdp-13310">
      <rdfs:label xml:lang="fr">rue de la Roquette (11e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue de la Roquette (11e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de la Roquette</skos:altLabel>
      <rico:name>rue de la Roquette (11e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Roquette (rue de la)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzcy3yqh--278bq3vxew5i-vdp-13310"/>
