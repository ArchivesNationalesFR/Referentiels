   <rico:PlaceName rdf:about="placeName/FRAN_RI_025-d3nzc38y3n--15r9pqyk99qqj-rue%20Monsieur%20le%20Prince">
      <rico:textualValue xml:lang="fr">rue Monsieur le Prince</rico:textualValue>
      <rico:history xml:lang="fr">L’hôtel du prince de Condé s’étendait jusque là vers les fossés.</rico:history>
