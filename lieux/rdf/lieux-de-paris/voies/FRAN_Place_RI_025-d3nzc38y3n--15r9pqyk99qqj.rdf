   <rico:Place rdf:about="place/FRAN_RI_025-d3nzc38y3n--15r9pqyk99qqj">
      <rdfs:label xml:lang="fr">rue Monsieur le Prince (Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue Monsieur le Prince (Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Monsieur le Prince</skos:altLabel>
      <skos:hiddenLabel xml:lang="fr">Monsieur-Le-Prince (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzc38y3n--15r9pqyk99qqj"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzc38y3n--15r9pqyk99qqj-rue%20Monsieur%20le%20Prince"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d’après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/d3nzc38y3n--15r9pqyk99qqj"/>
      <rico:hasOrHadIdentifier rdf:resource="identifier/12302_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">A l’origine c’était un chemin longeant les fossés de l’enceinte. La partie comprise entre le carrefour de l’Odéon et la rue de Vaugirard a successivement porté les noms de : chemin de Dessus les Fossés (1419) ; chemin allant à la Porte Saint-Michel (1510) ; rue des Fossés Saint-Germain (1559 à 1582) ; rue des Fossés Monsieur le Prince et rue de la Liberté (1793 à 1805). La partie M était, avant 1851, la rue des Francs Bourgeois Saint-Michel.</rico:history>
