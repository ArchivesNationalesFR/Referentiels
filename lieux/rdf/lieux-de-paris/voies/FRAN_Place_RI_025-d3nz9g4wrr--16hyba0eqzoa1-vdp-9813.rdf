   <rico:Activity rdf:about="activity/classement-FRAN_RI_025-d3nz9g4wrr--16hyba0eqzoa1-vdp-9813_1859-11-11_1863-05-23">
      <rico:generalDescription xml:lang="fr">Décret du 23 mai 1863, dans la voirie parisienne. La partie comprise depuis l'origine de la voie jusqu'à la rue Raymond Losserand (M) avait été classée dans la voirie de la commune de Vaugirard par arrêté du 11 novembre 1859. Le surplus était une voie de la commune de Montrouge.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/classement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nz9g4wrr--16hyba0eqzoa1-vdp-9813"/>
