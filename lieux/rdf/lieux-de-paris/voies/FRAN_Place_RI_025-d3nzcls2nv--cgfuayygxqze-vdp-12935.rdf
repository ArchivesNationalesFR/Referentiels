   <rico:Place rdf:about="place/FRAN_RI_025-d3nzcls2nv--cgfuayygxqze-vdp-12935">
      <rdfs:label xml:lang="fr">rue de la Pompe (16e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue de la Pompe (16e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de la Pompe</skos:altLabel>
      <rico:name>rue de la Pompe (16e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Pompe (rue de la)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzcls2nv--cgfuayygxqze-vdp-12935"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzcls2nv--cgfuayygxqze-rue%20de%20la%20Pompe"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzcls2nv--cgfuayygxqze"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/12935_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Elle est tracée à l'état de chemin sur le plan de Roussel (1730). La partie qui était comprise entre l'avenue Foch et la rue Pergolèse a pris en 1868 le nom de rue Duret. Le début de l'avenue Jules Janin a été classé par décret du 8 janvier 1887 puis, incorporé à la rue de la Pompe au droit du n° 12. | Origine du nom : Dû à la pompe qui fournissait l'eau au château de la Muette.</rico:history>
