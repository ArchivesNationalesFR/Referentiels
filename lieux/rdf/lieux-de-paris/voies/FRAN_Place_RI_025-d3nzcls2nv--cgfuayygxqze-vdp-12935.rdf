   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nzcls2nv--cgfuayygxqze-vdp-12935_1882-05-22_1965-02-03_1882-05-22">
      <rico:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1882-05-22</rico:date>
      <rico:wasSubeventOf rdf:resource="activity/alignement-FRAN_RI_025-d3nzcls2nv--cgfuayygxqze-vdp-12935_1882-05-22_1965-02-03"/>
      <rico:precedesInTime rdf:resource="activity/alignement-FRAN_RI_025-d3nzcls2nv--cgfuayygxqze-vdp-12935_1882-05-22_1965-02-03_1887-01-08"/>
   </rico:Activity>
   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nzcls2nv--cgfuayygxqze-vdp-12935_1882-05-22_1965-02-03">
      <rico:generalDescription xml:lang="fr">Non retenus au POS et non repris au PLU : Décret du 22 mai 1882, sauf les parties régies par les textes suivants : Décret du 8 mars 1926, pan coupé, côté pair, à l'angle de l'avenue Paul Doumer. Décret du 21 mars 1913 (côté pair), entre l'avenue Paul Doumer et la rue Faustin Hélie (non exécutoire par mesure ordinaire de voirie). Décret du 8 janvier 1887, au droit du n° 12. Décret du 11 août 1937 : 1° côté impair : entre la ligne séparative des nos 15, 17, et la rue de Siam ; pans coupés aux angles des rues de Siam, de la Tour et de l'avenue Henri Martin (côté impair), sauf sur une longueur de 5 m environ à partir de la rue Jean Richepin, partie régie par l'arrêté du 3 février 1965 ; 2° côté pair : entre l'avenue Jules Janin et la ligne séparative des nos 28, 30 ; entre la rue Nicolo et l'avenue Georges Mandel. L'arrêté du 11 janvier 1935 (relatif à la rue de Longchamp) a approuvé un pan coupé de 8 m, côté pair, à l'angle de la rue de Longchamp, côté pair.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nzcls2nv--cgfuayygxqze-vdp-12935"/>
