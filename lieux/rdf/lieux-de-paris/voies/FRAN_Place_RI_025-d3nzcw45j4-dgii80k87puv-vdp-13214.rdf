   <rico:Activity rdf:about="activity/denomination-FRAN_RI_025-d3nzcw45j4-dgii80k87puv_1850-11-16_1889-08-20">
      <rico:generalDescription xml:lang="fr">dénomination : Délibération du Conseil Municipal de Charonne du 16 novembre 1850, entre la rue d'Avron et la place de la Réunion. Arrêté du 2 avril 1868, entre la place de la Réunion et la rue de Bagnolet (M). Arrêté du 20 août 1889, partie B.</rico:generalDescription>
