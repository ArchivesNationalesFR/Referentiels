   <rico:Place rdf:about="place/FRAN_RI_025-d3nzcx346k-1vmm9qhifzens">
      <rdfs:label xml:lang="fr">rue Robert Esnault-Pelterie (Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue Robert Esnault-Pelterie (Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Robert Esnault-Pelterie</skos:altLabel>
