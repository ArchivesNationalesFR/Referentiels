      <rico:recordResourceSourceOfInformation xml:lang="fr">Notice relative à la voie 9293 dans la nomenclature des voies de Paris publiée en open data par la mairie de Paris (jeu de données de 2023)</rico:recordResourceSourceOfInformation>
      <skos:changeNote>
         <rdf:Description>
            <dc:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-12-26</dc:date>
            <rdf:value xml:lang="fr">Intégration automatique à la notice de nombreuses données relatives à ce lieu dans la nomenclature de la mairie de Paris (historique, coordonnées géographiques, données géométriques, indication des arrondissements et quartiers traversés...), ainsi que différentes activités (alignement, nivellement, numérotage...) liés à ce lieu.</rdf:value>
         </rdf:Description>
      </skos:changeNote>
   </rico:Record>
   <rico:Place rdf:about="place/FRAN_RI_025-d3nz8ttud1-yc9r1p0n7g8j-vdp-9293">
      <skos:prefLabel xml:lang="fr">rue Bergère (9e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Bergère</skos:altLabel>
      <rico:name>rue Bergère (9e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Bergère (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz8ttud1-yc9r1p0n7g8j-vdp-9293"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nz8ttud1-yc9r1p0n7g8j-rue%20Berg%C3%A8re"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nz8ttud1-yc9r1p0n7g8j"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/9293_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Ce n'était, anciennement, qu'un simple chemin. On l'appela successivement rue du Clos aux Halliers, rue aux Halliers, rue au Berger, rue Bergère (vers 1652) ; on y construisit les premières maisons en 1738. [Origine du nom de la voie :] Jean Bergier, maître teinturier, à qui l'Hôtel Dieu avait donné à bail une terre de labour sur le grand chemin de Montmartre (XVIIe siècle).</rico:history>
      <rico:isOrWasAffectedBy rdf:resource="activity/alignement-vdp-9293_1833-08-23_1937-08-23"/>
      <rico:isOrWasAffectedBy rdf:resource="activity/nivellement-vdp-9293_1937-08-23"/>
      <rico:hasExtent rdf:resource="extent/vdp-9293_numero_impair"/>
      <rico:hasExtent rdf:resource="extent/vdp-9293_numero_pair"/>
      <rico:hasExtent rdf:resource="extent/vdp-9293_largeur"/>
      <rico:hasExtent rdf:resource="extent/vdp-9293_longueur"/>
      <anf-onto:startingAtPoint xml:lang="fr">rue du Faubourg Poissonnière, 13.</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">rue du Faubourg Montmartre, 12.</anf-onto:endingAtPoint>
      <rico:isOrWasContainedBy rdf:resource="place/FRAN_RI_023-d3nyvfyymm--3q593nbcvt1s"/>
      <rico:isOrWasContainedBy rdf:resource="place/FRAN_RI_022-d3nyv8il1a-d31b8dfjb0g5"/>
      <rico:hasOrHadPhysicalLocation rdf:resource="physicalLocation/vdp-9293"/>
   </rico:Place>
