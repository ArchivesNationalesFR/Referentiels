   <rico:Activity rdf:about="activity/alignement-vdp-9293_1833-08-23_1937-08-23">
      <rico:generalDescription xml:lang="fr">Non retenus au POS et non repris au PLU : Ordonnance du 23 août 1833, sauf les parties suivantes régies par l'arrêté du 23 août 1937 : côté impair, entre la rue du Faubourg Poissonnière et la ligne séparative des nos 25, 27 ; côté pair, pan coupé à l'angle de la rue du Faubourg Poissonnière, et entre la ligne séparative des nos 20, 22 et la rue du Faubourg Montmartre.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nz8ttud1-yc9r1p0n7g8j-vdp-9293"/>
