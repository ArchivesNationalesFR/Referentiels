   <rico:Place rdf:about="place/FRAN_RI_025-d3nz9n2x8q-mbsjzmlbn5a0-vdp-10018">
      <rdfs:label xml:lang="fr">rue de Constantine (7e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue de Constantine (7e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de Constantine</skos:altLabel>
      <rico:name>rue de Constantine (7e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Constantine (rue de)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz9n2x8q-mbsjzmlbn5a0-vdp-10018"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nz9n2x8q-mbsjzmlbn5a0-rue%20de%20Constantine"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nz9n2x8q-mbsjzmlbn5a0"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/10018_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Précédemment, partie de la rue d'Iéna. A l'angle de cette rue et de la rue Saint-Dominique était placée la barrière des Invalides. Le tronçon compris entre la quai d'Orsay et la rue de l'Université a été dénommé rue Robert Esnault-Pelterie par arrêté du 27 décembre 1965. Cet arrêté a rapporté l'arrêté du 11 mars 1965 qui avait attribué cette dénomination au tronçon compris entre les rues Saint-Dominique et de Grenelle. | Origine du nom : Ville d'Algérie.</rico:history>
