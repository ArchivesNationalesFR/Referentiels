   <rico:Place rdf:about="place/FRAN_RI_025-d3nzc49pmx--133esvc789ehg-vdp-12354">
      <rdfs:label xml:lang="fr">rue Montorgueil (1er-2e arrondissements, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue Montorgueil (1er-2e arrondissements, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Montorgueil</skos:altLabel>
      <rico:name>rue Montorgueil (1er-2e arrondissements, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Montorgueil (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzc49pmx--133esvc789ehg-vdp-12354"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzc49pmx--133esvc789ehg-rue%20Montorgueil"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzc49pmx--133esvc789ehg"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/12354_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">La partie comprise entre les rues Montmartre et Mauconseil a primitivement porté les noms de rue Nicolas Arrode, rue au Comte d'Artois ou de la Comtesse d'Artois et de rue de la Porte au Comte ou à la Comtesse d'Artois. Réunie à la rue Montorgueil en 1792, elle a repris le nom de rue de la Comtesse d'Artois en 1814 et a été de nouveau réunie à la rue Montorgueil en 1830. | Origine du nom : Ancien nom (XIIIe siècle) ; cette voie conduisait au mont Orgueilleux dont le sommet est occupé par la rue Beauregard.</rico:history>
