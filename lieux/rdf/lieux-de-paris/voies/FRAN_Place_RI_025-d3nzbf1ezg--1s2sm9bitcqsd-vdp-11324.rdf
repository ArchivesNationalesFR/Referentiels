   <rico:Place rdf:about="place/FRAN_RI_025-d3nzbf1ezg--1s2sm9bitcqsd-vdp-11324">
      <rdfs:label xml:lang="fr">rue de la Huchette (5e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue de la Huchette (5e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de la Huchette</skos:altLabel>
      <rico:name>rue de la Huchette (5e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Huchette (rue de la)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzbf1ezg--1s2sm9bitcqsd-vdp-11324"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzbf1ezg--1s2sm9bitcqsd-rue%20de%20la%20Huchette"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzbf1ezg--1s2sm9bitcqsd"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/11324_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Elle existait en 1200 et portait le nom de rue de Laas. En 1284, c'était déjà la rue de la Huchette. Au commencement du XVIIe siècle, rue des Rôtisseurs. Le débouché sur la place Saint-Michel a été formé lors de la création de cette place. | Origine du nom : Maison dite de la Huchette, probablement à cause de son enseigne, et qui appartenait, au XIVe siècle, au chapitre de Notre-Dame.</rico:history>
