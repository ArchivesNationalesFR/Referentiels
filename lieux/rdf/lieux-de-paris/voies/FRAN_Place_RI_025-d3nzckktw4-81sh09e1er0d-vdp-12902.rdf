   <rico:Activity rdf:about="activity/classement-FRAN_RI_025-d3nzckktw4-81sh09e1er0d-vdp-12902_1863-05-23_1935-07-23">
      <rico:generalDescription xml:lang="fr">Décret du 3 juin 1899, sauf entre les rues Bénard et du Moulin Vert. Décret du 23 juillet 1935, partie M. La partie entre la rue d'Alésia et le boulevard Brune, voie de la commune de Montrouge, n'avait pas été classée dans la voirie parisienne par le décret du 23 mai 1863.</rico:generalDescription>
