   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nzckktw4-81sh09e1er0d-vdp-12902_1826-12-06_1967-08-17">
      <rico:generalDescription xml:lang="fr">Retenus au POS et non repris au PLU : Arrêté du 31 août 1934, au droit du n° 34 bis. Non retenus au POS et non repris au PLU : Décret du 6 décembre 1826, au droit des nos 21 bis et 23. Arrêté du 17 août 1967, raccordement du côté impair avec la rue de Châtillon. Décret du 23 juillet 1935, côté pair, partie M. Arrêté du 31 août 1934, le surplus de la voie et pan coupé de 8 m, côté impair, à l'angle de la rue du Moulin Vert, côté pair, sauf au droit du n° 34 bis.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nzckktw4-81sh09e1er0d-vdp-12902"/>
