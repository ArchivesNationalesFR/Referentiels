   <rico:Place rdf:about="place/FRAN_RI_025-d3nz9e0pry--wabtev429lq0-vdp-9733">
      <skos:prefLabel xml:lang="fr">rue de la Chapelle (18e arrondissement, Paris, France ; id : 9733)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de la Chapelle</skos:altLabel>
      <rico:name>rue de la Chapelle (18e arrondissement, Paris, France ; id : 9733)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Chapelle (rue de la)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz9e0pry--wabtev429lq0-vdp-9733"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nz9e0pry--wabtev429lq0-rue%20de%20la%20Chapelle"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nz9e0pry--wabtev429lq0"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/9733_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Précédemment, partie de la grande rue de la Chapelle ; cette dernière voie s'est appelée route Royale n° 1 ; grande rue ou rue de la Chapelle Franciade pendant la Révolution ; rue du Faubourg de Gloire (1814) entre le boulevard de la Chapelle et la rue Ordener. Partie de la route nationale n° 1. Le tronçon compris entre la place de la Chapelle et la rue Ordener a pris en 1945 le nom de rue Marx Dormoy. [Origine du nom de la voie :] Principale rue de l'ancienne commune de la Chapelle Saint-Denis.</rico:history>
