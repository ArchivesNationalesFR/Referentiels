   <rico:Place rdf:about="place/FRAN_RI_025-d3nzc6pd7n-rfw345orhawe-vdp-12441">
      <rdfs:label xml:lang="fr">rue Nationale (13e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue Nationale (13e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Nationale</skos:altLabel>
      <rico:name>rue Nationale (13e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Nationale (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzc6pd7n-rfw345orhawe-vdp-12441"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzc6pd7n-rfw345orhawe-rue%20Nationale"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzc6pd7n-rfw345orhawe"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/12441_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">La partie C était indiquée sur le plan cadastral de 1812. Un arr. du 4 octobre 1937 a déclaré d'utilité publique l'ouverture d'une voie nouvelle (avenue Edison), entre le carrefour des rues Nationale et de Tolbiac et la place d'Italie. | Origine du nom : Donné après la Révolution de 1848.</rico:history>
