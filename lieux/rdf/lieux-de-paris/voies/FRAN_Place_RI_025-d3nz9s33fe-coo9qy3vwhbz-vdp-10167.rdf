   <rico:Place rdf:about="place/FRAN_RI_025-d3nz9s33fe-coo9qy3vwhbz-vdp-10167">
      <skos:prefLabel xml:lang="fr">villa Daumesnil (12e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">villa Daumesnil</skos:altLabel>
      <rico:name>villa Daumesnil (12e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Daumesnil (villa)</skos:hiddenLabel>
