      <rico:hasExtent rdf:resource="extent/vdp-10167_longueur"/>
      <anf-onto:startingAtPoint xml:lang="fr">avenue Daumesnil, 218.</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">rue de Fécamp, 59.</anf-onto:endingAtPoint>
