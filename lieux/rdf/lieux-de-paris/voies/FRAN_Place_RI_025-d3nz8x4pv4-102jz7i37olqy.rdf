   <rico:Place rdf:about="place/FRAN_RI_025-d3nz8x4pv4-102jz7i37olqy">
      <rdfs:label xml:lang="fr">rue Bois Le Vent (Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue Bois Le Vent (Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Bois Le Vent</skos:altLabel>
      <skos:hiddenLabel xml:lang="fr">Bois-le-Vent (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz8x4pv4-102jz7i37olqy"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nz8x4pv4-102jz7i37olqy-rue%20Bois%20Le%20Vent"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d’après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/9375_VdP"/>
      <rico:hasOrHadIdentifier rdf:resource="identifier/d3nz8x4pv4-102jz7i37olqy"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Précédemment, rue Bois le Vent, entre la place de Passy et la rue de Boulainvilliers et rue des Vignes, entre la rue de Boulainvilliers et l’avenue Mozart. Elle était pavée en 1720. Elle est indiquée sur le plan de Roussel (1730). Les immeubles portant les nos 3 et 7 ont été démolis par la Ville pour le dégagement du marché de Passy (déc. du 17 octobre 1888, UP).</rico:history>
      <rico:isOrWasRegulatedBy rdf:resource="rule/arrete-FRAN_RI_025-d3nz8x4pv4-102jz7i37olqy"/>
