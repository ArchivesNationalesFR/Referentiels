      <rico:hasExtent rdf:resource="extent/vdp-11124_numero_impair"/>
      <anf-onto:startingAtPoint xml:lang="fr">place Michel Debré, 2 et rue du Dragon, 44.</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">avenue de La Bourdonnais, 83.</anf-onto:endingAtPoint>
