   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nza9zk3i-1llyoorylyeow_1935-02-12">
      <rico:generalDescription xml:lang="fr">Non retenus au POS et non repris au PLU : Arrêté du 12 février 1935, au droit du n° 7. Retenus au PAZ de la Zac "Amandiers" et non repris au PLU : Arrêté du 12 février 1935, au droit des nos 20 à 22 (entre la rue Soleillet et la rue Sorbier). Non retenus au PAZ de la Zac "Amandiers" et non repris au PLU : Arrêté du 12 février 1935, le surplus.</rico:generalDescription>
      <rico:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1935-02-12</rico:date>
