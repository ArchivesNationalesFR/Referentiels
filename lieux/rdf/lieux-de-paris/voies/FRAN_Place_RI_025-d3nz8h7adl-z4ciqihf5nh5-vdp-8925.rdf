   <rico:Place rdf:about="place/FRAN_RI_025-d3nz8h7adl-z4ciqihf5nh5-vdp-8925">
      <rdfs:label xml:lang="fr">rue des Amandiers (20e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue des Amandiers (20e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue des Amandiers</skos:altLabel>
      <rico:name>rue des Amandiers (20e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Amandiers (rue des)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz8h7adl-z4ciqihf5nh5-vdp-8925"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nz8h7adl-z4ciqihf5nh5-rue%20des%20Amandiers"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nz8h7adl-z4ciqihf5nh5"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/8925_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Elle est indiquée sur le plan de Jouvin de Rochefort (1672). La partie qui débouchait sur le boulevard de Ménilmontant a été dénommée place Auguste Métivier par arrêté préfectoral du 28 octobre 1910. | Origine du nom : Voie faisant suite à l'ancienne rue des Amandiers (devenue rue du Chemin Vert), qui avait été percée sur un terrain dit des Amandiers.</rico:history>
