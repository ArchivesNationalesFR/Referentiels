   </rico:Activity>
   <rico:Activity rdf:about="activity/classement-FRAN_RI_025-d3nz8h7adl-z4ciqihf5nh5-vdp-8925_1863-05-23">
      <rico:generalDescription xml:lang="fr">Décret du 23 mai 1863, dans la voirie parisienne. Précédemment voie des anciennes communes de Charonne et de Belleville.</rico:generalDescription>
      <rico:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1863-05-23</rico:date>
