   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nz8h7adl-z4ciqihf5nh5-vdp-8925_1931-03-05">
      <rico:generalDescription xml:lang="fr">Retenus au PAZ de la Zac "Amandiers" et non repris au PLU : Arrêté du 5 mars 1931, au droit des nos 31 à 59 et 65 à 75. Non retenus au PAZ de la Zac "Amandiers" et non repris au PLU : Arrêté du 5 mars 1931, au droit des nos 13 à 29, 61, 77 à 121 et 2 à 102. Non retenus au POS et non repris au PLU : Arrêté du 5 mars 1931, sauf au droit des nos 13 à 121 et 2 à 102.</rico:generalDescription>
      <rico:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1931-03-05</rico:date>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
