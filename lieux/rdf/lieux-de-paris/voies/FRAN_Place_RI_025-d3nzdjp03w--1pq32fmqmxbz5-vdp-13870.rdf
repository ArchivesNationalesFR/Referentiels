      <rico:hasExtent rdf:resource="extent/vdp-13870_numero_pair"/>
      <rico:hasExtent rdf:resource="extent/vdp-13870_numero_impair"/>
      <anf-onto:startingAtPoint xml:lang="fr">quai de la Rapée, 84.</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">rue du Faubourg Saint-Antoine, 100 et avenue Ledru-Rollin, 88.</anf-onto:endingAtPoint>
