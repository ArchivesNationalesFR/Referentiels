   <rico:Place rdf:about="place/FRAN_RI_025-d3nzdjp03w--1pq32fmqmxbz5-vdp-13870">
      <skos:prefLabel xml:lang="fr">rue Traversière (12e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Traversière</skos:altLabel>
      <rico:name>rue Traversière (12e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Traversière (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzdjp03w--1pq32fmqmxbz5-vdp-13870"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzdjp03w--1pq32fmqmxbz5-rue%20Traversi%C3%A8re"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzdjp03w--1pq32fmqmxbz5"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">En 1806, rue des Chantiers ou rue du Cler Chantier, entre le quai et la rue de Bercy ; rue Pavée, entre les rues de Bercy et de Charenton. Cette voie est tracée sur le plan de Jouvin de Rochefort (1672). [Origine du nom de la voie :] Au XVIIe siècle, un jardinier du nom de Traversire ou Traversier possédait des terrains en cet endroit.</rico:history>
