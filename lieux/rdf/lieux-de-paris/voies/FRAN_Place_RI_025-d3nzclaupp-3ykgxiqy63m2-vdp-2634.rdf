      <rico:name>rue des Poirées (5e arrondissement, Paris, France ; id : 2634)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Poirées (rue des)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzclaupp-3ykgxiqy63m2-vdp-2634"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzclaupp-3ykgxiqy63m2-rue%20des%20Poir%C3%A9es"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzclaupp-3ykgxiqy63m2"/>
      <anf-onto:streetStatus xml:lang="fr">voie caduque d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/2634_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:endDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1864-08-24</rico:endDate>
      <rico:history xml:lang="fr">Dénommée rue Gerson (supprimée) et rue Restaut (supprimée) par décret impérial du 24 août 1864. Supprimée par l'agrandissement de la Sorbonne. Elle allait de la rue Saint-Jacques à la rue Neuve des Poirées. En 1236, rue Thomas d'Argenteuil. En 1254, rue Guillaume d'Argenteuil. En 1443, le peuple lui donne le nom de rue aux Ecoliers de Rethel, à cause du collège de Rethel qui y était établi. En 1824, elle a été prolongée jusqu'à la place de la Sorbonne. En 1839, elle a été confondue avec la place du Lycée Louis le Grand (Supprimé.). En 1864, elle a été nommée rue et place Gerson. Sur le plan de l'Abbé Delagrive, elle est nommée rue Grenouiller ou Grenouillière.</rico:history>
      <rico:isOrWasContainedBy rdf:resource="place/FRAN_RI_023-d3nyvh2pig-13rb8i6kjc8hv"/>
      <rico:isOrWasContainedBy rdf:resource="place/FRAN_RI_022-d3nyv8haov--4rhgfxrxatvr"/>
   </rico:Place>
