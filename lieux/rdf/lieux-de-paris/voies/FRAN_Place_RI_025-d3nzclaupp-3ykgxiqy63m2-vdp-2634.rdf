   <rico:Place rdf:about="place/FRAN_RI_025-d3nzclaupp-3ykgxiqy63m2-vdp-2634">
      <rdfs:label xml:lang="fr">rue des Poirées (5e arrondissement, Paris, France ; id : 2634)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue des Poirées (5e arrondissement, Paris, France ; id : 2634)</skos:prefLabel>
