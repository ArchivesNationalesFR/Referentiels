   <rico:Place rdf:about="place/FRAN_RI_025-d3nz9fb0ww--1jfnixcittijg-vdp-9797">
      <rdfs:label xml:lang="fr">rue Charlot (3e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue Charlot (3e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Charlot</skos:altLabel>
      <rico:name>rue Charlot (3e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Charlot (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz9fb0ww--1jfnixcittijg-vdp-9797"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nz9fb0ww--1jfnixcittijg-rue%20Charlot"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nz9fb0ww--1jfnixcittijg"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/9797_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Précédemment, rue d'Orléans ou rue d'Orléans au Marais, entre les rues des Quatre Fils et de Poitou ; rue de Berry, entre les rues de Poitou et de Bretagne ; rue Charlot, entre la rue de Bretagne et le boulevard du Temple. L'ancienne rue Charlot s'est appelée primitivement rue d'Angoumois. | Origine du nom : Claude Charlot y avait fait bâtir plusieurs maisons au XVIIe siècle.</rico:history>
