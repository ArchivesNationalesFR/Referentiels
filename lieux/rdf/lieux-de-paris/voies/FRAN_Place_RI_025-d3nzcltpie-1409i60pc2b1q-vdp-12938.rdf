   <rico:Place rdf:about="place/FRAN_RI_025-d3nzcltpie-1409i60pc2b1q-vdp-12938">
      <rdfs:label xml:lang="fr">rue du Ponceau (2e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue du Ponceau (2e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue du Ponceau</skos:altLabel>
      <rico:name>rue du Ponceau (2e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Ponceau (rue du)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzcltpie-1409i60pc2b1q-vdp-12938"/>
