   <rico:Place rdf:about="place/FRAN_RI_025-d3nz8ivu45-crej177zq98t-vdp-8988">
      <rdfs:label xml:lang="fr">rue d'Anjou (8e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue d'Anjou (8e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue d'Anjou</skos:altLabel>
      <rico:name>rue d'Anjou (8e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Anjou (rue d')</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz8ivu45-crej177zq98t-vdp-8988"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nz8ivu45-crej177zq98t-rue%20d%27Anjou"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nz8ivu45-crej177zq98t"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/8988_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Précédemment rue d'Anjou Saint-Honoré, elle a porté le nom de rue des Morfondus. La partie comprise entre les rues du Faubourg Saint-Honoré et de la Ville l'Evêque, figure sur le plan de Jouvin de Rochefort (1672). Elle fut prolongée jusqu'au grand égout en 1721 et, en 1778, jusqu'à la rue de la Pépinière ; ce dernier tronçon porta primitivement le nom de rue Quatremère. | Origine du nom : Probablement en l'honneur du duc d'Anjou (Henri III).</rico:history>
