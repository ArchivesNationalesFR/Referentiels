   <rico:Place rdf:about="place/FRAN_RI_025-d3nzc0lwix-1fpw6hohexuzs-vdp-12192">
      <rdfs:label xml:lang="fr">rue de Mazagran (10e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue de Mazagran (10e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de Mazagran</skos:altLabel>
      <rico:name>rue de Mazagran (10e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Mazagran (rue de)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzc0lwix-1fpw6hohexuzs-vdp-12192"/>
