   <rico:Place rdf:about="place/FRAN_RI_025-d3nz9l0ip7-18pxlhujjwr4e-vdp-9944">
      <rdfs:label xml:lang="fr">rue Cochin (5e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue Cochin (5e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Cochin</skos:altLabel>
      <rico:name>rue Cochin (5e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Cochin (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz9l0ip7-18pxlhujjwr4e-vdp-9944"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nz9l0ip7-18pxlhujjwr4e-rue%20Cochin"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nz9l0ip7-18pxlhujjwr4e"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/9944_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Précédemment, partie de la grande rue Sartine. La grande rue Sartine a porté le nom de place de la Halle aux Veaux ou du Marché aux Veaux. Elle entourait la Halle aux Veaux installée sur l'emplacement du couvent des Bernardins, supprimée par le décret du 11 août 1855. Elle fut formée en 1774 en même temps que la Halle aux Veaux. | Origine du nom : Jean Denys Alaric Cochin (1789-1841), philanthrope, maire et député de Paris.</rico:history>
