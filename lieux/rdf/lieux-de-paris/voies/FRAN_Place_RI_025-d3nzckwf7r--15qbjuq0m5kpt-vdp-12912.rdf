   <rico:Place rdf:about="place/FRAN_RI_025-d3nzckwf7r--15qbjuq0m5kpt-vdp-12912">
      <rdfs:label xml:lang="fr">rue Pleyel (12e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue Pleyel (12e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Pleyel</skos:altLabel>
      <rico:name>rue Pleyel (12e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Pleyel (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzckwf7r--15qbjuq0m5kpt-vdp-12912"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzckwf7r--15qbjuq0m5kpt-rue%20Pleyel"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzckwf7r--15qbjuq0m5kpt"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/12912_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Précédemment rue du Trou à Sable ; on l'a appelée aussi rue des Trois Sabres. Elle est indiquée sur le plan de Jaillot (1772). Cette voie s'étendait autrefois jusqu'à la rue de Reuilly. Le tronçon compris entre les rues de Reuilly et Dugommier a été supprimé lors de l'ouverture de l'avenue Daumesnil ; au droit des nos 1 à 7, elle formait une place triangulaire convertie en rue de 13 m de largeur à la même époque. | Origine du nom : Joseph Etienne Camille Pleyel (1788-1855), compositeur et facteur de piano.</rico:history>
