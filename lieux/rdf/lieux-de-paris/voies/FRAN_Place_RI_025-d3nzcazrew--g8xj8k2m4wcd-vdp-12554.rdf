   <rico:Place rdf:about="place/FRAN_RI_025-d3nzcazrew--g8xj8k2m4wcd-vdp-12554">
      <rdfs:label xml:lang="fr">rue des Orfèvres (1er arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue des Orfèvres (1er arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue des Orfèvres</skos:altLabel>
      <rico:name>rue des Orfèvres (1er arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Orfèvres (rue des)</skos:hiddenLabel>
