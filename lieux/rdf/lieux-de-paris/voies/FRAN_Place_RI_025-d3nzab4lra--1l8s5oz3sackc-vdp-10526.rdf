   <rico:Place rdf:about="place/FRAN_RI_025-d3nzab4lra--1l8s5oz3sackc-vdp-10526">
      <skos:prefLabel xml:lang="fr">rue d'Enghien (10e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue d'Enghien</skos:altLabel>
      <rico:name>rue d'Enghien (10e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Enghien (rue d')</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzab4lra--1l8s5oz3sackc-vdp-10526"/>
