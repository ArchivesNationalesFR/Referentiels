      <rico:hasOrHadIdentifier rdf:resource="identifier/10526_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Précédemment, rue Mably. [Origine du nom de la voie :] Louis Antoine Henri de Bourbon, duc d'Enghien, né en 1772, fusillé à Vincennes en 1804.</rico:history>
