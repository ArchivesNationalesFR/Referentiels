   <rico:Place rdf:about="place/FRAN_RI_025-d3nz8t5wzi-15b5yzcc7k9u7-vdp-9262">
      <skos:prefLabel xml:lang="fr">rue de Bellevue (19e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de Bellevue</skos:altLabel>
      <rico:name>rue de Bellevue (19e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Bellevue (rue de)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz8t5wzi-15b5yzcc7k9u7-vdp-9262"/>
