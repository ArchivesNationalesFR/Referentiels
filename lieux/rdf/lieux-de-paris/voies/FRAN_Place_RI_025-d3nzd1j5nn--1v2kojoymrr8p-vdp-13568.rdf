   <rico:Activity rdf:about="activity/classement-FRAN_RI_025-d3nzd1j5nn--1v2kojoymrr8p-vdp-13568_1863-05-23">
      <rico:generalDescription xml:lang="fr">Décret du 23 mai 1863 (dans la voirie parisienne), entre le boulevard de Grenelle et un point situé à 130 m au-delà du rond-point Saint-Charles. Précédemment voie de l'ancienne commune de Grenelle dans cette partie. Décret du 23 mai 1863, le surplus.</rico:generalDescription>
      <rico:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1863-05-23</rico:date>
