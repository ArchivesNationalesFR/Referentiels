   <rico:Place rdf:about="place/FRAN_RI_025-d3nza3c3nn--b18wtkiul0c5-vdp-10230">
      <rdfs:label xml:lang="fr">rue Desaix (15e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue Desaix (15e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Desaix</skos:altLabel>
      <rico:name>rue Desaix (15e arrondissement, Paris, France)</rico:name>
