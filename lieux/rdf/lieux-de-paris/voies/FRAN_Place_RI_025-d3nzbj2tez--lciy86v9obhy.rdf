   <rico:Activity rdf:about="activity/classement-FRAN_RI_025-d3nzbj2tez--lciy86v9obhy_1863-05-23_1932-10-11">
      <rico:generalDescription xml:lang="fr">Décret du 23 mai 1863 (dans la voirie parisienne), entre la place de la bataille de Stalingrad et le tronçon supprimé du boulevard Sérurier (un point situé actuellement 35 m au-delà du côté pair de la Sente des Dorées) (A). Arrêté du 11 octobre 1932, entre le point ci-dessus défini et la limite de la zone "non aedificandi" (B).</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/classement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nzbj2tez--lciy86v9obhy"/>
