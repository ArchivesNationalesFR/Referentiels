   <rico:Place rdf:about="place/FRAN_RI_025-d3nzd1dy4c-795rfg0rjrsb-vdp-13560">
      <rdfs:label xml:lang="fr">rue Saint-Bernard (11e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue Saint-Bernard (11e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Saint-Bernard</skos:altLabel>
      <rico:name>rue Saint-Bernard (11e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Saint-Bernard (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzd1dy4c-795rfg0rjrsb-vdp-13560"/>
