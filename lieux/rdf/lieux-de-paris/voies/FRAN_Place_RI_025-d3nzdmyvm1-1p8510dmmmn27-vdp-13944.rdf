   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nzdmyvm1-1p8510dmmmn27-vdp-13944_1840-08-22_1915-12-16">
      <rico:generalDescription xml:lang="fr">Non retenus au POS et non repris au PLU : Ordonnance du 22 août 1840, côté impair en entier et côté pair de la partie A. Décret du 16 décembre 1915, côté pair, sur une longueur de 101 m environ à partir de la rue du Colonel Driant, et pan coupé de 8 m du côté pair, à l'angle de la rue des Petits Champs (ces alignements ne sont exécutoires par mesure ordinaire de voirie). Décret du 23 novembre 1912, le surplus du côté pair jusqu'à la rue des Petits Champs (M) (ces alignements ne sont exécutoires par mesure ordinaire de voirie).</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nzdmyvm1-1p8510dmmmn27-vdp-13944"/>
      <rico:hadSubevent rdf:resource="activity/alignement-FRAN_RI_025-d3nzdmyvm1-1p8510dmmmn27-vdp-13944_1840-08-22_1915-12-16_1840-08-22"/>
      <rico:hadSubevent rdf:resource="activity/alignement-FRAN_RI_025-d3nzdmyvm1-1p8510dmmmn27-vdp-13944_1840-08-22_1915-12-16_1912-11-23"/>
