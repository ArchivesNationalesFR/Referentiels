   <rico:Activity rdf:about="activity/nivellement-FRAN_RI_025-d3nzdmyvm1-1p8510dmmmn27-vdp-13944_1912-11-23">
      <rico:generalDescription xml:lang="fr">Décret du 23 novembre 1912, partie côté pair entre un point situé environ à 101 m à partir de la rue du Colonel Driant jusqu'à la rue de Beaujolais.</rico:generalDescription>
      <rico:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1912-11-23</rico:date>
