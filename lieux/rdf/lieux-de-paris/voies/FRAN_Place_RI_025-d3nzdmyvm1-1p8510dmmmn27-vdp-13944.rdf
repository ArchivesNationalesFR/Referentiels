   <rico:Place rdf:about="place/FRAN_RI_025-d3nzdmyvm1-1p8510dmmmn27-vdp-13944">
      <rdfs:label xml:lang="fr">rue de Valois (1er arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue de Valois (1er arrondissement, Paris, France)</skos:prefLabel>
