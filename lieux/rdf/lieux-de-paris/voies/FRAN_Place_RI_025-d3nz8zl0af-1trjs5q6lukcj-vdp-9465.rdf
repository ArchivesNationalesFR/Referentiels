      <skos:altLabel xml:lang="fr">rue Boyer</skos:altLabel>
      <rico:name>rue Boyer (20e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Boyer (rue)</skos:hiddenLabel>
