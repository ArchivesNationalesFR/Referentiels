      <skos:altLabel xml:lang="fr">rue de Strasbourg</skos:altLabel>
      <rico:name>rue de Strasbourg (10e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Strasbourg (rue de)</skos:hiddenLabel>
