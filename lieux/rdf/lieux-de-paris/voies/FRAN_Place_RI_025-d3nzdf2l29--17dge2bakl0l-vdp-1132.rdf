      <anf-onto:startingAtPoint xml:lang="fr">rue du Faubourg Saint-Martin, 131.</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">boulevard de Magenta, 84 et rue du Faubourg Saint-Denis, 122.</anf-onto:endingAtPoint>
