      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:endDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1966-02-17</rico:endDate>
      <rico:history xml:lang="fr">Dénommée rue du 8 Mai 1945 par arrêté du 17 février 1966. Précédemment rue Neuve Chabrol. [Origine du nom de la voie :] Strasbourg, capitale de l'Alsace ; voisinage de la Gare de l'Est.</rico:history>
