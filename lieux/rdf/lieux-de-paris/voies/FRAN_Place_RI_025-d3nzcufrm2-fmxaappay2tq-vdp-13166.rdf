      <skos:altLabel xml:lang="fr">rue du Regard</skos:altLabel>
      <rico:name>rue du Regard (6e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Regard (rue du)</skos:hiddenLabel>
