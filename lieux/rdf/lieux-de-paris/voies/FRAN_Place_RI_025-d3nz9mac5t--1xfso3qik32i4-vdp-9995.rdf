   <rico:Place rdf:about="place/FRAN_RI_025-d3nz9mac5t--1xfso3qik32i4-vdp-9995">
      <rdfs:label xml:lang="fr">rue du Commerce (15e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue du Commerce (15e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue du Commerce</skos:altLabel>
      <rico:name>rue du Commerce (15e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Commerce (rue du)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz9mac5t--1xfso3qik32i4-vdp-9995"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nz9mac5t--1xfso3qik32i4-rue%20du%20Commerce"/>
