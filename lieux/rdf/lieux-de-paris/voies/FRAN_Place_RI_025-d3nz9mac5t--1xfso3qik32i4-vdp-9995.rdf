   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nz9mac5t--1xfso3qik32i4-vdp-9995_1881-08-30_1938-01-12">
      <rico:generalDescription xml:lang="fr">Non retenus au POS et non repris au PLU : Décret du 30 août 1881, côté pair, entre le boulevard de Grenelle et la rue Tiphaine. Arrêté du 16 janvier 1932 (relatif à la rue Frémicourt), au droit des nos 35 et 37. Arrêté du 12 janvier 1938, le surplus et pans coupés, côté pair : 1° à l'angle du boulevard de Grenelle ; 2° à l'angle de la rue Tiphaine, côté impair.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nz9mac5t--1xfso3qik32i4-vdp-9995"/>
      <rico:hadSubevent rdf:resource="activity/alignement-FRAN_RI_025-d3nz9mac5t--1xfso3qik32i4-vdp-9995_1881-08-30_1938-01-12_1881-08-30"/>
