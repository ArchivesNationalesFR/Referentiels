   <rico:Place rdf:about="place/FRAN_RI_025-d3nzc9m5pw-li2n57v3e689-vdp-3341">
      <skos:prefLabel xml:lang="fr">cité du Nord (17e arrondissement, Paris, France ; id : 3341)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">cité du Nord</skos:altLabel>
      <rico:name>cité du Nord (17e arrondissement, Paris, France ; id : 3341)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Nord (cité du)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzc9m5pw-li2n57v3e689-vdp-3341"/>
