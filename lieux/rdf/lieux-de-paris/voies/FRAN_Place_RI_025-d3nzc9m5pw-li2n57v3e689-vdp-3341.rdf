      <rico:hasOrHadIdentifier rdf:resource="identifier/3341_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/cit%C3%A9"/>
      <rico:history xml:lang="fr">Actuellement partie de la rue Ernest Roche. La cité du Nord avait été ouverte, lors de l'établissement du chemin de fer de Ceinture par les compagnies concessionnaires, remise en avait été faite aux riverains par arrêté du 17 mai 1901. La cité du Nord, avant 1927, a porté le nom d'impasse du Docteur.</rico:history>
      <rico:isOrWasContainedBy rdf:resource="place/FRAN_RI_022-d3nyv8ljb1--rjak82kccgxp"/>
   </rico:Place>
