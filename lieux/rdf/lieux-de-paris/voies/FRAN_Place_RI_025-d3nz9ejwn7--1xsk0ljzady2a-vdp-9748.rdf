   <rico:Place rdf:about="place/FRAN_RI_025-d3nz9ejwn7--1xsk0ljzady2a-vdp-9748">
      <skos:prefLabel xml:lang="fr">rue Charlemagne (4e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Charlemagne</skos:altLabel>
      <rico:name>rue Charlemagne (4e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Charlemagne (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz9ejwn7--1xsk0ljzady2a-vdp-9748"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nz9ejwn7--1xsk0ljzady2a-rue%20Charlemagne"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nz9ejwn7--1xsk0ljzady2a"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/9748_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Cette voie existait vers le milieu du XIVe siècle ; d'abord comprise dans la rue de Jouy, elle porta aussi le nom de rue de l'Abbé de Jouy, rue de la Fausse Poterne, rue de la Fausse Poterne Saint-Paul ; plus tard, elle fut dénommée rue de l'Archet Saint-Paul et rue des Prêtres Saint-Paul. [Origine du nom de la voie :] Voisinage du lycée Charlemagne.</rico:history>
