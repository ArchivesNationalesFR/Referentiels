   <rico:Place rdf:about="place/FRAN_RI_025-d3nzc4ek0v-1kprw2u4z6x3w-vdp-12360">
      <rdfs:label xml:lang="fr">rue de Montpensier (1er arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue de Montpensier (1er arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de Montpensier</skos:altLabel>
