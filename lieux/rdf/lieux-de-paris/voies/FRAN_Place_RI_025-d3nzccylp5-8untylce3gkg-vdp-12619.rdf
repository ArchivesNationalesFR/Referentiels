   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nzccylp5-8untylce3gkg-vdp-12619_1850-03-22_1952-02-22">
      <rico:generalDescription xml:lang="fr">Non retenus au POS et non repris au PLU : Décret du Président de la République du 22 mars 1850 : 1° côté impair du n° 1 au n° 21 bis inclus ; 2° côté pair entre les rues d'Hauteville et du Faubourg Poissonnière. Arr. du 22 février 1952, le surplus et pans coupés : 1° côté impair aux angles de la rue Martel. 2° côté pair à l'angle de la rue du Faubourg Poissonnière.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nzccylp5-8untylce3gkg-vdp-12619"/>
      <rico:hadSubevent rdf:resource="activity/alignement-FRAN_RI_025-d3nzccylp5-8untylce3gkg-vdp-12619_1850-03-22_1952-02-22_1850-03-22"/>
