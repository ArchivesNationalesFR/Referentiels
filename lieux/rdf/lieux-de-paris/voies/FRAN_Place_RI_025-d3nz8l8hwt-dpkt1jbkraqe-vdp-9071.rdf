   <rico:Place rdf:about="place/FRAN_RI_025-d3nz8l8hwt-dpkt1jbkraqe-vdp-9071">
      <rdfs:label xml:lang="fr">rue d'Artois (8e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue d'Artois (8e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue d'Artois</skos:altLabel>
      <rico:name>rue d'Artois (8e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Artois (rue d')</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz8l8hwt-dpkt1jbkraqe-vdp-9071"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nz8l8hwt-dpkt1jbkraqe-rue%20d%27Artois"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nz8l8hwt-dpkt1jbkraqe"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/9071_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Créée sous le nom de rue Neuve de Poitiers. Dénommée en 1823 rue des Ecuries d'Artois ; en 1848 rue de la Réforme ; reprit le nom de rue des Ecuries d'Artois en 1852. Jusqu'en 1877, la rue Berryer, créée en 1842, faisait partie de la rue des Ecuries d'Artois. La partie comprise entre les rues de Berri et Washington a été percée à la fin du XVIIIe siècle. | Origine du nom : Ouverte sur l'emplacement des écuries du comte d'Artois (Charles X).</rico:history>
