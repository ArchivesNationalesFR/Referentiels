   <rico:PlaceName rdf:about="placeName/FRAN_RI_025-d3nzc09udz-apiu85xwsbzk-rue%20Maurice%20et%20Louis%20de%20Broglie">
      <rico:textualValue xml:lang="fr">rue Maurice et Louis de Broglie</rico:textualValue>
      <rico:history xml:lang="fr">Maurice (Paris, 1875-Neuilly, 1960) et Louis (Dieppe, 1892-Louveciennes, 1987) ducs de Broglie, physiciens français. Le premier était auteur de travaux sur les rayons X et le second, créateur de la mécanique ondulatoire, a été prix Nobel de physique en 1929. Ils étaient membres de l’Académie des sciences et de l’Académie française.</rico:history>
      <rico:isOrWasPlaceNameOf rdf:resource="place/FRAN_RI_025-d3nzc09udz-apiu85xwsbzk"/>
      <rico:resultsOrResultedFrom rdf:resource="activity/denomination-FRAN_RI_025-d3nzc09udz-apiu85xwsbzk_1988-12-20"/>
   </rico:PlaceName>
