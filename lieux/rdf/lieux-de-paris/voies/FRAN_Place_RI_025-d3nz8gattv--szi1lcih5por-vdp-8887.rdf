   <rico:Place rdf:about="place/FRAN_RI_025-d3nz8gattv--szi1lcih5por-vdp-8887">
      <rdfs:label xml:lang="fr">rue d'Alger (1er arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue d'Alger (1er arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue d'Alger</skos:altLabel>
