   <rico:PlaceName rdf:about="placeName/FRAN_RI_025-d3nza8wi03-1do2qvdqoo0gk-place%20de%20l%27%C3%89dit%20de%20Nantes">
      <rico:textualValue xml:lang="fr">place de l’Édit de Nantes</rico:textualValue>
      <rico:history xml:lang="fr">Edit de pacification religieuse signé par Henri IV le 13 avril 1598, afin de mettre fin aux guerres civiles qui opposaient catholiques et protestants, et accordant des garanties sur le plan politique et religieux aux protestants.</rico:history>
