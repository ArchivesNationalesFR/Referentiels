   <rico:Place rdf:about="place/FRAN_RI_025-d3nz9qnrfp-16kl1saycb6ev-vdp-10112">
      <rdfs:label xml:lang="fr">rue de la Cure (16e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue de la Cure (16e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de la Cure</skos:altLabel>
      <rico:name>rue de la Cure (16e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Cure (rue de la)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz9qnrfp-16kl1saycb6ev-vdp-10112"/>
