   <rico:Activity rdf:about="activity/classement-vdp-13354_1854-09-19_1863-05-23">
      <rico:generalDescription xml:lang="fr">Décret du 23 mai 1863, dans la voirie parisienne. Précédemment voie de l'ancienne commune de Passy. Le tronçon compris entre la place de Mexico et l'avenue Georges Mandel avait été classé dans la voirie de Passy par arrêté préfectoral du 19 septembre 1854.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/classement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nzd0bifz--1cfz6rjann3e5-vdp-13354"/>
