   <rico:Activity rdf:about="activity/denomination-FRAN_RI_025-d3nzd0bifz--1cfz6rjann3e5_1868-04-02">
      <rico:generalDescription xml:lang="fr">dénomination : Arrêté du 2 avril 1868, réunissant la rue des Bornes, comprise entre les places de Mexico et Possoz, à la rue des Sablons, comprise entre la rue Saint-Didier et la place de Mexico.</rico:generalDescription>
      <rico:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1868-04-02</rico:date>
