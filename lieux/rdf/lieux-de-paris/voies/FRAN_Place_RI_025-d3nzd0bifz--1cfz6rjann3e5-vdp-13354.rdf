      <rico:hasExtent rdf:resource="extent/vdp-13354_longueur"/>
      <rico:hasExtent rdf:resource="extent/vdp-13354_numero_pair"/>
      <anf-onto:startingAtPoint xml:lang="fr">rue Saint-Didier, 35.</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">avenue Georges Mandel, 32-36.</anf-onto:endingAtPoint>
