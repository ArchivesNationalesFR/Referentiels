   <rico:Place rdf:about="place/FRAN_RI_025-d3nzcg5ojb-1hgrwf6hx9j35-vdp-12767">
      <rdfs:label xml:lang="fr">rue Perronet (7e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue Perronet (7e arrondissement, Paris, France)</skos:prefLabel>
