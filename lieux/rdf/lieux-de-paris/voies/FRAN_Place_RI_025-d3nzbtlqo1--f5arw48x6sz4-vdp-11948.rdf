   <rico:Place rdf:about="place/FRAN_RI_025-d3nzbtlqo1--f5arw48x6sz4-vdp-11948">
      <rdfs:label xml:lang="fr">rue du Louvre (1er-2e arrondissements, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue du Louvre (1er-2e arrondissements, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue du Louvre</skos:altLabel>
      <rico:name>rue du Louvre (1er-2e arrondissements, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Louvre (rue du)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzbtlqo1--f5arw48x6sz4-vdp-11948"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzbtlqo1--f5arw48x6sz4-rue%20du%20Louvre"/>
