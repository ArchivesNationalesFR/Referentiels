   <rico:Activity rdf:about="activity/ouverture-FRAN_RI_025-d3nzbtlqo1--f5arw48x6sz4-vdp-11948_1853-11-15_1906">
      <rico:generalDescription xml:lang="fr">Décret des 15 et 22 novembre 1853 (UP), entre la rue de Rivoli et la rue Saint-Honoré. Décret du 9 juin 1860 (UP) entre la rue Saint-Honoré et la rue Montmartre. Le décret précédent a été exécuté : en 1888, entre les rues Saint-Honoré et Coquillière ; en 1880, entre les rues Coquillière et d'Argout ; en 1906, entre la rue d'Argout et le passage du Vigan (supprimé, il commençait rue d'Argout, 63, et finissait rue d'Aboukir, 14).</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/ouverture%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nzbtlqo1--f5arw48x6sz4-vdp-11948"/>
