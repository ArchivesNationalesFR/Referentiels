   <rico:Place rdf:about="place/FRAN_RI_025-d3nz8jxl7u-1v52zzacbmcgw-vdp-9023">
      <skos:prefLabel xml:lang="fr">rue de l'Arbalète (5e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de l'Arbalète</skos:altLabel>
      <rico:name>rue de l'Arbalète (5e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Arbalète (rue de l')</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz8jxl7u-1v52zzacbmcgw-vdp-9023"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nz8jxl7u-1v52zzacbmcgw-rue%20de%20l%27Arbal%C3%A8te"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nz8jxl7u-1v52zzacbmcgw"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/9023_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Précédemment cul-de-sac des Patriarches entre les rues des Patriarches et Mouffetard. La partie comprise entre les rues Mouffetard et Berthollet s'est appelée rue des Sept Voies (XIVe siècle) et rue de la Porte de l'Arbalète (milieu du XVIe siècle). [Origine du nom de la voie :] Ancien tir à l'arbalète.</rico:history>
