   <rico:Place rdf:about="place/FRAN_RI_025-d3nzd7vs5e--eqtkj5mgg1dw-vdp-13713">
      <rdfs:label xml:lang="fr">place Sainte-Geneviève (5e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">place Sainte-Geneviève (5e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">place Sainte-Geneviève</skos:altLabel>
