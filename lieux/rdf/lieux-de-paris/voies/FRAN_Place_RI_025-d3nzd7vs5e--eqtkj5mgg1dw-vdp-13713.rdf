      <rico:hasOrHadIdentifier rdf:resource="identifier/13713_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/place"/>
      <rico:history xml:lang="fr">Commencée vers 1770. Elle a été appelée carré Sainte-Geneviève. | Origine du nom : Située à l'angle nord-est de la place du Panthéon, devant l'église Saint-Etienne du Mont, où est conservée la châsse de Sainte-Geneviève, patronne de Paris.</rico:history>
      <rico:isOrWasAffectedBy rdf:resource="activity/alignement-FRAN_RI_025-d3nzd7vs5e--eqtkj5mgg1dw-vdp-13713_1873-10-06_1972-08-30"/>
