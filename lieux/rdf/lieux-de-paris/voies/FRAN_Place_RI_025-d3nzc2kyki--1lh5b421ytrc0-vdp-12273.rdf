      <skos:hiddenLabel xml:lang="fr">Mogador (rue de)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzc2kyki--1lh5b421ytrc0-vdp-12273"/>
