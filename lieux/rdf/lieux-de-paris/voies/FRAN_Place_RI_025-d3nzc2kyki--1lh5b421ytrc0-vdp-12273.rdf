   <rico:Place rdf:about="place/FRAN_RI_025-d3nzc2kyki--1lh5b421ytrc0-vdp-12273">
      <rdfs:label xml:lang="fr">rue de Mogador (9e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue de Mogador (9e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de Mogador</skos:altLabel>
