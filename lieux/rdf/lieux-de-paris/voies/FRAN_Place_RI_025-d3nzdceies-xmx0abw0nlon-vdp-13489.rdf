   <rico:Place rdf:about="place/FRAN_RI_025-d3nzdceies-xmx0abw0nlon-vdp-13489">
      <rdfs:label xml:lang="fr">rue de la Sorbonne (5e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue de la Sorbonne (5e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de la Sorbonne</skos:altLabel>
      <rico:name>rue de la Sorbonne (5e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Sorbonne (rue de la)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzdceies-xmx0abw0nlon-vdp-13489"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzdceies-xmx0abw0nlon-rue%20de%20la%20Sorbonne"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzdceies-xmx0abw0nlon"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/13489_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Dénommée d'abord, au XIIIe siècle, rue des Portes et des Deux Portes, puis rue Sorbonne (vers 1281) ; Guillot, en 1300, l'appelle rue aux Hoirs de Sabonnes. En 1792, elle reçut le nom de rue Catinat ; en 1802, elle reprit celui de rue de la Sorbonne. En 1934, la partie comprise entre les rues des Ecoles et Du Sommerard a été englobée dans la place Paul Painlevé. | Origine du nom : Longe la Sorbonne.</rico:history>
