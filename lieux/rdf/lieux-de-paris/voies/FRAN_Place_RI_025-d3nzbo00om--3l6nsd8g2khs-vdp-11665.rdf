   <rico:Place rdf:about="place/FRAN_RI_025-d3nzbo00om--3l6nsd8g2khs-vdp-11665">
      <rdfs:label xml:lang="fr">rue Lamartine (9e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue Lamartine (9e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Lamartine</skos:altLabel>
      <rico:name>rue Lamartine (9e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Lamartine (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzbo00om--3l6nsd8g2khs-vdp-11665"/>
