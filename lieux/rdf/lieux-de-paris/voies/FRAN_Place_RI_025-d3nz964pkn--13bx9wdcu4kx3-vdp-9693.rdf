   <rico:Activity rdf:about="activity/alignement-vdp-9693_1890-07-01_1939-01-05">
      <rico:generalDescription xml:lang="fr">Retenus au POS et non repris au PLU : Arrêté du 1er septembre 1932, au droit des nos 29 à 37. Non retenus au POS et non repris au PLU : Décret du 1er juillet 1890, partie A. Arrêté du 1er septembre 1932, partie B sauf au droit des nos 29 à 37. Arrêté du 5 janvier 1939 (UP), pan coupé, côté pair, à l'angle de la rue Castagnary, côté pair. Cet arrêté a déclaré d'utilité publique l'élargissement de la voie entre les rues Fizeau et Castagnary.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nz964pkn--13bx9wdcu4kx3-vdp-9693"/>
