   <rico:Activity rdf:about="activity/classement-vdp-11064_1837-03-09_1863-05-23">
      <rico:generalDescription xml:lang="fr">Arrêté du 9 mars 1837, dans la voirie de la commune de Gentilly, et décret du 23 mai 1863, dans la voirie parisienne, partie B.</rico:generalDescription>
