   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nzaklbb4-14dad7d59d9yb-vdp-10877_1832-04-06_1883-03-15">
      <rico:generalDescription xml:lang="fr">Non retenus au POS et non repris au PLU : Décret du 17 septembre 1864, partie A. Ordonnance du 6 avril 1832 ; entre la place des Etats-Unis et la rue Vernet (B), sauf sur une longueur de 24 m environ, côté pair, avant l'avenue Marceau : partie régie par le décret du 6 mars 1858. Décret du 16 novembre 1853, partie C. Décret du 15 mars 1883, pans coupés, côté pair, à l'angle de l'avenue d'Iéna, côté impair et aux angles de la place de l'Uruguay.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nzaklbb4-14dad7d59d9yb-vdp-10877"/>
