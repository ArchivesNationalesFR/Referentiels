   <rico:Place rdf:about="place/FRAN_RI_025-d3nzcb2shj-1ffq6shdjea63-vdp-12559">
      <skos:prefLabel xml:lang="fr">rue de l'Orillon (11e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de l'Orillon</skos:altLabel>
      <rico:name>rue de l'Orillon (11e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Orillon (rue de l')</skos:hiddenLabel>
