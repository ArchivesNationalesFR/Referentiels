   <rico:PlaceName rdf:about="placeName/FRAN_RI_025-d3nzbp0tq8-1pktbk2q8t0b8-rue%20Le%20Brix%20et%20Mesmin">
      <rico:textualValue xml:lang="fr">rue Le Brix et Mesmin</rico:textualValue>
      <rico:history xml:lang="fr">Joseph Le Brix (1899-1931) et André Mesmin (1897-1931), aviateurs, morts en Sibérie au cours d’une tentative de raid Paris-Tokyo ; voisinage de la résidence de Le Brix.</rico:history>
