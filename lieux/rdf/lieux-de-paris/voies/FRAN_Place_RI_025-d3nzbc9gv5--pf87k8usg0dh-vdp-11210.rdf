   <rico:Place rdf:about="place/FRAN_RI_025-d3nzbc9gv5--pf87k8usg0dh-vdp-11210">
      <skos:prefLabel xml:lang="fr">rue des Haudriettes (3e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue des Haudriettes</skos:altLabel>
      <rico:name>rue des Haudriettes (3e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Haudriettes (rue des)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzbc9gv5--pf87k8usg0dh-vdp-11210"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzbc9gv5--pf87k8usg0dh-rue%20des%20Haudriettes"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzbc9gv5--pf87k8usg0dh"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Précédemment, rue des Vieilles Haudriettes ; elle s'appelait ainsi en 1650. Elle a été dénommée rue Jehan l'Huilier (1290), rue des Haudriettes, rue de l'Echelle du Temple, rue de la Fontaine Neuve (1636). [Origine du nom de la voie :] Société des femmes veuves, dites Haudriettes, parce que leur maison avait été fondée par Etienne Haudri, grand panetier de Philippe le Bel ; elles y avaient diverses propriétés.</rico:history>
