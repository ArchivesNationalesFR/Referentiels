      <anf-onto:startingAtPoint xml:lang="fr">rue des Archives, 53.</anf-onto:startingAtPoint>
      <anf-onto:endingOnStreet xml:lang="fr">rue du Temple, 78-84 et place Renée Vivien.</anf-onto:endingOnStreet>
