   <rico:PlaceName rdf:about="placeName/FRAN_RI_025-d3nzadc590--7dn62lur3yge-rue%20Eug%C3%A9nie%20%C3%89bou%C3%A9">
      <rico:textualValue xml:lang="fr">rue Eugénie Éboué</rico:textualValue>
      <rico:history xml:lang="fr">Eugénie Eboué (Cayenne, 1891-Pontoise, 1972), institutrice, épouse de Félix Eboué. Après le décès en 1944 de son mari, elle poursuivit l’oeuvre de celui-ci pour l’amélioration de la condition des noirs. Elle fut député et sénateur de la Guadeloupe.</rico:history>
      <rico:isOrWasPlaceNameOf rdf:resource="place/FRAN_RI_025-d3nzadc590--7dn62lur3yge"/>
      <rico:resultsOrResultedFrom rdf:resource="activity/denomination-FRAN_RI_025-d3nzadc590--7dn62lur3yge_1977-07-22"/>
   </rico:PlaceName>
