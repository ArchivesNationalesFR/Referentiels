   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nz92j5xz-1olszfxgd0wuz-vdp-9544_1929-03-14_1972-05-15">
      <rico:generalDescription xml:lang="fr">Non retenus au POS et non repris au PLU : Arrêté du 14 mars 1929. Le décret du 3 avril 1938 (relatif à la rue de la Croix Nivert) fixe l'alignement sur la rue de la Croix Nivert des immeubles portant les nos 15 et 17 de la rue de Cadix et rapporte les alignements approuvés par l'arrêté du 14 mars 1929 sur la rue de Cadix, au droit des immeubles portant les nos 17 et 19. Arrêté du 15 mai 1972 (relatif à la rue du Hameau), pans coupés aux angles de cette dernière voie.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nz92j5xz-1olszfxgd0wuz-vdp-9544"/>
      <rico:hadSubevent rdf:resource="activity/alignement-FRAN_RI_025-d3nz92j5xz-1olszfxgd0wuz-vdp-9544_1929-03-14_1972-05-15_1929-03-14"/>
