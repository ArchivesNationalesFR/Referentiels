      <rico:wasSubeventOf rdf:resource="activity/alignement-FRAN_RI_025-d3nz92j5xz-1olszfxgd0wuz-vdp-9544_1929-03-14_1972-05-15"/>
      <rico:precedesInTime rdf:resource="activity/alignement-FRAN_RI_025-d3nz92j5xz-1olszfxgd0wuz-vdp-9544_1929-03-14_1972-05-15_1938-04-03"/>
