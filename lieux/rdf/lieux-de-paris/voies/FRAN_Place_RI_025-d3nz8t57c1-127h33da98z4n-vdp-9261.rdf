   <rico:Place rdf:about="place/FRAN_RI_025-d3nz8t57c1-127h33da98z4n-vdp-9261">
      <skos:prefLabel xml:lang="fr">rue de Belleville (19e-20e arrondissements, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de Belleville</skos:altLabel>
      <rico:name>rue de Belleville (19e-20e arrondissements, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Belleville (rue de)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz8t57c1-127h33da98z4n-vdp-9261"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nz8t57c1-127h33da98z4n-rue%20de%20Belleville"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nz8t57c1-127h33da98z4n"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/9261_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Précédemment, rue de Paris, entre le boulevard de la Villette et la rue Compans ; rue du Parc, entre la rue Compans et le boulevard Sérurier. La rue de Belleville est indiquée sur le plan de Jouvin de Rochefort (1672). La partie N a été ouverte sur les terrains du Parc de Ménilmontant. [Origine du nom de la voie :] Principale rue de l'ancien village de Belleville.</rico:history>
