   <rico:PlaceName rdf:about="placeName/FRAN_RI_025-d3nzcr4b78-1e4rl8dt4zvbf-place%20des%2044%20Enfants%20d%27Izieu">
      <rico:textualValue xml:lang="fr">place des 44 Enfants d’Izieu</rico:textualValue>
      <rico:history xml:lang="fr">En hommage aux quarante-quatre enfants juifs, recueillis par Miron et Sabine ZLATIN, ainsi qu’aux adultes qui se sont occupés d’eux et y laissèrent leur vies. Ils furent déportés et assassinés à Auschwitz, en 1944.</rico:history>
      <rico:isOrWasPlaceNameOf rdf:resource="place/FRAN_RI_025-d3nzcr4b78-1e4rl8dt4zvbf"/>
      <rico:resultsOrResultedFrom rdf:resource="activity/denomination-FRAN_RI_025-d3nzcr4b78-1e4rl8dt4zvbf_2005-05-19"/>
   </rico:PlaceName>
