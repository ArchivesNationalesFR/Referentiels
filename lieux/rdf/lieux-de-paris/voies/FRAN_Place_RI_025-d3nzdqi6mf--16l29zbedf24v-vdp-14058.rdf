   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nzdqi6mf--16l29zbedf24v-vdp-14058_1856-02-16_1960-08-18">
      <rico:generalDescription xml:lang="fr">Non retenus au POS et non repris au PLU : Arrêté du 18 août 1960 : 1° partie A, sauf du côté impair : a) sur une longueur de 58 m environ à partir de la rue Raynouard ; b) depuis le n° 51 inclus jusqu'à la rue de Boulainvilliers. Parties régies par l'arrêté du 16 février 1856 ; 2° pans coupés aux angles de la rue de Boulainvilliers, côté impair. Décret du 22 avril 1908, partie B. Décret du 6 mars 1884, le surplus (partie C).</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nzdqi6mf--16l29zbedf24v-vdp-14058"/>
