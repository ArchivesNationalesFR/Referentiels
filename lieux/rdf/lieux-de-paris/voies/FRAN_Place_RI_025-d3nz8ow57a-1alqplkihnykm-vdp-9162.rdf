   <rico:Place rdf:about="place/FRAN_RI_025-d3nz8ow57a-1alqplkihnykm-vdp-9162">
      <skos:prefLabel xml:lang="fr">rue Baltard (1er arrondissement, Paris, France ; id : 9162)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Baltard</skos:altLabel>
      <rico:name>rue Baltard (1er arrondissement, Paris, France ; id : 9162)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Baltard (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz8ow57a-1alqplkihnykm-vdp-9162"/>
