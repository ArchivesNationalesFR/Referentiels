      <anf-onto:startingOnStreet xml:lang="fr">allée Saint-John Perse.</anf-onto:startingOnStreet>
      <anf-onto:endingOnStreet xml:lang="fr">rue Rambuteau.</anf-onto:endingOnStreet>
