      <rico:recordResourceSourceOfInformation xml:lang="fr">Notice relative à la voie 11333 dans la nomenclature des voies de Paris publiée en open data par la mairie de Paris (jeu de données de 2023)</rico:recordResourceSourceOfInformation>
      <skos:changeNote>
         <rdf:Description>
            <dc:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-12-26</dc:date>
            <rdf:value xml:lang="fr">Intégration automatique à la notice de nombreuses données relatives à ce lieu dans la nomenclature de la mairie de Paris (historique, coordonnées géographiques, données géométriques, indication des arrondissements et quartiers traversés...), ainsi que différentes activités (alignement, nivellement, numérotage...) liés à ce lieu.</rdf:value>
         </rdf:Description>
      </skos:changeNote>
   </rico:Record>
   <rico:Place rdf:about="place/FRAN_RI_025-d3nzbg55fr--1qgvr3u1i9zjf-vdp-11333">
      <skos:prefLabel xml:lang="fr">place d'Iéna (16e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">place d'Iéna</skos:altLabel>
