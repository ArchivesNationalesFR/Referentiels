   <rico:Place rdf:about="place/FRAN_RI_025-d3nzbbj164-ge5jz4t9swjy-vdp-5106">
      <skos:prefLabel xml:lang="fr">rue Gutenberg (14e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Gutenberg</skos:altLabel>
      <rico:name>rue Gutenberg (14e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Gutenberg (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzbbj164-ge5jz4t9swjy-vdp-5106"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzbbj164-ge5jz4t9swjy-rue%20Gutenberg"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzbbj164-ge5jz4t9swjy"/>
      <anf-onto:streetStatus xml:lang="fr">voie caduque d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:endDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1946-06-08</rico:endDate>
      <rico:history xml:lang="fr">Partie de la rue Gutenberg comprise dans la zone des servitudes de l'enceinte fortifiée, située autrefois sur le territoire de Montrouge annexé à Paris par décret du 3 avril 1925. Englobée par le boulevard Romain Rolland en 1946. [Origine du nom de la voie :] Jean Gensfleisch dit Gutenberg (1397-1468), imprimeur allemand, inventeur de la presse à imprimer.</rico:history>
