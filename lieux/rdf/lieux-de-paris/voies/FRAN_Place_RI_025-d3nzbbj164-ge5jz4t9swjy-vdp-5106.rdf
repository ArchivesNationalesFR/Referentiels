      <rico:hasExtent rdf:resource="extent/vdp-5106_largeur"/>
      <rico:hasExtent rdf:resource="extent/vdp-5106_numero_pair"/>
      <rico:hasExtent rdf:resource="extent/vdp-5106_numero_impair"/>
      <anf-onto:startingAtPoint xml:lang="fr">chemin du Reposoir, 9</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">rue Gutenberg, sur le territoire de Montrouge</anf-onto:endingAtPoint>
      <rico:isOrWasContainedBy rdf:resource="place/FRAN_RI_022-d3nyv8kgpz-117o9k86ze75x"/>
   </rico:Place>
