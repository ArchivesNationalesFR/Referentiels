   <rico:Place rdf:about="place/FRAN_RI_025-d3nzczqqga-1kszjfepo01fw-vdp-13340">
      <rdfs:label xml:lang="fr">rue Royale (8e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue Royale (8e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Royale</skos:altLabel>
      <rico:name>rue Royale (8e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Royale (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzczqqga-1kszjfepo01fw-vdp-13340"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzczqqga-1kszjfepo01fw-rue%20Royale"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzczqqga-1kszjfepo01fw"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/13340_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Vers 1792, on l'appela rue de la Révolution et ensuite rue Royale Saint-Honoré ; en 1795, rue de la Concorde ; un arrêté préfectoral du 27 avril 1814 lui rendit le nom de rue Royale. Son ouverture a supprimé dans la partie A une voie dénommée rue des Fossés des Tuileries sur le plan de Lacaille (1715). | Origine du nom : Ouverte pour donner accès à la place Louis XV, aujourd'hui place de la Concorde.</rico:history>
