   <rico:Place rdf:about="place/FRAN_RI_025-d3nzbnv6if--11puhjubkmpk2-vdp-11657">
      <rdfs:label xml:lang="fr">rue Lakanal (15e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue Lakanal (15e arrondissement, Paris, France)</skos:prefLabel>
