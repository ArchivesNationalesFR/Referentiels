   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nzd2pfai--6mptn3lxougo-vdp-13592_1826-05-04_1938-02-15">
      <rico:generalDescription xml:lang="fr">Non retenus au POS et non repris au PLU : Ordonnance du 4 mai 1826. L'arrêté du 15 février 1938 (relatif à la rue des Jeûneurs) a fixé les alignements de la rue Saint-Fiacre au droit des numéros 1 présumé et 2 présumé.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
