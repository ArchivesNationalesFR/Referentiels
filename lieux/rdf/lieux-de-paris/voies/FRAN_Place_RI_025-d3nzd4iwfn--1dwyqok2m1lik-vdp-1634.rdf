   <rico:Place rdf:about="place/FRAN_RI_025-d3nzd4iwfn--1dwyqok2m1lik-vdp-1634">
      <skos:prefLabel xml:lang="fr">rue Saint-Landry (4e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Saint-Landry</skos:altLabel>
      <rico:name>rue Saint-Landry (4e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Saint-Landry (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzd4iwfn--1dwyqok2m1lik-vdp-1634"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzd4iwfn--1dwyqok2m1lik-rue%20Saint-Landry"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzd4iwfn--1dwyqok2m1lik"/>
      <anf-onto:streetStatus xml:lang="fr">voie caduque d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:endDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1865-05-22</rico:endDate>
      <rico:history xml:lang="fr">Supprimée par la reconstruction de l'Hôtel Dieu (décret du 22 mai 1865). Confondue autrefois avec les rues des Marmousets, Basse des Ursins et d'Enfer, elle était désignée par les noms du port Notre-Dame, port Sainte-Marie et port Saint-Landry. Elle aurait aussi porté les noms de rue de l'Image Sainte-Catherine et rue des Hauts Moulins. Son extrémité vers le pont Rouge était, en 1213, appelée vicus Firmarii et, en 1222, rue du Fumer.</rico:history>
      <anf-onto:startingOnStreet xml:lang="fr">quai Napoléon</anf-onto:startingOnStreet>
      <anf-onto:endingOnStreet xml:lang="fr">rue des Marmousets (Supprimée)</anf-onto:endingOnStreet>
      <rico:isOrWasContainedBy rdf:resource="place/FRAN_RI_023-d3nyvghezd--sdud8qy9ue1i"/>
      <rico:isOrWasContainedBy rdf:resource="place/FRAN_RI_022-d3nyv8gz1t--152mje02aeqk1"/>
   </rico:Place>
