   <rico:Place rdf:about="place/FRAN_RI_025-d3nzd78cg7--23udbruvfy8u-vdp-13691">
      <skos:prefLabel xml:lang="fr">rue Saint-Vincent (18e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Saint-Vincent</skos:altLabel>
      <rico:name>rue Saint-Vincent (18e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Saint-Vincent (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzd78cg7--23udbruvfy8u-vdp-13691"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzd78cg7--23udbruvfy8u-rue%20Saint-Vincent"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzd78cg7--23udbruvfy8u"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/13691_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Voie de l'ancien village de Montmartre, indiquée sur le plan de Jouvin de Rochefort (1672). Sur le plan cadastral de 1825, elle est appelée chemin des Ruelles Saint-Vincent. [Origine du nom de la voie :] Vincent, prénom de M. Compoint, ancien propriétaire.</rico:history>
      <rico:isOrWasAffectedBy rdf:resource="activity/classement-vdp-13691_1863-05-23"/>
      <rico:isOrWasAffectedBy rdf:resource="activity/numerotage-vdp-13691_1889-02-18"/>
      <rico:isOrWasAffectedBy rdf:resource="activity/declassement-vdp-13691_1970-09-03"/>
      <rico:isOrWasAffectedBy rdf:resource="activity/alignement-vdp-13691_1867-08-11"/>
      <rico:hasExtent rdf:resource="extent/vdp-13691_largeur"/>
      <rico:hasExtent rdf:resource="extent/vdp-13691_numero_pair"/>
      <rico:hasExtent rdf:resource="extent/vdp-13691_numero_impair"/>
      <rico:hasExtent rdf:resource="extent/vdp-13691_longueur"/>
      <anf-onto:startingAtPoint xml:lang="fr">rue de la Bonne, 12.</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">rue Girardon et place Constantin Pecqueur, 2.</anf-onto:endingAtPoint>
      <anf-onto:crossesOrCrossed rdf:resource="place/FRAN_RI_023-d3nyvfvtob--1ccq8rb4h470c"/>
