   </rico:Activity>
   <rico:Activity rdf:about="activity/declassement-vdp-13691_1970-09-03">
      <rico:generalDescription xml:lang="fr">Arrêté du 3 septembre 1970, déclassant une parcelle de voie située au droit du n° 33.</rico:generalDescription>
      <rico:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1970-09-03</rico:date>
      <rico:hasActivityType rdf:resource="activityType/d%C3%A9classement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nzd78cg7--23udbruvfy8u-vdp-13691"/>
   </rico:Activity>
   <rico:Activity rdf:about="activity/alignement-vdp-13691_1867-08-11">
      <rico:generalDescription xml:lang="fr">Non retenus au POS et non repris au PLU : Décret du 11 août 1867 (UP), côté pair, sur une longueur de 35 m environ à partir d'un point situé à 52,30 m environ de là rue des Saules. Le décret du 11 août 1867 (UP), avait prévu la suppression de la partie comprise entre les rues de la Bonne et des Saules et la modification du tracé entre les rues des Saules et Girardon.</rico:generalDescription>
      <rico:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1867-08-11</rico:date>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nzd78cg7--23udbruvfy8u-vdp-13691"/>
   </rico:Activity>
