   <rico:Place rdf:about="place/FRAN_RI_025-d3nzd77dba-b9msu4ebt9ur-vdp-13689">
      <skos:prefLabel xml:lang="fr">rue Saint-Victor (5e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Saint-Victor</skos:altLabel>
      <rico:name>rue Saint-Victor (5e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Saint-Victor (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzd77dba-b9msu4ebt9ur-vdp-13689"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzd77dba-b9msu4ebt9ur-rue%20Saint-Victor"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzd77dba-b9msu4ebt9ur"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/13689_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Cette voie existait lors de la création de l'abbaye Saint-Victor au XIe siècle. Elle s'étendait de la rue Copeau (rue Lacépède actuelle) à la place Maubert. Le boulevard Saint-Germain, les rues Monge et des Ecoles en ont absorbé des tronçons. La partie comprise entre la rue des Fossés Saint-Bernard et la place Jussieu a été réunie à la rue Jussieu par arrêté préfectoral du 3 septembre 1869. Un décret du 2 octobre 1865 a dénommé rue Linné le tronçon compris entre la place Jussieu et la rue Lacépède. Ces deux parties ont porté le nom de rue du Faubourg Saint-Victor. [Origine du nom de la voie :] Voisinage de l'ancienne abbaye Saint-Victor.</rico:history>
      <rico:isOrWasAffectedBy rdf:resource="activity/nivellement-vdp-13689_1921-04-27"/>
      <rico:isOrWasAffectedBy rdf:resource="activity/numerotage-vdp-13689_1883-11-23"/>
      <rico:isOrWasAffectedBy rdf:resource="activity/alignement-vdp-13689_1855-08-11"/>
      <rico:hasExtent rdf:resource="extent/vdp-13689_largeur"/>
      <rico:hasExtent rdf:resource="extent/vdp-13689_numero_impair"/>
      <rico:hasExtent rdf:resource="extent/vdp-13689_numero_pair"/>
      <rico:hasExtent rdf:resource="extent/vdp-13689_longueur"/>
      <anf-onto:startingAtPoint xml:lang="fr">rue des Ecoles, 6, et rue de Poissy, 32.</anf-onto:startingAtPoint>
      <anf-onto:endingOnStreet xml:lang="fr">rue Monge, 11, et rue des Bernardins.</anf-onto:endingOnStreet>
