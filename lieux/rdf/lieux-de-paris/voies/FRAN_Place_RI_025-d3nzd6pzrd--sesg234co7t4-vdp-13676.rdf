   <rico:Place rdf:about="place/FRAN_RI_025-d3nzd6pzrd--sesg234co7t4-vdp-13676">
      <skos:prefLabel xml:lang="fr">rue Saint-Sauveur (2e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Saint-Sauveur</skos:altLabel>
      <rico:name>rue Saint-Sauveur (2e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Saint-Sauveur (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzd6pzrd--sesg234co7t4-vdp-13676"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzd6pzrd--sesg234co7t4-rue%20Saint-Sauveur"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzd6pzrd--sesg234co7t4"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/13676_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Cette voie était déjà dénommée rue Saint-Sauveur en 1285. La partie qui était comprise entre les rues Montorgueil et Montmartre a pris en 1937 le nom de rue Léopold Bellan. Cette même partie avait été réunie à la rue Saint-Sauveur en 1851. [Origine du nom de la voie :] Voie latérale à l'ancienne église Saint-Sauveur, située rue Saint-Denis.</rico:history>
      <rico:isOrWasAffectedBy rdf:resource="activity/alignement-vdp-13676_1826-06-21_1937-02-26"/>
      <rico:isOrWasAffectedBy rdf:resource="activity/nivellement-vdp-13676_1914-02-13_1937-02-26"/>
      <rico:isOrWasAffectedBy rdf:resource="activity/declassement-vdp-13676_1984-03-01"/>
      <rico:hasExtent rdf:resource="extent/vdp-13676_largeur"/>
      <rico:hasExtent rdf:resource="extent/vdp-13676_numero_impair"/>
      <rico:hasExtent rdf:resource="extent/vdp-13676_numero_pair"/>
      <rico:hasExtent rdf:resource="extent/vdp-13676_longueur"/>
      <anf-onto:startingAtPoint xml:lang="fr">rue Saint-Denis, 181.</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">rue Montorgueil, 102, et rue des Petits Carreaux, 2.</anf-onto:endingAtPoint>
      <rico:isOrWasContainedBy rdf:resource="place/FRAN_RI_023-d3nyvfot96-v4utuwrppfm3"/>
