   <rico:Activity rdf:about="activity/alignement-vdp-13676_1826-06-21_1937-02-26">
      <rico:generalDescription xml:lang="fr">Non retenus au POS et non repris au PLU : Ordonnance du 21 juin 1826, entre la rue Saint-Denis et la rue Dussoubs. Un décret du 11 avril 1932 a modifié l'alignement du côté pair depuis le n° 6 inclus jusqu'à la rue Dussoubs. Arrêté du 26 février 1937, le surplus.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
