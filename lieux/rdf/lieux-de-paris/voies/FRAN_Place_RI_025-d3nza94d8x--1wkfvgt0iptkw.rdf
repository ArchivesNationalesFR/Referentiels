   <rico:PlaceName rdf:about="placeName/FRAN_RI_025-d3nza94d8x--1wkfvgt0iptkw-rue%20%C3%89douard%20Qu%C3%A9nu">
      <rico:textualValue xml:lang="fr">rue Édouard Quénu</rico:textualValue>
      <rico:history xml:lang="fr">Edouard André Victor Alfred Quénu (1852-1933), chirurgien, membre de l’Académie de Médecine et de l’Institut.</rico:history>
