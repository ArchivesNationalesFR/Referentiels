   <rico:Place rdf:about="place/FRAN_RI_025-d3nza94d8x--1wkfvgt0iptkw">
      <rdfs:label xml:lang="fr">rue Édouard Quénu (Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue Édouard Quénu (Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Édouard Quénu</skos:altLabel>
      <skos:hiddenLabel xml:lang="fr">Edouard-Quénu (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nza94d8x--1wkfvgt0iptkw"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nza94d8x--1wkfvgt0iptkw-rue%20%C3%89douard%20Qu%C3%A9nu"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d’après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/d3nza94d8x--1wkfvgt0iptkw"/>
      <rico:hasOrHadIdentifier rdf:resource="identifier/10458_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Précédemment, partie de la rue Broca et, avant 1890, partie de la rue de Lourcine. Ce nom a souvent changé ; ainsi on a écrit : Loursine, l’Oursine, l’Orsine, l’Ursine, Lorcines (Jaillot). Elle a été aussi appelée rue du Clos Ganay, et rue de la Franchise. Dheulland la nomme rue des Cordelières.</rico:history>
