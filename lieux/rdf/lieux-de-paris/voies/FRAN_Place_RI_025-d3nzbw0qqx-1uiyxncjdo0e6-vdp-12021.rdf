      <rico:hasExtent rdf:resource="extent/vdp-12021_longueur"/>
      <rico:hasExtent rdf:resource="extent/vdp-12021_largeur"/>
      <anf-onto:startingAtPoint xml:lang="fr">rue Oberkampf, 21.</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">rue du Faubourg du Temple, 14.</anf-onto:endingAtPoint>
