   <rico:Place rdf:about="place/FRAN_RI_025-d3nzbw0qqx-1uiyxncjdo0e6-vdp-12021">
      <skos:prefLabel xml:lang="fr">rue de Malte (11e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de Malte</skos:altLabel>
      <rico:name>rue de Malte (11e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Malte (rue de)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzbw0qqx-1uiyxncjdo0e6-vdp-12021"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzbw0qqx-1uiyxncjdo0e6-rue%20de%20Malte"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzbw0qqx-1uiyxncjdo0e6"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/12021_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">L'arr. préf. du 11 mars 1851, réunissait à la partie A la rue du Haut Moulin, comprise entre les rues Rampon et du Faubourg du Temple. La rue du Haut Moulin était précédemment rue des Marais, antérieurement rue des Trois Portes, plus anciennement rue Merderet et rue des Marais du Temple. [Origine du nom de la voie :] Le comte d'Artois était grand prieur du Temple (ordre de Malte), lorsque cette voie fut ouverte sur les dépendances du Grand Prieuré (1780).</rico:history>
