   <rico:Place rdf:about="place/FRAN_RI_025-d3nz8oh88s-1onqrx52ccgby-vdp-9148">
      <skos:prefLabel xml:lang="fr">rue de Bagnolet (20e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de Bagnolet</skos:altLabel>
      <rico:name>rue de Bagnolet (20e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Bagnolet (rue de)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz8oh88s-1onqrx52ccgby-vdp-9148"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nz8oh88s-1onqrx52ccgby-rue%20de%20Bagnolet"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nz8oh88s-1onqrx52ccgby"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/9148_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Précédemment, rue de Paris, entre le boulevard de Charonne et la place Saint-Blaise ; rue de Bagnolet, entre la place Saint-Blaise et le boulevard Davout ; plus anciennement, la partie entre le boulevard de Charonne et la rue de la Réunion était comprise dans la rue de Fontarabie. Elle était indiquée sur le plan de Jouvin de Rochefort (1672). La partie entre la rue des Prairies et le boulevard Davout limitait extérieurement le parc du Château de Bagnolet. [Origine du nom de la voie :] Voie conduisant à Bagnolet.</rico:history>
