   <rico:Activity rdf:about="activity/alignement-vdp-9148_1841-02-10_1981-02-26">
      <rico:generalDescription xml:lang="fr">Non retenus au PAZ de la Zac "Ancien Village de Charonne" et non repris au PLU : Arrêté du 5 janvier 1939 (relatif à la rue Saint-Blaise), au droit des nos 118 à 120 bis inclus. Arrêté municipal du 26 février 1981, au droit du n° 122. Non retenus au POS et non repris au PLU : Ordonnance du 10 février 1841, partie A et côté pair de la partie B. Arrêté du 25 janvier 1949 (relatif à la rue de Fontarabie), au droit du n° 60. Décret du 12 novembre 1909 (UP), le surplus.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nz8oh88s-1onqrx52ccgby-vdp-9148"/>
