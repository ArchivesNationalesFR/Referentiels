   <rico:Activity rdf:about="activity/classement-vdp-13851_1863-05-23">
      <rico:generalDescription xml:lang="fr">Décret du 23 mai 1863, dans la voirie parisienne, partie A. Précédemment voie de l'ancienne commune de Belleville dans cette dernière partie.</rico:generalDescription>
      <rico:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1863-05-23</rico:date>
      <rico:hasActivityType rdf:resource="activityType/classement%20de%20voie%20urbaine"/>
