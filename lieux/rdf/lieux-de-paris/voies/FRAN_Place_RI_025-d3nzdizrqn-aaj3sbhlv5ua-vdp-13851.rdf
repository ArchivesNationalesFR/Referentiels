   <rico:Activity rdf:about="activity/alignement-vdp-13851_1843-07-21_1932-04-11">
      <rico:generalDescription xml:lang="fr">Retenus au POS et non repris au PLU : Ordonnance du 21 juillet 1843, au droit des nos 22 à 28. Arrêté préfectoral du 11 avril 1932, au droit des nos 1 à 19 et 2 à 20. Non retenus au POS et non repris au PLU : Arrêté du 11 avril 1932 : 1° le surplus de la partie A et pan coupé, côté pair, à l'angle de l'avenue Gambetta côté impair ; 2° côté pair de la partie B.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nzdizrqn-aaj3sbhlv5ua-vdp-13851"/>
