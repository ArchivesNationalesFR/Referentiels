      <rico:recordResourceSourceOfInformation xml:lang="fr">Notice relative à la voie 13851 dans la nomenclature des voies de Paris publiée en open data par la mairie de Paris (jeu de données de 2023)</rico:recordResourceSourceOfInformation>
      <skos:changeNote>
         <rdf:Description>
            <dc:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-12-26</dc:date>
            <rdf:value xml:lang="fr">Intégration automatique à la notice de nombreuses données relatives à ce lieu dans la nomenclature de la mairie de Paris (historique, coordonnées géographiques, données géométriques, indication des arrondissements et quartiers traversés...), ainsi que différentes activités (alignement, nivellement, numérotage...) liés à ce lieu.</rdf:value>
         </rdf:Description>
      </skos:changeNote>
