   <rico:Place rdf:about="place/FRAN_RI_025-d3nzdizrqn-aaj3sbhlv5ua-vdp-13851">
      <skos:prefLabel xml:lang="fr">rue des Tourelles (20e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue des Tourelles</skos:altLabel>
      <rico:name>rue des Tourelles (20e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Tourelles (rue des)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzdizrqn-aaj3sbhlv5ua-vdp-13851"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzdizrqn-aaj3sbhlv5ua-rue%20des%20Tourelles"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzdizrqn-aaj3sbhlv5ua"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/13851_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">La partie A est tracée sur le plan cadastral de 1812. Le tronçon B a été ouvert lors de la construction de la caserne des Tourelles, en remplacement d'une partie de la voie qui avait un tracé différent. [Origine du nom de la voie :] Lieu-dit, en raison des tourelles à pans coupés d'un pavillon qui était situé dans le parc Saint-Fargeau.</rico:history>
      <rico:isOrWasAffectedBy rdf:resource="activity/classement-vdp-13851_1863-05-23"/>
      <rico:isOrWasAffectedBy rdf:resource="activity/alignement-vdp-13851_1843-07-21_1932-04-11"/>
      <rico:isOrWasAffectedBy rdf:resource="activity/nivellement-vdp-13851_1932-04-11"/>
      <rico:hasExtent rdf:resource="extent/vdp-13851_numero_impair"/>
      <rico:hasExtent rdf:resource="extent/vdp-13851_longueur"/>
      <rico:hasExtent rdf:resource="extent/vdp-13851_largeur"/>
      <rico:hasExtent rdf:resource="extent/vdp-13851_numero_pair"/>
      <anf-onto:startingAtPoint xml:lang="fr">rue Haxo, 86.</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">boulevard Mortier, 161.</anf-onto:endingAtPoint>
      <rico:isOrWasContainedBy rdf:resource="place/FRAN_RI_023-d3nyvgs7mw-zfo68kjvfnd6"/>
      <rico:isOrWasContainedBy rdf:resource="place/FRAN_RI_022-d3nyv8mloc-m4l1ul9hwhpp"/>
