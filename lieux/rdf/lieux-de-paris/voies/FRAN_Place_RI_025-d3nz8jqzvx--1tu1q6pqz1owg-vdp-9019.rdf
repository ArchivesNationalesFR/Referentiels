   <rico:Place rdf:about="place/FRAN_RI_025-d3nz8jqzvx--1tu1q6pqz1owg-vdp-9019">
      <rdfs:label xml:lang="fr">rue de l'Aqueduc (10e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue de l'Aqueduc (10e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de l'Aqueduc</skos:altLabel>
      <rico:name>rue de l'Aqueduc (10e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Aqueduc (rue de l')</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz8jqzvx--1tu1q6pqz1owg-vdp-9019"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nz8jqzvx--1tu1q6pqz1owg-rue%20de%20l%27Aqueduc"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nz8jqzvx--1tu1q6pqz1owg"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/9019_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Ouverte par la Ville de Paris. Un décret du 7 juin 1859 a autorisé la Ville à concéder aux propriétaires limitrophes des droits de jours et d'issues, moyennant un prix de 300 francs par mètre de façade. | Origine du nom : Construite au-dessus de l'aqueduc de ceinture des eaux du canal de l'Ourcq, établi vers 1825.</rico:history>
