      <rico:hasExtent rdf:resource="extent/FRAN_RI_025-d3nz8xygri-1gie8mwtrrnrq-vdp-9404_numero_pair"/>
      <anf-onto:startingAtPoint xml:lang="fr">rue du Transvaal, 16.</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">en impasse</anf-onto:endingAtPoint>
