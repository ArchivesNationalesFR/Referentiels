      <rico:hasExtent rdf:resource="extent/FRAN_RI_025-d3nzc31yz3--1m5d793vbzay-vdp-12290_numero_impair"/>
      <anf-onto:startingAtPoint xml:lang="fr">rue Rambuteau, 102.</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">rue du Cygne, 19 et rue de Turbigo, 10.</anf-onto:endingAtPoint>
