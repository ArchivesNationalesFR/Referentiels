   <rico:Place rdf:about="place/FRAN_RI_025-d3nzc31yz3--1m5d793vbzay-vdp-12290">
      <rdfs:label xml:lang="fr">rue Mondétour (1er arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue Mondétour (1er arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Mondétour</skos:altLabel>
      <rico:name>rue Mondétour (1er arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Mondétour (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzc31yz3--1m5d793vbzay-vdp-12290"/>
