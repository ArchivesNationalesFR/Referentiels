      <anf-onto:startingAtPoint xml:lang="fr">rue Jacob, 31.</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">boulevard Saint-Germain, 170.</anf-onto:endingAtPoint>
