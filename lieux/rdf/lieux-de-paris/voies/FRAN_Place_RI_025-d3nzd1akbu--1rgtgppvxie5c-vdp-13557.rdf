   <rico:Place rdf:about="place/FRAN_RI_025-d3nzd1akbu--1rgtgppvxie5c-vdp-13557">
      <rdfs:label xml:lang="fr">rue Saint-Benoît (6e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue Saint-Benoît (6e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Saint-Benoît</skos:altLabel>
      <rico:name>rue Saint-Benoît (6e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Saint-Benoît (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzd1akbu--1rgtgppvxie5c-vdp-13557"/>
