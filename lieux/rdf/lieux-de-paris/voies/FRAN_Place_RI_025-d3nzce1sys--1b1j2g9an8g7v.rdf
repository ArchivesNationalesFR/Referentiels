   <rico:PlaceName rdf:about="placeName/FRAN_RI_025-d3nzce1sys--1b1j2g9an8g7v-rue%20Paul%20et%20Jean%20Lerolle">
      <rico:textualValue xml:lang="fr">rue Paul et Jean Lerolle</rico:textualValue>
      <rico:history xml:lang="fr">Paul Lerolle (Paris, 1846-Paris, 1912) conseiller municipal du 1884 à 1898 et député du VIIe arrondissement de Paris de 1898 à 1912. Son fils, Jean Lerolle (Paris, 1873-1962), avocat, député du VIIe arrondissement de Paris de 1912 à 1919 et de 1928 à 19 à 1936. Il se sont beaucoup occupés d’oeuvres sociales.</rico:history>
      <rico:isOrWasPlaceNameOf rdf:resource="place/FRAN_RI_025-d3nzce1sys--1b1j2g9an8g7v"/>
      <rico:resultsOrResultedFrom rdf:resource="activity/denomination-FRAN_RI_025-d3nzce1sys--1b1j2g9an8g7v_1990-03-08"/>
   </rico:PlaceName>
