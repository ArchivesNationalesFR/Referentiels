      <rico:hasExtent rdf:resource="extent/vdp-9334_numero_pair"/>
      <rico:hasExtent rdf:resource="extent/vdp-9334_numero_impair"/>
      <anf-onto:startingAtPoint xml:lang="fr">quai de la Tournelle, 65.</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">boulevard Saint-Germain, 52.</anf-onto:endingAtPoint>
      <rico:isOrWasContainedBy rdf:resource="place/FRAN_RI_023-d3nyvh0r0v--1330tdzzpw7fy"/>
