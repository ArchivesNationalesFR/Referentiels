   <rico:Place rdf:about="place/FRAN_RI_025-d3nz8v9o12--th1st5c6ereg-vdp-9334">
      <skos:prefLabel xml:lang="fr">rue de Bièvre (5e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de Bièvre</skos:altLabel>
      <rico:name>rue de Bièvre (5e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Bièvre (rue de)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz8v9o12--th1st5c6ereg-vdp-9334"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nz8v9o12--th1st5c6ereg-rue%20de%20Bi%C3%A8vre"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nz8v9o12--th1st5c6ereg"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Cette voie portait, dès 1250, son nom actuel. Le percement du boulevard Saint-Germain a entraîné la suppression de la partie de la rue de Bièvre qui aboutissait rue Saint-Victor et place Maubert. [Origine du nom de la voie :] Cette voie longeait l'ancien cours de la Bièvre.</rico:history>
