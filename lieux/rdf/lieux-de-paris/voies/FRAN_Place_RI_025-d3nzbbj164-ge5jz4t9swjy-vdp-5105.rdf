   <rico:Place rdf:about="place/FRAN_RI_025-d3nzbbj164-ge5jz4t9swjy-vdp-5105">
      <skos:prefLabel xml:lang="fr">rue Gutenberg (1er arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Gutenberg</skos:altLabel>
      <rico:name>rue Gutenberg (1er arrondissement, Paris, France)</rico:name>
