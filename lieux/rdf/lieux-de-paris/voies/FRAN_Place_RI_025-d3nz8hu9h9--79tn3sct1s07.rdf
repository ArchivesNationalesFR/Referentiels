   <rico:PlaceName rdf:about="placeName/FRAN_RI_025-d3nz8hu9h9--79tn3sct1s07-rue%20Anatole%20de%20La%20Forge">
      <rico:textualValue xml:lang="fr">rue Anatole de La Forge</rico:textualValue>
      <rico:history xml:lang="fr">Anatole de la Forge (1821-1892), publiciste et homme politique ; organisa, en qualité de préfet de l’Aisne, la défense de Saint-Quentin.</rico:history>
