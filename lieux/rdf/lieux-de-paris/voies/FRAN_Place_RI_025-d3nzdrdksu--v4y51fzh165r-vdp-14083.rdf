   <rico:Place rdf:about="place/FRAN_RI_025-d3nzdrdksu--v4y51fzh165r-vdp-14083">
      <rdfs:label xml:lang="fr">rue des Vinaigriers (10e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue des Vinaigriers (10e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue des Vinaigriers</skos:altLabel>
      <rico:name>rue des Vinaigriers (10e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Vinaigriers (rue des)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzdrdksu--v4y51fzh165r-vdp-14083"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzdrdksu--v4y51fzh165r-rue%20des%20Vinaigriers"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzdrdksu--v4y51fzh165r"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/14083_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Elle a porté les noms de ruelle des Vinaigriers sur le plan de Delagrive (1728) et de rue Carême Prenant sur le plan de Gomboust (1652). D'après Jaillot, elle était appelée, sur le plan de la même époque, ruelle de l'Héritier. En 1946, la partie comprise entre le quai de Valmy, 73, et le quai de Valmy, 87, a pris le nom de rue Jean Poulmarch. | Origine du nom : Lieu-dit (XVIIIe siècle).</rico:history>
      <rico:isOrWasAffectedBy rdf:resource="activity/numerotage-FRAN_RI_025-d3nzdrdksu--v4y51fzh165r-vdp-14083_1881-12-31"/>
      <rico:isOrWasAffectedBy rdf:resource="activity/alignement-FRAN_RI_025-d3nzdrdksu--v4y51fzh165r-vdp-14083_1847-03-31"/>
      <rico:hasExtent rdf:resource="extent/FRAN_RI_025-d3nzdrdksu--v4y51fzh165r-vdp-14083_largeur"/>
      <rico:hasExtent rdf:resource="extent/FRAN_RI_025-d3nzdrdksu--v4y51fzh165r-vdp-14083_longueur"/>
      <rico:hasExtent rdf:resource="extent/FRAN_RI_025-d3nzdrdksu--v4y51fzh165r-vdp-14083_numero_impair"/>
      <anf-onto:startingAtPoint xml:lang="fr">rue Jean Poulmarch, 21 et quai de Valmy, 89.</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">rue du Faubourg Saint-Martin, 100.</anf-onto:endingAtPoint>
      <rico:isOrWasContainedBy rdf:resource="place/FRAN_RI_022-d3nyv8j47y--q19vvxm7arwm"/>
