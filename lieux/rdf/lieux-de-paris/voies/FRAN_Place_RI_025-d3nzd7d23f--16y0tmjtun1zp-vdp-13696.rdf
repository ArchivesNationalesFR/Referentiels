   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nzd7d23f--16y0tmjtun1zp-vdp-13696_1826-10-04_1876-06-27">
      <rico:generalDescription xml:lang="fr">Non retenus au POS et non repris au PLU : Ordonnance du 4 octobre 1826. Décret du 27 juin 1876 (relatif à l'avenue de l'Opéra) : au droit du n° 1 (partie), sur une longueur de 7 m environ à partir d'un point situé à 13 m de l'avenue de l'Opéra (ancienne rue des Orties supprimée), et au droit du n° 2 (partie), sur une longueur de 7 m à partir d'un point situé à 6 m de l'avenue de l'Opéra (ancienne rue du Clos Georgeau supprimée).</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nzd7d23f--16y0tmjtun1zp-vdp-13696"/>
