   <rico:Place rdf:about="place/FRAN_RI_025-d3nzd7d23f--16y0tmjtun1zp-vdp-13696">
      <rdfs:label xml:lang="fr">rue Sainte-Anne (1er-2e arrondissements, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue Sainte-Anne (1er-2e arrondissements, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Sainte-Anne</skos:altLabel>
      <rico:name>rue Sainte-Anne (1er-2e arrondissements, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Sainte-Anne (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzd7d23f--16y0tmjtun1zp-vdp-13696"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzd7d23f--16y0tmjtun1zp-rue%20Sainte-Anne"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzd7d23f--16y0tmjtun1zp"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/13696_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Le tronçon qui était compris entre la rue de l'Anglade (supprimée) et l'avenue de l'Opéra a été absorbé en partie par la rue de l'Echelle en 1866 et le surplus par l'avenue de l'Opéra en 1876. Ce tronçon, qui avait été ouvert en vertu d'un arrêt du Conseil du Roi du 23 novembre 1633 sous le nom de rue Sainte-Anne avait été appelé également rue des Moulins. La partie comprise entre les rues des Petits Champs et Saint-Augustin, indiquée en 1652 sur le plan de Gomboust, a porté, au XVIIIe siècle le nom de rue de Lionne ou de Lyonne. La voie entière s'appelait déjà rue Sainte-Anne sur le plan de Deharme (1763) ; elle reçut le nom de rue Helvétius de 1792 à 1814. | Origine du nom : Anne d'Autriche était reine de France lorsqu'on commença d'ouvrir cette voie.</rico:history>
