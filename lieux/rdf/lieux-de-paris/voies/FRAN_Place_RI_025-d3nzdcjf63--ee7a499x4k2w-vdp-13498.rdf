   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nzdcjf63--ee7a499x4k2w-vdp-13498_1828-01-28_1937-04-26">
      <rico:generalDescription xml:lang="fr">Non retenus au POS et non repris au PLU : Arrêté du 26 avril 1937, tronçon A, sauf pour les parties suivantes régies par l'arrêté du 28 janvier 1828 : côté impair, à partir de la rue Ribera, sur une longueur de 61 m environ au droit des nos 1, 3, 5 ; côté pair, entre la rue Chamfort et l'avenue Mozart. Arrêté du 28 janvier 1828, tronçon B. Décret du 5 novembre 1883, pan coupé sur le n° 15 à l'angle de l'avenue Mozart.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nzdcjf63--ee7a499x4k2w-vdp-13498"/>
