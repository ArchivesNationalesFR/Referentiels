   <rico:Place rdf:about="place/FRAN_RI_025-d3nz8z5c64-1bao0y641ypyo-vdp-9444">
      <skos:prefLabel xml:lang="fr">rue de Bourgogne (7e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de Bourgogne</skos:altLabel>
      <rico:name>rue de Bourgogne (7e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Bourgogne (rue de)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz8z5c64-1bao0y641ypyo-vdp-9444"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nz8z5c64-1bao0y641ypyo-rue%20de%20Bourgogne"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nz8z5c64-1bao0y641ypyo"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/9444_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Le 29 nivôse an VI, un arrêté du Conseil des Cinq Cents avait dénommé cette voie rue du Conseil des Cinq Cents. La partie comprise entre le boulevard Saint-Germain et la rue de l'Université a été dénommée rue Aristide Briand en 1963. [Origine du nom de la voie :] Louis, duc de Bourgogne (1682-1712), petit-fils de Louis XIV.</rico:history>
