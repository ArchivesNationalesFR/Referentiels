      <anf-onto:startingAtPoint xml:lang="fr">rue de l'Adjudant Réau, 5.</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">rue du Surmelin, 34.</anf-onto:endingAtPoint>
