   <rico:Place rdf:about="place/FRAN_RI_025-d3nz8k1jx2--ubzyn7sx9c58-vdp-9026">
      <skos:prefLabel xml:lang="fr">rue de l'Arcade (8e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de l'Arcade</skos:altLabel>
      <rico:name>rue de l'Arcade (8e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Arcade (rue de l')</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz8k1jx2--ubzyn7sx9c58-vdp-9026"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nz8k1jx2--ubzyn7sx9c58-rue%20de%20l%27Arcade"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nz8k1jx2--ubzyn7sx9c58"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/9026_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Cette voie existait au XVIIe siècle sous le nom de chemin d'Argenteuil. Elle a porté le nom de rue de la Pologne, entre les rues des Mathurins et de Rome. [Origine du nom de la voie :] Dû à une arcade qui servait de communication entre les jardins des religieuses de la Ville l'Evêque.</rico:history>
      <rico:isOrWasAffectedBy rdf:resource="activity/alignement-vdp-9026_1836-11-25_1868-02-22"/>
      <rico:hasExtent rdf:resource="extent/vdp-9026_largeur"/>
      <rico:hasExtent rdf:resource="extent/vdp-9026_longueur"/>
      <rico:hasExtent rdf:resource="extent/vdp-9026_numero_pair"/>
      <rico:hasExtent rdf:resource="extent/vdp-9026_numero_impair"/>
      <anf-onto:startingAtPoint xml:lang="fr">boulevard Malesherbes, 4.</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">place Gabriel Péri, et rue de Rome, 9.</anf-onto:endingAtPoint>
      <rico:isOrWasContainedBy rdf:resource="place/FRAN_RI_023-d3nyvgbfmz--11ww01vod4uww"/>
      <rico:isOrWasContainedBy rdf:resource="place/FRAN_RI_022-d3nyv8i9m0-ys1mraoxv8ln"/>
      <rico:hasOrHadPhysicalLocation rdf:resource="physicalLocation/vdp-9026"/>
   </rico:Place>
