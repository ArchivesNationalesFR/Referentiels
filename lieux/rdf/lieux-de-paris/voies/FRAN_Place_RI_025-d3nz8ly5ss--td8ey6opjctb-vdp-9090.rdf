   <rico:Place rdf:about="place/FRAN_RI_025-d3nz8ly5ss--td8ey6opjctb-vdp-9090">
      <rdfs:label xml:lang="fr">rue d'Aubervilliers (18e-19e arrondissements, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue d'Aubervilliers (18e-19e arrondissements, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue d'Aubervilliers</skos:altLabel>
      <rico:name>rue d'Aubervilliers (18e-19e arrondissements, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Aubervilliers (rue d')</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz8ly5ss--td8ey6opjctb-vdp-9090"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nz8ly5ss--td8ey6opjctb-rue%20d%27Aubervilliers"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nz8ly5ss--td8ey6opjctb"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/9090_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Précédemment rue des Vertus dans la partie A et chemin d'Aubervilliers dans le surplus de la voie. Elle est indiquée sur le plan de Roussel (1730) sous le nom de chemin de Notre-Dame des Vertus et sur celui de Delagrive (1740), comme chemin d'Aubervilliers. La partie comprise entre les nos 192 et 222, déclassée par l'arrêté municipal du 19 octobre 1981, a été supprimée. La rue d'Aubervilliers suit un nouveau tracé à cette hauteur. | Origine du nom : Ancien chemin vicinal conduisant au village d'Aubervilliers.</rico:history>
      <rico:isOrWasAffectedBy rdf:resource="activity/alignement-FRAN_RI_025-d3nz8ly5ss--td8ey6opjctb-vdp-9090_1842-09-11_2011-11-15"/>
