   <rico:PlaceName rdf:about="placeName/FRAN_RI_025-d3nz92iuqg--15s1tiyu3clrf-rue%20des%20Cadets%20de%20la%20France%20Libre">
      <rico:textualValue xml:lang="fr">rue des Cadets de la France Libre</rico:textualValue>
      <rico:history xml:lang="fr">En hommage aux 280 jeunes français environ accueillis en Angleterre dans les rangs de l’Ecole Militaire des Cadets de la France Libre entre 1940 et 1944, et dont 55 sont morts pour la France.</rico:history>
