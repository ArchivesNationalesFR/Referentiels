   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nzdhvxeo--1gewylxhk7ldk-vdp-13812_1833-05-16_1976-01-15">
      <rico:generalDescription xml:lang="fr">Non retenus au PSMV du Marais : Ordonnance du 16 mai 1833, entre la place de Thorigny et les rues des Coutures Saint-Gervais et Sainte-Anastase, sauf au droit des nos 1, 3, 2 et 4, parties régies par arrêté du 15 janvier 1976 (relatif à la place de Thorigny). Ordonnance du 31 mars 1835, le surplus.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nzdhvxeo--1gewylxhk7ldk-vdp-13812"/>
