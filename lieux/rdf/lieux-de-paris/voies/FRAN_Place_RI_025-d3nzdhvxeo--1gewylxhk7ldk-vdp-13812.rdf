   <rico:Place rdf:about="place/FRAN_RI_025-d3nzdhvxeo--1gewylxhk7ldk-vdp-13812">
      <rdfs:label xml:lang="fr">rue de Thorigny (3e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue de Thorigny (3e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de Thorigny</skos:altLabel>
      <rico:name>rue de Thorigny (3e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Thorigny (rue de)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzdhvxeo--1gewylxhk7ldk-vdp-13812"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzdhvxeo--1gewylxhk7ldk-rue%20de%20Thorigny"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzdhvxeo--1gewylxhk7ldk"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/13812_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">La partie entre la place de Thorigny et les rues des Coutures Saint-Gervais et Sainte-Anastase porte le nom de Thorigny depuis 1575 ; c'était plus anciennement la rue Neuve Saint-Gervais. Le surplus de la voie a été ouvert sous le nom de rue Neuve Saint-Gervais, puis rue Saint-Gervais ; elle est appelée sur plusieurs plans du XVIIe siècle rue des Morins. L'actuelle rue du Parc Royal a été comprise dans la rue de Thorigny. | Origine du nom : L'hôtel de Thorigny était situé dans le voisinage.</rico:history>
