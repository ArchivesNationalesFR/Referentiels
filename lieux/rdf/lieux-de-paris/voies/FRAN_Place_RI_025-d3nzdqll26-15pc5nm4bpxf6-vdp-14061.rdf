      <rico:isOrWasAffectedBy rdf:resource="activity/denomination-FRAN_RI_025-d3nzdqll26-15pc5nm4bpxf6_1881-01-20"/>
      <rico:isOrWasAffectedBy rdf:resource="activity/ouverture-vdp-14061_1823-11-05"/>
