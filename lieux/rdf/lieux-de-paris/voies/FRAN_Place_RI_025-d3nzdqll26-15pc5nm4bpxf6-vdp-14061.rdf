   <rico:Place rdf:about="place/FRAN_RI_025-d3nzdqll26-15pc5nm4bpxf6-vdp-14061">
      <skos:prefLabel xml:lang="fr">rue Vignon (8e-9e arrondissements, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Vignon</skos:altLabel>
      <rico:name>rue Vignon (8e-9e arrondissements, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Vignon (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzdqll26-15pc5nm4bpxf6-vdp-14061"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzdqll26-15pc5nm4bpxf6-rue%20Vignon"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzdqll26-15pc5nm4bpxf6"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/14061_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Précédemment partie de la rue de la Ferme des Mathurins et plus anciennement cul-de-sac de la Ferme des Mathurins. Une partie de la rue de la Ferme des Mathurins, comprise entre les rues des Mathurins et de Provence, ouverte en 1775, a été supprimée lors de l'ouverture du boulevard Haussmann. [Origine du nom de la voie :] Pierre Alexandre Vignon (1762-1846), architecte de l'église de la Madeleine ; voisinage de ce monument.</rico:history>
