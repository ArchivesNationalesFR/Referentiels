      <rico:hasExtent rdf:resource="extent/vdp-14061_largeur"/>
      <rico:hasExtent rdf:resource="extent/vdp-14061_numero_impair"/>
      <anf-onto:startingAtPoint xml:lang="fr">boulevard de la Madeleine, 14.</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">rue Tronchet, 26.</anf-onto:endingAtPoint>
