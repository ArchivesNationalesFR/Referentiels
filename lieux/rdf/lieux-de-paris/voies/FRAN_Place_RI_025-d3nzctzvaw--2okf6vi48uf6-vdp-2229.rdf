   <rico:Place rdf:about="place/FRAN_RI_025-d3nzctzvaw--2okf6vi48uf6-vdp-2229">
      <rdfs:label xml:lang="fr">rue de la Réale (1er arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue de la Réale (1er arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de la Réale</skos:altLabel>
      <rico:name>rue de la Réale (1er arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Réale (rue de la)</skos:hiddenLabel>
