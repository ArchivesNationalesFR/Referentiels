      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">En 1564, une partie de la rue d'Argenteuil était dénommée rue de la Haute Voirie Saint-Honoré. [Origine du nom de la voie :] Ancien chemin d'Argenteuil.</rico:history>
