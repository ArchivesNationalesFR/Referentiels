   <rico:Activity rdf:about="activity/alignement-vdp-9040_1826-10-04_1876-06-27">
      <rico:generalDescription xml:lang="fr">Non retenus au POS et non repris au PLU : Décret du 27 juin 1876 (UP) : 1° côté pair ; 2° côté impair sur une longueur de 72 m environ à partir de la rue de l'Echelle. Ordonnance du 4 octobre 1826, le surplus de la voie.</rico:generalDescription>
