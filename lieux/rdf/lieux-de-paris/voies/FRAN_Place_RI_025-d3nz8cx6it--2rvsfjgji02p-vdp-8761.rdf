   <rico:Place rdf:about="place/FRAN_RI_025-d3nz8cx6it--2rvsfjgji02p-vdp-8761">
      <skos:prefLabel xml:lang="fr">rue de l'Abbaye (6e arrondissement, Paris, France ; id : 8761)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de l'Abbaye</skos:altLabel>
      <rico:name>rue de l'Abbaye (6e arrondissement, Paris, France ; id : 8761)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Abbaye (rue de l')</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz8cx6it--2rvsfjgji02p-vdp-8761"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nz8cx6it--2rvsfjgji02p-rue%20de%20l%27Abbaye"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nz8cx6it--2rvsfjgji02p"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/8761_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Ouverte sur les terrains de l'abbaye Saint-Germain des Prés ; dénommée successivement : rue de la Paix (1802), rue Neuve de l'Abbaye (1809), rue de l'Abbaye (1815). En 1951, la partie qui était comprise entre les rues Bonaparte et Saint-Benoît a pris le nom de rue Guillaume Apollinaire. [Origine du nom de la voie :] L'abbaye Saint-Germain des Prés, fondée par Childebert en 543.</rico:history>
