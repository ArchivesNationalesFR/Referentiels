      <rico:isOrWasAffectedBy rdf:resource="activity/numerotage-vdp-8761_1877-07-21"/>
      <rico:isOrWasAffectedBy rdf:resource="activity/alignement-vdp-8761_1839-04-29_1844-04-30"/>
