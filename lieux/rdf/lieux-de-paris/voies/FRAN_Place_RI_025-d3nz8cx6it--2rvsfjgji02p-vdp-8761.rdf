      <rico:hasExtent rdf:resource="extent/vdp-8761_numero_pair"/>
      <anf-onto:startingAtPoint xml:lang="fr">rue de l'Echaudé, 18.</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">place Saint-Germain des Prés, 1, et rue Bonaparte, 37.</anf-onto:endingAtPoint>
