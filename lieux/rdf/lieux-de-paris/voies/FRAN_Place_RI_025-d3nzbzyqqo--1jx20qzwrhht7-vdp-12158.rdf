   <rico:Place rdf:about="place/FRAN_RI_025-d3nzbzyqqo--1jx20qzwrhht7-vdp-12158">
      <rdfs:label xml:lang="fr">rue Mauconseil (1er arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue Mauconseil (1er arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Mauconseil</skos:altLabel>
      <rico:name>rue Mauconseil (1er arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Mauconseil (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzbzyqqo--1jx20qzwrhht7-vdp-12158"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzbzyqqo--1jx20qzwrhht7-rue%20Mauconseil"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzbzyqqo--1jx20qzwrhht7"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/12158_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Cette rue existait dès 1250 sous le nom de rue Mauconseil. De 1792 à 1806, elle fut appelée rue Bonconseil. Elle fut appelée également rue Monconseil. Elle aboutissait autrefois rue Saint-Denis. Sur le plan de Mérian la partie entre la rue Mondétour et la rue Saint-Denis est appelée rue Saint-Jacques de l'Hôpital.</rico:history>
