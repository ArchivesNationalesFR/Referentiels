   <rico:Place rdf:about="place/FRAN_RI_025-d3nzbm9qne--nif9g74p9zov-vdp-11604">
      <rdfs:label xml:lang="fr">rue de la Justice (20e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue de la Justice (20e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de la Justice</skos:altLabel>
      <rico:name>rue de la Justice (20e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Justice (rue de la)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzbm9qne--nif9g74p9zov-vdp-11604"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzbm9qne--nif9g74p9zov-rue%20de%20la%20Justice"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzbm9qne--nif9g74p9zov"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/11604_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Précédemment sentier de la Justice et antérieurement, sentier des Vaches. Il est tracé sur le plan cadastral de la commune de Charonne, dressé en 1812. Dans la traversée du talus du boulevard Mortier, le sol de la voie, qui appartenait à l'Etat, a été acquis par la Ville de Paris, suivant acte administratif du 27 avril 1898. Elle a été ouverte par la Ville de Paris. | Origine du nom : Aboutissait à l'ancienne justice de Charonne.</rico:history>
