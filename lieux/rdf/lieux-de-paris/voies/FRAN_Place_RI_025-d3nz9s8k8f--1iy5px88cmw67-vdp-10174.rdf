   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nz9s8k8f--1iy5px88cmw67-vdp-10174_1829-10-25_1934-04-25">
      <rico:generalDescription xml:lang="fr">Non retenus au POS et non repris au PLU : Ordonnace royale du 25 octobre 1829, côté pair, sauf sur une longueur de 12,50 m environ à partir du quai de Conti. Arrêté préfectoral du 25 avril 1934, le surplus et pans coupés aux angles de la rue de Nesle et à l'angle de la rue Mazarine.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
