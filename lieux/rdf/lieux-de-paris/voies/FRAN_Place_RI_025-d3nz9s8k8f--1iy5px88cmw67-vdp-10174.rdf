   <rico:Place rdf:about="place/FRAN_RI_025-d3nz9s8k8f--1iy5px88cmw67-vdp-10174">
      <rdfs:label xml:lang="fr">rue Dauphine (6e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue Dauphine (6e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Dauphine</skos:altLabel>
      <rico:name>rue Dauphine (6e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Dauphine (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz9s8k8f--1iy5px88cmw67-vdp-10174"/>
