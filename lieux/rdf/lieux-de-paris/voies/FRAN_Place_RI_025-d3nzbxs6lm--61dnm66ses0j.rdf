   <rico:Place rdf:about="place/FRAN_RI_025-d3nzbxs6lm--61dnm66ses0j">
      <rdfs:label xml:lang="fr">avenue du Maréchal Fayolle (Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">avenue du Maréchal Fayolle (Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">avenue du Maréchal Fayolle</skos:altLabel>
      <skos:hiddenLabel xml:lang="fr">Maréchal-Fayolle (avenue du)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzbxs6lm--61dnm66ses0j"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzbxs6lm--61dnm66ses0j-avenue%20du%20Mar%C3%A9chal%20Fayolle"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d’après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/12073_VdP"/>
      <rico:hasOrHadIdentifier rdf:resource="identifier/d3nzbxs6lm--61dnm66ses0j"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/avenue"/>
      <rico:history xml:lang="fr">Ouverte par la Ville de Paris sur l’emplacement des bastions 55, 56, 57. Précédemment avenue du Maréchal Joffre, partie A. Le tronçon qui débouchait place de Colombie a pris, en 1936, le nom d’avenue Louis Barthou.</rico:history>
