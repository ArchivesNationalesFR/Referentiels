   <rico:PlaceName rdf:about="placeName/FRAN_RI_025-d3nzbxs6lm--61dnm66ses0j-avenue%20du%20Mar%C3%A9chal%20Fayolle">
      <rico:textualValue xml:lang="fr">avenue du Maréchal Fayolle</rico:textualValue>
      <rico:history xml:lang="fr">Marie Emile Fayolle (1852-1928), maréchal de France, vainqueur de la Somme.</rico:history>
