   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nzcxyb8x-1gwqh86nfquvs-vdp-13301_1859-06-30_1931-08-03">
      <rico:generalDescription xml:lang="fr">Non retenus au POS et non repris au PLU : Décret du 22 février 1868 (UP), partie A. Décret du 30 juin 1859 (UP), partie B, sauf : 1° côté impair, entre la rue Bernoulli et le boulevard des Batignolles ; 2° côté pair, sur une longueur de 13 m environ avant ledit boulevard. Décret du 19 février 1862 (UP), partie C. Arrêté du 3 août 1931 (relatif à la rue Cardinet), raccordement côté pair avec ladite rue.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
