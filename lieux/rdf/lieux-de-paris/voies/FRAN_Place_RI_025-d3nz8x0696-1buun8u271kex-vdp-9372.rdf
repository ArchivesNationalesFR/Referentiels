   <rico:Place rdf:about="place/FRAN_RI_025-d3nz8x0696-1buun8u271kex-vdp-9372">
      <skos:prefLabel xml:lang="fr">rue des Bois (19e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue des Bois</skos:altLabel>
      <rico:name>rue des Bois (19e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Bois (rue des)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz8x0696-1buun8u271kex-vdp-9372"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nz8x0696-1buun8u271kex-rue%20des%20Bois"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nz8x0696-1buun8u271kex"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Cette voie est indiquée sur le plan de Roussel (1730) et sur le plan cadastral de la commune de Belleville dressé en 1812. [Origine du nom de la voie :] Souvenir du bois des Rigones, qui existait au XIVe siècle.</rico:history>
