      <anf-onto:startingAtPoint xml:lang="fr">rue du Pré Saint-Gervais, 42 bis, et rue Henri Ribière, 24.</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">boulevard Sérurier, 71.</anf-onto:endingAtPoint>
