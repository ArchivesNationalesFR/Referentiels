   <rico:Place rdf:about="place/FRAN_RI_025-d3nzbbj164-ge5jz4t9swjy-vdp-11185">
      <skos:prefLabel xml:lang="fr">rue Gutenberg (15e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Gutenberg</skos:altLabel>
      <rico:name>rue Gutenberg (15e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Gutenberg (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzbbj164-ge5jz4t9swjy-vdp-11185"/>
