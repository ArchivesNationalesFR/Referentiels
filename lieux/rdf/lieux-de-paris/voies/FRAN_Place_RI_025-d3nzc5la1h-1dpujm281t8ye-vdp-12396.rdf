   <rico:Place rdf:about="place/FRAN_RI_025-d3nzc5la1h-1dpujm281t8ye-vdp-12396">
      <rdfs:label xml:lang="fr">rue des Moulins (1er arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue des Moulins (1er arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue des Moulins</skos:altLabel>
      <rico:name>rue des Moulins (1er arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Moulins (rue des)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzc5la1h-1dpujm281t8ye-vdp-12396"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzc5la1h-1dpujm281t8ye-rue%20des%20Moulins"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzc5la1h-1dpujm281t8ye"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/12396_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Précédemment rue Royale, antérieurement rue Neuve de Richelieu. En 1793, elle fut réunie à l'ancienne rue des Moulins qui, située entre la rue des Orties (sup.) et la rue Thérèse, a été supprimée par l'ouverture de l'avenue de l'Opéra. Cette voie existait dès 1624 et s'étendait alors des rues l'Evèque (sup.) et des Orties (sup.) à la butte des Moulins et enfin à la rue Thérèse lors de son ouverture. | Origine du nom : Cette voie doit son nom aux moulins de la butte qui existaient encore au XVIIe siècle.</rico:history>
