   <rico:Place rdf:about="place/FRAN_RI_025-d3nzdasc18-1bda8mu3aadao-vdp-13424">
      <rdfs:label xml:lang="fr">rue de Seine (6e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue de Seine (6e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de Seine</skos:altLabel>
      <rico:name>rue de Seine (6e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Seine (rue de)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzdasc18-1bda8mu3aadao-vdp-13424"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzdasc18-1bda8mu3aadao-rue%20de%20Seine"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzdasc18-1bda8mu3aadao"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/13424_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Un arrêté préfectoral du 26 février 1867 lui avait donné le nom de rue du Sénat. La partie comprise entre le quai Malaquais et la rue de Buci existait en 1259. On l'a appelée : chemin du Pré aux Clercs, chemin tendant de la Porte de Buci au Pré aux Clercs, chemin de la Porte de Buci à la Seine, chemin du Pilori au Pré aux Clercs, rue de Seine (dès 1489) ; elle aurait aussi porté, suivant Sauval, le nom de rue Dauphine. | Origine du nom : Voie formée sur la partie du fossé de la Ville aboutissant à la Seine.</rico:history>
      <rico:isOrWasAffectedBy rdf:resource="activity/alignement-FRAN_RI_025-d3nzdasc18-1bda8mu3aadao-vdp-13424_1839-04-29_1866-07-28"/>
