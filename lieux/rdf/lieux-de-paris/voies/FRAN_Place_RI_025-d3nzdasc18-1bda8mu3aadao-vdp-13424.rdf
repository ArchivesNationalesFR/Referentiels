      <rico:hasExtent rdf:resource="extent/FRAN_RI_025-d3nzdasc18-1bda8mu3aadao-vdp-13424_numero_impair"/>
      <anf-onto:startingAtPoint xml:lang="fr">quai Malaquais, 3.</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">rue Saint-Sulpice, 16.</anf-onto:endingAtPoint>
