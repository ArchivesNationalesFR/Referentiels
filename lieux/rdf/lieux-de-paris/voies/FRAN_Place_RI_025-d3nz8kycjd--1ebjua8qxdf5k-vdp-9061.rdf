   <rico:Place rdf:about="place/FRAN_RI_025-d3nz8kycjd--1ebjua8qxdf5k-vdp-9061">
      <skos:prefLabel xml:lang="fr">rue d'Arras (5e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue d'Arras</skos:altLabel>
      <rico:name>rue d'Arras (5e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Arras (rue d')</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nz8kycjd--1ebjua8qxdf5k-vdp-9061"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nz8kycjd--1ebjua8qxdf5k-rue%20d%27Arras"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nz8kycjd--1ebjua8qxdf5k"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Cette voie longeait l'enceinte de Philippe-Auguste et portait originairement le nom de rue des Murs. Au XIVe siècle, elle fut appelée rue d'Arras, et par altération rue Dras et rue du ou des Ras. Au XVIe siècle, elle fut aussi désignée sous les noms de rue du Puits et de rue du Champ Gaillard. Un tronçon de la voie, sur une longueur de 37 m environ, au-delà de la partie en impasse, a été déclassé par arrêté du 20 novembre 1957, pour être incorporé à l'Ecole Polytechnique. La partie en impasse a été englobée dans la rue Jacques-Henri Lartigue par arr. mun. du 18 juillet 1995. [Origine du nom de la voie :] Le collège d'Arras avait été construit dans cette rue en 1332.</rico:history>
      <rico:isOrWasAffectedBy rdf:resource="activity/alignement-vdp-9061_1846-06-05"/>
      <rico:hasExtent rdf:resource="extent/vdp-9061_longueur"/>
      <rico:hasExtent rdf:resource="extent/vdp-9061_largeur"/>
      <rico:hasExtent rdf:resource="extent/vdp-9061_numero_pair"/>
      <rico:hasExtent rdf:resource="extent/vdp-9061_numero_impair"/>
      <anf-onto:startingAtPoint xml:lang="fr">rue des Écoles, 7.</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">rue Monge, 27.</anf-onto:endingAtPoint>
      <rico:isOrWasContainedBy rdf:resource="place/FRAN_RI_023-d3nyvh0r0v--1330tdzzpw7fy"/>
      <rico:isOrWasContainedBy rdf:resource="place/FRAN_RI_022-d3nyv8haov--4rhgfxrxatvr"/>
      <rico:hasOrHadPhysicalLocation rdf:resource="physicalLocation/vdp-9061"/>
