   <rico:Place rdf:about="place/FRAN_RI_025-d3nzcexk2u-1oygcpfmucuym-vdp-12731">
      <skos:prefLabel xml:lang="fr">rue de Penthièvre (8e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de Penthièvre</skos:altLabel>
      <rico:name>rue de Penthièvre (8e arrondissement, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Penthièvre (rue de)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzcexk2u-1oygcpfmucuym-vdp-12731"/>
