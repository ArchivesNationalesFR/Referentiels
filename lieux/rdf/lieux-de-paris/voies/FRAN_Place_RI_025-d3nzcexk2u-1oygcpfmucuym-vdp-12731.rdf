      <anf-onto:startingAtPoint xml:lang="fr">rue Cambacérès, 21.</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">rue du Faubourg Saint-Honoré, 124.</anf-onto:endingAtPoint>
