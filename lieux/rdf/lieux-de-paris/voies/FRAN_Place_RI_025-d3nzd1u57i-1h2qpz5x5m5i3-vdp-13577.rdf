   <rico:Place rdf:about="place/FRAN_RI_025-d3nzd1u57i-1h2qpz5x5m5i3-vdp-13577">
      <skos:prefLabel xml:lang="fr">rue Saint-Denis (1er-2e arrondissements, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Saint-Denis</skos:altLabel>
      <rico:name>rue Saint-Denis (1er-2e arrondissements, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Saint-Denis (rue)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzd1u57i-1h2qpz5x5m5i3-vdp-13577"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzd1u57i-1h2qpz5x5m5i3-rue%20Saint-Denis"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzd1u57i-1h2qpz5x5m5i3"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/13577_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Ancienne voie romaine (chemin de Flandre) conduisant à Saint-Denis. Bordée de maisons dès 1134, elle a porté les noms de la Sellerie de Paris et de la Sellerie de la Grande Rue (XIIIe siècle) ; grand'rue de Paris ; grande rue ou rue des Saints Innocents et grant chaussée de Monsieur ou grant chaussée de Monseigneur Saint-Denis (XIVe siècle). Pendant la Révolution, on l'appelait rue de Franciade. [Origine du nom de la voie :] Ancienne route de Saint-Denis.</rico:history>
