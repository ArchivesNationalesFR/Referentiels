      <anf-onto:startingAtPoint xml:lang="fr">avenue Victoria, 12.</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">boulevard de Bonne Nouvelle, 1, et boulevard Saint-Denis, 19.</anf-onto:endingAtPoint>
