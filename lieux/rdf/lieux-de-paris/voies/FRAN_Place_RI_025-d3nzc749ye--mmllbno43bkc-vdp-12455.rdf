      <rico:hasExtent rdf:resource="extent/vdp-12455_largeur"/>
      <anf-onto:startingOnStreet xml:lang="fr">place de la Porte Maillot.</anf-onto:startingOnStreet>
      <anf-onto:endingAtPoint xml:lang="fr">avenue Charles de Gaulle à la limite du territoire de Neuilly-sur-Seine.</anf-onto:endingAtPoint>
