      <rico:isOrWasAffectedBy rdf:resource="activity/ouverture-vdp-13316_1848-03-26"/>
      <rico:hasExtent rdf:resource="extent/vdp-13316_longueur"/>
      <rico:hasExtent rdf:resource="extent/vdp-13316_numero_impair"/>
      <rico:hasExtent rdf:resource="extent/vdp-13316_largeur"/>
      <rico:hasExtent rdf:resource="extent/vdp-13316_numero_pair"/>
      <anf-onto:startingAtPoint xml:lang="fr">rue Malher, 131.</anf-onto:startingAtPoint>
      <anf-onto:endingAtPoint xml:lang="fr">rue Vieille du Temple, 40.</anf-onto:endingAtPoint>
