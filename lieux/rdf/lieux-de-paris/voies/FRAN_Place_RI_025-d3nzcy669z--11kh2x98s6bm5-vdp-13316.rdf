   <rico:Activity rdf:about="activity/ouverture-vdp-13316_1848-03-26">
      <rico:generalDescription xml:lang="fr">Arrêté du Pouvoir exécutif du 26 mars 1848 (UP), sur une longueur de 81 m environ à partir de la rue Malher (A), prolongement de l'ancienne impasse Coquerelle jusqu'à la rue Malher.</rico:generalDescription>
