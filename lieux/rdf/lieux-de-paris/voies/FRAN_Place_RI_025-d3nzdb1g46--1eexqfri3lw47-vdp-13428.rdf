   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nzdb1g46--1eexqfri3lw47-vdp-13428_1826-05-04_1956-02-02">
      <rico:generalDescription xml:lang="fr">Non retenus au POS et non repris au PLU : Ordonnance du 4 mai 1826. Arrêté du 2 février 1956, pans coupés aux angles de la rue des Jeûneurs et raccord au droit des nos 12 et 16 et sur une longueur de 5 m environ, avant le n° 29.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
