   <rico:Activity rdf:about="activity/denomination-FRAN_RI_025-d3nzdb1g46--1eexqfri3lw47_1849-08-28">
      <rico:generalDescription xml:lang="fr">dénomination : Décision ministérielle du 28 août 1849, réunissant la rue du Gros Chenet à la rue du Sentier.</rico:generalDescription>
      <rico:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1849-08-28</rico:date>
