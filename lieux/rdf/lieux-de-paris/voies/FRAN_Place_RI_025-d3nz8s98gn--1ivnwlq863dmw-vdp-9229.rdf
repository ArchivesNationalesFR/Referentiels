   <rico:Place rdf:about="place/FRAN_RI_025-d3nz8s98gn--1ivnwlq863dmw-vdp-9229">
      <rdfs:label xml:lang="fr">rue de Beaujolais (1er arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue de Beaujolais (1er arrondissement, Paris, France)</skos:prefLabel>
