   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nzd9ijfo-1cl1rwo7c24qp-vdp-13379_1933-05-10_1973-01-11">
      <rico:generalDescription xml:lang="fr">Retenus au POS et non repris au PLU : Arrêté du 11 janvier 1973, au droit des nos 121-121 bis et pan coupé à l'angle de la rue Boutin. Non retenus au POS et non repris au PLU : Décret du 10 mai 1933, sauf, côté impair, les parties régies par les textes suivants : 1° arrêté du 20 août 1960, entre le boulevard Auguste Blanqui et le passage Victor Marchand ; 2° arrêté du 11 janvier 1973, entre le passage Victor Marchand et la rue de la Glacière, sauf au droit des nos 121-121 bis et pan coupé à l'angle de la rue Boutin.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nzd9ijfo-1cl1rwo7c24qp-vdp-13379"/>
      <rico:hadSubevent rdf:resource="activity/alignement-FRAN_RI_025-d3nzd9ijfo-1cl1rwo7c24qp-vdp-13379_1933-05-10_1973-01-11_1933-05-10"/>
