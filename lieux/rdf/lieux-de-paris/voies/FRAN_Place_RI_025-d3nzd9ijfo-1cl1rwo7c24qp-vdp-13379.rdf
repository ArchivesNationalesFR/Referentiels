   </rico:Activity>
   <rico:Activity rdf:about="activity/nivellement-FRAN_RI_025-d3nzd9ijfo-1cl1rwo7c24qp-vdp-13379_1933-05-10_1973-01-11">
      <rico:generalDescription xml:lang="fr">Décret du 10 mai 1933 entre le boulevard de Port-Royal et les boulevards Saint-Jacques et Auguste Blanqui. Arrêté du 11 janvier 1973, le surplus.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/nivellement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nzd9ijfo-1cl1rwo7c24qp-vdp-13379"/>
