   </rico:Activity>
   <rico:Activity rdf:about="activity/classement-FRAN_RI_025-d3nzd9ijfo-1cl1rwo7c24qp-vdp-13379_1863-05-23">
      <rico:generalDescription xml:lang="fr">Décret du 23 mai 1863, entre le boulevard Saint-Jacques et la rue d'Alésia. Précédemment voie de l'ancienne commune de Gentilly dans cette partie.</rico:generalDescription>
