   <rico:Place rdf:about="place/FRAN_RI_025-d3nzd9ijfo-1cl1rwo7c24qp-vdp-13379">
      <rdfs:label xml:lang="fr">rue de la Santé (13e-14e arrondissements, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue de la Santé (13e-14e arrondissements, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de la Santé</skos:altLabel>
      <rico:name>rue de la Santé (13e-14e arrondissements, Paris, France)</rico:name>
      <skos:hiddenLabel xml:lang="fr">Santé (rue de la)</skos:hiddenLabel>
      <rico:isOrWasDescribedBy rdf:resource="record/FRAN_RI_025-d3nzd9ijfo-1cl1rwo7c24qp-vdp-13379"/>
      <rico:hasOrHadPlaceName rdf:resource="placeName/FRAN_RI_025-d3nzd9ijfo-1cl1rwo7c24qp-rue%20de%20la%20Sant%C3%A9"/>
      <rico:thingIsTargetOfRelation rdf:resource="appellationRelation/FRAN_RI_025-d3nzd9ijfo-1cl1rwo7c24qp"/>
      <anf-onto:streetStatus xml:lang="fr">voie actuelle d'après la nomenclature officielle des voies parisiennes en date du 31 mai 2023</anf-onto:streetStatus>
      <rico:hasOrHadIdentifier rdf:resource="identifier/13379_VdP"/>
      <rico:hasOrHadPlaceType rdf:resource="placeType/rue"/>
      <rico:history xml:lang="fr">Elle figure sur le plan de Jouvin de Rochefort (1672), sous le nom de chemin d'Arcueil. Le tronçon entre le boulevard Saint-Jacques et la rue de la Glacière était autrefois l'ancien chemin de Gentilly (chemin vicinal dont la largeur avait été fixée à 6 m par arrêté préfectoral du 16 avril 1817). | Origine du nom : Conduit à l'hôpital de la Santé ou Sainte-Anne, du nom d'Anne d'Autriche, sa fondatrice.</rico:history>
      <rico:isOrWasAffectedBy rdf:resource="activity/alignement-FRAN_RI_025-d3nzd9ijfo-1cl1rwo7c24qp-vdp-13379_1933-05-10_1973-01-11"/>
      <rico:isOrWasAffectedBy rdf:resource="activity/nivellement-FRAN_RI_025-d3nzd9ijfo-1cl1rwo7c24qp-vdp-13379_1933-05-10_1973-01-11"/>
