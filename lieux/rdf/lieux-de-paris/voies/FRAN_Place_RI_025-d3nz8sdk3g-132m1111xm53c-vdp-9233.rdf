   <rico:Place rdf:about="place/FRAN_RI_025-d3nz8sdk3g-132m1111xm53c-vdp-9233">
      <rdfs:label xml:lang="fr">rue de Beaune (7e arrondissement, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue de Beaune (7e arrondissement, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue de Beaune</skos:altLabel>
      <rico:name>rue de Beaune (7e arrondissement, Paris, France)</rico:name>
