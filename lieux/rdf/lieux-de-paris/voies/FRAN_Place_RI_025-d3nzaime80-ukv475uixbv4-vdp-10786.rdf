   <rico:Place rdf:about="place/FRAN_RI_025-d3nzaime80-ukv475uixbv4-vdp-10786">
      <rdfs:label xml:lang="fr">rue Française (1er-2e arrondissements, Paris, France)</rdfs:label>
      <skos:prefLabel xml:lang="fr">rue Française (1er-2e arrondissements, Paris, France)</skos:prefLabel>
      <skos:altLabel xml:lang="fr">rue Française</skos:altLabel>
