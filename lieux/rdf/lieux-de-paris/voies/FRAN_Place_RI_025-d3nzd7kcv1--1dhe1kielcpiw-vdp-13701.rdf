   <rico:Activity rdf:about="activity/alignement-FRAN_RI_025-d3nzd7kcv1--1dhe1kielcpiw-vdp-13701_1853-11-30_1956-01-03">
      <rico:generalDescription xml:lang="fr">Non retenus au POS et non repris au PLU : Arrêté du 3 janvier 1956, partie B ; sur une longueur de 9 m environ, côté pair, avant la rue du Conservatoire, pans coupés : à l'angle de la rue du Faubourg Poissonnière ; côté impair, à l'angle de la rue du Conservatoire (côté pair), côté pair à l'angle de la rue du Conservatoire (côté impair). Décret du 30 novembre 1853, le surplus.</rico:generalDescription>
      <rico:hasActivityType rdf:resource="activityType/alignement%20de%20voie%20urbaine"/>
      <rico:affectsOrAffected rdf:resource="place/FRAN_RI_025-d3nzd7kcv1--1dhe1kielcpiw-vdp-13701"/>
