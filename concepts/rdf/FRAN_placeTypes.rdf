   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/enceinte">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">enceinte</skos:prefLabel>
      <rdfs:label xml:lang="fr">enceinte</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20b%C3%A2timent%20militaire"/>
      <skos:definition xml:lang="fr">Une enceinte est une « clôture continue enveloppant une place forte ou une partie de place forte pour sa
            défense. Une place forte peut avoir plusieurs enceintes qui se commandent les unes les autres. Elles se numérotent de l’extérieur vers
            l’intérieur ». (Source : Thésaurus de la désignation des œuvres architecturales et des espaces aménagés.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzugvmqi--euvq7oav44kv">
            <rico:name xml:lang="fr">Charles V, enceinte de (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-478"/>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q5375326"/>
      <skos:closeMatch rdf:resource="http://fr.dbpedia.org/resource/Enceinte_fortifi%C3%A9e"/>
      <skos:relatedMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11931504g"/>
      <skos:relatedMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-444"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/enclos">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">enclos</skos:prefLabel>
      <rdfs:label xml:lang="fr">enclos</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">« Un enclos est un espace de terrain entouré d’une clôture qui sert à contenir des animaux domestiques, à
            délimiter un monument commémoratif, un espace sacré. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3m0cugvsxw--1pt99rgdkx4tj">
            <rico:name xml:lang="fr">Bernardins, enclos (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-1306"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Enclos"/>
      <skos:relatedMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11964852h"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/enseigne">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">enseigne</skos:prefLabel>
      <rdfs:label xml:lang="fr">enseigne</rdfs:label>
      <skos:altLabel xml:lang="fr">image</skos:altLabel>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Une enseigne est un « panneau portant un emblème, une inscription ou un objet symbolique, placé à la façade
            d'un établissement professionnel, qu'il soit commercial, artisanal, libéral, industriel ou autre pour en signaler l'existence au public »
            (source : Thésaurus de la désignation des objets mobiliers). Par extension, le nom de l’enseigne sert souvent à désigner l’édifice que
            celle-ci orne.</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3m0cugt2as-1x8ooz37krc8e">
            <rico:name xml:lang="fr">Chèvre-qui-paît, enseigne de la (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d5bknxwvt8--rou0h5ldoiz">
            <rico:name xml:lang="fr">Sainte-Anne, image (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:closeMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T69-330"/>
      <skos:closeMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb119730183"/>
      <skos:closeMatch rdf:resource="http://fr.dbpedia.org/resource/Enseigne"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/entrep%C3%B4t%20industriel">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">entrepôt industriel</skos:prefLabel>
      <rdfs:label xml:lang="fr">entrepôt industriel</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Un magasin, sous l’Ancien Régime et la Révolution, désigne un dépôt public ou royal destiné à l’entreposage et
            à la gestion de biens stratégiques (armes, matériaux, vivres, etc.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzuinlk3-amuu7j7r7aqs">
            <rico:name xml:lang="fr">Feuillants, magasins des (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/escalier">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">escalier</skos:prefLabel>
      <rdfs:label xml:lang="fr">escalier</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">« Un escalier est une construction architecturale constituée d’une suite régulière de marches, ou degrés,
            permettant d’accéder à un étage, de passer d’un niveau à un autre en montant et descendant. » « Par extension, ce type de construction a
            donné son nom à un escalier, voie piétonne, à ciel ouvert ou couverte, constituée d’une ou plusieurs marches. » (Source :
            Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nz8vio8b--g2579affw2bw">
            <rico:name xml:lang="fr">escalier Biron (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q12511"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T69-65"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11976932v"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Escalier"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/esplanade">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">esplanade</skos:prefLabel>
      <rdfs:label xml:lang="fr">esplanade</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/place"/>
      <skos:definition xml:lang="fr">« Une esplanade est un terrain plat devant une citadelle, glacis s’étendant jusqu’aux portes d’une ville [...]
            ou, plus généralement, un espace uni et découvert situé devant ou aux abords d’un édifice [...]. Par extension, le mot désigne une place
            de grande dimension, souvent aménagée avec art, et destinée à la promenade. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nz8i45l0-z9yn89qmkdfs">
            <rico:name xml:lang="fr">esplanade André Chamson (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q88372"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-53"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Esplanade"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/%C3%A9tablissement%20conventuel">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">établissement conventuel</skos:prefLabel>
      <rdfs:label xml:lang="fr">établissement conventuel</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/construction%20ou%20%C3%A9difice%20%C3%A0%20usage%20religieux"/>
      <skos:narrower rdf:resource="placeType/commanderie"/>
      <skos:narrower rdf:resource="placeType/couvent"/>
      <skos:narrower rdf:resource="placeType/monast%C3%A8re"/>
      <skos:narrower rdf:resource="placeType/prieur%C3%A9"/>
      <skos:narrower rdf:resource="placeType/abbaye"/>
      <skos:definition xml:lang="fr">Un établissement conventuel est un lieu abritant une communauté religieuse d’hommes ou de femmes. (D’après la
            Liste d’autorités Représentation - Joconde).</skos:definition>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/facult%C3%A9">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">faculté</skos:prefLabel>
      <rdfs:label xml:lang="fr">faculté</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/lieu%20d%E2%80%99enseignement"/>
      <skos:definition xml:lang="fr">« Une faculté est traditionnellement une des structures constitutives d’une université chargée de
            l’enseignement et de la recherche dans un champ disciplinaire homogène, regroupant des domaines de formation et de connaissance
            apparentés. » (Source : Wikipédia.) Par extension, le mot désigne le lieu où une telle structure est installée.</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzulbdnc--ycc6vcfihrth">
            <rico:name xml:lang="fr">Médecine, faculté de (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q180958"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/faubourg">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">faubourg</skos:prefLabel>
      <rdfs:label xml:lang="fr">faubourg</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/quartier"/>
      <skos:narrower rdf:resource="placeType/ancien%20faubourg%20de%20Paris"/>
      <skos:definition xml:lang="fr">Un faubourg est « à l’origine, un quartier développé à l’extérieur de l’enceinte d’une ville, généralement le
            long d’une voie conduisant à une porte. Par extension, quartier situé à l’extérieur d’un boulevard ou au-delà d’une barrière d’octroi
            enserrant un centre ancien ». (Source : Thésaurus de la désignation des œuvres architecturales et des espaces aménagés.)</skos:definition>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Faubourg"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-22"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/fausse%20porte">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">fausse porte</skos:prefLabel>
      <rdfs:label xml:lang="fr">fausse porte</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">« Une fausse porte est une représentation artistique d’une porte, mais qui ne fonctionne pas comme une vraie. »
            (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nzd1ryyl--rlc6acx7xsye">
            <rico:name xml:lang="fr">fausse porte Saint-Denis (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q902996"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : exemple(s), relation(s)
                    sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/foire">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">foire</skos:prefLabel>
      <rdfs:label xml:lang="fr">foire</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">« Une foire, qui peut être appelée aussi marché de grande importance, se déroule sur un foirail ou champ de
            foire. C’est une manifestation commerciale d’exposants faisant partie d’un même secteur économique (comme le secteur agricole par exemple)
            se tenant dans une ville, un bourg à une époque et en un lieu généralement fixe. » (Source : Wikipédia.) Par extension, le mot désigne le
            lieu où une foire se déroule.</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3m0cugdfrj--1f11gmoi26205">
            <rico:name xml:lang="fr">Saint-Germain, foire (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb119314197"/>
      <skos:closeMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T1-470"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/fontaine">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">fontaine</skos:prefLabel>
      <rdfs:label xml:lang="fr">fontaine</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/ouvrage%20li%C3%A9%20%C3%A0%20l%E2%80%99alimentation%20en%20eau"/>
      <skos:definition xml:lang="fr">« Une fontaine est d’abord le lieu d’une source, d’une « eau vive qui sort de terre », selon le premier
            dictionnaire de l’Académie française. C’est également une construction architecturale, généralement accompagnée d’un bassin, d’où jaillit
            de l’eau. » (Source : Wikipédia.)</skos:definition>
      <skos:related rdf:resource="placeType/%C3%A9l%C3%A9ment%20d%E2%80%99hydrographie"/>
      <skos:closeMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-1080"/>
      <skos:closeMatch rdf:resource="http://fr.dbpedia.org/resource/Fontaine_(bassin)"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/for%C3%AAt">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">forêt</skos:prefLabel>
      <rdfs:label xml:lang="fr">forêt</rdfs:label>
      <skos:altLabel xml:lang="fr">bois</skos:altLabel>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
      <skos:definition xml:lang="fr">Une forêt est un « vaste couvert dans lequel les végétaux ligneux, feuillus ou résineux prédominent et peuvent
            être exploités par l’homme pour un usage commercial ou constituer un espace de loisirs pour la promenade ou pour la chasse ». (Source :
            Thésaurus de la désignation des œuvres architecturales et des espaces aménagés.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d3m08zmakla--jfj1oesnfl2n">
            <rico:name xml:lang="fr">forêt de Blois (Loir-et-Cher, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q4421"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-1212"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb119314375"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/For%C3%AAt"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, exemple(s),
                    relation(s) sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/forteresse">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">forteresse</skos:prefLabel>
      <rdfs:label xml:lang="fr">forteresse</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20b%C3%A2timent%20militaire"/>
      <skos:definition xml:lang="fr">Une forteresse est un ensemble cohérent de fortifications visant à protéger non seulement le terrain enclos,
            mais aussi le terroir environnant et un territoire situé en arrière (vis-à-vis d’un ennemi) de la forteresse. (D’après
            Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d5bknwg382--129urhk67s8b6">
            <rico:name xml:lang="fr">Temple, forteresse du (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-455"/>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q3390714"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Fort"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/fortification">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">fortification</skos:prefLabel>
      <rdfs:label xml:lang="fr">fortification</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20b%C3%A2timent%20militaire"/>
      <skos:definition xml:lang="fr">« La fortification est l’art militaire de renforcer une position ou un lieu par des ouvrages de défense en
            prévision de leur éventuelle attaque. Par extension, la fortification désigne ces ouvrages de défense eux-mêmes. » (Source :
            Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-7353rnhm1--1q2vtbdhxupup">
            <rico:name xml:lang="fr">fort Boyard (Charente-Maritime, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:related rdf:resource="placeType/poterne"/>
      <skos:related rdf:resource="placeType/chemin%20de%20ronde"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-443"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11931504g"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Fortification"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, exemple(s),
                    relation(s) d’association avec des concepts du vocabulaire, relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/galerie">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">galerie</skos:prefLabel>
      <rdfs:label xml:lang="fr">galerie</rdfs:label>
      <skos:altLabel xml:lang="fr">galeries</skos:altLabel>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">« Une galerie est un espace couvert ayant une fonction de lieu de séjour et de lieu de circulation. » (Source :
            Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nz8tthff--w8kr88ye9ygp">
            <rico:name xml:lang="fr">galerie Bergère (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:related rdf:resource="placeType/clo%C3%AEtre"/>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q164419"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-1331"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb12067143x"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Galerie_(architecture)"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) d’association avec des concepts du vocabulaire,
                    relation(s) sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/gare">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">gare</skos:prefLabel>
      <rdfs:label xml:lang="fr">gare</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:narrower rdf:resource="placeType/gare%20d%E2%80%99eau"/>
      <skos:narrower rdf:resource="placeType/gare%20ferroviaire"/>
      <skos:definition xml:lang="fr">« Une gare, dans un réseau de transport en commun, est un lieu destiné à la montée et à la descente des
            voyageurs. Elle se distingue généralement d’un simple arrêt par son envergure et ses équipements. » (Source :
            Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzukw82f-1wd1a6pu7b09f">
            <rico:name xml:lang="fr">Lyon, gare de (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-1032"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb119470471"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Gare"/>
      <skos:closeMatch rdf:resource="http://www.wikidata.org/entity/Q55488"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/gare%20d%E2%80%99eau">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">gare d’eau</skos:prefLabel>
      <rdfs:label xml:lang="fr">gare d’eau</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/gare"/>
      <skos:definition xml:lang="fr">Une gare d’eau est un « bief ou partie de bief assez large pour permettre à deux bateaux de se croiser ou de se
            doubler ; il permet en outre aux bateaux de stationner ou d’attendre leur tour pour franchir une dénivelée sans gêner la navigation. Il
            peut abriter des fonctions portuaires (chargement, déchargement, stockage) ». (Source : Thésaurus de la désignation des œuvres
            architecturales et des espaces aménagés.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzuj88t2-1hqagqo7fdpg8">
            <rico:name xml:lang="fr">Grenelle, gare d’eau de (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:related rdf:resource="placeType/%C3%A9l%C3%A9ment%20d%E2%80%99hydrographie"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-1020"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/gare%20ferroviaire">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">gare ferroviaire</skos:prefLabel>
      <rdfs:label xml:lang="fr">gare ferroviaire</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/gare"/>
      <skos:definition xml:lang="fr">« Une gare ferroviaire est le lieu d’arrêt des trains. Une gare comprend diverses installations qui ont une
            double fonction : permettre la montée et la descente des voyageurs [...], ou le chargement et le déchargement des marchandises [...] ainsi
            que pour certaines d’entre elles, assurer des fonctions de sécurité dans la circulation des trains. » (Source :
            Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzuf41xb--6e30qgzk1aln">
            <rico:name xml:lang="fr">Austerlitz, gare d’ (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q55488"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, exemple(s),
                    relation(s) sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/gibet">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">gibet</skos:prefLabel>
      <rdfs:label xml:lang="fr">gibet</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Un gibet est une potence ou un ensemble de potences où l’on pendait les condamnés à mort (d’après le Thésaurus
            de la désignation des œuvres architecturales et des espaces aménagés). Par extension, le terme en est venu à désigner non plus seulement
            l’instrument, mais aussi l’endroit lui-même, devenu un lieu identifié dans la ville.</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzulpid9--ter7gt26sv7c">
            <rico:name xml:lang="fr">Montfaucon, gibet de (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-249"/>
      <skos:closeMatch rdf:resource="https://fr.wikipedia.org/wiki/Potence_(pendaison)"/>
      <skos:closeMatch rdf:resource="http://www.wikidata.org/entity/Q243778"/>
      <skos:closeMatch rdf:resource="http://fr.dbpedia.org/resource/Potence_(pendaison)"/>
      <skos:closeMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb144696474"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/golfe">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">golfe</skos:prefLabel>
      <rdfs:label xml:lang="fr">golfe</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20d%E2%80%99hydrographie"/>
      <skos:definition xml:lang="fr">Un golfe est une partie de mer ou de lac avancée dans les terres. (D’après Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d5bdox440w--1lqxusrzbpuh7">
            <rico:name xml:lang="fr">golfe de Gascogne (France / Espagne)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q1322134"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-04-19</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/gorge">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">gorge</skos:prefLabel>
      <rdfs:label xml:lang="fr">gorge</rdfs:label>
      <skos:altLabel xml:lang="fr">canyon</skos:altLabel>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
      <skos:definition xml:lang="fr">Une gorge (appelée aussi en anglais canyon), est « un passage encaissé entre deux reliefs résultant de
            l’érosion hydraulique sur tout type de roche mais préférentiellement sur les sédimentaires. Une gorge peut être confondue avec une clue ou
            un défilé ». (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-803tfm5w1--1pw8e7hckg15s">
            <rico:name xml:lang="fr">gorges du Gardon (Gard, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q150784"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout d’un exemple.</rdf:value>
            <dc:date>2026-04-18</dc:date>
         </rdf:Description>
      </skos:changeNote>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : relation(s) sémantique(s)
                    vers des concepts d’autres vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/gouffre">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">gouffre</skos:prefLabel>
      <rdfs:label xml:lang="fr">gouffre</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
      <skos:definition xml:lang="fr">« Un gouffre (ou abîme, en géologie) est au sens propre une cavité souterraine, souvent d’origine karstique,
            dont l’entrée généralement imposante présente une verticalité marquée. Le gouffre ou abîme s’oppose à la caverne ou à la grotte, dont
            l’entrée est plutôt horizontale. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-80zojg4za--1tg4s9rg1p87p">
            <rico:name xml:lang="fr">gouffre de La Pierre Saint-Martin (Pyrénées-Atlantiques, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q35509"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-04-18</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/grand%20magasin">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">grand magasin</skos:prefLabel>
      <rdfs:label xml:lang="fr">grand magasin</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9difice%20ou%20local%20commercial"/>
      <skos:definition xml:lang="fr">Un grand magasin est un commerce de détail multi-spécialiste exploité par une société commerciale unique.
            L’assortiment des marchandises proposé est large. Généralement implantée en centre-ville et occupant plusieurs étages d’un bâtiment, cette
            forme de commerce apparaît au cours de la seconde partie du XIXe siècle. (D’après Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzukrfmb-q066c4of59cw">
            <rico:name xml:lang="fr">Louvre, grands magasins du (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb119344894"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Grand_magasin"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/grotte">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">grotte</skos:prefLabel>
      <rdfs:label xml:lang="fr">grotte</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
      <skos:definition xml:lang="fr">En géomorphologie, une grotte est « une cavité souterraine naturelle comportant au moins une partie horizontale
            accessible ». (Source : Wikipédia.)</skos:definition>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q35509"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : exemple(s), relation(s)
                    sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/hameau">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">hameau</skos:prefLabel>
      <rdfs:label xml:lang="fr">hameau</rdfs:label>
      <skos:altLabel xml:lang="fr">écart</skos:altLabel>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20humaine"/>
      <skos:definition xml:lang="fr">« Un hameau, ou un écart, est un groupe d’habitations en milieu rural, généralement trop petit pour être
            considéré comme un village. L’élément fondateur est très souvent une ferme. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-35nu76u2g-ulv7d2fqbz3o">
            <rico:name xml:lang="fr">Cerneux-Monnots (Bonnétage, Doubs, France ; hameau)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q5084"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition,
                    exemple(s)</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/h%C3%B4pital">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">hôpital</skos:prefLabel>
      <rdfs:label xml:lang="fr">hôpital</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Un hôpital est un « établissement dans lequel sont associés des services de médecine et de chirurgie générales
            à des services relevant des principales spécialités médico-chirurgicales ainsi qu’à des laboratoires. Quelle que soit sa taille, il abrite
            généralement une morgue et un lieu de prière (chapelle, etc.). Les différents services peuvent être répartis dans un ensemble de bâtiments
            ou sous un toit unique ». (Source : Thésaurus de la désignation des œuvres architecturales et des espaces aménagés.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzufc9vz--8tcoxqity82k">
            <rico:name xml:lang="fr">Baudelocque, hôpital (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q16917"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-292"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11940402g"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/H%C3%B4pital"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : définition, exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/hospice">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">hospice</skos:prefLabel>
      <rdfs:label xml:lang="fr">hospice</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/lieu%20d%E2%80%99assistance%20ou%20de%20protection%20sociale"/>
      <skos:definition xml:lang="fr">Un hospice est, au XIXe et au début du XXe siècle, un « établissement destiné à héberger et soigner les
            personnes indigentes (orphelins, vieillards, etc.) ». (Source : Thésaurus de la désignation des œuvres architecturales et des espaces
            aménagés.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzuhn818-13qjjoykl102a">
            <rico:name xml:lang="fr">Convalescents, hospice des (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-287"/>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q608152"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Hospice"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/h%C3%B4tel">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">hôtel</skos:prefLabel>
      <rdfs:label xml:lang="fr">hôtel</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9difice%20%C3%A0%20usage%20d%E2%80%99habitation"/>
      <skos:definition xml:lang="fr">Dans l’architecture classique, un hôtel est la « demeure citadine d’un grand seigneur ou d’un riche
            particulier, accompagnée généralement de communs, d’une cour et d’un jardin ». (Source : Thésaurus de la désignation des œuvres
            architecturales et des espaces aménagés.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzug43ld-1mm0rn8yx1p59">
            <rico:name xml:lang="fr">Brienne, hôtel de (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-517"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11959153x"/>
      <skos:closeMatch rdf:resource="http://fr.dbpedia.org/resource/H%C3%B4tel_particulier"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/h%C3%B4tel%20meubl%C3%A9">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">hôtel meublé</skos:prefLabel>
      <rdfs:label xml:lang="fr">hôtel meublé</rdfs:label>
      <skos:altLabel xml:lang="fr">hôtel garni</skos:altLabel>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9difice%20%C3%A0%20usage%20d%E2%80%99habitation"/>
      <skos:definition xml:lang="fr">« Un hôtel meublé, aussi appelé un garni (sens vieilli) est, en France, un établissement offrant des
            prestations hôtelières (draps, téléphone…) mais qui sert en général de résidence principale à ses résidents. C’est néanmoins le plus
            souvent une résidence considérée comme transitoire avant de trouver une résidence permanente indépendante. » (Source :
            Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzuerfqp-owebv47396dq">
            <rico:name xml:lang="fr">Albe, hôtel garni d’</rico:name>
         </rico:Place>
      </skos:example>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/%C3%AEle">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">île</skos:prefLabel>
      <rdfs:label xml:lang="fr">île</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
      <skos:definition xml:lang="fr">« Une île est une surface de terre entourée d’eau de manière permanente ou parfois de manière temporaire en
            fonction des marées. » L’eau baignant les îles peut être celle d’un océan, d’une mer, d’un lac ou d’un cours d’eau. Les îles peuvent être
            temporaires (banc de sable, volcans, etc.) ou permanentes, isolées ou groupées avec d’autres îles et peuvent alors former un archipel. Une
            petite île est parfois désignée sous les termes d’îlet ou d’îlot. Les îles peuvent être reliées à d’autres îles ou à un continent par une
            chaussée, un pont ou un tunnel. (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-7ru6fjocw-165d9c54ak1ea">
            <rico:name xml:lang="fr">île de Berder (Larmor-Baden, Morbihan, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q23442"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/fr/ark:/12148/cb119499428"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, exemple(s),
                    relation(s) sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/impasse">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">impasse</skos:prefLabel>
      <rdfs:label xml:lang="fr">impasse</rdfs:label>
      <skos:altLabel xml:lang="fr">cul-de-sac</skos:altLabel>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/voie"/>
      <skos:definition xml:lang="fr">« Une impasse, aussi appelée cul-de-sac ou voie sans issue, est une voie aérienne (rue, ruelle) ou souterraine
            (galerie, tunnel) ne possédant qu’un seul point d’entrée et sortie pour les véhicules, et qui nécessite par conséquent de faire un
            demi-tour ou une marche arrière pour pouvoir en sortir. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nz8fwqei--x30t2c3oz45k">
            <rico:name xml:lang="fr">impasse Alexandre Dumas (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q12731"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-68"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Impasse"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/institut%20culturel">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">institut culturel</skos:prefLabel>
      <rdfs:label xml:lang="fr">institut culturel</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Un lieu abritant une organisation qui œuvre à la préservation ou à la promotion de la culture. (D’après
            Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzujngz4-1mdj6j0eyxsw3">
            <rico:name xml:lang="fr">Irlandais, institut culturel</rico:name>
         </rico:Place>
      </skos:example>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/institut%20national">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">institut national</skos:prefLabel>
      <rdfs:label xml:lang="fr">institut national</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Un institut national est un établissement d’envergure nationale, généralement placé sous la tutelle de l’État,
            qui exerce des missions de recherche, de formation, de conservation, de normalisation ou de diffusion des savoirs dans un domaine
            spécifique. Il constitue une référence scientifique, culturelle ou technique reconnue au niveau national et, parfois, à l’échelle
            internationale.</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3m0cugtjc1--1hokukoerkozk">
            <rico:name xml:lang="fr">Jeunes sourds, institut national de (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/jardin">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">jardin</skos:prefLabel>
      <rdfs:label xml:lang="fr">jardin</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:narrower rdf:resource="placeType/parc"/>
      <skos:definition xml:lang="fr">Un jardin est un « espace organisé, public ou privé, comportant des végétaux en pleine terre ou hors sol ».
            (Source : Thésaurus de la désignation des œuvres architecturales et des espaces aménagés.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzuqar5w--juhxp1bfs0yz">
            <rico:name xml:lang="fr">Tuileries, jardin des (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-1116"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Jardin"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/lac">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">lac</skos:prefLabel>
      <rdfs:label xml:lang="fr">lac</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20d%E2%80%99hydrographie"/>
      <skos:definition xml:lang="fr">Un lac est une étendue d’eau terrestre : bassin, étang, lac, mare. (Source : vocabulaire
            IGN.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-7b2wo51gg-flwr84h4ngl4">
            <rico:name xml:lang="fr">lac de Bosméléac (Côtes-d’Armor, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.ign.fr/id/codes/topo/typedezai/Lac"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : définition, exemple(s)</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/lagune">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">lagune</skos:prefLabel>
      <rdfs:label xml:lang="fr">lagune</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20d%E2%80%99hydrographie"/>
      <skos:definition xml:lang="fr">« Une lagune est une étendue d’eaux côtières généralement peu profonde séparée de la mer par un cordon littoral
            de largeur variable. Ce cordon se modifie naturellement et, lorsqu’il est fin, peut être vulnérable aux assauts de la mer (tempêtes,
            tsunamis) et à diverses formes d’artificialisation. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d5bdphoh3f-1e5v5agzw6t16">
            <rico:name xml:lang="fr">étang de Berre (Bouches-du-Rhône, France ; lagune)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-04-17</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/lieu-dit">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">lieu-dit</skos:prefLabel>
      <rdfs:label xml:lang="fr">lieu-dit</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20humaine"/>
      <skos:definition xml:lang="fr">Un lieu-dit est un endroit de faible étendue auquel est associé un nom propre. Contrairement au hameau, un
            lieu-dit n’est pas forcément un lieu habité ; ce peut être un champ, un carrefour ou encore un bois. Il s’agit en fait d’un lieu marqué
            dans le paysage par un établissement ou un aménagement humain, sélectionné parmi l’ensemble des microtoponymes dans la nomenclature, la
            cartographie et la signalétique officielle des lieux d’un pays. (D’après Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-57bir2eed--19uuyuyhzy62n">
            <rico:name xml:lang="fr">Becléguer (Lannion, Côtes-d'Armor, France ; lieu-dit)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition,
                    exemple(s)</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/lieu%20d%E2%80%99assistance%20ou%20de%20protection%20sociale">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">lieu d’assistance ou de protection sociale</skos:prefLabel>
      <rdfs:label xml:lang="fr">lieu d’assistance ou de protection sociale</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:narrower rdf:resource="placeType/asile-ouvroir"/>
      <skos:narrower rdf:resource="placeType/hospice"/>
      <skos:narrower rdf:resource="placeType/cit%C3%A9%20sanitaire"/>
      <skos:definition xml:lang="fr">Un lieu d’assistance ou de protection sociale est une « construction ou groupe de constructions abritant des
            activités d’assistance privée, religieuse ou civile, ou de protection sociale ». (Source : Thésaurus de la désignation des œuvres
            architecturales et des espaces aménagés.)</skos:definition>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-273"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/lieu%20d%E2%80%99enseignement">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">lieu d’enseignement</skos:prefLabel>
      <rdfs:label xml:lang="fr">lieu d’enseignement</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:narrower rdf:resource="placeType/coll%C3%A8ge"/>
      <skos:narrower rdf:resource="placeType/conservatoire"/>
      <skos:narrower rdf:resource="placeType/%C3%A9cole"/>
      <skos:narrower rdf:resource="placeType/facult%C3%A9"/>
      <skos:narrower rdf:resource="placeType/lyc%C3%A9e"/>
      <skos:narrower rdf:resource="placeType/noviciat"/>
      <skos:narrower rdf:resource="placeType/s%C3%A9minaire"/>
      <skos:definition xml:lang="fr">Un lieu d’enseignement est un lieu occupé par une organisation qui offre un service d’éducation, sous forme
            d’objectif principal ou auxiliaire. Il peut s’agir d’un établissement d’enseignement public ou d’une entreprise privée, d’une organisation
            non gouvernementale ou d’un organisme public, même si l’enseignement n’est pas son objet principal. (D’après le Réseau Inter-agences pour
            l’Éducation en Situations d’Urgence.)</skos:definition>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T1-662"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/lyc%C3%A9e">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">lycée</skos:prefLabel>
      <rdfs:label xml:lang="fr">lycée</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/lieu%20d%E2%80%99enseignement"/>
      <skos:definition xml:lang="fr">Un lycée, en France, est un « établissement d’enseignement général ou technique, dispensant l’enseignement du
            second cycle ». (Source : Thésaurus de la désignation des œuvres architecturales et des espaces aménagés.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3m0cugar3r-1lgo6pkzgsbir">
            <rico:name xml:lang="fr">Henri IV, lycée (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-316"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11963528k"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Lyc%C3%A9e_en_France"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/maison">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">maison</skos:prefLabel>
      <rdfs:label xml:lang="fr">maison</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Le mot "maison" désigne un lieu bâti identifié, servant le plus souvent d’habitation, parfois porteur d’un rôle
            institutionnel, religieux, social ou symbolique, et nommé en fonction de sa fonction, de ses occupants ou d’une
            enseigne.</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3m0cugg7zp--1s7fmc2ryxhen">
            <rico:name xml:lang="fr">Orphelines de la Légion d’honneur, maison des (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/maison%20de%20sant%C3%A9">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">maison de santé</skos:prefLabel>
      <rdfs:label xml:lang="fr">maison de santé</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Une maison de santé est un bâtiment où l’on accueille des malades, souvent des personnes atteintes de maladies
            mentales. (D’après le Dictionnaire de l’Académie Française, 9e édition, et le Dictionnaire de français Larousse en
            ligne.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3m0cufzdvo--yjzyoqlv32yq">
            <rico:name xml:lang="fr">maison de santé de la Butte Montmartre</rico:name>
         </rico:Place>
      </skos:example>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/manoir">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">manoir</skos:prefLabel>
      <rdfs:label xml:lang="fr">manoir</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9difice%20%C3%A0%20usage%20d%E2%80%99habitation"/>
      <skos:definition xml:lang="fr">« Un manoir est avant tout le siège d’un domaine d’origine seigneuriale. C’est un terme utilisé majoritairement
            dans le nord de la France. C’est la résidence ou la demeure d’un noble, son logis seigneurial. » « La distinction entre un manoir et un
            château n’est pas toujours claire et telle gentilhommière sera tour à tour appelée manoir ou château. Jusqu’à la Révolution française, le
            manoir — qui a désigné d’abord la taxe imposée aux manants, puis le lieu du paiement d’icelle — peut être défini comme une demeure
            seigneuriale attachée à une exploitation agricole gérée directement par le seigneur, c’est-à-dire par un membre de cette petite noblesse
            rurale qui ne fréquentait pas la cour et n’exerçait pas de fonctions honorifiques, militaires ou administratives. » (Source :
            Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-1g85e564g-1gevlw0qmc7tu">
            <rico:name xml:lang="fr">manoir de Chaubuisson (Fontenay-Trésigny, Seine-et-Marne, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q2116450"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-522"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb12139586b"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Manoir"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, exemple(s),
                    relation(s) sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/manufacture">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">manufacture</skos:prefLabel>
      <rdfs:label xml:lang="fr">manufacture</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:narrower rdf:resource="placeType/manufacture%20royale"/>
      <skos:definition xml:lang="fr">« Une manufacture (du latin manufactura, « fait à la main ») est un lieu de fabrication dans lequel des
            produits sont à l’origine fabriqués à la main par des ouvriers et qui sert à désigner aujourd’hui une entreprise dans laquelle les biens
            sont produits directement ou indirectement (robotisation) par l’homme. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzupkkb1--19j4xyyvk42mj">
            <rico:name xml:lang="fr">Manufacture de la Savonnerie</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb15565552s"/>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q380342"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T1-1402"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/manufacture%20royale">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">manufacture royale</skos:prefLabel>
      <rdfs:label xml:lang="fr">manufacture royale</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/manufacture"/>
      <skos:definition xml:lang="fr">Une manufacture royale est un lieu de fabrication développé en France aux XVIIe et XVIIIe siècles avec le
            soutien du pouvoir royal. (D’après Wikidata.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzuprcja--1eott59jpdcko">
            <rico:name xml:lang="fr">Tabacs, manufacture royale des (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q105071173"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/march%C3%A9">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">marché</skos:prefLabel>
      <rdfs:label xml:lang="fr">marché</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Un marché est un « espace public ou édifice où l’on vend toutes sortes de marchandises, sur des étals fixes ou
            mobiles ». (Source : Thésaurus de la désignation des œuvres architecturales et des espaces aménagés.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3m0cug8410--6cvt8k531pzf">
            <rico:name xml:lang="fr">Saint-Martin, marché (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMathc rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-635"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/March%C3%A9"/>
      <skos:exactMatch rdf:resource="http://vocab.getty.edu/aat/300005238"/>
      <skos:closeMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb119344952"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/massif">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">massif</skos:prefLabel>
      <rdfs:label xml:lang="fr">massif</rdfs:label>
      <skos:altLabel xml:lang="fr">massif montagneux</skos:altLabel>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
      <skos:definition xml:lang="fr">Un massif est un ensemble de montagnes formant un bloc continu qui suit une ligne de crête, et s’oppose à une
            chaîne de montagnes. Il présente la particularité de former un ensemble de reliefs continus, séparé souvent par des rivières, des vallées,
            entourés d’abîmes ou des reliefs distincts. (D’après Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d3ntxq5e6s-3b4l4rx947ol">
            <rico:name xml:lang="fr">Alpes (Europe ; massif)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q1061151"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, exemple(s),
                    relation(s) sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/mer">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">mer</skos:prefLabel>
      <rdfs:label xml:lang="fr">mer</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20d%E2%80%99hydrographie"/>
      <skos:definition xml:lang="fr">Une mer est une étendue d’eau salée. « En hydronymie, sauf exceptions et malgré un contact fréquent, une mer se
            distingue d’un océan par sa position géographique souvent assez enclavée entre des masses terrestres, donc avec une étendue et une
            profondeur nettement moindres, ou par une limitation à un plateau continental. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d5bdpl9rvx-5jkisx57fz3y">
            <rico:name xml:lang="fr">mer Méditerranée</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q165"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-04-17</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/monast%C3%A8re">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">monastère</skos:prefLabel>
      <rdfs:label xml:lang="fr">monastère</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9tablissement%20conventuel"/>
      <skos:definition xml:lang="fr">« Un monastère est un ensemble de bâtiments où vit une communauté religieuse de moines ou de moniales. »
            (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzum2g6x--ypoc3k7w2mcf">
            <rico:name xml:lang="fr">Notre-Dame-de-Grâce, monastère de (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q44613"/>
      <skos:exactMatch rdf:resource="https://dbpedia.org/ontology/Monastery"/>
      <skos:closeMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-98"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/montagne">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">montagne</skos:prefLabel>
      <rdfs:label xml:lang="fr">montagne</rdfs:label>
      <skos:altLabel xml:lang="fr">mont</skos:altLabel>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
      <skos:definition xml:lang="fr">« Une montagne est une forme topographique de relief positif [...] et faisant partie d’un ensemble — une chaîne
            de montagnes — ou formant un relief isolé. Elle est caractérisée par son altitude et, plus généralement, par sa hauteur relative, voire
            par sa pente. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-1g86cbv28--1cqe6odjrywgr">
            <rico:name xml:lang="fr">Meije (Hautes-Alpes / Isère, France ; montagne)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb119323641"/>
      <skos:closeMatch rdf:resource="http://data.ign.fr/id/codes/topo/typederelief/Montagne"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout d’un exemple.</rdf:value>
            <dc:date>2026-04-18</dc:date>
         </rdf:Description>
      </skos:changeNote>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, relation(s)
                    sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/monument%20comm%C3%A9moratif">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">monument commémoratif</skos:prefLabel>
      <rdfs:label xml:lang="fr">monument commémoratif</rdfs:label>
      <skos:altLabel xml:lang="fr">mémorial</skos:altLabel>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:narrower rdf:resource="placeType/arc%20de%20triomphe"/>
      <skos:narrower rdf:resource="placeType/colonne"/>
      <skos:narrower rdf:resource="placeType/ob%C3%A9lisque"/>
      <skos:definition xml:lang="fr">Un monument commémoratif est un monument érigé en souvenir d’un événement, ou/et en l’honneur d’une ou
            plusieurs personnes décédées. (D’après Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-1g85e46mo--q6k7icxtlcnz">
            <rico:name xml:lang="fr">monument de la Cote 304 (Esnes-en-Argonne, Meuse, France ; monument commémoratif)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout d’un exemple.</rdf:value>
            <dc:date>2026-04-18</dc:date>
         </rdf:Description>
      </skos:changeNote>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : définition</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/noviciat">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">noviciat</skos:prefLabel>
      <rdfs:label xml:lang="fr">noviciat</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/lieu%20d%E2%80%99enseignement"/>
      <skos:definition xml:lang="fr">Un noviciat est un « établissement pour l’éducation des novices d’un ordre religieux chrétien ». (Source :
            Thésaurus de la désignation des œuvres architecturales et des espaces aménagés.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzujslhs-1tf8hylsls7r5">
            <rico:name xml:lang="fr">Jésuites, noviciat des (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-325"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/ob%C3%A9lisque">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">obélisque</skos:prefLabel>
      <rdfs:label xml:lang="fr">obélisque</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/monument%20comm%C3%A9moratif"/>
      <skos:definition xml:lang="fr">Un obélisque est un « monument en forme de pyramide élancée, habituellement terminé par un amortissement qui
            remplace la pointe trop fragile que formerait la rencontre des faces ». (Source : Thésaurus de la désignation des œuvres architecturales
            et des espaces aménagés.)</skos:definition>
      <skos:scopeNote xml:lang="fr">L’obélisque se distingue de la pyramide par sa hauteur qui est supérieure à trois fois la moitié de sa
            base.</skos:scopeNote>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzuksfu0-1anzqi7m6jvxp">
            <rico:name xml:lang="fr">Obélisque de Louxor</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-192"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb119780487"/>
      <skos:exactMatch rdf:resource="http://vocab.getty.edu/aat/300007021"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Ob%C3%A9lisque"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/observatoire">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">observatoire</skos:prefLabel>
      <rdfs:label xml:lang="fr">observatoire</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Un observatoire est un « établissement de recherche abritant les services et l’instrumentation nécessaires aux
            observations, mesures et analyses en astronomie (astrométrie, astrophysique, etc.) et/ou en géophysique (météorologie, géomagnétisme,
            sismologie, etc.) ». (Source : Thésaurus de la désignation des œuvres architecturales et des espaces aménagés.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzulsvq8-11znz4cr4n6u9">
            <rico:name xml:lang="fr">Montsouris, observatoire de (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-387"/>
      <skos:exactMatch rdf:resource="http://vocab.getty.edu/aat/300007680"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Observatoire_astronomique"/>
      <skos:closeMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11981276j"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/oc%C3%A9an">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">océan</skos:prefLabel>
      <rdfs:label xml:lang="fr">océan</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20d%E2%80%99hydrographie"/>
      <skos:definition xml:lang="fr">« Un océan est souvent défini, en géographie, comme une vaste étendue d’eau salée comprise entre deux
            continents. En fait, il s’agit plutôt d’un volume dont l’eau est en permanence brassée par des courants marins. » (Source :
            Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d3ntxq319a--10olszrou0nhs">
            <rico:name xml:lang="fr">océan Atlantique</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q9430"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Ocean"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout d’un exemple.</rdf:value>
            <dc:date>2026-04-18</dc:date>
         </rdf:Description>
      </skos:changeNote>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-04-17</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/orangerie">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">orangerie</skos:prefLabel>
      <rdfs:label xml:lang="fr">orangerie</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Une orangerie est un « bâtiment ou une pièce chauffé où l’on remise l’hiver les orangers et autres arbres et
            plantes en pot pour les protéger du gel ». (Source : Thésaurus de la désignation des œuvres architecturales et des espaces
            aménagés.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzuqbmmw--ec855ok25fd6">
            <rico:name xml:lang="fr">Orangerie des Tuileries</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-1165"/>
      <skos:exactMatch rdf:resource="http://vocab.getty.edu/aat/300006804"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb12080670x"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Orangerie"/>
      <skos:related rdf:resource="placeType/jardin"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/oratoire">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">oratoire</skos:prefLabel>
      <rdfs:label xml:lang="fr">oratoire</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9dicule%20religieux"/>
      <skos:definition xml:lang="fr">Un oratoire est un « petit édifice ou édicule où l’on se retire pour faire oraison : contrairement à la
            chapelle l’oratoire n’a pas d’autel consacré. Il peut aussi consister en une peinture ou une sculpture placée dans une niche, sous un dais
            ou sur un support spécifique ». (Source : Thésaurus de la désignation des œuvres architecturales et des espaces
            aménagés.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d5bknx6p64--8gwd05y7ujsi">
            <rico:name xml:lang="fr">Oratoire du Louvre</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-119"/>
      <skos:exactMatch rdf:resource="http://vocab.getty.edu/aat/300007459"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb126524363"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Oratoire_%28%C3%A9difice_religieux%29"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/ouvrage%20li%C3%A9%20%C3%A0%20l%E2%80%99alimentation%20en%20eau">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">ouvrage lié à l’alimentation en eau</skos:prefLabel>
      <rdfs:label xml:lang="fr">ouvrage lié à l’alimentation en eau</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:narrower rdf:resource="placeType/fontaine"/>
      <skos:narrower rdf:resource="placeType/pompe%20%C3%A0%20eau"/>
      <skos:definition xml:lang="fr">Un « aménagement ou mobilier permettant de recueillir ou de faire circuler l’eau ». (Source : Thésaurus de la
            désignation des objets mobiliers.)</skos:definition>
      <skos:related rdf:resource="placeType/%C3%A9l%C3%A9ment%20d%E2%80%99hydrographie"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T69-500"/>
      <skos:closeMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb119421860"/>
      <skos:closeMatch rdf:resource="http://fr.dbpedia.org/resource/Adduction_d’eau"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/palais">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">palais</skos:prefLabel>
      <rdfs:label xml:lang="fr">palais</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">« Un palais peut être : le lieu de résidence urbaine d’un personnage important, vivant un train de vie princier
            ou fastueux ; le siège d’une institution publique, dans lequel se déroule l’exercice du pouvoir. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzumefyi-l5d82y9cbl8v">
            <rico:name xml:lang="fr">Orsay, palais d’ (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-523"/>
      <skos:exactMatch rdf:resource="http://vocab.getty.edu/aat/300005734"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11937594q"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Palais"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/parc">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">parc</skos:prefLabel>
      <rdfs:label xml:lang="fr">parc</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/jardin"/>
      <skos:definition xml:lang="fr">Un parc est un « jardin clos de grande superficie, public ou privé, en général d’agrément, présentant un
            important couvert. On nomme parc ouvert celui dont les limites ne sont pas closes ». (Source : Thésaurus de la désignation des œuvres
            architecturales et des espaces aménagés.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzult7l1--eq5dswmvk0y8">
            <rico:name xml:lang="fr">Montsouris, parc (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-1134"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11933025j"/>
      <skos:exactMatch rdf:resource="http://vocab.getty.edu/aat/300254248"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Parc"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/parc%20industriel">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">parc industriel</skos:prefLabel>
      <rdfs:label xml:lang="fr">parc industriel</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">« Un parc industriel, aussi appelé zone industrielle ou site industriel, est une zone d’activité prévue pour un
            usage industriel, situé à l'extérieur ou en périphérie d’une agglomération, réservé aux activités industrielles et regroupant différentes
            entreprises. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-1g85e4q88--1dt4ywffcrc53">
            <rico:name xml:lang="fr">Bataville (Moussey ; parc industriel)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q1662100"/>
      <skos:closeMatch rdf:resource="http://data.ign.fr/id/codes/topo/typedezai/ZoneIndustrielle"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : définition, exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/paroisse">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">paroisse</skos:prefLabel>
      <rdfs:label xml:lang="fr">paroisse</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20humaine"/>
      <skos:narrower rdf:resource="placeType/paroisse%20de%20Paris%20avant%201789"/>
      <skos:definition xml:lang="fr">La paroisse est le territoire de la subdivision de base, dans le christianisme, d’un diocèse de l’Église. La
            paroisse occupe un rôle essentiel dans la vie religieuse, elle est le lieu de culte, de célébration pour les croyants. (D’après
            Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_024-d3nyvp4aef--lj9z4juc8apm">
            <rico:name xml:lang="fr">La Madeleine (Paris, France ; paroisse)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q102496"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11941179g"/>
      <skos:closeMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-96"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, exemple(s),
                    relation(s) sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/paroisse%20de%20Paris%20avant%201789">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">paroisse de Paris avant 1789</skos:prefLabel>
      <rdfs:label xml:lang="fr">paroisse de Paris avant 1789</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/paroisse"/>
      <skos:definition xml:lang="fr">Les paroisses de Paris, à la fin de l’Ancien Régime, couvrent la zone urbaine du territoire du diocèse de Paris
            selon les déclarations de patrimoine établies par leurs curés en 1790 et les relevés des prestations de serment de leurs prêtres à la
            Constitution civile du clergé les 9 et 16 janvier 1791. Cette organisation est sensiblement modifiée au début de 1791. (D’après
            Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_024-d3nyvosba5--16qzzcu3058e5">
            <rico:name xml:lang="fr">Saint-André-des-Arts (Paris, France ; paroisse)</rico:name>
         </rico:Place>
      </skos:example>
      <rdfs:seeAlso rdf:resource="http://www.wikidata.org/entity/Q55598931"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/parvis">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">parvis</skos:prefLabel>
      <rdfs:label xml:lang="fr">parvis</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/place"/>
      <skos:definition xml:lang="fr">« Un parvis est l’espace ouvert devant l’entrée d’une église dont le périmètre est délimité par une clôture. »
            (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nzcry5js-1ev7geaq4hery">
            <rico:name xml:lang="fr">parvis de la Raison (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q283977"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-55"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Parvis"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb123491994"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/passage">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">passage</skos:prefLabel>
      <rdfs:label xml:lang="fr">passage</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/voie"/>
      <skos:definition xml:lang="fr">« Un passage est, en construction-architecture, urbanisme et voirie, une voie qui sert de passage entre deux
            rues ou entre deux bâtiments ». (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nz8dagul-1ve20yu7gwa5g">
            <rico:name xml:lang="fr">passage Abel Leblanc (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q13634881"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-69"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Passage_(voie)"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/passerelle">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">passerelle</skos:prefLabel>
      <rdfs:label xml:lang="fr">passerelle</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/pont"/>
      <skos:definition xml:lang="fr">« Une passerelle est, dans le domaine de l’architecture, un pont ou un passage aérien, à l’usage exclusif des
            piétons voire des cyclistes, pouvant par exemple relier deux bâtiments entre eux, enjamber un cours d’eau ou une voie navigable, un axe de
            circulation routière ou ferroviaire, etc. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nz9n2kb4-18f8webqcwbdx">
            <rico:name xml:lang="fr">passerelle de Constantine (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q1068842"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-1098"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb13177898n"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Passerelle_(architecture)"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/pavillon">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">pavillon</skos:prefLabel>
      <rdfs:label xml:lang="fr">pavillon</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Un pavillon est un « bâtiment ou corps de bâtiment caractérisé par un plan sensiblement carré. Un pavillon peut
            être isolé, hors-œuvre, demi-hors-œuvre, dans-œuvre, sur l’angle, dans l’angle ». (Source : Thésaurus de la désignation des œuvres
            architecturales et des espaces aménagés.)</skos:definition>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-1328"/>
      <skos:exactMatch rdf:resource="http://vocab.getty.edu/aat/300002660"/>
      <skos:closeMatch rdf:resource="http://fr.dbpedia.org/resource/Pavillon_%28architecture%29"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/pays">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">pays</skos:prefLabel>
      <rdfs:label xml:lang="fr">pays</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20humaine"/>
      <skos:definition xml:lang="fr">« Un pays est un territoire constituant une entité géographique et humaine qui peut être souveraine, autonome
            en association avec une autre entité souveraine pour sa part, ou bien indépendante de fait mais non reconnue de droit (par le droit
            international et l’ONU). » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d3ntxku8g8--8c7e9zxf15do">
            <rico:name xml:lang="fr">Italie</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q6256"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T1-1372"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, exemple(s),
                    relation(s) sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/p%C3%A9ninsule">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">péninsule</skos:prefLabel>
      <rdfs:label xml:lang="fr">péninsule</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
      <skos:definition xml:lang="fr">« Une péninsule (du latin paeninsula, paene signifiant « presque » et insula « île ») est une partie de terres
            émergées rattachée à une masse continentale par un de ses côtés. Elle se distingue d'une presqu’île par sa taille supérieure, ou par
            l’absence d’isthme. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-1fsq9iyb8-8l3pongtlqv7">
            <rico:name xml:lang="fr">péninsule de Gallipoli (Turquie)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q1061151"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-04-18</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/p%C3%A9pini%C3%A8re">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">pépinière</skos:prefLabel>
      <rdfs:label xml:lang="fr">pépinière</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">« En agriculture, sylviculture, arboriculture ou horticulture, une pépinière est un champ ou une parcelle de
            terre réservée à la multiplication des plantes ligneuses principalement (arbres, arbustes) mais aussi de plantes vivaces, et à leur
            culture jusqu’à ce qu’elles atteignent le stade où elles peuvent être transplantées ou commercialisées. » (Source :
            Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3m0cugrzh6-r3zowig8uyxo">
            <rico:name xml:lang="fr">Roi, pépinière du (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/p%C3%A9ristyle">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">péristyle</skos:prefLabel>
      <rdfs:label xml:lang="fr">péristyle</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Un péristyle est une « colonnade à plusieurs retours, sur le périmètre complet ou presque complet d’un
            bâtiment, d’une cour, d’une place, etc. Elle peut être interne ou externe ». (Source : Thésaurus de la désignation des œuvres
            architecturales et des espaces aménagés.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nz8s8vj1-in2j4erankss">
            <rico:name xml:lang="fr">péristyle de Beaujolais (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q725453"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-1255"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb133252217"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/phare">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">phare</skos:prefLabel>
      <rdfs:label xml:lang="fr">phare</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Un phare est un « ouvrage, généralement en forme de tour, construit sur un point de la côte, à l’extrémité
            d’une jetée ou sur une île, et portant un signal lumineux de forte intensité servant à guider les navires ». (Source : Thésaurus de la
            désignation des œuvres architecturales et des espaces aménagés.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-6l8o47280--dx1zhzxfh9om">
            <rico:name xml:lang="fr">phare des Baleines (Saint-Clément-des-Baleines, Charente-Maritime, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q39715"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-1039"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb119330900"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Phare"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : définition, exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/pic">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">pic</skos:prefLabel>
      <rdfs:label xml:lang="fr">pic</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
      <skos:definition xml:lang="fr">Un pic est un sommet montagneux pointu. (D’après Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-1g86cbsqw--1kutj8qyj7hcl">
            <rico:name xml:lang="fr">Grand pic de Belledonne (Isère, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.ign.fr/id/codes/topo/typederelief/Pic"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition,
                    exemple(s)</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/pilier">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">pilier</skos:prefLabel>
      <rdfs:label xml:lang="fr">pilier</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Un pilier est un élément architectural vertical, de plan généralement massif (carré, cylindrique, polygonal),
            servant de support à une construction (d’après Wikipédia). Par extension, le terme peut désigner des arcades ou galeries
            marchandes.</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3m0cugoiot--148vdz9oo8tir">
            <rico:name xml:lang="fr">Tonnellerie, piliers de la (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/pilori">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">pilori</skos:prefLabel>
      <rdfs:label xml:lang="fr">pilori</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">« Un pilori est un poteau ou un dispositif vertical auquel un condamné est attaché temporairement, à l’aide de
            cordes ou d’un carcan, pour être vu et raillé par la foule. Les formes de ce support d’exposition varient, depuis le poteau en bois
            initialement élevé sur la place du marché ou le pan de mur, jusqu’à l’intégration progressive du carcan puis la transformation du poteau
            en pilori charpenté, en pilier de pierre ou en tour maçonnée. Les piloris présentent, malgré leur diversité, une caractéristique commune,
            celle de leur implantation dans un lieu public (place, carrefour, pont, porte de la ville) ancré dans le paysage urbain, choisi pour
            maximiser la publicité de ce supplice. » (Source : Wikipédia.) Par extension, le terme en est venu à désigner non plus seulement
            l’instrument, mais aussi l’endroit lui-même, devenu un lieu identifié dans la ville.</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzujck84-gbxmftxf2o7n">
            <rico:name xml:lang="fr">Halles, pilori des (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-251"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb12173120p"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Pilori"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/place">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">place</skos:prefLabel>
      <rdfs:label xml:lang="fr">place</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:narrower rdf:resource="placeType/esplanade"/>
      <skos:narrower rdf:resource="placeType/parvis"/>
      <skos:definition xml:lang="fr">« Une place est un espace public non bâti, desservi par des voies de communication ; elle peut être affectée
            aux piétons ou aux véhicules ». (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nz8e4gsw--1c8m8o4k6ocz3">
            <rico:name xml:lang="fr">place Adolphe Chérioux (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q174782"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-51"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Place"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11954989x"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/plage">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">plage</skos:prefLabel>
      <rdfs:label xml:lang="fr">plage</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
      <skos:definition xml:lang="fr">Une plage est « une berge ou un rivage en pente douce ou très douce correspondant à une étendue de sable, de
            gravier ou de galets qui se poursuit sous le niveau de l’eau (définition qui prend en compte les plages maritimes le long des mers et des
            océans, et les plages continentales le long des cours d’eau ou en bordures de plan d’eau) ». (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-5hh2vt4x5--1hnq9xzkcmqwf">
            <rico:name xml:lang="fr">plage de Bréhec (Plouha, Côtes-d’Armor, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q40080"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, exemple(s),
                    relation(s) sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/plateau">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">plateau</skos:prefLabel>
      <rdfs:label xml:lang="fr">plateau</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
      <skos:definition xml:lang="fr">Un plateau est une zone géographique où les cours d’eau sont encaissés, par opposition aux plaines où les cours
            d’eau coulent à fleur de sol. Le relief y est peu marqué, ce qui différencie un plateau d’une montagne. (D’après
            Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-9hudi4z2v-1o9i0wl4y057j">
            <rico:name xml:lang="fr">plateau de Gergovie (Puy-de-Dôme, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition,
                    exemple(s)</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/pompe%20%C3%A0%20eau">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">pompe à eau</skos:prefLabel>
      <rdfs:label xml:lang="fr">pompe à eau</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/ouvrage%20li%C3%A9%20%C3%A0%20l%E2%80%99alimentation%20en%20eau"/>
      <skos:narrower rdf:resource="placeType/pompe%20%C3%A0%20feu"/>
      <skos:definition xml:lang="fr">Une pompe à eau est une machine construite afin de prélever l’eau pour alimenter un ou plusieurs édifices. Par
            extension, le terme désigne le bâtiment qui abrite cette machine. (D’après Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzupif4x--xbjsjbtds6cd">
            <rico:name xml:lang="fr">Samaritaine, pompe à eau de la (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/pompe%20%C3%A0%20feu">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">pompe à feu</skos:prefLabel>
      <rdfs:label xml:lang="fr">pompe à feu</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/pompe%20%C3%A0%20eau"/>
      <skos:definition xml:lang="fr">Une pompe à feu est une pompe actionnée par la vapeur pour l’adduction d’eau. (D’après
            Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3m0cugqcuh-1lqpbi4ccosw2">
            <rico:name xml:lang="fr">Gros Caillou, pompe à feu du (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/pont">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">pont</skos:prefLabel>
      <rdfs:label xml:lang="fr">pont</rdfs:label>
      <skos:altLabel xml:lang="fr">petit pont</skos:altLabel>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:narrower rdf:resource="placeType/passerelle"/>
      <skos:narrower rdf:resource="placeType/pont-canal"/>
      <skos:narrower rdf:resource="placeType/viaduc"/>
      <skos:definition xml:lang="fr">« Un pont est un ouvrage d’art qui permet de franchir un obstacle naturel ou artificiel (dépression, cours
            d’eau, voie de communication, vallée, ravin, canyon) en passant par-dessus. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-8ku2vs00a--1qr65mse1egd1">
            <rico:name xml:lang="fr">pont du Bonhomme (Kervignac, Morbihan, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q12280"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-1097"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11932837h"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Pont"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/pont-canal">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">pont-canal</skos:prefLabel>
      <rdfs:label xml:lang="fr">pont-canal</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/pont"/>
      <skos:definition xml:lang="fr">« Un pont-canal est un pont qui permet à un canal de franchir un obstacle en déblai, une vallée ou un vallon le
            plus souvent. Un autre usage du pont-canal est l’accès par l’amont à un ascenseur à bateaux. Un pont-canal permet le passage de la
            navigation au-dessus d’une rivière (cas le plus fréquent), d’une route (exemple du pont-canal des Herbettes sur le canal du Midi), d’une
            voie ferrée (exemple de l’ascenseur à bateaux des Fontinettes) ou de divers autres obstacles. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-13p814kqj--yf15boemr1ys">
            <rico:name xml:lang="fr">pont-canal du Guétin (Cher, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s)</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/port">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">port</skos:prefLabel>
      <rdfs:label xml:lang="fr">port</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">« Un port est une infrastructure construite par l’homme, située sur le littoral maritime, sur les berges d’un
            lac ou sur un cours d’eau, et destinée à accueillir des bateaux et navires. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-3pjcsy658--1ikovhyytfq5z">
            <rico:name xml:lang="fr">port de Moguériec (Sibiril, Finistère, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q44782"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout d’un exemple.</rdf:value>
            <dc:date>2026-04-18</dc:date>
         </rdf:Description>
      </skos:changeNote>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : définition, relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/porte">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">porte</skos:prefLabel>
      <rdfs:label xml:lang="fr">porte</rdfs:label>
      <skos:altLabel xml:lang="fr">porta</skos:altLabel>
      <skos:altLabel xml:lang="fr">porte de ville</skos:altLabel>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Une porte de ville fait partie des fortifications d’une ville. C’était jusqu’à l’Époque moderne le seul moyen
            de franchir les remparts entourant la ville. (D’après Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nzafpbss--dwzi11aco2uy">
            <rico:name xml:lang="fr">porta Ferri (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q82117"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T69-155"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11948204j"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Porte_(architecture)"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/poterne">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">poterne</skos:prefLabel>
      <rdfs:label xml:lang="fr">poterne</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">« Une poterne est une petite porte qui était intégrée aux murailles d’une fortification, de façon discrète et
            qui permettait aux habitants du château de sortir ou rentrer à l’insu de l’assiégeant. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nz8p2mva--e88x9nq7nz5l">
            <rico:name xml:lang="fr">poterne Barbeau (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:related rdf:resource="placeType/fortification"/>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q23418"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-499"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Poterne"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) d’association avec des concepts du vocabulaire,
                    relation(s) sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/pr%C3%A9au">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">préau</skos:prefLabel>
      <rdfs:label xml:lang="fr">préau</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Un préau est « un espace couvert ou non couvert, situé à l’intérieur de certains édifices tels que des
            hôpitaux, des prisons ou des monastères (préau claustral) généralement utilisé pour la promenade des personnes qui y résident ». (Source :
            Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nza811o2-z8wvq21h3ao">
            <rico:name xml:lang="fr">préau des Eaux de Vie (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:closeMatch rdf:resource="http://www.wikidata.org/entity/Q109041888"/>
      <skos:closeMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-337"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : définition, exemple(s)</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/prieur%C3%A9">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">prieuré</skos:prefLabel>
      <rdfs:label xml:lang="fr">prieuré</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9tablissement%20conventuel"/>
      <skos:definition xml:lang="fr">« Un prieuré est un monastère placé sous l’autorité d’un prieur. Il peut être indépendant ou subordonné à une
            abbaye plus importante, le prieur étant alors lui-même dépendant de l’abbé. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzum20o7--1vq57648zec15">
            <rico:name xml:lang="fr">Notre-Dame, prieuré (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-104"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11978047w"/>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q2750108"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/prison">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">prison</skos:prefLabel>
      <rdfs:label xml:lang="fr">prison</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Une prison est un lieu dédié à l’enfermement de certaines personnes condamnées appelées prisonniers ou détenus.
            (D’après Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzuenl4x--h6vxqs3tklx3">
            <rico:name xml:lang="fr">Abbaye, prison de l’ (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q40357"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-244"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb13318425p"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Prison"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : définition, exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/promenade">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">promenade</skos:prefLabel>
      <rdfs:label xml:lang="fr">promenade</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/voie"/>
      <skos:definition xml:lang="fr">« Une promenade est un lieu (parc, square…) ou une voie sur lesquels on se promène. » (Source :
            Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nz8u05rz--1fks0z4scs186">
            <rico:name xml:lang="fr">promenade Bernard Lafay (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q787113"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-73"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Promenade_(lieu_ou_voie)"/>
      <skos:closeMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb136010225"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/quai">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">quai</skos:prefLabel>
      <rdfs:label xml:lang="fr">quai</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">« Un quai est un dispositif permettant le chargement et le déchargement de passagers et de biens au bord d’une
            étendue d’eau. [...] Les voies de circulation qui longent les voies d’eau, particulièrement en zone urbaine, prennent fréquemment le nom
            de "quai" même en l’absence d’accostage. [...] Le terme de quai est également utilisé dans les chemins de fer ; il provient du monde de la
            marine. Il permet d’embarquer ou de débarquer les voyageurs et les marchandises dans les trains. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nz8hvdkn-1qr5kaaf2b4rp">
            <rico:name xml:lang="fr">quai Anatole France (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q828909"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-1105"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb119494913"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Quai_(voie)"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/quartier">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">quartier</skos:prefLabel>
      <rdfs:label xml:lang="fr">quartier</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20humaine"/>
      <skos:narrower rdf:resource="placeType/faubourg"/>
      <skos:narrower rdf:resource="placeType/quartier%20administratif%20actuel%20de%20Paris"/>
      <skos:narrower rdf:resource="placeType/quartier%20historique%20ou%20administratif%20ancien%20de%20Paris"/>
      <skos:definition xml:lang="fr">Un quartier est une subdivision d’une ville. C'est aussi souvent une échelle d’appropriation d’une partie de la
            ville par ses habitants, donc un ensemble urbain comportant certaines caractéristiques particulières ou une certaine unité. (D’après
            Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_023-d3nyvg6yee--avg1nwx4nj8w">
            <rico:name xml:lang="fr">Hôtel-de-Ville (Paris, France ; quartier)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:related rdf:resource="placeType/villa%20%28voie%29"/>
      <skos:exactMatch rdf:resource="http://data.ign.fr/id/codes/topo/typedezai/Quartier"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-29"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Quartier_(ville)"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, exemple(s),
                    relation(s) d’association avec des concepts du vocabulaire, relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/quartier%20administratif%20actuel%20de%20Paris">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">quartier administratif actuel de Paris</skos:prefLabel>
      <rdfs:label xml:lang="fr">quartier administratif actuel de Paris</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/quartier"/>
      <skos:definition xml:lang="fr">« Les 80 quartiers administratifs constituent le niveau le plus fin de l’administration publique à Paris.
            Chacun contient un poste de police. Chaque arrondissement parisien compte quatre quartiers administratifs. Ces 80 quartiers (historiques,
            encore utilisés au sein de la préfecture de Paris et de populations très différentes) sont distincts à la fois des 116 conseils de
            quartier de Paris (plus équilibrés en population) et des 18 circonscriptions législatives pour l’élection des députés à l’Assemblée
            nationale. » Ces quartiers administratifs ont été mis en place en application du décret impérial du 1er novembre 1859 et d’un arrêté du
            préfet de la Seine du 3 novembre 1859. (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_023-d3nyvgj653-pntrwb37dxqp">
            <rico:name xml:lang="fr">Palais-Royal (Paris, France ; quartier)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/quartier%20historique%20ou%20administratif%20ancien%20de%20Paris">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">quartier historique ou administratif ancien de Paris</skos:prefLabel>
      <rdfs:label xml:lang="fr">quartier historique ou administratif ancien de Paris</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/quartier"/>
      <skos:definition xml:lang="fr">Il s’agit des quartiers de Paris avant 1860, date à laquelle sont mis en place les quatre-vingts quartiers
            administratifs actuels de Paris, en application du décret impérial du 1er novembre 1859. Le nombre et les limites de ces quartiers ont
            évolué au fil des siècles, servant tour à tour à l’exercice de la police, de la fiscalité et de la représentation
            municipale.</skos:definition>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/r%C3%A9gion">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">région française</skos:prefLabel>
      <rdfs:label xml:lang="fr">région française</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/unit%C3%A9%20administrative%20fran%C3%A7aise"/>
      <skos:definition xml:lang="fr">En France, une région est une division administrative du territoire et des services déconcentrés de l’État.
            C’est aussi le territoire d’exercice de la collectivité territoriale de même nom. Les régions sont régies par le titre XII de la
            Constitution de 1958 et la quatrième partie du code général des collectivités territoriales. (D’après Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d3ntb5n2ct-ucurm8b2xf66">
            <rico:name xml:lang="fr">région Alsace (France). 1982-2015</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q36784"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, exemple(s),
                    relation(s) sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/r%C3%A9gion%20historique">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">région historique</skos:prefLabel>
      <rdfs:label xml:lang="fr">région historique</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20humaine"/>
      <skos:definition xml:lang="fr">Une région historique est une zone géographique délimitée par l’étendue d’une culture archéologique, d’une
            civilisation historique ou d’un peuplement présentant des traits culturels spécifiques tels que la langue, la cuisine, la musique ou
            l’architecture traditionnelle. Les habitants de cette région, autochtones ou non, peuvent constituer un peuple, une société ou une nation
            identifiable au cours d’une période historique donnée. Les limites d’une telle région peuvent être déterminées par les contraintes de la
            géographie physique ou par des aires historiques de diffusion culturelle. Les contours des régions historiques sont en général sans
            rapport avec les frontières politiques et l’organisation territoriale moderne : la concordance est d’autant plus rare que les
            délimitations passées sont plus anciennes. (D’après Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d3m08zzgaid--1um1a0exl283v">
            <rico:name xml:lang="fr">Silésie (Europe ; région historique)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout d’un exemple.</rdf:value>
            <dc:date>2026-04-18</dc:date>
         </rdf:Description>
      </skos:changeNote>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/r%C3%A9gion%20naturelle">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">région naturelle</skos:prefLabel>
      <rdfs:label xml:lang="fr">région naturelle</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
      <skos:definition xml:lang="fr">« Une région naturelle est une unité géographique de base présentant des similarités géographiques,
            topographiques, géologiques et/ou climatiques. » (Source : Wikipédia.) Cette notion est relativement subjective.</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d3m08yzx14j-itod9uxd5ahy">
            <rico:name xml:lang="fr">Ponthieu (France ; région naturelle)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la dénomination préférentielle (skos:prefLabel). Ajout des données suivantes : définition,
                    exemple(s)</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/rond-point">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">rond-point</skos:prefLabel>
      <rdfs:label xml:lang="fr">rond-point</rdfs:label>
      <skos:altLabel xml:lang="fr">rondpoint</skos:altLabel>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/carrefour"/>
      <skos:definition xml:lang="fr">« Un rond-point, ou rondpoint est une dépendance routière consistant généralement en une place circulaire
            (ronde, ovale ou polygonale) ou demi-circulaire. Un édicule (œuvre d’art, fontaine) est généralement placé en son centre ». (Source :
            Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nz91hzbi-18g0n59nvj0nl">
            <rico:name xml:lang="fr">rond-point Bugeaud (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q1529"/>
      <skos:closeMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-45"/>
      <skos:closeMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb120111663"/>
      <skos:closeMatch rdf:resource="http://fr.dbpedia.org/resource/Carrefour_giratoire"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/route">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">route</skos:prefLabel>
      <rdfs:label xml:lang="fr">route</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/voie"/>
      <skos:definition xml:lang="fr">« Une route est au sens littéral une voie terrestre (au niveau du sol ou sur viaduc) aménagée pour permettre la
            circulation de véhicules à roues. Ce terme s’applique plutôt aux voies importantes situées en rase campagne et ne peut être apparenté à
            une rue. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nz8exsm2-mjkoa4m59n7j">
            <rico:name xml:lang="fr">route Aimable (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q34442"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-74"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11932808x"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Route"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/rue">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">rue</skos:prefLabel>
      <rdfs:label xml:lang="fr">rue</rdfs:label>
      <skos:altLabel xml:lang="fr">grande rue</skos:altLabel>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/voie"/>
      <skos:narrower rdf:resource="placeType/ruelle"/>
      <skos:narrower rdf:resource="placeType/vicus"/>
      <skos:definition xml:lang="fr">Une rue est une « voie de circulation bordée de bâtiments et située dans une agglomération ». (Source :
            Wikidata.) « La rue se distingue des autres voies urbaines (voirie) comme les allées, les cours ou les boulevards et avenues par sa
            relative faible largeur notamment, et par l’absence de contre-allées. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nzcwxu24--1g3t2gfx9dhpf-vdp-13247">
            <rico:name xml:lang="fr">rue de Rivoli (1er-4e arrondissements, Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q79007"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-75"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11975928c"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Rue"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout d’un exemple.</rdf:value>
            <dc:date>2026-04-18</dc:date>
         </rdf:Description>
      </skos:changeNote>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : définition, relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/ruelle">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">ruelle</skos:prefLabel>
      <rdfs:label xml:lang="fr">ruelle</rdfs:label>
      <skos:altLabel xml:lang="fr">petite rue</skos:altLabel>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/rue"/>
      <skos:definition xml:lang="fr">« Une ruelle est une petite rue entre plusieurs bâtiments, souvent accessible uniquement pour les piétons. »
            (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nzcspgps-a1mcaanofngh">
            <rico:name xml:lang="fr">ruelle Raoul (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q1251403"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s)</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/sanctuaire">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">sanctuaire</skos:prefLabel>
      <rdfs:label xml:lang="fr">sanctuaire</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9dicule%20religieux"/>
      <skos:definition xml:lang="fr">« En anthropologie religieuse, un sanctuaire (de sanctus, « sacré ») est généralement un édifice ou lieu rendu
            (par « consécration ») ou devenu sacré, par son association au Divin ou Transcendant. Le terme désigne donc un site sacré. » (Source :
            Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-8d3edwuny-2bt9szu7p6k3">
            <rico:name xml:lang="fr">sanctuaire de La Salette (La Salette-Fallavaux, Isère, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:closeMatch rdf:resource="http://www.wikidata.org/entity/Q29553"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : exemple(s), relation(s)
                    sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/s%C3%A9minaire">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">séminaire</skos:prefLabel>
      <rdfs:label xml:lang="fr">séminaire</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/lieu%20d%E2%80%99enseignement"/>
      <skos:definition xml:lang="fr">« Le séminaire est l’institution qui forme les ministres (prêtres ou pasteurs) dans le christianisme. Les
            institutions évangéliques utilisent également l’expression institut de théologie évangélique. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzukeech-1q9m78wstobkf">
            <rico:name xml:lang="fr">Lazaristes, séminaire des (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-328"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb119687975"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/sentier">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">sentier</skos:prefLabel>
      <rdfs:label xml:lang="fr">sentier</rdfs:label>
      <skos:altLabel xml:lang="fr">sente</skos:altLabel>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/voie"/>
      <skos:definition xml:lang="fr">Un sentier est « une voie de communication étroite, moins large qu’un chemin et inaccessible aux véhicules à la
            différence de ces derniers ». (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nz8vb3rh--1u7moszjzc9l7">
            <rico:name xml:lang="fr">sente à Bigot (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q628179"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-76"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb13162947m"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Sentier"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/sentier%20de%20traverse">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">sentier de traverse</skos:prefLabel>
      <rdfs:label xml:lang="fr">sentier de traverse</rdfs:label>
      <skos:altLabel xml:lang="fr">chemin de traverse</skos:altLabel>
      <skos:altLabel xml:lang="fr">traverse</skos:altLabel>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/chemin"/>
      <skos:definition xml:lang="fr">« Un chemin de traverse ou traverse est une voie qui permet un raccourci. » (Source :
            Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nzcqwhoh--up7269rwe8kl">
            <rico:name xml:lang="fr">sentier de traverse de la Py (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q16538937"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s)</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/site%20nucl%C3%A9aire">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">site nucléaire</skos:prefLabel>
      <rdfs:label xml:lang="fr">site nucléaire</rdfs:label>
      <skos:altLabel xml:lang="fr">installation nucléaire</skos:altLabel>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Une installation nucléaire est définie par la Convention de Paris sur la responsabilité civile dans le domaine
            de l’énergie nucléaire comme « les réacteurs à l’exception de ceux qui font partie d’un moyen de transport (exemple : sous-marin
            nucléaire, porte-avions nucléaire, etc.) ; les usines de préparation ou de fabrication de substances nucléaires ; les usines de séparation
            des isotopes de combustibles nucléaires ; les usines de traitement de combustibles nucléaires irradiés ; les installations de stockage de
            substances nucléaires à l’exclusion du stockage de ces substances en cours de transport, ainsi que toute autre installation dans laquelle
            des combustibles nucléaires ou des produits ou des déchets radioactifs sont détenus et qui serait désignée par le comité de direction de
            l’Énergie nucléaire de l’organisation [...]. Toute partie contractante peut décider que seront considérées comme une installation
            nucléaire unique, plusieurs installations nucléaires ayant le même exploitant et se trouvant sur le même site, ainsi que toute autre
            installation sur ce site où sont détenues des matières radioactives ». (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-1g85e5f5g--16p9mmx096etu">
            <rico:name xml:lang="fr">site nucléaire de Marcoule (Gard, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:closeMatch rdf:resource="http://www.wikidata.org/entity/Q134447"/>
      <skos:closeMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-681"/>
      <skos:closeMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11937705t"/>
      <skos:exactMatch rdf:resource="https://rdf.archives-nationales.culture.gouv.fr/thing/FRAN_RI_004-d3ndf9vja9-1b83649uqtt76"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : définition, exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/sommet">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">sommet</skos:prefLabel>
      <rdfs:label xml:lang="fr">sommet</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
      <skos:definition xml:lang="fr">Un sommet est un point haut du relief non caractérisé par un profil abrupt (source : vocabulaire
            IGN).</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-5sryr6hag-yq17l6dcjyy8">
            <rico:name xml:lang="fr">mont Aigoual (Gard / Lozère, France ; sommet)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.ign.fr/id/codes/topo/typederelief/Sommet"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition,
                    exemple(s)</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/square">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">square</skos:prefLabel>
      <rdfs:label xml:lang="fr">square</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">« Un square est généralement une petite place urbaine occupée par un jardin public. [...] Cependant, le terme
            de square peut également aussi bien désigner un jardin public clôturé, même si celui-ci n’est pas inséré au sein d’une place publique (par
            exemple, le square Jean-XXIII ou le square du Vert-Galant sur l’île de la Cité à Paris), qu’une petite place arborée. » (Source :
            Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nzak9bz2--fhax7x0tnx7w">
            <rico:name xml:lang="fr">square Gabriel Fauré (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q2026833"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-1121"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Square_(lieu)"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/station%20baln%C3%A9aire">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">station balnéaire</skos:prefLabel>
      <rdfs:label xml:lang="fr">station balnéaire</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">« Une station balnéaire est un lieu de séjour situé en bord de mer ou tout autre endroit présentant des bains
            et aménagé pour l’accueil des vacanciers. Une station balnéaire peut être une ville littorale aménagée ou un site créé ex nihilo. »
            (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-1g85e4llk-1it62r57i7uhi">
            <rico:name xml:lang="fr">station balnéaire de Hardelot-Plage (Neufchâtel-Hardelot, Pas-de-Calais, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-12"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb120119638"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Station_baln%C3%A9aire"/>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q1021711"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : définition, exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/station%20de%20ski">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">station de ski</skos:prefLabel>
      <rdfs:label xml:lang="fr">station de ski</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Une station de ski est une « station touristique aménagée pour la pratique du ski et des autres activités
            sportives et ludiques liées à la neige ». (Source : Wiktionnaire.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-6s87l9frb--9x70hdnpi91k">
            <rico:name xml:lang="fr">station de ski de Gourette (Eaux-Bonnes, Pyrénées-Atlantiques, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:closeMatch rdf:resource="http://www.wikidata.org/entity/Q130003"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : définition, exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/statue">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">statue</skos:prefLabel>
      <rdfs:label xml:lang="fr">statue</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Une statue est un monument en trois dimensions, généralement sculpté ou moulé, représentant une figure humaine,
            animale ou symbolique. Placée dans l’espace public (place, jardin, carrefour, devant un bâtiment, etc.), elle sert de point de repère et
            contribue à désigner ou caractériser un lieu. (D’après Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3m0cufyk62--vk86yle4mg1d">
            <rico:name xml:lang="fr">Henri IV, statue (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T69-4837"/>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q179700"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb119333152"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Statue"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/temple">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">temple</skos:prefLabel>
      <rdfs:label xml:lang="fr">temple</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9glise"/>
      <skos:definition xml:lang="fr">Un temple est une église du culte réformé. (Source : Thésaurus de la désignation des œuvres architecturales et
            des espaces aménagés.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzufnqgw-g95khusazxd1">
            <rico:name xml:lang="fr">Billettes, temple des (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-97"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11982410d"/>
      <skos:relatedMatch rdf:resource="http://vocab.getty.edu/aat/300073735"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Temple"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/terrasse">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">terrasse</skos:prefLabel>
      <rdfs:label xml:lang="fr">terrasse</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">« Une terrasse est un espace de vie extérieur, prolongement à ciel ouvert d’une maison (ou immeuble,
            appartement, bâtiment, bar, restaurant, jardin public...), généralement aménagé au rez-de-chaussée (ou sur un toit-terrasse), avec
            revêtement de sol, mobilier de jardin, plantes ornementales, et délimitation par une balustrade. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nz96h6ss-1joftlf5cbn3t">
            <rico:name xml:lang="fr">terrasse de Champagne (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q641406"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s)</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/territoire%20ou%20ville%20%C3%A9tranger">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">territoire ou ville étranger</skos:prefLabel>
      <rdfs:label xml:lang="fr">territoire ou ville étranger</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20humaine"/>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d3m08zpxah1-190bwee41vjy9">
            <rico:name xml:lang="fr">Aarau (Suisse)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : exemple(s)</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/territoire%20d%E2%80%99outre-mer">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">territoire d’outre-mer</skos:prefLabel>
      <rdfs:label xml:lang="fr">territoire d’outre-mer</rdfs:label>
      <skos:altLabel xml:lang="fr">TOM</skos:altLabel>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/unit%C3%A9%20administrative%20fran%C3%A7aise"/>
      <skos:scopeNote xml:lang="fr">« Un territoire d’outre-mer, ou TOM, est un type de collectivité française d’outre-mer créé en 1946 avec l’Union
            française, en remplacement du statut de colonie. En 1958, la plupart des territoires d’outre-mer deviennent des États membres de la
            Communauté française avant de devenir indépendants au moment de la décolonisation de l’Afrique. Le statut de territoire d’outre-mer
            perdure toutefois jusqu’en 2003 où les TOM restants (Mayotte, Polynésie française, Saint-Pierre-et-Miquelon et Wallis-et-Futuna)
            deviennent des collectivités d’outre-mer (hors Mayotte qui est un département d’outre-mer). Seules les Terres australes et antarctiques
            françaises (TAAF), qui n’ont pas de population permanente, sont encore considérées comme un territoire d’outre-mer. » (Source :
            Wikipédia.) </skos:scopeNote>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d3ntb8wf3t--3sy7nuiy6lqb">
            <rico:name xml:lang="fr">Terres australes et antarctiques françaises</rico:name>
         </rico:Place>
      </skos:example>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté</rdf:value>
            <dc:date>2026-04-19</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/th%C3%A9%C3%A2tre">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">théâtre</skos:prefLabel>
      <rdfs:label xml:lang="fr">théâtre</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Un théâtre est un édifice destiné aux représentations dramatiques. (Source : Thésaurus de la désignation des
            œuvres architecturales et des espaces aménagés.)</skos:definition>
      <skos:scopeNote xml:lang="fr">Ne pas confondre avec théâtre de jardin, ni avec théâtre de verdure.</skos:scopeNote>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzugz82l-bkr4d3tgwnb9">
            <rico:name xml:lang="fr">Châtelet, théâtre du (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-419"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11938054b"/>
      <skos:exactMatch rdf:resource="http://vocab.getty.edu/aat/300007117"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Th%C3%A9%C3%A2tre_%28%C3%A9difice%29"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/tour">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">tour</skos:prefLabel>
      <rdfs:label xml:lang="fr">tour</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">« Une tour est un édifice plus haut que large et dont la base est au sol (à ne pas confondre avec une
            échauguette). » (Source : Wikipédia.) Par extension, le terme désigne également une construction monumentale isolée, souvent à caractère
            défensif, religieux ou commémoratif.</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzuidegl-52cdx9jw84og">
            <rico:name xml:lang="fr">tour Eiffel</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q12518"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-1355"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11965217k"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Tour_(%C3%A9difice)"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/tunnel">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">tunnel</skos:prefLabel>
      <rdfs:label xml:lang="fr">tunnel</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Un tunnel est un « ouvrage de franchissement souterrain par une voie de communication d’un obstacle naturel
            (montagne, cours d’eau, bras de mer, etc.). » (Source : Thésaurus de la désignation des œuvres architecturales et des espaces
            aménagés.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d5bdpmiwrw--xvut4oms1wm6">
            <rico:name xml:lang="fr">tunnel du Mont-Blanc (France / Italie)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-1114"/>
      <skos:exactMatch rdf:resource="http://data.bnf.fr/ark:/12148/cb119754118"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Tunnel"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-04-12</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/unit%C3%A9%20administrative%20fran%C3%A7aise">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">unité administrative française</skos:prefLabel>
      <rdfs:label xml:lang="fr">unité administrative française</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20humaine"/>
      <skos:narrower rdf:resource="placeType/ancien%20d%C3%A9partement"/>
      <skos:narrower rdf:resource="placeType/ancienne%20commune"/>
      <skos:narrower rdf:resource="placeType/arrondissement"/>
      <skos:narrower rdf:resource="placeType/arrondissement%20municipal"/>
      <skos:narrower rdf:resource="placeType/canton"/>
      <skos:narrower rdf:resource="placeType/collectivit%C3%A9%20%C3%A0%20statut%20particulier"/>
      <skos:narrower rdf:resource="placeType/collectivit%C3%A9%20d%E2%80%99outre-mer"/>
      <skos:narrower rdf:resource="placeType/commune"/>
      <skos:narrower rdf:resource="placeType/d%C3%A9partement"/>
      <skos:narrower rdf:resource="placeType/r%C3%A9gion"/>
      <skos:narrower rdf:resource="placeType/territoire%20d%E2%80%99outre-mer"/>
      <skos:definition xml:lang="fr">Une unité administrative française est un objet géographique résultant du découpage administratif du territoire
            français. (Source : Ontologie des unités administratives de l’IGN, Release 2021-02-18.)</skos:definition>
      <skos:related rdf:resource="placeType/ville%20nouvelle"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/vall%C3%A9e">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">vallée</skos:prefLabel>
      <rdfs:label xml:lang="fr">vallée</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
      <skos:definition xml:lang="fr">« Une vallée est une dépression géographique généralement de forme allongée et façonnée dans le relief par un
            cours d’eau (vallée fluviale) ou un glacier (vallée glaciaire). » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-1g86cbqic--1kha1vdq64i9a">
            <rico:name xml:lang="fr">vallée de l’Arve (Haute-Savoie, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:closeMatch rdf:resource="http://data.ign.fr/id/codes/topo/typederelief/Vallee"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition,
                    exemple(s)</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/viaduc">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">viaduc</skos:prefLabel>
      <rdfs:label xml:lang="fr">viaduc</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/pont"/>
      <skos:definition xml:lang="fr">« Un viaduc est un ouvrage d’art, routier ou ferroviaire, passant au-dessus d’une rivière, un bras de mer ou
            tout autre obstacle et qui présente une hauteur ou une longueur, parfois les deux, plus grande que celle qu’exigerait la seule traversée
            de la rivière ou de la voie à franchir. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-1gtuyrhgb-pam7ci9xv7ei">
            <rico:name xml:lang="fr">viaduc de Busseau (Creuse, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:closeMatch rdf:resource="http://www.wikidata.org/entity/Q181348"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : définition, exemple(s)</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/vicus">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">vicus</skos:prefLabel>
      <rdfs:label xml:lang="fr">vicus</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/rue"/>
      <skos:definition xml:lang="fr">Dans la civilisation romaine, le concept de vicus avait plusieurs sens, dont celui de quartier d’une grande
            ville. Par extension, il peut aussi désigner une rue. (D’après Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nz8fef08-1fmg703ywzjlz">
            <rico:name xml:lang="fr">vicus Alberici Carnificis (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:relatedMatch rdf:resource="http://www.wikidata.org/entity/Q763590"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : définition, exemple(s)</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/villa%20%28voie%29">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">villa (voie)</skos:prefLabel>
      <rdfs:label xml:lang="fr">villa (voie)</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/voie"/>
      <skos:definition xml:lang="fr">« Une villa, parfois appelée hameau, désigne à partir du XIXe siècle une voie ou impasse bordée à l’origine par
            des habitations individuelles. [...] Une villa peut également être une forme de quartier privé dans Paris et dans certaines villes
            d’Île-de-France. [...] Contrairement à un domaine privé, la villa est située au cœur d’une grande ville [...]. Elle est généralement
            desservie par une ou plusieurs voies privées dont l’accès est réservé aux riverains et à leurs invités. » (Source :
            Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nzd88d98--1phialk6ov8fe">
            <rico:name xml:lang="fr">villa Sainte-Marie (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:related rdf:resource="placeType/quartier"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition,
                    exemple(s)</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/village">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">village</skos:prefLabel>
      <rdfs:label xml:lang="fr">village</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20humaine"/>
      <skos:definition xml:lang="fr">« Un village est une agglomération rurale caractérisée par un habitat plus ou moins concentré, possédant des
            services de première nécessité et offrant une forme de vie communautaire. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-rffj0jzc--b0x2ejghzvlq">
            <rico:name xml:lang="fr">Bigny (Vallenay, Cher, France ; village)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:closeMatch rdf:resource="http://www.wikidata.org/entity/Q532"/>
      <skos:closeMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-15"/>
      <skos:closeMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11939034z"/>
      <skos:closeMatch rdf:resource="http://fr.dbpedia.org/resource/Village"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : exemple(s), relation(s)
                    sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/ville">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">ville</skos:prefLabel>
      <rdfs:label xml:lang="fr">ville</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20humaine"/>
      <skos:narrower rdf:resource="placeType/ville%20nouvelle"/>
      <skos:definition xml:lang="fr">« Une ville est un lieu qui se caractérise par une forte densité de population et une forte densité de
            bâtiments. La population qui l’habite y organise l’espace en fonction de ses besoins et de ses activités propres, ainsi que de
            l’environnement physique. » (Source : Wikipédia.)</skos:definition>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/ville%20nouvelle">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">ville nouvelle</skos:prefLabel>
      <rdfs:label xml:lang="fr">ville nouvelle</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/ville"/>
      <skos:definition xml:lang="fr">« Une ville nouvelle, ville neuve ou ville planifiée est une ville, ou un ensemble de communes, qui naît
            généralement d’une volonté politique, et qui se construit peu à peu sur un emplacement auparavant peu ou pas habité. » (Source :
            Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-6pq92g7ej-ur2297ejqwh">
            <rico:name xml:lang="fr">Sénart (Ile-de-France, France ; ville nouvelle)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:related rdf:resource="placeType/unit%C3%A9%20administrative%20fran%C3%A7aise"/>
      <skos:closeMatch rdf:resource="http://www.wikidata.org/entity/Q1074523"/>
      <skos:closeMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-17"/>
      <skos:closeMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11963619w"/>
      <skos:closeMatch rdf:resource="http://fr.dbpedia.org/resource/Ville_nouvelle"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : exemple(s), relation(s)
                    d’association avec des concepts du vocabulaire, relation(s) sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/voie">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">voie</skos:prefLabel>
      <rdfs:label xml:lang="fr">voie</rdfs:label>
      <skos:altLabel xml:lang="fr">voie de communication</skos:altLabel>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:narrower rdf:resource="placeType/all%C3%A9e"/>
      <skos:narrower rdf:resource="placeType/autoroute"/>
      <skos:narrower rdf:resource="placeType/avenue"/>
      <skos:narrower rdf:resource="placeType/boulevard"/>
      <skos:narrower rdf:resource="placeType/carrefour"/>
      <skos:narrower rdf:resource="placeType/chauss%C3%A9e"/>
      <skos:narrower rdf:resource="placeType/chemin"/>
      <skos:narrower rdf:resource="placeType/chemin%20vicinal"/>
      <skos:narrower rdf:resource="placeType/cit%C3%A9"/>
      <skos:narrower rdf:resource="placeType/cour"/>
      <skos:narrower rdf:resource="placeType/cours"/>
      <skos:narrower rdf:resource="placeType/impasse"/>
      <skos:narrower rdf:resource="placeType/passage"/>
      <skos:narrower rdf:resource="placeType/promenade"/>
      <skos:narrower rdf:resource="placeType/route"/>
      <skos:narrower rdf:resource="placeType/rue"/>
      <skos:narrower rdf:resource="placeType/sentier"/>
      <skos:narrower rdf:resource="placeType/villa%20%28voie%29"/>
      <skos:definition xml:lang="fr">« Une voie ou voie de communication est un itinéraire aménagé permettant de passer d’un lieu à un autre à pied
            ou en véhicule, par exemple un chemin, une rue ou une voie rapide. Lorsqu’elle est située en ville, on parle de voie urbaine (rue, avenue,
            boulevard, etc.). » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nzb6oqg5--1ilggqgvq5cy2">
            <rico:name xml:lang="fr">voie Georges Pompidou (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q83620"/>
      <skos:closeMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-58"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : exemple(s), relation(s)
                    sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/voirie">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">voirie</skos:prefLabel>
      <rdfs:label xml:lang="fr">voirie</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Une voirie est un « lieu où l’on portait les ordures, les immondices, les vidanges, les fumiers et les débris
            d’animaux. » (Source : Trésor de la Langue Française informatisé). Il y avait à Paris, du Moyen Âge au XIXe siècle, de nombreuses voiries,
            dépotoirs, dépôts publics ou particuliers d’ordures ménagères, d’immondices, de matières fécales humaines et animales et d’animaux morts,
            situés à l’intérieur ou en périphérie immédiate de la ville. (D’après Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nzb9y6fl-1ip4kkxigspoz">
            <rico:name xml:lang="fr">voirie dite des Grésillons (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:closeMatch rdf:resource="http://www.wikidata.org/entity/Q358078"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/volcan">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">volcan</skos:prefLabel>
      <rdfs:label xml:lang="fr">volcan</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
      <skos:definition xml:lang="fr">« Un volcan est une structure géologique qui résulte de la montée d’un magma puis de l’éruption de matériaux
            (gaz et lave) issus de ce magma, à la surface de la croûte terrestre ou d’un autre astre. Il peut être aérien ou sous-marin. » (Source :
            Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-9dm8ta8fg-1s9gx05stzokz">
            <rico:name xml:lang="fr">puy de Côme (Puy-de-Dôme, France ; volcan)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q8072"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, exemple(s),
                    relation(s) sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
</rdf:RDF>
