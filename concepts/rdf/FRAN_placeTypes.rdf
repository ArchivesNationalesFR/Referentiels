      <skos:broader rdf:resource="placeType/construction%20ou%20%C3%A9difice%20%C3%A0%20usage%20religieux"/>
      <skos:narrower rdf:resource="placeType/oratoire"/>
      <skos:narrower rdf:resource="placeType/sanctuaire"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-112"/>
      <skos:definition xml:lang="fr">Un édicule religieux est une « construction autonome non habitable à fonction religieuse ». (Source : Thésaurus
            de la désignation des œuvres architecturales et des espaces aménagés.)</skos:definition>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
