   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/biblioth%C3%A8que">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">bibliothèque</skos:prefLabel>
      <rdfs:label xml:lang="fr">bibliothèque</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Une bibliothèque est un « édifice ou partie d’édifice réservé au rangement, au catalogage et à la consultation
            des livres, des périodiques et autres médias ». (Source : Thésaurus de la désignation des œuvres architecturales et des espaces
            aménagés.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzukr1lw--1ah3pkmq23yov">
            <rico:name xml:lang="fr">Louvre, bibliothèque du (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-356"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb13318325d"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Biblioth%C3%A8que"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/boulevard">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">boulevard</skos:prefLabel>
      <rdfs:label xml:lang="fr">boulevard</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/voie"/>
      <skos:definition xml:lang="fr">« Un boulevard est une voie généralement large (quatre voies de circulation ou plus) avec souvent des allées
            piétonnières sur ses bords. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nzctch40-teyuun8ehowz">
            <rico:name xml:lang="fr">boulevard Raspail (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q54114"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-62"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Boulevard"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/bourg">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">bourg</skos:prefLabel>
      <rdfs:label xml:lang="fr">bourg</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20humaine"/>
      <skos:definition xml:lang="fr">« Un bourg est une agglomération rurale, moins importante que la ville mais plus importante que le village. Il
            tient lieu de centre administratif local (un droit de fortification existait à l’époque médiévale), ce qui le distingue de la simple
            bourgade. C’est aussi au bourg que se tient généralement le marché des villages environnants. On parle de bourg pour désigner une localité
            de taille intermédiaire entre le village et la ville, sans faubourg ou banlieue. Sur le plan administratif, le bourg est généralement au
            cœur d’une commune dont peuvent dépendre des villages et hameaux. Cependant, la fonction et l’importance symbolique, économique ou
            politique du bourg ont pu évoluer au cours des siècles et le terme même a changé de sens. Ainsi, en régions d’habitat dispersé, notamment
            dans les régions bocagères françaises, le terme désigne simplement le chef-lieu de la commune où il arrive que l’on ne trouve guère que
            les quelques bâtiments publics : l’église, la mairie, l’école, un commerce. » (Source : Wikipédia.)</skos:definition>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-6"/>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-98p1lzrv5-1d43i2h6linly">
            <rico:name xml:lang="fr">Ploumanac'h (Perros-Guirrec, Côtes-d'Armor, France ; bourg)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Bourg"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout d’un exemple.</rdf:value>
            <dc:date>2026-04-18</dc:date>
         </rdf:Description>
      </skos:changeNote>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, relation(s)
                    sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/bourse">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">bourse</skos:prefLabel>
      <rdfs:label xml:lang="fr">bourse</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Une bourse, au sens économique et financier, est un marché réglementé qui permet de découvrir et d’afficher le
            prix d’actifs standardisés et d’en faciliter les échanges dans des conditions de sécurité satisfaisante pour l’acheteur et le vendeur. Par
            extension, le terme désigne également le lieu, souvent un bâtiment emblématique, où se tiennent ces transactions et où se rassemblent
            courtiers et opérateurs financiers. (D’après Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzug0yn2-4ekzncd5ea3m">
            <rico:name xml:lang="fr">Commerce, bourse du (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:closeMatch rdf:resource="http://www.wikidata.org/entity/Q10882966"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/boutique">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">boutique</skos:prefLabel>
      <rdfs:label xml:lang="fr">boutique</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9difice%20ou%20local%20commercial"/>
      <skos:definition xml:lang="fr">Une boutique est un « local au rez-de-chaussée d’un édifice, ouvert sur la voie publique, destiné à une
            activité commerciale ». (Source : Thésaurus de la désignation des œuvres architecturales et des espaces aménagés.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3m0cug5jq3-orcuesjyw0ue">
            <rico:name xml:lang="fr">Palais de Justice, boutique (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-650"/>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q1068824"/>
      <skos:closeMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb119766650"/>
      <skos:closeMatch rdf:resource="http://fr.dbpedia.org/resource/Commerce_de_d%C3%A9tail"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/camp%20de%20concentration">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">camp de concentration</skos:prefLabel>
      <rdfs:label xml:lang="fr">camp de concentration</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">« Un camp de concentration est un lieu fermé de grande taille construit pour regrouper et pour détenir une
            population considérée comme ennemie, généralement dans de très mauvaises conditions de vie. Cette population peut se composer d’opposants
            politiques, de ressortissants de pays avec lesquels le pays d’accueil est en état de guerre, de groupes ethniques ou religieux
            spécifiques, de civils d’une zone critique de combats, ou d’autres groupes humains, souvent pendant une guerre. Les personnes sont
            détenues en raison de critères généraux, sans procédure juridique, et non en vertu d’un jugement individuel. » (Source :
            Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d5bdpklq77--1a4rirn4ncm2j">
            <rico:name xml:lang="fr">camp de concentration d’Auschwitz (Pologne)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q152081"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/fr/ark:/12148/cb12647723k"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : définition, relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/camp%20d%E2%80%99internement">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">camp d’internement</skos:prefLabel>
      <rdfs:label xml:lang="fr">camp d’internement</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">« Un camp d’internement français est une appellation générique qui désigne tout à la fois des centres de
            rétention administrative, des camps de réfugiés ou de prisonniers de guerre, créés en France pendant la période s’étalant de la Première
            Guerre mondiale à la guerre d'Algérie. » (Source : Wikipédia.) Par extension, ce terme désigne tout camp de travail ou de
            détention.</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d5bdph5l06--he0a86n97k4g">
            <rico:name xml:lang="fr">camp d'internement de Rivesaltes (Pyrénées-Orientales, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q2935245"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout du concept.</rdf:value>
            <dc:date>2026-04-12</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/camp%20militaire">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">camp militaire</skos:prefLabel>
      <rdfs:label xml:lang="fr">camp militaire</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20b%C3%A2timent%20militaire"/>
      <skos:definition xml:lang="fr">« Un camp militaire est un regroupement de troupes, installé temporairement ou définitivement. Il peut servir à
            former des recrues, ou être utilisé comme lieu de repos. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-1xspc1r54--x16ag8a6jp1d">
            <rico:name xml:lang="fr">camp militaire de La Valbonne (Ain, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q1198413"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/fr/ark:/12148/cb119939854"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, exemple(s),
                    relation(s) sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/canal">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">canal</skos:prefLabel>
      <rdfs:label xml:lang="fr">canal</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Un canal est un « cours d’eau artificiel de section ouverte, navigable ou non. On distingue les canaux qui
            servent à transporter de l’eau (canaux d’alimentation, de drainage, d’irrigation, etc.) et les canaux où l’eau sert à porter des engins de
            transport (canaux de navigation) ». (Source : Thésaurus de la désignation des œuvres architecturales et des espaces
            aménagés.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-b80paf5qn--jkhzg0vzo6nv">
            <rico:name xml:lang="fr">canal de Marseille au Rhône (Bouches-du-Rhône, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:related rdf:resource="placeType/%C3%A9l%C3%A9ment%20d%E2%80%99hydrographie"/>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q12284"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-1007"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11937681n"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Canal_(voie_d’eau)"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : définition, exemple(s), relation(s) d’association avec des concepts du
                    vocabulaire, relation(s) sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Modification de l’exemple.</rdf:value>
            <dc:date>2026-04-13</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/canton">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">canton français</skos:prefLabel>
      <rdfs:label xml:lang="fr">canton français</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/unit%C3%A9%20administrative%20fran%C3%A7aise"/>
      <skos:definition xml:lang="fr">« Un canton en France est la circonscription d’élection des conseillers départementaux, membres du conseil
            départemental. » (Source : Wikipédia.)</skos:definition>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/cap">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">cap</skos:prefLabel>
      <rdfs:label xml:lang="fr">cap</rdfs:label>
      <skos:altLabel xml:lang="fr">pointe</skos:altLabel>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
      <skos:definition xml:lang="fr">« Un cap ou une pointe est une avancée des terres dans une étendue d’eau et constituant une proéminence du
            littoral. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-69765uo6u--1uc8lcnzjzk7x">
            <rico:name xml:lang="fr">cap Janet (Marseille, Bouches-du-Rhône, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q185113"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout d’un libellé alternatif.</rdf:value>
            <dc:date>2026-04-18</dc:date>
         </rdf:Description>
      </skos:changeNote>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, exemple(s),
                    relation(s) sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/carrefour">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">carrefour</skos:prefLabel>
      <rdfs:label xml:lang="fr">carrefour</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/voie"/>
      <skos:narrower rdf:resource="placeType/rond-point"/>
      <skos:definition xml:lang="fr">Un carrefour routier est « une zone comprise à l’intérieur du prolongement des bordures (ou des rives) de deux
            chaussées qui se coupent à angle droit, ou presque droit. Plus généralement, il s’agit de la zone dans laquelle des véhicules circulant
            sur des routes qui se coupent à un angle quelconque peuvent se rencontrer ». (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nzdm911i--1skkim6l7usg2">
            <rico:name xml:lang="fr">carrefour aux Vaches (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q285783"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-44"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Carrefour"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/caserne">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">caserne</skos:prefLabel>
      <rdfs:label xml:lang="fr">caserne</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20b%C3%A2timent%20militaire"/>
      <skos:definition xml:lang="fr">Une caserne est une « construction destinée au logement des troupes. La caserne est un édifice isolé ou un
            bâtiment compris dans un ouvrage de fortification : dans ce dernier cas, elle est souvent casematée ». (Source : Thésaurus de la
            désignation des œuvres architecturales et des espaces aménagés.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzuf1vgm-1bevd7p41d98w">
            <rico:name xml:lang="fr">Assomption, caserne de l’ (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-459"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11948010x"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Caserne"/>
      <skos:closeMatch rdf:resource="http://www.wikidata.org/entity/Q131263"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/cath%C3%A9drale">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">cathédrale</skos:prefLabel>
      <rdfs:label xml:lang="fr">cathédrale</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9glise"/>
      <skos:definition xml:lang="fr">Une cathédrale est une « église principale d’un diocèse, siège de l’évêque, desservie autrefois par un chapitre
            de chanoines ». (Source : Thésaurus de la désignation des œuvres architecturales et des espaces aménagés.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzum12ec-kyzlpjuajk5l">
            <rico:name xml:lang="fr">Notre-Dame, cathédrale (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q2977"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-92"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb119360734"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Cath%C3%A9drale"/>
      <skos:relatedMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-90"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/cha%C3%AEne%20de%20montagnes">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">chaîne de montagnes</skos:prefLabel>
      <rdfs:label xml:lang="fr">chaîne de montagnes</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
      <skos:definition xml:lang="fr">Une chaîne de montagnes est un relief d'altitude qui s'étend sur une longueur variable, allant de quelques
            centaines à quelques milliers de kilomètres, et dont la largeur est nettement inférieure. (D’après Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d5bdozn61d-1xdljp3kxz3gh">
            <rico:name xml:lang="fr">Pyrénées (Europe ; chaîne de montagnes)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q46831"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-04-18</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/chapelle">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">chapelle</skos:prefLabel>
      <rdfs:label xml:lang="fr">chapelle</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9glise"/>
      <skos:definition xml:lang="fr">Une chapelle est une « petite église isolée sans fonction paroissiale ». (Source : Thésaurus de la désignation
            des œuvres architecturales et des espaces aménagés.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3m0cugd4o8-14qerj9vdcabu">
            <rico:name xml:lang="fr">Notre-Dame-de-l’Assomption, chapelle (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q108325"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-93"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb119822058"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Chapelle"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/ch%C3%A2teau">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">château</skos:prefLabel>
      <rdfs:label xml:lang="fr">château</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9difice%20%C3%A0%20usage%20d%E2%80%99habitation"/>
      <skos:definition xml:lang="fr">Au Moyen Âge, un château est une demeure seigneuriale ou royale, en général fortifiée et défendue par des
            douves. Par la suite, c’est une demeure de grandes dimensions liée à une vaste propriété et comprenant généralement parc, domaine
            forestier et dépendances, ainsi qu’une ferme située à l’écart. (D’après le Thésaurus de la désignation des œuvres architecturales et des
            espaces aménagés.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d3m08zziwsl--175iirbdy6jko">
            <rico:name xml:lang="fr">château d’Amboise (Indre-et-Loire, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-516"/>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q751876"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb119311647"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Château"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, exemple(s),
                    relation(s) sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/chauss%C3%A9e">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">chaussée</skos:prefLabel>
      <rdfs:label xml:lang="fr">chaussée</rdfs:label>
      <skos:altLabel xml:lang="fr">chauciée</skos:altLabel>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/voie"/>
      <skos:definition xml:lang="fr">La chaussée est la partie médiane d’une voie de communication affectée à la circulation des véhicules, par
            contraste avec les trottoirs et bermes réservés aux piétons. Le mot fait référence aux routes médiévales importantes qui étaient
            recouvertes de cailloux et de pierres liés à la chaux. (D’après Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nz8j6a1u-1gsfpxp6r6n1c">
            <rico:name xml:lang="fr">chaussée d’Antin (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q1645474"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-65"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb12526922z"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Chauss%C3%A9e"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/chemin">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">chemin</skos:prefLabel>
      <rdfs:label xml:lang="fr">chemin</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/voie"/>
      <skos:narrower rdf:resource="placeType/sentier%20de%20traverse"/>
      <skos:definition xml:lang="fr">« Un chemin est une voie, un passage destiné à la circulation humaine ou animale. Il peut être revêtu d’une
            chaussée ou directement tracé sur le sol. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nzcofx4h-1vv57ohib63aw">
            <rico:name xml:lang="fr">chemin allant à la Porte Saint-Michel (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q5004679"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-66"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Chemin"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/chemin%20de%20ronde">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">chemin de ronde</skos:prefLabel>
      <rdfs:label xml:lang="fr">chemin de ronde</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">« Un chemin de ronde est un élément d’architecture destiné à la circulation des sentinelles, consistant en une
            voie en position sommitale, en saillie d’une muraille, d’une courtine ou de tours d’une fortification. » (Source :
            Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nz8mqoq3--1vayiz9208w64/">
            <rico:name xml:lang="fr">chemin de ronde d’Aunay (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:related rdf:resource="placeType/fortification"/>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q299232"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) d’association avec des concepts du
                    vocabulaire</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/chemin%20vicinal">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">chemin vicinal</skos:prefLabel>
      <rdfs:label xml:lang="fr">chemin vicinal</rdfs:label>
      <skos:altLabel xml:lang="fr">voie communale</skos:altLabel>
      <skos:altLabel xml:lang="fr">route vicinale</skos:altLabel>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/voie"/>
      <skos:definition xml:lang="fr">Le terme route vicinale ou chemin vicinal est un « terme ancien datant de la révolution qui désigne la notion
            d’une route de faible importance reliant le voisinage ». (Source : https://www.securite-routiere-az.fr/r/route-vicinale/). Les chemins
            vicinaux constituaient les chemins nécessaires à la communication entre les communes et avaient été définis par une loi du 28 juillet
            1824. Cette catégorie est remplacée par la notion plus large de voie communale, définie par l’ordonnance n° 59-115 du 7 janvier 1959
            relative à la voirie des collectivités locales. (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nzb96nag--1sq344s8ubs9t">
            <rico:name xml:lang="fr">chemin vicinal des Grandes Carrières (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q86685550"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : définition, exemple(s)</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/cimeti%C3%A8re">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">cimetière</skos:prefLabel>
      <rdfs:label xml:lang="fr">cimetière</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:narrower rdf:resource="placeType/cimeti%C3%A8re%20militaire"/>
      <skos:definition xml:lang="fr">« Un cimetière est un groupement de sépultures parfois attenant à un lieu de culte. » (Source :
            Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzuoa7ns--1akrhk5guriol">
            <rico:name xml:lang="fr">Saint-Eustache, cimetière (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-161"/>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q39614"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11938920h"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Cimeti%C3%A8re"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/cimeti%C3%A8re%20militaire">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">cimetière militaire</skos:prefLabel>
      <rdfs:label xml:lang="fr">cimetière militaire</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/cimeti%C3%A8re"/>
      <skos:definition xml:lang="fr">Un cimetière militaire est un lieu où sont inhumés les soldats morts lors d’une guerre.</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-92hwn9rgm-etqt1bnab4z7">
            <rico:name xml:lang="fr">cimetière militaire du Hartmannswillerkopf (Haut-Rhin, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:related rdf:resource="placeType/am%C3%A9nagement%20ou%20b%C3%A2timent%20militaire"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/fr/ark:/12148/cb11966824r"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, exemple(s),
                    relation(s) d’association avec des concepts du vocabulaire, relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/cirque">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">cirque</skos:prefLabel>
      <rdfs:label xml:lang="fr">cirque</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
      <skos:definition xml:lang="fr">« Un cirque, en géomorphologie, ou cirque naturel, est une enceinte naturelle à parois abruptes, de forme
            semi-circulaire (parfois circulaire), formée par une dépression d'origine glaciaire [[...], volcanique [...] ou hydrologique [...], ou
            encore formé par l'érosion karstique [...].  » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-1g86cclls--15hrn1skfb4um">
            <rico:name xml:lang="fr">cirque d’Anéou (Pyrénées-Atlantiques, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-04-17</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/cit%C3%A9">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">cité (voie)</skos:prefLabel>
      <rdfs:label xml:lang="fr">cité (voie)</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/voie"/>
      <skos:definition xml:lang="fr">« Le mot cité est un odonyme, c'est-à-dire un terme servant à désigner une voie publique. En effet, il est par
            extension le terme utilisé pour la voie qui longe un grand ensemble d'une cité. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nz8e9r53--o9uvoklp6y78">
            <rico:name xml:lang="fr">cité Adrienne (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q15070223"/>
      <skos:relatedMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-36"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la dénomination préférentielle (skos:prefLabel). Ajout des données suivantes :
                    exemple(s)</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/cit%C3%A9%20sanitaire">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">cité sanitaire</skos:prefLabel>
      <rdfs:label xml:lang="fr">cité sanitaire</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/lieu%20d%E2%80%99assistance%20ou%20de%20protection%20sociale"/>
      <skos:definition xml:lang="fr">Une cité sanitaire est un établissement médico-social conçu comme une petite ville autonome, qui regroupe des
            infrastructures de soins et des équipements collectifs (logements, écoles, ateliers, espaces de vie), afin d’assurer à des malades ou
            convalescents à la fois un suivi médical et une vie sociale ordinaire. (D’après Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-2q6cnkaks--rbph69leaoj6">
            <rico:name xml:lang="fr">cité sanitaire de Clairvivre (Salagnac, Dordogne, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition,
                    exemple(s)</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/clo%C3%AEtre">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">cloître</skos:prefLabel>
      <rdfs:label xml:lang="fr">cloître</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/construction%20ou%20%C3%A9difice%20%C3%A0%20usage%20religieux"/>
      <skos:definition xml:lang="fr">Un cloître est, « dans l’architecture religieuse, une galerie ouverte délimitant une cour centrale ou un préau.
            Le cloître est généralement carré. La disposition de la galerie ouverte est quelquefois répétée à l’étage (cloître à galeries hautes) ».
            (Source : Thésaurus de la désignation des œuvres architecturales et des espaces aménagés.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3m0cufzmlf-1umgtn2erodrz">
            <rico:name xml:lang="fr">Sainte-Geneviève, cloître (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:related rdf:resource="placeType/galerie"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-124"/>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q1430154"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb119407358"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Clo%C3%AEtre"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/col">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">col</skos:prefLabel>
      <rdfs:label xml:lang="fr">col</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-5pku8agyz-1ugbz4zdcy5y6">
            <rico:name xml:lang="fr">col du Tourmalet (Hautes-Pyrénées, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q2231510"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : exemple(s), relation(s)
                    sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/collectivit%C3%A9%20%C3%A0%20statut%20particulier">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">collectivité à statut particulier</skos:prefLabel>
      <rdfs:label xml:lang="fr">collectivité à statut particulier</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/unit%C3%A9%20administrative%20fran%C3%A7aise"/>
      <skos:definition xml:lang="fr">« Une collectivité à statut particulier est, en France, une collectivité territoriale qui relève de l’article 72 de la Constitution sans être une commune, un département ou une région ni une collectivité d’outre-mer régie par l'article 74 de la Constitution. » (Source : Wikipédia.)</skos:definition>
      <skos:scopeNote xml:lang="fr">Inclut notamment Paris depuis janvier 2019.</skos:scopeNote>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté</rdf:value>
            <dc:date>2026-04-22</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/collectivit%C3%A9%20d%E2%80%99outre-mer">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">collectivité d’outre-mer</skos:prefLabel>
      <rdfs:label xml:lang="fr">collectivité d’outre-mer</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/unit%C3%A9%20administrative%20fran%C3%A7aise"/>
      <skos:scopeNote xml:lang="fr">Inclut la Nouvelle-Calédonie, qui dispose d’un statut spécial de collectivité d’outre-mer fançaise sui
            generis.</skos:scopeNote>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté</rdf:value>
            <dc:date>2026-04-19</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/coll%C3%A8ge">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">collège</skos:prefLabel>
      <rdfs:label xml:lang="fr">collège</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/lieu%20d%E2%80%99enseignement"/>
      <skos:definition xml:lang="fr">Un collège est un lieu d’enseignement, relevant d’un établissement public ou privé. Sous l’Ancien Régime, il
            dépendait souvent d’une institution religieuse. À partir du XIXe siècle, il s’agit fréquemment d’un établissement d’enseignement du
            premier cycle. (D’après le Thésaurus de la désignation des œuvres architecturales et des espaces aménagés.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzupqpgy--1bnyfs1peyeh9">
            <rico:name xml:lang="fr">Stanislas, collège (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-315"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11936525n"/>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q189004"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Coll%C3%A8ge"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/colonne">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">colonne</skos:prefLabel>
      <rdfs:label xml:lang="fr">colonne</rdfs:label>
      <skos:altLabel xml:lang="fr">colonne commémorative</skos:altLabel>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/monument%20comm%C3%A9moratif"/>
      <skos:definition xml:lang="fr">« Une colonne commémorative est un monument érigé en commémoration d’un événement important, victoire
            militaire, prise d’indépendance ou autre événement politique, ou encore en l’honneur d’un personnage important. » (Source :
            Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzuju48v--18lz8srqft84a">
            <rico:name xml:lang="fr">Juillet, colonne de (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="https://fr.dbpedia.org/resource/Colonne_comm%C3%A9morative"/>
      <skos:closeMatch rdf:resource="https://data.bnf.fr/fr/ark:/12148/cb16766391v"/>
      <skos:closeMatch rdf:resource="http://www.idref.fr/178803901/id"/>
      <skos:relatedMatch rdf:resource="http://www.wikidata.org/entity/Q1930585"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/commanderie">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">commanderie</skos:prefLabel>
      <rdfs:label xml:lang="fr">commanderie</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9tablissement%20conventuel"/>
      <skos:definition xml:lang="fr">Une commanderie est un lieu occupé par un ordre religieux militaire (source : Thésaurus de la désignation des
            œuvres architecturales et des espaces aménagés).</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzuom8i5-1lpt0qrfejve0">
            <rico:name xml:lang="fr">Saint-Jean-de-Latran, commanderie (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-101"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb119671242"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Commanderie"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/commune">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">commune française</skos:prefLabel>
      <rdfs:label xml:lang="fr">commune française</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/unit%C3%A9%20administrative%20fran%C3%A7aise"/>
      <skos:definition xml:lang="fr">La commune est une division élémentaire du territoire français qui sert de division de gestion du territoire.
            C’est notamment le territoire d’exercice de la collectivité territoriale de même nom. En tant que circonscription administrative, la
            commune constitue aussi l’organe élémentaire d’exercice de l’État sur le territoire national. Elle sert aussi de maille élémentaire pour
            de nombreuses statistiques. L’histoire des communes, en tant qu’institution, commence formellement avec le décret du 12 novembre 1789.
            Elles succèdent aux communautés, seigneuries et paroisses de l’Ancien Régime et connaissent une évolution continue de leur droit avec
            essentiellement deux lois fondatrices : 1884, l’élection au suffrage universel, et 1982 sur la décentralisation. (D’après
            Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d3ntxeji2p-1lu39awemgiwf">
            <rico:name xml:lang="fr">Clichy (Hauts-de-Seine, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q484170"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, exemple(s),
                    relation(s) sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/conservatoire">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">conservatoire</skos:prefLabel>
      <rdfs:label xml:lang="fr">conservatoire</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/lieu%20d%E2%80%99enseignement"/>
      <skos:definition xml:lang="fr">Un conservatoire est un établissement d’enseignement de la musique et des arts vivants (danse, théâtre, arts du
            cirque...). (D’après Wikipédia.)</skos:definition>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-321"/>
      <skos:closeMatch rdf:resource="http://fr.dbpedia.org/resource/Conservatoire"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/construction%20ou%20%C3%A9difice%20%C3%A0%20usage%20religieux">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">construction ou édifice à usage religieux</skos:prefLabel>
      <rdfs:label xml:lang="fr">construction ou édifice à usage religieux</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:narrower rdf:resource="placeType/clo%C3%AEtre"/>
      <skos:narrower rdf:resource="placeType/%C3%A9dicule%20religieux"/>
      <skos:narrower rdf:resource="placeType/%C3%A9glise"/>
      <skos:narrower rdf:resource="placeType/%C3%A9tablissement%20conventuel"/>
      <skos:definition xml:lang="fr">Construction, partie de construction ou ensemble de construction utilisés par les pratiquants d’une
            religion.</skos:definition>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/cour">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">cour (voie)</skos:prefLabel>
      <rdfs:label xml:lang="fr">cour (voie)</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/voie"/>
      <skos:definition xml:lang="fr">« Le mot cour est un odonyme, c'est-à-dire un terme servant à désigner une voie publique. » Par extension, une
            cour est « une voie d’accès qui est une ou plusieurs cours en enfilade, donnant accès à des bâtiments enclavés dans un îlot d’immeubles ».
            (Source : Wikipédia.)</skos:definition>
      <skos:scopeNote xml:lang="fr">Ne pas confondre avec "cours".</skos:scopeNote>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nzclt2vl-ljtt7cc5y5dq">
            <rico:name xml:lang="fr">cour du Ponant (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q17383262"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la dénomination préférentielle (skos:prefLabel). Ajout des données suivantes : définition,
                    exemple(s)</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/cours">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">cours (voie)</skos:prefLabel>
      <rdfs:label xml:lang="fr">cours (voie)</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/voie"/>
      <skos:definition xml:lang="fr">Un cours est « une large avenue urbaine, ordinairement plantée d’arbres ». (Source :
            Wikipédia).</skos:definition>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q16544740"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la dénomination préférentielle (skos:prefLabel). Ajout des données suivantes :
                    définition</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/cours%20d%E2%80%99eau">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">cours d’eau</skos:prefLabel>
      <rdfs:label xml:lang="fr">cours d’eau</rdfs:label>
      <skos:altLabel xml:lang="fr">rivière</skos:altLabel>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20d%E2%80%99hydrographie"/>
      <skos:definition xml:lang="fr">« Un cours d’eau est un écoulement terrestre d’eau liquide entre une source et une embouchure ou une confluence
            avec un débit à module supérieur à zéro. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-83llb70pi-u76a4g72e8lc">
            <rico:name xml:lang="fr">Eure (France ; cours d’eau)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/fr/ark:/12148/cb11952208p"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout d’un exemple.</rdf:value>
            <dc:date>2026-04-18</dc:date>
         </rdf:Description>
      </skos:changeNote>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : définition, relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/couvent">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">couvent</skos:prefLabel>
      <rdfs:label xml:lang="fr">couvent</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9tablissement%20conventuel"/>
      <skos:definition xml:lang="fr">Un couvent est l’« établissement d’une communauté religieuse d’hommes ou de femmes, à l’exclusion de l’abbaye,
            du prieuré, du béguinage, de la commanderie et de l’ermitage ». (Source : Thésaurus de la désignation des œuvres architecturales et des
            espaces aménagés.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzuin694-o1jn03745z92">
            <rico:name xml:lang="fr">Feuillants, couvent des (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-102"/>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q1128397"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb119780456"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Couvent"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/d%C3%A9partement">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">département français</skos:prefLabel>
      <rdfs:label xml:lang="fr">département français</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/unit%C3%A9%20administrative%20fran%C3%A7aise"/>
      <skos:definition xml:lang="fr">Le département est « une circonscription administrative et le territoire de compétence des services
            déconcentrés de l’État (le plus souvent appelée simplement département, mais parfois appelée circonscription départementale en cas
            d’ambiguïté quand les territoires de compétence de la circonscription et de la collectivité homonyme ne coïncident pas) ». (Source :
            Wikipédia.)</skos:definition>
      <skos:scopeNote xml:lang="fr">Employé ici pour les départements actuels.</skos:scopeNote>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d3ntb7ow7c--5vehi4l7x7op">
            <rico:name xml:lang="fr">département du Finistère (France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q6465"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Modifié la note d’application.</rdf:value>
            <dc:date>2026-04-20</dc:date>
         </rdf:Description>
      </skos:changeNote>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, exemple(s),
                    relation(s) sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/d%C3%A9sert">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#archipel"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">désert</skos:prefLabel>
      <rdfs:label xml:lang="fr">désert</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
      <skos:definition xml:lang="fr">« Un désert est une zone de terre où les précipitations sont rares et peu abondantes, et où, par conséquent,
            les conditions de vie sont hostiles pour les plantes et pour les animaux. Les déserts font partie des environnements extrêmes. » (Source :
            Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d5bdpehfjt-i35y7mwfd82w">
            <rico:name xml:lang="fr">Sahara (Afrique ; désert)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q8514"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-04-18</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/%C3%A9cole">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">école</skos:prefLabel>
      <rdfs:label xml:lang="fr">école</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/lieu%20d%E2%80%99enseignement"/>
      <skos:definition xml:lang="fr">« Une école est un établissement où l’on accueille des individus appelés élèves afin que des professeurs leur
            dispensent un enseignement de façon collective, dans une salle de classe. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzuoc6d4-1210yn573xg27">
            <rico:name xml:lang="fr">Saint-Germain, école (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d5bknwquss--1whli4madtah4">
            <rico:name xml:lang="fr">Beaux-Arts, école nationale supérieure des (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T1-1340"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11948031w"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/%C3%A9curie">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">écurie</skos:prefLabel>
      <rdfs:label xml:lang="fr">écurie</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Une écurie est un « abri pour les chevaux de selle ou d’attelage. L’écurie fait partie en général des communs
            d’une demeure. L’écurie de course est meublée d’installations destinées non seulement au logement, mais également aux soins, au fourrage,
            au harnachement, de terrains d’entraînement des chevaux, sans compter bureaux et logement du personnel qui s’en occupe ». (Source :
            Thésaurus de la désignation des œuvres architecturales et des espaces aménagés.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzumcpvl--7a7ygdvx9zil">
            <rico:name xml:lang="fr">Orléans, écuries d’ (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-535"/>
      <skos:closeMatch rdf:resource="http://vocab.getty.edu/aat/300005015"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb12181795z"/>
      <skos:closeMatch rdf:resource="http://fr.dbpedia.org/resource/%C3%89curie"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
