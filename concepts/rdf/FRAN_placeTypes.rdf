      <skos:narrower rdf:resource="placeType/site%20nucl%C3%A9aire"/>
      <skos:narrower rdf:resource="placeType/square"/>
      <skos:narrower rdf:resource="placeType/station%20baln%C3%A9aire"/>
      <skos:narrower rdf:resource="placeType/station%20de%20ski"/>
      <skos:narrower rdf:resource="placeType/terrasse"/>
      <skos:narrower rdf:resource="placeType/tunnel"/>
      <skos:narrower rdf:resource="placeType/voie"/>
      <skos:narrower rdf:resource="placeType/voirie"/>
      <skos:definition xml:lang="fr">Construction, partie de construction, ensemble de constructions ou infrastructure terrestre créés par l’homme
            pour lui permettre de s’abriter, de se protéger ou d’exercer ses activités.</skos:definition>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
