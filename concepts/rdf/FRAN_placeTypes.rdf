      <skos:narrower rdf:resource="placeType/lagune"/>
      <skos:narrower rdf:resource="placeType/mer"/>
      <skos:narrower rdf:resource="placeType/oc%C3%A9an"/>
      <skos:definition xml:lang="fr">Un élément d’hydrographie est un cours d’eau ou une étendue d’eau.</skos:definition>
      <skos:related rdf:resource="placeType/ouvrage%20li%C3%A9%20%C3%A0%20l%E2%80%99alimentation%20en%20eau"/>
