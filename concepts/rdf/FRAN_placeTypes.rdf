                 rdf:about="placeType/ancien%20d%C3%A9partement">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">ancien département français</skos:prefLabel>
      <rdfs:label xml:lang="fr">ancien département français</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/unit%C3%A9%20administrative%20fran%C3%A7aise"/>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d3ntb7ng95--a84n333y97sr">
            <rico:name xml:lang="fr">département de l’Escaut (France). 1795-1814</rico:name>
         </rico:Place>
      </skos:example>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté</rdf:value>
            <dc:date>2026-04-19</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/ancien%20faubourg%20de%20Paris">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">ancien faubourg de Paris</skos:prefLabel>
      <rdfs:label xml:lang="fr">ancien faubourg de Paris</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/faubourg"/>
      <skos:definition xml:lang="fr">Les anciens faubourgs de Paris sont les quartiers situés autrefois à l’extérieur des enceintes de la ville,
            développés autour des portes et annexés progressivement à Paris, mais qui ont disparu en tant qu’entités distinctes avec l’extension de la
            ville.</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_023-d3nyvgeifp-hljbb2s4l00l">
            <rico:name xml:lang="fr">Montmartre, faubourg (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/ancienne%20commune">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">ancienne commune française</skos:prefLabel>
      <rdfs:label xml:lang="fr">ancienne commune française</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/unit%C3%A9%20administrative%20fran%C3%A7aise"/>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-1g86bwwmw-1xu3dibfwfbej">
            <rico:name xml:lang="fr">Annapes (Villeneuve-d’Ascq, Nord, France ; ancienne commune)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : exemple(s)</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/arcades">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">arcades</skos:prefLabel>
      <rdfs:label xml:lang="fr">arcades</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Une arcade est, dans le sens courant, une série ordonnée de baies cintrées. Le terme peut aussi désigner une
            ouverture dans un mur (une baie) qui est cintrée en suivant diverses formes d’arc. Dans ce cas elle peut notamment être praticable ou
            réelle : elle donne alors la possibilité de circuler en offrant un passage direct. (D’après Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nz96rr1o-1x4e5atup1zud">
            <rico:name xml:lang="fr">arcades des Champs Élysées (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q186637"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/fr/ark:/12148/cb11982699j"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/arc%20de%20triomphe">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">arc de triomphe</skos:prefLabel>
      <rdfs:label xml:lang="fr">arc de triomphe</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/monument%20comm%C3%A9moratif"/>
      <skos:definition xml:lang="fr">« Un arc de triomphe, et plus généralement un arc monumental, est une structure libre monumentale enjambant une
            voie et utilisant la forme architecturale de l’arc avec un ou plusieurs passages voûtés. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzugmmr0--buw9116kzhyx">
            <rico:name xml:lang="fr">Carrousel, arc de triomphe du (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11977585k"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-189"/>
      <skos:exactMatch rdf:resource="http://www.idref.fr/027814785/id"/>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q143912"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Arc_de_triomphe"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/archipel">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#archipel"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">archipel</skos:prefLabel>
      <rdfs:label xml:lang="fr">archipel</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
      <skos:definition xml:lang="fr">« Un archipel est un ensemble d’îles relativement proches les unes des autres. La proximité se double le plus
            souvent d’une origine géologique commune, en général volcanique. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d3m08zy6sfa--1vurhe1dhr86v">
            <rico:name xml:lang="fr">îles Ioniennes (Grèce)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q33837"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-04-17</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/arrondissement">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">arrondissement français</skos:prefLabel>
      <rdfs:label xml:lang="fr">arrondissement français</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/unit%C3%A9%20administrative%20fran%C3%A7aise"/>
      <skos:definition xml:lang="fr">« L’arrondissement est une circonscription administrative de la France, à savoir une zone géographique
            résultant d’une division du territoire national à des fins de gestion administrative. Apparu en l’an VIII (1800), il constitue une
            subdivision intermédiaire entre le département et le canton, et se trouve rapidement assimilé à la sous-préfecture. Dépourvu de
            personnalité juridique depuis 1940 (abolition du conseil et du scrutin), il sert de cadre à l’action de l’État sur ce territoire et
            devient, depuis la réduction cantonale de 2015, une division supra-communale. Un arrondissement porte généralement le nom de son chef-lieu
            (la sous-préfecture, sauf s’il s’agit de la préfecture du département) et est administré par un sous-préfet (sauf l’arrondissement dont le
            chef-lieu est également celui du département, qui est administré par le secrétaire général de préfecture). » (Source :
            Wikipédia.)</skos:definition>
      <skos:scopeNote xml:lang="fr">Ne pas confondre avec les arrondissements municipaux</skos:scopeNote>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q194203"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, relation(s)
                    sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/arrondissement%20municipal">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">arrondissement municipal</skos:prefLabel>
      <rdfs:label xml:lang="fr">arrondissement municipal</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/unit%C3%A9%20administrative%20fran%C3%A7aise"/>
      <skos:definition xml:lang="fr">« Les arrondissements municipaux sont une subdivision territoriale des communes de Lyon, Marseille et Paris. »
            (Source : Wikipédia.)</skos:definition>
      <skos:scopeNote xml:lang="fr">utilisé uniquement pour les villes de Paris, Lyon et Marseille</skos:scopeNote>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_022-d3nyv8kgpz-117o9k86ze75x">
            <rico:name xml:lang="fr">14e arrondissement (Paris, France ; 1860-....)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition,
                    exemple(s)</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/asile">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">asile</skos:prefLabel>
      <rdfs:label xml:lang="fr">asile</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Un asile est un « établissement hospitalier destiné au traitement des malades mentaux ». (Source : Thésaurus de
            la désignation des œuvres architecturales et des espaces aménagés.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzukgmj8--bw46kywks2jx">
            <rico:name xml:lang="fr">Les Petites-Maisons, asile (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:closeMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-293"/>
      <skos:closeMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb13318477x"/>
      <skos:closeMatch rdf:resource="http://fr.dbpedia.org/resource/H%C3%B4pital_psychiatrique"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/asile-ouvroir">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">asile-ouvroir</skos:prefLabel>
      <rdfs:label xml:lang="fr">asile-ouvroir</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/lieu%20d%E2%80%99assistance%20ou%20de%20protection%20sociale"/>
      <skos:definition xml:lang="fr">Dans la France de la fin du XIXe siècle et du début du XXe siècle, un asile-ouvroir est à la fois un lieu
            d’hébergement et un atelier où sont reçus et travaillent des hommes ou des femmes (parfois des mères célibataires) en situation précaire.
            (Source : publication du Centre d’action sociale de la ville de Paris, Du refuge à la réinsertion sociale : 120 ans d’accueil et
            d’assistance à Paris, consultée le 19 mars 2026 à l’adresse https://www.calameo.com/books/000197834b43bac63a257).</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzuizgky--1tlafhzrh47ro">
            <rico:name xml:lang="fr">Gérando, asile-ouvroir (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/autoroute">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">autoroute</skos:prefLabel>
      <rdfs:label xml:lang="fr">autoroute</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/voie"/>
      <skos:definition xml:lang="fr">« Une autoroute est une voie de communication routière à chaussées séparées, réservée à la circulation à
            vitesse élevée des véhicules motorisés (automobiles, motos, camions et autocars). » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nz8cokjq--1t7rzmzlw78im">
            <rico:name xml:lang="fr">autoroute A4 (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q46622"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-60"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb119310012"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Autoroute"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/avenue">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">avenue</skos:prefLabel>
      <rdfs:label xml:lang="fr">avenue</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/voie"/>
      <skos:definition xml:lang="fr">Une avenue est « une grande voie urbaine ou une plus petite plantée d’arbres, et à la campagne ou en forêt, une
            avenue est un chemin frayé dans la nature ». (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nzc6mxp1--1bxa6ua5d7qmk">
            <rico:name xml:lang="fr">avenue de la Nation (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q7543083"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-61"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Avenue"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/baie">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">baie</skos:prefLabel>
      <rdfs:label xml:lang="fr">baie</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
      <skos:definition xml:lang="fr">En géographie, une baie est une échancrure du littoral mais aussi de la berge d’un lac. Une baie est moins
            grande qu’un golfe et moins profonde qu’une rade. Une baie de petite dimension est plutôt appelée anse. Si l’échancrure est de très petite
            dimension, on parle d’une crique. En général, un ou plusieurs fleuves se jettent dans une baie. (D’après Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-2jwmv8dmv--1nk7ti03it1dc">
            <rico:name xml:lang="fr">baie de Morlaix (Finistère, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:closeMatch rdf:resource="http://data.ign.fr/id/codes/topo/typedezai/Baie"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : exemple(s)</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/bain">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">bains</skos:prefLabel>
      <rdfs:label xml:lang="fr">bains</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Les bains sont un « établissement d’hygiène permettant à la clientèle de se laver, de se détendre et de laver
            son linge ». (Source : Thésaurus de la désignation des œuvres architecturales et des espaces aménagés.))</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzuqlxec--182mr2m0qqbkk">
            <rico:name xml:lang="fr">Vigier, bains (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:closeMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-381"/>
      <skos:closeMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11978599h"/>
      <skos:closeMatch rdf:resource="http://fr.dbpedia.org/resource/Bains_publics"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/balcon">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">balcon</skos:prefLabel>
      <rdfs:label xml:lang="fr">balcon</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Un balcon est un élément d’architecture consistant en une plate-forme se dégageant du mur d’un édifice. Il peut
            se situer dans une cour fermée et peut ne pas communiquer directement avec une pièce. (D’après Wikipédia).</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_025-d3nzd2k7jf-1sguyvayts9rl">
            <rico:name xml:lang="fr">balcon Saint-Eustache (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q170552"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T69-60"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Balcon"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb12273807k"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/barrage">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">barrage</skos:prefLabel>
      <rdfs:label xml:lang="fr">barrage</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Un barrage est « un ouvrage d’art construit en travers d’un cours d’eau et de sa vallée et destiné à réguler
            son cours ou à stocker de l’eau pour différents usages : irrigation, industrie, hydroélectricité, pisciculture, réserve d’eau potable,
            etc. ». (Source : Thésaurus de la désignation des œuvres architecturales et des espaces aménagés.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-b9zkmf1by-1bpf3jai67j3a">
            <rico:name xml:lang="fr">barrage de Lanau (Neuvéglise, Cantal, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:related rdf:resource="placeType/%C3%A9l%C3%A9ment%20d%E2%80%99hydrographie"/>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q12323"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-1049"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb119470351"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Barrage"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout des données suivantes : définition, exemple(s), relation(s) d’association avec des concepts du
                    vocabulaire, relation(s) sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/barri%C3%A8re">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">barrière</skos:prefLabel>
      <rdfs:label xml:lang="fr">barrière</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Une barrière est une « enceinte érigée autour d’une ville pour permettre le recouvrement des taxes sur les
            marchandises ». (Source : Thésaurus de la désignation des œuvres architecturales et des espaces aménagés.)</skos:definition>
      <skos:scopeNote xml:lang="fr">À Paris, les barrières étaient de trois sortes. Voir à ce sujet Wikipédia : Liste des barrières de Paris
            (https://fr.wikipedia.org/wiki/Liste_des_barri%C3%A8res_de_Paris).</skos:scopeNote>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzunvx4c--1krgtdmeunfd9">
            <rico:name xml:lang="fr">Roule, barrière du (Paris, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:closeMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb12356004t"/>
      <skos:closeMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-256"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/base%20a%C3%A9rienne">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">base aérienne</skos:prefLabel>
      <rdfs:label xml:lang="fr">base aérienne</rdfs:label>
      <skos:altLabel xml:lang="fr">base aérienne militaire</skos:altLabel>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20b%C3%A2timent%20militaire"/>
      <skos:definition xml:lang="fr">« Une base aérienne est un aérodrome ou une partie d’un aérodrome utilisée par les forces armées d’un pays pour
            mettre en œuvre la composante aérienne. » (Source : Wikipédia.)</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_005-d-6ywd0c54b--vezx6xmv9xnb">
            <rico:name xml:lang="fr">base aérienne d’Orange-Caritat (Vaucluse, France)</rico:name>
         </rico:Place>
      </skos:example>
      <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q695850"/>
      <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-438"/>
      <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11937704g"/>
      <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Base_a%C3%A9rienne"/>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Ajout d’un exemple.</rdf:value>
            <dc:date>2026-04-18</dc:date>
         </rdf:Description>
      </skos:changeNote>
      <skos:changeNote>
         <rdf:Description>
            <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, relation(s)
                    sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
            <dc:date>2026-02-23</dc:date>
         </rdf:Description>
      </skos:changeNote>
   </skos:Concept>
   <skos:Concept xmlns:cc="http://creativecommons.org/ns#"
                 xmlns:dct="http://purl.org/dc/terms/"
                 xmlns:iso-thes="http://purl.org/iso25964/skos-thes#"
                 rdf:about="placeType/bassin">
      <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
      <skos:inScheme rdf:resource="placeTypes"/>
      <skos:prefLabel xml:lang="fr">bassin</skos:prefLabel>
      <rdfs:label xml:lang="fr">bassin</rdfs:label>
      <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
      <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
      <skos:definition xml:lang="fr">Un bassin est un plan d’eau artificiel</skos:definition>
      <skos:example>
         <rico:Place rdf:about="place/FRAN_RI_026-d3nzuk62i4--1bulb10635kge">
            <rico:name xml:lang="fr">La Villette, bassin de (Paris, France)</rico:name>
         </rico:Place>
