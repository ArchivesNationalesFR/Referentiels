                <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s)</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/territoire%20ou%20ville%20%C3%A9tranger">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">territoire ou ville étranger</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20humaine"/>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_005-d3m08zpxah1-190bwee41vjy9">
                <rico:name xml:lang="fr">Aarau (Suisse)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : exemple(s)</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/th%C3%A9%C3%A2tre">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">théâtre</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">Un théâtre est un édifice destiné aux représentations dramatiques. (Source : Les vocabulaires du Ministère de
            la Culture et de la Communication)</skos:definition>
        <skos:scopeNote xml:lang="fr">Ne pas confondre avec théâtre de jardin, ni avec théâtre de verdure.</skos:scopeNote>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3nzugz82l-bkr4d3tgwnb9">
                <rico:name xml:lang="fr">Châtelet, théâtre du (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-419"/>
        <skos:exactMatch rdf:resource="http://data.bnf.fr/ark:/12148/cb11938054b"/>
        <skos:exactMatch rdf:resource="http://vocab.getty.edu/aat/300007117"/>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Th%C3%A9%C3%A2tre_%28%C3%A9difice%29"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/tour">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">tour</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">Une tour est un édifice plus haut que large et dont la base est au sol (à ne pas confondre avec une
            échauguette). Par extension, le terme désigne également une construction monumentale isolée, souvent à caractère défensif, religieux ou
            commémoratif. (Source : Wikipédia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3nzuidegl-52cdx9jw84og">
                <rico:name xml:lang="fr">tour Eiffel</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="https://www.wikidata.org/wiki/Q12518"/>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-1355"/>
        <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11965217k"/>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/page/Tour_(%C3%A9difice)"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/unit%C3%A9%20administrative%20fran%C3%A7aise">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">unité administrative française</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20humaine"/>
        <skos:narrower rdf:resource="placeType/ancienne%20commune"/>
        <skos:narrower rdf:resource="placeType/arrondissement"/>
        <skos:narrower rdf:resource="placeType/arrondissement%20municipal"/>
        <skos:narrower rdf:resource="placeType/canton"/>
        <skos:narrower rdf:resource="placeType/commune"/>
        <skos:narrower rdf:resource="placeType/d%C3%A9partement"/>
        <skos:narrower rdf:resource="placeType/r%C3%A9gion"/>
        <skos:definition xml:lang="fr">Une unité administrative fraçaise est un objet géographique résultant du découpage administratif du territoire
            français. (Source : Ontologie des unités administratives de l’IGN, Release 2021-02-18)</skos:definition>
        <skos:related rdf:resource="placeType/ville%20nouvelle"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/vall%C3%A9e">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">vallée</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
        <skos:definition xml:lang="fr">Une vallée est une dépression géographique généralement de forme allongée et façonnée dans le relief par un
            cours d’eau (vallée fluviale) ou un glacier (vallée glaciaire) (source : Wikipédia).</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_005-d-1g86cbqic--1kha1vdq64i9a">
                <rico:name xml:lang="fr">Arve, vallée de l’ (Haute-Savoie ; vallée)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:closeMatch rdf:resource="http://data.ign.fr/id/codes/topo/typederelief/Vallee"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition,
                    exemple(s)</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/viaduc">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">viaduc</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/pont"/>
        <skos:definition xml:lang="fr">« Un viaduc est un ouvrage d’art, routier ou ferroviaire, passant au-dessus d’une rivière, un bras de mer ou
            tout autre obstacle et qui présente une hauteur ou une longueur, parfois les deux, plus grande que celle qu’exigerait la seule traversée
            de la rivière ou de la voie à franchir ». (source: Wikipédia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_005-d-1gtuyrhgb-pam7ci9xv7ei">
                <rico:name xml:lang="fr">Busseau, viaduc de (Creuse ; viaduc)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:closeMatch rdf:resource="https://www.wikidata.org/wiki/Q181348"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Ajout des données suivantes : définition, exemple(s)</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/vicus">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">vicus</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/rue"/>
        <skos:definition xml:lang="fr">Dans la civilisation romaine, le concept de vicus avait plusieurs sens, dont celui de quartier d’une grande
            ville. Par extension, il peut aussi désigner une rue. (d’après Wikipédia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_025-d3nz8fef08-1fmg703ywzjlz">
                <rico:name xml:lang="fr">vicus Alberici Carnificis (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:closeMatch rdf:resource="https://www.wikidata.org/wiki/Q763590"/>
        <skos:relatedMatch rdf:resource="http://www.wikidata.org/entity/Q763590"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Ajout des données suivantes : définition, exemple(s)</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/villa%20%28voie%29">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">villa (voie)</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/voie"/>
        <skos:definition xml:lang="fr">« À partir du XIXe siècle, une villa est une voie ou impasse bordée à l’origine par des habitations
            individuelles. [...] Une villa peut également être une forme de quartier privé dans Paris et dans certaines villes d’Île-de-France.
            Contrairement à un domaine privé, la villa est située au cœur d’une grande ville [...]. Elle est généralement desservie par une ou
            plusieurs voies privées dont l’accès est réservé aux riverains et à leurs invités » (source: Wikipédia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_025-d3nzd88d98--1phialk6ov8fe">
                <rico:name xml:lang="fr">villa Sainte-Marie (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:related rdf:resource="placeType/quartier"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition,
                    exemple(s)</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/village">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">village</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20humaine"/>
        <skos:definition xml:lang="fr">Un village est une agglomération rurale caractérisée par un habitat plus ou moins concentré, possédant des
            services de première nécessité et offrant une forme de vie communautaire (source : Wikipédia).</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_005-d-rffj0jzc--b0x2ejghzvlq">
                <rico:name xml:lang="fr">Bigny (Vallenay ; village)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:closeMatch rdf:resource="https://www.wikidata.org/wiki/Q532"/>
        <skos:closeMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-15"/>
        <skos:closeMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11939034z"/>
        <skos:closeMatch rdf:resource="http://fr.dbpedia.org/page/Village"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : exemple(s), relation(s)
                    sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/ville">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">ville</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20humaine"/>
        <skos:narrower rdf:resource="placeType/ville%20nouvelle"/>
        <skos:definition xml:lang="fr">Une ville est un lieu qui se caractérise par une forte densité de population et une forte densité de bâtiments.
            La population qui l’habite y organise l’espace en fonction de ses besoins et de ses activités propres, ainsi que de l’environnement
            physique. (Source : Wikipédia)</skos:definition>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/ville%20nouvelle">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">ville nouvelle</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/ville"/>
        <skos:definition xml:lang="fr">Une ville nouvelle, ville neuve ou ville planifiée est une ville, ou un ensemble de communes, qui naît
            généralement d’une volonté politique, et qui se construit peu à peu sur un emplacement auparavant peu ou pas habité (source :
            Wikipédia).</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_005-d-6pq92g7ej-ur2297ejqwh">
                <rico:name xml:lang="fr">Sénart (Ile-de-France ; ville nouvelle)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:related rdf:resource="placeType/unit%C3%A9%20administrative%20fran%C3%A7aise"/>
        <skos:closeMatch rdf:resource="https://www.wikidata.org/wiki/Q1074523"/>
        <skos:closeMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-17"/>
        <skos:closeMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11963619w"/>
        <skos:closeMatch rdf:resource="http://fr.dbpedia.org/page/Ville_nouvelle"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : exemple(s), relation(s)
                    d’association avec des concepts du vocabulaire, relation(s) sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/voie">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">voie</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:narrower rdf:resource="placeType/all%C3%A9e"/>
        <skos:narrower rdf:resource="placeType/autoroute"/>
        <skos:narrower rdf:resource="placeType/avenue"/>
        <skos:narrower rdf:resource="placeType/boulevard"/>
        <skos:narrower rdf:resource="placeType/carrefour"/>
        <skos:narrower rdf:resource="placeType/chauss%C3%A9e"/>
        <skos:narrower rdf:resource="placeType/chemin"/>
        <skos:narrower rdf:resource="placeType/chemin%20vicinal"/>
        <skos:narrower rdf:resource="placeType/cit%C3%A9"/>
        <skos:narrower rdf:resource="placeType/cour"/>
        <skos:narrower rdf:resource="placeType/cours"/>
        <skos:narrower rdf:resource="placeType/impasse"/>
        <skos:narrower rdf:resource="placeType/passage"/>
        <skos:narrower rdf:resource="placeType/promenade"/>
        <skos:narrower rdf:resource="placeType/route"/>
        <skos:narrower rdf:resource="placeType/rue"/>
        <skos:narrower rdf:resource="placeType/sentier"/>
        <skos:narrower rdf:resource="placeType/villa%20%28voie%29"/>
        <skos:definition xml:lang="fr">« Une voie ou voie de communication est un itinéraire aménagé permettant de passer d’un lieu à un autre à pied
            ou en véhicule, par exemple un chemin, une rue ou une voie rapide. Lorsqu’elle est située en ville, on parle de voie urbaine (rue, avenue,
            boulevard, etc.) » (source : Wikipédia).</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_025-d3nzb6oqg5--1ilggqgvq5cy2">
                <rico:name xml:lang="fr">voie Georges Pompidou (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q83620"/>
        <skos:closeMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-58"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : exemple(s), relation(s)
                    sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/voie%20urbaine">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">voie urbaine</skos:prefLabel>
        <iso-thes:status xml:lang="fr">obsolète</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Correction de la relation vers le concept générique.</rdf:value>
                <dc:date>2026-02-23</dc:date>
