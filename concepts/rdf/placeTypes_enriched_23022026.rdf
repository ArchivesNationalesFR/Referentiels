    <skos:Concept rdf:about="placeType/quai">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">quai</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">« Un quai est un dispositif permettant le chargement et le déchargement de passagers et de biens au bord d’une
            étendue d’eau (source: Wikipédia) ». « Les voies de circulation qui longent les voies d’eau, particulièrement en zone urbaine, prennent
            fréquemment le nom de "quai" même en l’absence d’accostage ». « Le terme de quai est également utilisé dans les chemins de fer ; il
            provient du monde de la marine. Il permet d’embarquer ou de débarquer les voyageurs et les marchandises dans les trains (source:
            Wikipédia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_025-d3nz8hvdkn-1qr5kaaf2b4rp">
                <rico:name xml:lang="fr">quai Anatole France (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="https://www.wikidata.org/wiki/Q828909"/>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-1105"/>
        <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb119494913"/>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/page/Quai_(voie)"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/quartier">
