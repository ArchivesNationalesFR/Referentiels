            </rico:Place>
        </skos:example>
        <skos:closeMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-381"/>
        <skos:closeMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11978599h"/>
