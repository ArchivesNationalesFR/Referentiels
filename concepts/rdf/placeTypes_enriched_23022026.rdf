            </rico:Place>
        </skos:example>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/pompe%20%C3%A0%20feu">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">pompe à feu</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/ouvrage%20li%C3%A9%20%C3%A0%20l%E2%80%99alimentation%20en%20eau"/>
        <skos:definition xml:lang="fr">Une pompe à eau est un édifice d’élévation des eaux construit afin d’alimenter des fontaines dans une ville.
            (Source : Wikipédia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3m0cugqcuh-1lqpbi4ccosw2">
                <rico:name xml:lang="fr">Gros Caillou, pompe à feu du (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/pont">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">pont</skos:prefLabel>
        <skos:altLabel xml:lang="fr">petit pont</skos:altLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:narrower rdf:resource="placeType/passerelle"/>
        <skos:narrower rdf:resource="placeType/pont-canal"/>
        <skos:narrower rdf:resource="placeType/viaduc"/>
        <skos:definition xml:lang="fr">Un pont est un ouvrage d’art qui permet de franchir un obstacle naturel ou artificiel en passant par-dessus.
            (source: Wikipédia).</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_005-d-8ku2vs00a--1qr65mse1egd1">
                <rico:name xml:lang="fr">Bonhomme, pont du (Kervignac ; pont)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q12280"/>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-1097"/>
        <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11932837h"/>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/page/Pont"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
