        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/voirie">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">voirie</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">« Les voiries étaient des dépôts qui accueillaient boues et immondices ». (source :
            FranceGenWeb)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_025-d3nzb9y6fl-1ip4kkxigspoz">
                <rico:name xml:lang="fr">voirie dite des Grésillons (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:closeMatch rdf:resource="https://www.wikidata.org/wiki/Q358078"/>
        <skos:changeNote>
