    <skos:Concept rdf:about="placeType/%C3%A9glise">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">église</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/construction%20ou%20%C3%A9difice%20%C3%A0%20usage%20religieux"/>
        <skos:narrower rdf:resource="placeType/cath%C3%A9drale"/>
        <skos:narrower rdf:resource="placeType/chapelle"/>
        <skos:narrower rdf:resource="placeType/temple"/>
        <skos:definition xml:lang="fr">Une église est un "édifice consacré au culte de la religion chrétienne, faisant ou ayant fait l’objet d’une
            desserte régulière. "(Source : Les vocabulaires du Ministère de la Culture et de la Communication)</skos:definition>
        <skos:scopeNote xml:lang="fr">Pour les églises n’appartenant pas ou plus au rite catholique, noter les destinataires : d’orthodoxes, de
            luthériens, etc. Pour une église où sont célébrés alternativement les cultes des rites catholique et luthérien, simultaneum constitue une
            précision sur la dénomination</skos:scopeNote>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3nzuoi16j--12w7mz19buaxr">
                <rico:name xml:lang="fr">Saint-Germain-l’Auxerrois, église (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T515-850"/>
        <skos:exactMatch rdf:resource="http://vocab.getty.edu/aat/300007466"/>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/%C3%89glise_%28%C3%A9difice%29"/>
        <skos:exactMatch rdf:resource="http://data.bnf.fr/ark:/12148/cb119345731"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
