        <skos:narrower rdf:resource="placeType/camp%20militaire"/>
        <skos:narrower rdf:resource="placeType/fortification"/>
        <skos:definition xml:lang="fr">Construction, partie de construction ou groupe de constructions liés aux activités
            militaires.</skos:definition>
        <skos:related rdf:resource="placeType/cimeti%C3%A8re%20militaire"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
