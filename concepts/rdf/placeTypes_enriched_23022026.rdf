        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">Un préau est « un espace couvert ou non couvert, situé à l’intérieur de certains édifices tels que des
            hôpitaux, des prisons ou des monastères (préau claustral) généralement utilisé pour la promenade des personnes qui y résident ». (source:
            Wikipédia).</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_025-d3nza811o2-z8wvq21h3ao">
