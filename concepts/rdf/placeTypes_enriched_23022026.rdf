        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Ajout des données suivantes : définition, exemple(s)</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/prieur%C3%A9">
