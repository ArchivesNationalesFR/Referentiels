    <skos:Concept rdf:about="placeType/port">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">port</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">Un port est une infrastructure construite par l’homme, située sur le littoral maritime, sur les berges d’un lac
            ou sur un cours d’eau, et destinée à accueillir des bateaux et navires. (Source : Wikipédia)</skos:definition>
        <skos:exactMatch rdf:resource="https://www.wikidata.org/wiki/Q44782"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Ajout des données suivantes : définition, relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/porte">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">porte</skos:prefLabel>
        <skos:altLabel xml:lang="fr">porta</skos:altLabel>
        <skos:altLabel xml:lang="fr">porte de ville</skos:altLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">Une porte de ville fait partie des fortifications d’une ville. (source : Wikipédia).</skos:definition>
        <skos:example>
