<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF xmlns:cc="http://creativecommons.org/ns#" xmlns:dc="http://purl.org/dc/elements/1.1/" xmlns:dcat="http://www.w3.org/ns/dcat#"
    xmlns:dct="http://purl.org/dc/terms/" xmlns:dcterms="http://purl.org/dc/terms/" xmlns:foaf="http://xmlns.com/foaf/0.1/"
    xmlns:html="http://www.w3.org/1999/xhtml" xmlns:iso-thes="http://purl.org/iso25964/skos-thes#" xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#" xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:rico="https://www.ica.org/standards/RiC/ontology#" xmlns:skos="http://www.w3.org/2004/02/skos/core#"
    xml:base="https://rdf.archives-nationales.culture.gouv.fr/">
    <skos:ConceptScheme rdf:about="placeTypes">
        <dcterms:title xml:lang="fr">Types de lieux</dcterms:title>
        <dcterms:description rdf:parseType="Literal">
            <html:div xml:lang="fr">
                <html:p>Thésaurus des types de lieux (entités géo-historiques). Saisi manuellement en se fondant sur les catégories de lieux
                    sous-jacentes ou implicites dans les référentiels de lieux des Archives nationales de France. Des enrichissements sont prévus dans
                    les prochains mois.</html:p>
                <html:p>Nombre de concepts : 193. Tous ces concepts sont des concepts candidats, le référentiel des types de lieux étant le seul
                    vocabulaire directement créé en RDF, et non instancié actuellement dans le SI des Archives nationales de France.</html:p>
            </html:div>
        </dcterms:description>
        <dcat:version xml:lang="fr">2.0</dcat:version>
        <dc:source xml:lang="fr">Les notions définies dans ce thésaurus sont, soit les notions qui servent à regrouper les lieux dans les versions XML
            des référentiels de lieux des Archives nationales de France tels que gérés par le système d’information archivistique (SIA), soit des
            notions utilisées pour catégoriser beaucoup plus précisément ces lieux, soit des notions génériques non utilisées directement.</dc:source>
        <dcterms:creator>
            <foaf:Organization>
                <foaf:mbox>le-lab.archives-nationales@culture.gouv.fr</foaf:mbox>
                <foaf:homepage>https://www.archives-nationales.culture.gouv.fr</foaf:homepage>
                <foaf:name xml:lang="fr">Archives nationales (France). Lab</foaf:name>
            </foaf:Organization>
        </dcterms:creator>
        <dcterms:publisher>
            <foaf:Organization>
                <foaf:name xml:lang="fr">Archives nationales de France</foaf:name>
                <owl:sameAs rdf:resource="https://rdf.archives-nationales.culture.gouv.fr/agent/005061"/>
            </foaf:Organization>
        </dcterms:publisher>
        <dcterms:created>2019-06</dcterms:created>
        <dcterms:modified>2021-12</dcterms:modified>
        <dcterms:modified>2022-03</dcterms:modified>
        <dcterms:modified>2025-03-12</dcterms:modified>
        <dcterms:modified>2025-07-28</dcterms:modified>
        <dcterms:modified>2026-02-23</dcterms:modified>
        <dc:coverage xml:lang="fr">du Moyen Âge à nos jours</dc:coverage>
        <skos:scopeNote xml:lang="fr">Ce thésaurus est utilisé par le Lab des Archives nationales de France pour qualifier les lieux décrits dans les
            référentiels de lieux des AnF. Son contenu reflète donc l’état actuel de ces référentiels.</skos:scopeNote>
        <dc:language>fr-FR</dc:language>
        <dcterms:language rdf:resource="http://id.loc.gov/vocabulary/iso639-2/fre"/>
        <dc:type xml:lang="fr">thésaurus</dc:type>
        <dc:rights xml:lang="fr">Ces données étant des informations publiques, l’usager dispose d’un droit non exclusif et gratuit de libre «
            réutilisation » à des fins commerciales ou non, dans le monde entier et pour une durée illimitée, de ce référentiel. Il doit accompagner
            chaque rediffusion des informations de l’indication précise de l’origine des métadonnées : « Archives nationales de France », du nom du
            référentiel, de son identifiant (URI), du numéro et de la date de la version du référentiel.</dc:rights>
        <dcat:distribution>
            <dcat:Distribution>
                <dcat:title xml:lang="fr">Version RDF/XML</dcat:title>
                <dcat:mediaType rdf:resource="https://www.iana.org/assignments/media-types/application/rdf+xml"/>
                <dcat:downloadURL
                    rdf:resource="https://raw.githubusercontent.com/ArchivesNationalesFR/Referentiels/refs/heads/main/concepts/rdf/FRAN_placeTypes.rdf"
                />
            </dcat:Distribution>
        </dcat:distribution>
        <dcat:distribution>
            <dcat:Distribution>
                <dcat:title xml:lang="fr">Version CSV générée à partir du fichier RDF/XML</dcat:title>
                <dcat:mediaType rdf:resource="http://www.iana.org/assignments/media-types/text/csv"/>
                <dcat:downloadURL
                    rdf:resource="https://raw.githubusercontent.com/ArchivesNationalesFR/Referentiels/refs/heads/main/concepts/csv/FRAN_placeTypes.csv"
                />
            </dcat:Distribution>
        </dcat:distribution>
        <skos:historyNote rdf:parseType="Literal">
            <html:ul>
                <html:li xml:lang="fr">Mars 2022 : regénéré le fichier, les métadonnées du vocabulaire ont été améliorées par rapport à la version de
                    décembre 2021. Les propriétés skos:hasTopConcept ont été rajoutées. Quelques coquilles corrigées.</html:li>
                <html:li xml:lang="fr">30 juillet 2024 : corrigé l’URI du cours d’eau dans la description du concept générique 'élément
                    d'hydrographie'.</html:li>
                <html:li xml:lang="fr">1er août 2024 : ajouté les assertions iso-thes:status et skos:topConceptOf ; modifié certaines définitions pour
                    leur intégrer la mention de la source ; traduit en langue française les notes de mise à jour.</html:li>
                <html:li xml:lang="fr">12 mars 2025 : intégré au référentiel 40 nouveaux concepts nécessaires pour catégoriser les voies de Paris.
                    Rendu le concept de 'voie urbaine' obsolète (il est remplacé par le concept de 'voie'). Procédé à de nombreuses corrections
                    typographiques. Enrichi les métadonnées du référentiel.</html:li>
                <html:li xml:lang="fr">28 juillet 2025 : ajouté le concept de villa (en tant que voie ou quartier urbain), nécessaire pour catégoriser
                    certaines voies de Paris.</html:li>
                <html:li xml:lang="fr">février 2026 : ajouté 85 nouveaux concepts, nécessaires pour catégoriser les lieux hors Paris et les édifices
                    parisiens ; ajouté des définitions, exemples et relations sémantiques à de nombreux concepts existants ; revu la hiérarchie des
                    concepts.</html:li>
            </html:ul>
        </skos:historyNote>
        <skos:hasTopConcept rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20humaine"/>
        <skos:hasTopConcept rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
    </skos:ConceptScheme>
    <skos:Concept rdf:about="placeType/abattoir">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">abattoir</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">Un abattoir est un lieu dans lequel les animaux d’élevage sont abattus par plusieurs personnes pour
            l’alimentation humaine dans le cadre de la consommation de produits d’origine animale. (Source : Wikipédia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3m0cugplig-vj59jsa36fa0">
                <rico:name xml:lang="fr">Villejuif, abattoirs de (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-604"/>
        <skos:exactMatch rdf:resource="https://fr.dbpedia.org/page/Abattoir"/>
        <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11936410b"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/abbaye">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">abbaye</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/%C3%A9tablissement%20conventuel"/>
        <skos:definition xml:lang="fr">« Une abbaye est un monastère de moines ou de moniales souvent catholiques, mais pouvant aussi parfois
            appartenir à d’autres dénominations chrétiennes (dont le luthéranisme, par exemple). L’abbaye est placée sous la direction d’un abbé — «
            père » en araméen — ou d’une abbesse, l’abbé étant le supérieur tout en étant « père spirituel » de la communauté religieuse, suivant les
            indications données au chapitre 2 de la règle de saint Benoît (du moins dans le monachisme occidental). » (Source:
            Wikipédia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_005-d-8vilywod-glatntey8ifn">
                <rico:name xml:lang="fr">Brou, abbaye de (Bourg-en-Bresse ; abbaye)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="https://www.wikidata.org/wiki/Q160742"/>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/page/Abbaye"/>
        <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11934704r"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, exemple(s),
                    relation(s) sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/a%C3%A9rodrome">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">aérodrome</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">« Un aérodrome est un site, civil ou militaire, aménagé pour permettre aux aéronefs de décoller et d’atterrir,
            et doté de l’infrastructure nécessaire pour les préparer à leurs missions. Il comprend une ou plusieurs pistes d’envol et d’atterrissage,
            des aires de stationnement, des ateliers de réparations et de vérifications. »(Source : Wikipédia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_005-d-3mrijhaqu--1co5m1ogqvl6d">
                <rico:name xml:lang="fr">Château-Arnoux-Saint-Auban, aérodrome de (Château-Arnoux-Saint-Auban)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="https://www.wikidata.org/wiki/Q62447"/>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-1004"/>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/A%C3%A9rodrome"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Ajout des données suivantes : définition, exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/aire%20g%C3%A9ographique">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">aire géographique</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
        <skos:definition xml:lang="fr">Une aire géographique est une région terrestre de grande taille, comme un continent.</skos:definition>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Correction de la dénomination préférentielle (skos:prefLabel). Ajout des données suivantes :
                    définition</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/all%C3%A9e">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">allée</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/voie"/>
        <skos:definition xml:lang="fr">« Une allée est composée généralement d’un chemin ou d’une route (goudronnée à proprement parler), accompagnée
            d’arbres, et sert de lieu de promenade ». (source: Wikipédia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_025-d3nzcqk13n-y8vae3640yhh">
                <rico:name xml:lang="fr">allée du Puits (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q207934"/>
        <skos:exactMatch rdf:resource="https://data.bnf.fr/fr/ark:/12148/cb15538404r"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/am%C3%A9nagement%20ou%20b%C3%A2timent%20militaire">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">aménagement ou bâtiment militaire</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
