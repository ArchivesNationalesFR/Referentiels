    <skos:Concept rdf:about="placeType/enceinte">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">enceinte</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20b%C3%A2timent%20militaire"/>
        <skos:definition xml:lang="fr">Une enceinte est une "clôture continue enveloppant une place forte ou une partie de place forte pour sa
            défense. Une place forte peut avoir plusieurs enceintes qui se commandent les unes les autres. Elles se numérotent de l’extérieur vers
            l’intérieur." (Source : Thésaurus de la désignation des œuvres architecturales et des espaces aménagés)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3nzugvmqi--euvq7oav44kv">
                <rico:name xml:lang="fr">Charles V, enceinte de (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-478"/>
        <skos:exactMatch rdf:resource="https://www.wikidata.org/wiki/Q5375326"/>
        <skos:closeMatch rdf:resource="http://fr.dbpedia.org/page/Enceinte_fortifi%C3%A9e"/>
        <skos:relatedMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11931504g"/>
        <skos:relatedMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-444"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/enclos">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">enclos</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">"Un enclos est un espace de terrain entouré d’une clôture qui sert à contenir des animaux domestiques, à
            délimiter un monument commémoratif."(Source : Wikipédia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3m0cugvsxw--1pt99rgdkx4tj">
                <rico:name xml:lang="fr">Bernardins, enclos (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-1306"/>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/page/Enclos"/>
        <skos:relatedMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11964852h"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/enseigne">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">enseigne</skos:prefLabel>
        <skos:altLabel xml:lang="fr">image</skos:altLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">Une enseigne est un panneau portant un emblème, une inscription ou un objet symbolique placé à la façade d’une
            boutique ou d’un édifice pour en signaler la présence au public (Source : Thésaurus de la désignation des œuvres architecturales et des
            espaces aménagés). Par extension, le nom de l’enseigne sert souvent à désigner l’édifice que celle-ci orne.</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3m0cugt2as-1x8ooz37krc8e">
                <rico:name xml:lang="fr">Chèvre-qui-paît, enseigne de la (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d5bknxwvt8--rou0h5ldoiz">
                <rico:name xml:lang="fr">Sainte-Anne, image (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:closeMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T69-333"/>
        <skos:closeMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb119730183"/>
        <skos:closeMatch rdf:resource="http://fr.dbpedia.org/page/Enseigne"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/entrep%C3%B4t%20industriel">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">entrepôt industriel</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">Un magasin, sous l’Ancien Régime et la Révolution, désigne un dépôt public ou royal destiné à l’entreposage et
            à la gestion de biens stratégiques (armes, matériaux, vivres, etc.)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3nzuinlk3-amuu7j7r7aqs">
                <rico:name xml:lang="fr">Feuillants, magasins des (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/escalier">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">escalier</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">« Un escalier est une construction architecturale constituée d’une suite régulière de marches, ou degrés,
            permettant d’accéder à un étage, de passer d’un niveau à un autre en montant et descendant. Par extension, ce type de construction a donné
            son nom à un escalier, voie piétonne, à ciel ouvert ou couverte, constituée d’une ou plusieurs marches ». (source:
            Wikipédia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_025-d3nz8vio8b--g2579affw2bw">
                <rico:name xml:lang="fr">escalier Biron (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q12511"/>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T69-65"/>
        <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11976932v"/>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/page/Escalier"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/esplanade">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">esplanade</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/place"/>
        <skos:definition xml:lang="fr">« Une esplanade est un terrain plat devant une citadelle, glacis s’étendant jusqu’aux portes d’une ville ou,
            plus généralement, un espace uni et découvert situé devant ou aux abords d’un édifice ». (source: Wikipédia).</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_025-d3nz8i45l0-z9yn89qmkdfs">
                <rico:name xml:lang="fr">esplanade André Chamson (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q88372"/>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-53"/>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/page/Esplanade"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/%C3%A9tablissement%20conventuel">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">établissement conventuel</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/construction%20ou%20%C3%A9difice%20%C3%A0%20usage%20religieux"/>
        <skos:narrower rdf:resource="placeType/commanderie"/>
        <skos:narrower rdf:resource="placeType/couvent"/>
        <skos:narrower rdf:resource="placeType/monast%C3%A8re"/>
        <skos:narrower rdf:resource="placeType/prieur%C3%A9"/>
        <skos:narrower rdf:resource="placeType/abbaye"/>
        <skos:definition xml:lang="fr">Un lieu abritant une communauté religieuse d’hommes ou de femmes. (Source : Thésaurus de la désignation des
            œuvres architecturales et des espaces aménagés)</skos:definition>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/facult%C3%A9">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">faculté</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/lieu%20d%E2%80%99enseignement"/>
        <skos:definition xml:lang="fr">"Une faculté est traditionnellement une des structures constitutives d’une université chargée de l’enseignement
            et de la recherche dans un champ disciplinaire homogène, regroupant des domaines de formation et de connaissance apparentés. "(Source :
            Wikipédia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3nzulbdnc--ycc6vcfihrth">
                <rico:name xml:lang="fr">Médecine, faculté de (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="https://www.wikidata.org/wiki/Q180958"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/faubourg">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">faubourg</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/quartier"/>
        <skos:narrower rdf:resource="placeType/ancien%20faubourg%20de%20Paris"/>
        <skos:definition xml:lang="fr">Un faubourg est "à l’origine, un quartier développé à l’extérieur de l’enceinte d’une ville, généralement le
            long d’une voie conduisant à une porte. Par extension, quartier situé à l’extérieur d’un boulevard ou au-delà d’une barrière d’octroi
            enserrant un centre ancien." (Source : Thésaurus de la désignation des œuvres architecturales et des espaces aménagés)</skos:definition>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/page/Faubourg"/>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-22"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/fausse%20porte">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">fausse porte</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">« Une fausse porte est une représentation artistique d’une porte, mais qui ne fonctionne pas comme une vraie ».
            (source: Wikipédia).</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_025-d3nzd1ryyl--rlc6acx7xsye">
                <rico:name xml:lang="fr">fausse porte Saint-Denis (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="https://www.wikidata.org/wiki/Q902996"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : exemple(s), relation(s)
                    sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/foire">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">foire</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">"Une foire, qui peut être appelée aussi marché de grande importance, se déroule sur un foirail ou champ de
            foire. C’est une manifestation commerciale d’exposants faisant partie d’un même secteur économique (comme le secteur agricole par exemple)
            se tenant dans une ville, un bourg à une époque et en un lieu généralement fixe. "(Source : Wikipédia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3m0cugdfrj--1f11gmoi26205">
                <rico:name xml:lang="fr">Saint-Germain, foire (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb119314197"/>
        <skos:closeMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T1-470"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/fontaine">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">fontaine</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/ouvrage%20li%C3%A9%20%C3%A0%20l%E2%80%99alimentation%20en%20eau"/>
        <skos:definition xml:lang="fr">"Une fontaine est d’abord le lieu d’une source, d’une « eau vive qui sort de terre », selon le premier
            dictionnaire de l’Académie française. C’est également une construction architecturale, généralement accompagnée d’un bassin, d’où jaillit
            de l’eau."(Source : Wikipédia)</skos:definition>
        <skos:related rdf:resource="placeType/%C3%A9l%C3%A9ment%20d%E2%80%99hydrographie"/>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T69-503"/>
        <skos:exactMatch rdf:resource="https://fr.dbpedia.org/page/Fontaine_(bassin)"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/for%C3%AAt">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">forêt</skos:prefLabel>
        <skos:altLabel xml:lang="fr">bois</skos:altLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
        <skos:definition xml:lang="fr">Une forêt est un « vaste couvert dans lequel les végétaux ligneux, feuillus ou résineux prédominent et peuvent
            être exploités par l’homme pour un usage commercial ou constituer un espace de loisirs pour la promenade ou pour la chasse ». (Source :
            Thésaurus de la désignation des œuvres architecturales et des espaces aménagés)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_005-d3m08zmakla--jfj1oesnfl2n">
                <rico:name xml:lang="fr">Blois (forêt)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="https://www.wikidata.org/wiki/Q4421"/>
        <skos:closeMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-1212"/>
        <skos:closeMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb119314375"/>
        <skos:closeMatch rdf:resource="http://fr.dbpedia.org/page/For%C3%AAt"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, exemple(s),
                    relation(s) sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/forteresse">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">forteresse</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20b%C3%A2timent%20militaire"/>
        <skos:definition xml:lang="fr">Une forteresse est un ensemble cohérent de fortifications visant à protéger non seulement le terrain enclos,
            mais aussi le terroir environnant et un territoire situé en arrière (vis-à-vis d’un ennemi) de la forteresse. (Source :
            Wikipédia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d5bknwg382--129urhk67s8b6">
                <rico:name xml:lang="fr">Temple, forteresse du (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-455"/>
        <skos:closeMatch rdf:resource="https://fr.wikipedia.org/wiki/Place_forte"/>
        <skos:closeMatch rdf:resource="http://fr.dbpedia.org/page/Fort"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/fortification">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">fortification</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20b%C3%A2timent%20militaire"/>
        <skos:definition xml:lang="fr">« La fortification est l’art militaire de renforcer une position ou un lieu par des ouvrages de défense en
            prévision de leur éventuelle attaque. Par extension, la fortification désigne ces ouvrages de défense eux-mêmes. ». (source:
            Wikipédia).</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_005-d-7353rnhm1--1q2vtbdhxupup">
                <rico:name xml:lang="fr">Boyard, fort (Charente-Maritime ; fortification)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:related rdf:resource="placeType/poterne"/>
        <skos:related rdf:resource="placeType/chemin%20de%20ronde"/>
        <skos:exactMatch rdf:resource="https://www.wikidata.org/wiki/Q57821"/>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-443"/>
        <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11931504g"/>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/page/Fortification"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, exemple(s),
                    relation(s) d’association avec des concepts du vocabulaire, relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/galerie">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">galerie</skos:prefLabel>
        <skos:altLabel xml:lang="fr">galeries</skos:altLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">« Une galerie est un espace couvert ayant une fonction de lieu de séjour et de lieu de circulation ». (source:
            Wikipédia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_025-d3nz8tthff--w8kr88ye9ygp">
                <rico:name xml:lang="fr">galerie Bergère (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:related rdf:resource="placeType/clo%C3%AEtre"/>
        <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q164419"/>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-1331"/>
        <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb12067143x"/>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/page/Galerie_(architecture)"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) d’association avec des concepts du vocabulaire,
                    relation(s) sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/gare">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">gare</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:narrower rdf:resource="placeType/gare%20d%E2%80%99eau"/>
        <skos:narrower rdf:resource="placeType/gare%20ferroviaire"/>
        <skos:definition xml:lang="fr">"Une gare, dans un réseau de transport en commun, est un lieu destiné à la montée et à la descente des
            voyageurs. Elle se distingue généralement d’un simple arrêt par son envergure et ses équipements." (Source : Wikipédia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3nzukw82f-1wd1a6pu7b09f">
                <rico:name xml:lang="fr">Lyon, gare de (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-1032"/>
        <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb119470471"/>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/page/Gare"/>
        <skos:closeMatch rdf:resource="https://www.wikidata.org/wiki/Q55488"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/gare%20d%E2%80%99eau">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">gare d’eau</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/gare"/>
        <skos:definition xml:lang="fr">Une gare d’eau est un bief ou partie de bief assez large pour permettre à deux bateaux de se croiser ou de se
            doubler ; il permet en outre aux bateaux de stationner ou d’attendre leur tour pour franchir une dénivelée sans gêner la navigation. Il
            peut abriter des fonctions portuaires (chargement, déchargement, stockage). (Source : Thésaurus de la désignation des œuvres
            architecturales et des espaces aménagés)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3nzuj88t2-1hqagqo7fdpg8">
                <rico:name xml:lang="fr">Grenelle, gare d’eau de (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:related rdf:resource="placeType/%C3%A9l%C3%A9ment%20d%E2%80%99hydrographie"/>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-1020"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/gare%20ferroviaire">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">gare ferroviaire</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/gare"/>
        <skos:definition xml:lang="fr">« Une gare ferroviaire est le lieu d’arrêt des trains. Une gare comprend diverses installations qui ont une
            double fonction : permettre la montée et la descente des voyageurs, ou le chargement et le déchargement des marchandises ainsi que pour
            certaines d’entre elles, assurer des fonctions de sécurité dans la circulation des trains ». (source: Wikipédia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3nzuf41xb--6e30qgzk1aln">
                <rico:name xml:lang="fr">Austerlitz, gare d’ (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="https://www.wikidata.org/wiki/Q55488"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, exemple(s),
                    relation(s) sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/gibet">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">gibet</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">Un gibet est une potence ou ensemble de potences où l’on pendait les condamnés à mort. Par extension, le terme
            en est venu à désigner non plus seulement l’instrument, mais aussi l’endroit lui-même, devenu un lieu identifié dans la ville. (Source :
            Thésaurus de la désignation des œuvres architecturales et des espaces aménagés)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3nzulpid9--ter7gt26sv7c">
                <rico:name xml:lang="fr">Montfaucon, gibet de (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-249"/>
        <skos:closeMatch rdf:resource="https://fr.wikipedia.org/wiki/Potence_(pendaison)"/>
        <skos:closeMatch rdf:resource="https://www.wikidata.org/wiki/Q243778"/>
        <skos:closeMatch rdf:resource="http://fr.dbpedia.org/page/Potence_(pendaison)"/>
        <skos:closeMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb144696474"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/gorge">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">gorge</skos:prefLabel>
        <skos:altLabel xml:lang="fr">canyon</skos:altLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
        <skos:definition xml:lang="fr">Une gorge (appelé aussi en anglais canyon, de l’espagnol cañón), est un passage encaissé entre deux reliefs
            résultant de l’érosion hydraulique sur tout type de roche mais préférentiellement sur les sédimentaires. Une gorge peut-être confondue
            avec une clue ou un défilé. (source : Wikipédia).</skos:definition>
        <skos:exactMatch rdf:resource="https://www.wikidata.org/wiki/Q150784"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : relation(s) sémantique(s)
                    vers des concepts d’autres vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/grand%20magasin">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">grand magasin</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/%C3%A9difice%20ou%20local%20commercial"/>
        <skos:definition xml:lang="fr">Un grand magasin est un commerce de détail multi-spécialiste exploité par une société commerciale
            unique.L’assortiment des marchandises proposé est large. Généralement implantée en centre-ville et occupant plusieurs étages d’un
            bâtiment, cette forme de commerce apparaît au cours de la seconde partie du XIXe siècle. (Source : Wikipédia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3nzukrfmb-q066c4of59cw">
                <rico:name xml:lang="fr">Louvre, grands magasins du (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb119344894"/>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/page/Grand_magasin"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/grotte">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">grotte</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
        <skos:definition xml:lang="fr">En géomorphologie, une grotte est une cavité souterraine naturelle comportant au moins une partie horizontale
            accessible (source : Wikipédia).</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_005-d-80zojg4za--1tg4s9rg1p87p">
                <rico:name xml:lang="fr">Pierre Saint-Martin, Gouffre de la (Pyrénées-Atlantiques)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="https://www.wikidata.org/wiki/Q35509"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : exemple(s), relation(s)
                    sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/hameau">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">hameau</skos:prefLabel>
        <skos:altLabel xml:lang="fr">écart</skos:altLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20humaine"/>
        <skos:definition xml:lang="fr">« Un hameau, ou un écart, est un groupe d’habitations en milieu rural, généralement trop petit pour être
            considéré comme un village. L’élément fondateur est très souvent une ferme. » (Source : Wikipédia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_005-d-35nu76u2g-ulv7d2fqbz3o">
                <rico:name xml:lang="fr">Cerneux-Monnots (Bonnétage ; hameau)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q5084"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition,
                    exemple(s)</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/h%C3%B4pital">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">hôpital</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">Un hôpital est un établissement dans lequel sont associés des services de médecine et de chirurgie générales à
            des services relevant des principales spécialités médico-chirurgicales ainsi qu’à des laboratoires. Quelle que soit sa taille, il abrite
            généralement une morgue et un lieu de prière (chapelle, etc.). Les différents services peuvent être répartis dans un ensemble de bâtiments
            ou sous un toit unique. (Source : Thésaurus de la désignation des œuvres architecturales et des espaces aménagés)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3nzufc9vz--8tcoxqity82k">
                <rico:name xml:lang="fr">Baudelocque, hôpital (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="https://www.wikidata.org/wiki/Q16917"/>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-292"/>
        <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11940402g"/>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/page/H%C3%B4pital"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Ajout des données suivantes : définition, exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/hospice">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">hospice</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/lieu%20d%E2%80%99assistance%20ou%20de%20protection%20sociale"/>
        <skos:definition xml:lang="fr">Un hospice est le lieu abritant un établissement destiné à héberger et soigner les personnes indigentes
            (orphelins, vieillards, etc.) (Source : Thésaurus de la désignation des œuvres architecturales et des espaces aménagés)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3nzuhn818-13qjjoykl102a">
                <rico:name xml:lang="fr">Convalescents, hospice des (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-287"/>
        <skos:exactMatch rdf:resource="https://www.wikidata.org/wiki/Q608152"/>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/page/Hospice"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/h%C3%B4tel">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">hôtel</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/%C3%A9difice%20%C3%A0%20usage%20d%E2%80%99habitation"/>
        <skos:definition xml:lang="fr">Dans l’architecture classique, un hôtel est la demeure citadine d’un grand seigneur ou d’un riche particulier
            ou un établissement public, accompagnée généralement de communs, d’une cour et d’un jardin. (Source : Thésaurus de la désignation des
            œuvres architecturales et des espaces aménagés)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3nzug43ld-1mm0rn8yx1p59">
                <rico:name xml:lang="fr">Brienne, hôtel de (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-517"/>
        <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11959153x"/>
        <skos:closeMatch rdf:resource="http://fr.dbpedia.org/page/H%C3%B4tel_particulier"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/h%C3%B4tel%20meubl%C3%A9">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">hôtel meublé</skos:prefLabel>
        <skos:altLabel xml:lang="fr">hôtel garni</skos:altLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/%C3%A9difice%20%C3%A0%20usage%20d%E2%80%99habitation"/>
        <skos:definition xml:lang="fr">Un hôtel meublé, aussi appelé un garni (sens vieilli) est, en France, un établissement offrant des prestations
            hôtelières (draps, téléphone…) mais qui sert en général de résidence principale à ses résidents. C’est néanmoins le plus souvent une
            résidence considérée comme transitoire avant de trouver une résidence permanente indépendante. (Source : Wikipédia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3nzuerfqp-owebv47396dq">
                <rico:name xml:lang="fr">Albe, hôtel garni d’</rico:name>
            </rico:Place>
        </skos:example>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/%C3%AEle">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">île</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
        <skos:definition xml:lang="fr">Une île est une masse de terre entourée d’eau de manière permanente ou parfois de manière temporaire en
            fonction des marées. L’eau baignant les îles peut être celle d’un océan, d’une mer, d’un lac ou d’un cours d’eau. Les îles peuvent être
            temporaires (banc de sable, volcans, etc.) ou permanentes, isolées ou groupées avec d’autres îles et peuvent alors former un archipel. Une
            petite île est parfois désignée sous les termes d’îlet ou d’îlot. Les îles peuvent être reliées à d’autres îles ou à un continent par une
            chaussée, un pont ou un tunnel (source : Wikipédia).</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_005-d-7ru6fjocw-165d9c54ak1ea">
                <rico:name xml:lang="fr">Berder, île de (Lamor-Baden ; île)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="https://www.wikidata.org/wiki/Q23442"/>
        <skos:exactMatch rdf:resource="https://data.bnf.fr/fr/ark:/12148/cb119499428"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, exemple(s),
                    relation(s) sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/impasse">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">impasse</skos:prefLabel>
        <skos:altLabel xml:lang="fr">cul-de-sac</skos:altLabel>
        <skos:altLabel xml:lang="fr">cul-de-sac de la rue</skos:altLabel>
        <skos:altLabel xml:lang="fr">petite impasse</skos:altLabel>
        <skos:altLabel xml:lang="fr">passage du cul-de-sac</skos:altLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/voie"/>
        <skos:definition xml:lang="fr">« Une impasse, aussi appelée cul-de-sac ou voie sans issue, est une voie aérienne (rue, ruelle) ou souterraine
            (galerie, tunnel) ne possédant qu’un seul point d’entrée et sortie pour les véhicules, et qui nécessite par conséquent de faire un
            demi-tour ou une marche arrière pour pouvoir en sortir ». (source: Wikipédia).</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_025-d3nz8fwqei--x30t2c3oz45k">
                <rico:name xml:lang="fr">impasse Alexandre Dumas (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q12731"/>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-68"/>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Impasse"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/institut%20culturel">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">institut culturel</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">Un lieu abritant une organisation qui œuvre à la préservation ou à la promotion de la culture. (Source :
            Wikipédia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3nzujngz4-1mdj6j0eyxsw3">
                <rico:name xml:lang="fr">Irlandais, institut culturel</rico:name>
            </rico:Place>
        </skos:example>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/institut%20national">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">institut national</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">Un institut national est une organisation publique d’envergure nationale, généralement placée sous la tutelle
            de l’État, qui exerce des missions de recherche, de formation, de conservation, de normalisation ou de diffusion des savoirs dans un
            domaine spécifique. Il constitue une référence scientifique, culturelle ou technique reconnue au niveau national et, parfois, à l’échelle
            internationale.</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3m0cugtjc1--1hokukoerkozk">
                <rico:name xml:lang="fr">Jeunes sourds, institut national de (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/jardin">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">jardin</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:narrower rdf:resource="placeType/parc"/>
        <skos:definition xml:lang="fr">Un jardin est un "espace organisé, public ou privé, comportant des végétaux en pleine terre ou hors sol."
            (Source : Les vocabulaires du Ministère de la Culture et de la Communication)"</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3nzuqar5w--juhxp1bfs0yz">
                <rico:name xml:lang="fr">Tuileries, jardin des (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-1116"/>
        <skos:exactMatch rdf:resource="http://dbpedia.org/ontology/Garden"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/lac">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">lac</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20d%E2%80%99hydrographie"/>
        <skos:definition xml:lang="fr">Un lac est une étendue d’eau terrestre : bassin, étang, lac, mare (source : vocabulaire IGN).</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_005-d-7b2wo51gg-flwr84h4ngl4">
                <rico:name xml:lang="fr">Bosméléac, lac de (Côtes-d’Armor ; lac)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://data.ign.fr/id/codes/topo/typedezai/Lac"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Ajout des données suivantes : définition, exemple(s)</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/lieu-dit">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">lieu-dit</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20humaine"/>
        <skos:definition xml:lang="fr">Un lieu-dit est un endroit de faible étendue auquel est associé un nom propre. Contrairement au hameau, un
            lieu-dit n’est pas forcément un lieu habité, il peut être un champ, un carrefour ou encore un bois. Il s’agit en fait d’un lieu marqué
            dans le paysage par un établissement ou un aménagement humain, sélectionné parmi l’ensemble des microtoponymes dans la nomenclature, la
            cartographie et la signalétique officielle des lieux d’un pays.</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_005-d-57bir2eed--19uuyuyhzy62n">
                <rico:name xml:lang="fr">Becléguer (Lannion ; lieu-dit)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition,
                    exemple(s)</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/lieu%20d%E2%80%99assistance%20ou%20de%20protection%20sociale">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">lieu d’assistance ou de protection sociale</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:narrower rdf:resource="placeType/asile-ouvroir"/>
        <skos:narrower rdf:resource="placeType/hospice"/>
        <skos:narrower rdf:resource="placeType/cit%C3%A9%20sanitaire"/>
        <skos:definition xml:lang="fr">Un lieu d’assistance ou de protection sociale est une "Construction ou groupe de constructions abritant des
            activités d’assistance privée, religieuse ou civile, ou de protection sociale." (Source : Thésaurus de la désignation des œuvres
            architecturales et des espaces aménagés)</skos:definition>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/lieu%20d%E2%80%99enseignement">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">lieu d’enseignement</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:narrower rdf:resource="placeType/coll%C3%A8ge"/>
        <skos:narrower rdf:resource="placeType/conservatoire%20national"/>
        <skos:narrower rdf:resource="placeType/%C3%A9cole"/>
        <skos:narrower rdf:resource="placeType/facult%C3%A9"/>
        <skos:narrower rdf:resource="placeType/lyc%C3%A9e"/>
        <skos:narrower rdf:resource="placeType/noviciat"/>
        <skos:narrower rdf:resource="placeType/s%C3%A9minaire"/>
        <skos:definition xml:lang="fr">Un lieu d’enseignement est un lieu occupé par une organisation qui offre un service d’éducation, sous forme
            d’objectif principal ou auxiliaire. Il peut s’agir d’un établissement d’enseignement public ou d’une entreprise privée, d’une organisation
            non-gouvernementale ou d’un organisme public dont l’objet n’est pas l’enseignement. (Source : Réseau Inter-agences pour l’Éducation en
            Situations d’Urgence )</skos:definition>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T1-662"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/lyc%C3%A9e">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">lycée</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/lieu%20d%E2%80%99enseignement"/>
        <skos:definition xml:lang="fr">Un lycée est le lieu abritant un "Établissement d’enseignement général ou technique, dispensant l’enseignement
            du second cycle." (Source : Les vocabulaires du Ministère de la Culture et de la Communication)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3m0cugar3r-1lgo6pkzgsbir">
                <rico:name xml:lang="fr">Henri IV, lycée (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://data.bnf.fr/ark:/12148/cb11963528k"/>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Lyc%C3%A9e_en_France"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/maison">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">maison</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">Le mot "maison" désigne un lieu bâti identifié, souvent porteur d’un rôle institutionnel, religieux, social ou
            symbolique, et nommé en fonction de sa fonction, de ses occupants ou d’une enseigne.</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3m0cugg7zp--1s7fmc2ryxhen">
                <rico:name xml:lang="fr">Orphelines de la Légion d’honneur, maison des (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/maison%20de%20sant%C3%A9">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">maison de santé</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">Une maison de santé est un lieu de soins de premier recours, doté de la personnalité morale, réunissant de
            manière organisée plusieurs professionnels médicaux, auxiliaires médicaux et, le cas échéant, pharmaciens, afin d’assurer une prise en
            charge coordonnée des patients.(Souce Sante.gouv.fr)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3m0cufzdvo--yjzyoqlv32yq">
                <rico:name xml:lang="fr">maison de santé de la Butte Montmartre</rico:name>
            </rico:Place>
        </skos:example>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/manoir">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">manoir</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/%C3%A9difice%20%C3%A0%20usage%20d%E2%80%99habitation"/>
        <skos:definition xml:lang="fr">« Un manoir est avant tout le siège d’un domaine d’origine seigneuriale. C’est un terme utilisé majoritairement
            dans le nord de la France. C’est la résidence ou la demeure d’un noble, son logis seigneurial. La maison forte (manoir fortifié) n’est ni
            plus ni moins qu’un manoir qui arbore des éléments défensifs (fossé, plate-forme ou talus) à la différence de la « maison manoriale »
            (manoir non fortifié) ». (source: Wikipédia).</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_005-d-1g85e564g-1gevlw0qmc7tu">
                <rico:name xml:lang="fr">Chaubuisson, manoir de (Fontenay-Trésigny ; manoir)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="https://www.wikidata.org/wiki/Q2116450"/>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-522"/>
        <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb12139586b"/>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/page/Manoir"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, exemple(s),
                    relation(s) sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/manufacture">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">manufacture</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:narrower rdf:resource="placeType/manufacture%20royale"/>
        <skos:definition xml:lang="fr">"Une manufacture (du latin manufactura, « fait à la main ») est un lieu de fabrication dans lequel des produits
            sont à l’origine fabriqués à la main par des ouvriers et qui sert à désigner aujourd’hui une entreprise dans laquelle les biens sont
            produits directement ou indirectement (robotisation) par l’homme." (Source wikipedia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3nzupkkb1--19j4xyyvk42mj">
                <rico:name xml:lang="fr">Manufacture de la Savonnerie</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb15565552s"/>
        <skos:exactMatch rdf:resource="https://www.wikidata.org/wiki/Q380342"/>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T1-1402"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/manufacture%20royale">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">manufacture royale</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/manufacture"/>
        <skos:definition xml:lang="fr">Une manufacture royale est un lieu de fabrication développé en France aux XVIIe et XVIIIe siècles avec le
            soutien du pouvoir royal (Souce : Wikidata)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3nzuprcja--1eott59jpdcko">
                <rico:name xml:lang="fr">Tabacs, manufacture royale des (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="https://www.wikidata.org/wiki/Q105071173"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/march%C3%A9">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">marché</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">Un marché est un "espace public ou édifice où l’on vend toutes sortes de marchandises, sur des étals fixes ou
            mobiles" (Source : Les vocabulaires du Ministère de la Culture et de la Communication)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3m0cug8410--6cvt8k531pzf">
                <rico:name xml:lang="fr">Saint-Martin, marché (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/page/March%C3%A9"/>
        <skos:exactMatch rdf:resource="http://vocab.getty.edu/aat/300005238"/>
        <skos:closeMatch rdf:resource="http://data.bnf.fr/ark:/12148/cb119344952"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/massif">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">massif</skos:prefLabel>
        <skos:altLabel xml:lang="fr">massif montagneux</skos:altLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
        <skos:definition xml:lang="fr">Un massif est un ensemble de montagnes formant un bloc continu qui suit une ligne de crête, et s’oppose à une
            chaîne de montagnes. Il présente la particularité de former un ensemble de reliefs continus, séparé souvent par des rivières, des vallées,
            entourés d’abîmes ou des reliefs distincts (source : Wikipédia).</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_005-d3ntxq5e6s-3b4l4rx947ol">
                <rico:name xml:lang="fr">Alpes (massif)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="https://www.wikidata.org/wiki/Q1061151"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, exemple(s),
                    relation(s) sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/monast%C3%A8re">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">monastère</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/%C3%A9tablissement%20conventuel"/>
        <skos:definition xml:lang="fr">"Un monastère est un ensemble de bâtiments où vit une communauté religieuse de moines ou de moniales. "(Source
            Wikipedia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3nzum2g6x--ypoc3k7w2mcf">
                <rico:name xml:lang="fr">Notre-Dame-de-Grâce, monastère de (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="https://www.wikidata.org/wiki/Q44613"/>
        <skos:exactMatch rdf:resource="https://dbpedia.org/ontology/Monastery"/>
        <skos:closeMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T1-529"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/montagne">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">montagne</skos:prefLabel>
        <skos:altLabel xml:lang="fr">mont</skos:altLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
        <skos:definition xml:lang="fr">Un mont est une forme topographique de relief positif, à la surface de planètes telluriques, et faisant partie
            d’un ensemble — une chaîne de montagnes — ou formant un relief isolé (source : Wikipédia).</skos:definition>
        <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb119323641"/>
        <skos:closeMatch rdf:resource="http://data.ign.fr/id/codes/topo/typederelief/Montagne"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, relation(s)
                    sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/monument%20comm%C3%A9moratif">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">monument commémoratif</skos:prefLabel>
        <skos:altLabel xml:lang="fr">mémorial</skos:altLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:narrower rdf:resource="placeType/arc%20de%20triomphe"/>
        <skos:narrower rdf:resource="placeType/colonne"/>
        <skos:narrower rdf:resource="placeType/ob%C3%A9lisque"/>
        <skos:definition xml:lang="fr">Un monument commémoratif est un monument érigé en souvenir d’un événement, ou / et, en l’honneur d’une ou
            plusieurs personnes décédées (source : Wikipédia).</skos:definition>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Ajout des données suivantes : définition</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/noviciat">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">noviciat</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/lieu%20d%E2%80%99enseignement"/>
        <skos:definition xml:lang="fr">Un noviciat est un lieu servant à l’éducation des novices d’un ordre religieux chrétien. (Source : Les
            vocabulaires du Ministère de la Culture et de la Communication)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3nzujslhs-1tf8hylsls7r5">
                <rico:name xml:lang="fr">Jésuites, noviciat des (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/ob%C3%A9lisque">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">obélisque</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/monument%20comm%C3%A9moratif"/>
        <skos:definition xml:lang="fr">Un obélisque est un "monument en forme de pyramide élancée, habituellement terminé par un amortissement qui
            remplace la pointe trop fragile que formerait la rencontre des faces. "(Source : Les vocabulaires du Ministère de la Culture et de la
            Communication)</skos:definition>
        <skos:scopeNote xml:lang="fr">L’obélisque se distingue de la pyramide par sa hauteur qui est supérieure à trois fois la moitié de sa
            base.</skos:scopeNote>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3nzuksfu0-1anzqi7m6jvxp">
                <rico:name xml:lang="fr">Obélisque de Louxor</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-192"/>
        <skos:exactMatch rdf:resource="http://data.bnf.fr/ark:/12148/cb119780487"/>
        <skos:exactMatch rdf:resource="http://vocab.getty.edu/aat/300007021"/>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Ob%C3%A9lisque"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/observatoire">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">observatoire</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">Un observatoie est un lieu abritant les services d’un établissement de recherche et l’instrumentation
            nécessaires aux observations, mesures et analyses en astronomie (astrométrie, astrophysique, etc.) et/ou en géophysique (météorologie,
            géomagnétisme, sismologie, etc.). (Source : Les vocabulaires du Ministère de la Culture et de la Communication)</skos:definition>
        <skos:scopeNote xml:lang="fr">Pour étudier l’instrumentation, voir le Thesaurus des objets mobiliers.</skos:scopeNote>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3nzulsvq8-11znz4cr4n6u9">
                <rico:name xml:lang="fr">Montsouris, observatoire de (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-387"/>
        <skos:exactMatch rdf:resource="http://vocab.getty.edu/aat/300007680"/>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Observatoire_astronomique"/>
        <skos:closeMatch rdf:resource="http://data.bnf.fr/ark:/12148/cb11981276j"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/orangerie">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">orangerie</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">Une orangerie est un bâtiment ou une pièce chauffée où l’on remise l’hiver les orangers et autres arbres et
            plantes en pot pour les protéger du gel.</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3nzuqbmmw--ec855ok25fd6">
                <rico:name xml:lang="fr">Orangerie des Tuileries</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-1165"/>
        <skos:exactMatch rdf:resource="http://vocab.getty.edu/aat/300006804"/>
        <skos:exactMatch rdf:resource="http://data.bnf.fr/ark:/12148/cb12080670x"/>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Orangerie"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/oratoire">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">oratoire</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/%C3%A9dicule%20religieux"/>
        <skos:definition xml:lang="fr">Un oratoire est un "Petit édifice ou édicule où l’on se retire pour faire oraison : contrairement à la chapelle
            l’oratoire n’a pas d’autel consacré. Il peut aussi consister en une peinture ou une sculpture placée dans une niche, sous un dais ou sur
            un support spécifique." (Source : Les vocabulaires du Ministère de la Culture et de la Communication)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d5bknx6p64--8gwd05y7ujsi">
                <rico:name xml:lang="fr">Oratoire du Louvre</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/resource/ark:/67717/T96-119"/>
        <skos:exactMatch rdf:resource="http://vocab.getty.edu/aat/300007459"/>
        <skos:exactMatch rdf:resource="http://data.bnf.fr/ark:/12148/cb126524363"/>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Oratoire_%28%C3%A9difice_religieux%29"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/ouvrage%20li%C3%A9%20%C3%A0%20l%E2%80%99alimentation%20en%20eau">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">ouvrage lié à l’alimentation en eau</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:narrower rdf:resource="placeType/fontaine"/>
        <skos:narrower rdf:resource="placeType/pompe%20%C3%A0%20eau"/>
        <skos:narrower rdf:resource="placeType/pompe%20%C3%A0%20feu"/>
        <skos:definition xml:lang="fr">Un "Aménagement ou mobilier permettant de recueillir ou de faire circuler l’eau."(Source : Thésaurus de la
            désignation des objets mobiliers)</skos:definition>
        <skos:related rdf:resource="placeType/%C3%A9l%C3%A9ment%20d%E2%80%99hydrographie"/>
        <skos:closeMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb119421860"/>
        <skos:closeMatch rdf:resource="http://fr.dbpedia.org/page/Adduction_d’eau"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/palais">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">palais</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">"Un palais peut être : le lieu de résidence urbaine d’un personnage important, vivant un train de vie princier
            ou fastueux ; le siège d’une institution publique, dans lequel se déroule l’exercice du pouvoir; au figuré, une exagération flatteuse pour
            un manoir ou une grande propriété." (Source : Wikipédia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3nzumefyi-l5d82y9cbl8v">
                <rico:name xml:lang="fr">Orsay, palais d’ (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-523"/>
        <skos:exactMatch rdf:resource="http://vocab.getty.edu/aat/300005734"/>
        <skos:exactMatch rdf:resource="http://data.bnf.fr/ark:/12148/cb11937594q"/>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Palais"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/parc">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">parc</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/jardin"/>
        <skos:definition xml:lang="fr">Un parc est un "jardin clos de grande superficie, public ou privé, en général d’agrément, présentant un
            important couvert. On nomme parc ouvert celui dont les limites ne sont pas closes. "(Source : Les vocabulaires du Ministère de la Culture
            et de la Communication)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3nzult7l1--eq5dswmvk0y8">
                <rico:name xml:lang="fr">Montsouris, parc (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-1134"/>
        <skos:exactMatch rdf:resource="http://data.bnf.fr/ark:/12148/cb11933025j"/>
        <skos:exactMatch rdf:resource="http://vocab.getty.edu/aat/300254248"/>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Parc"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/parc%20industriel">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">parc industriel</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">« Un parc industriel, aussi appelé zone industrielle ou site industriel, est une zone d’activité prévue pour un
            usage industriel ». (source: Wikipédia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_005-d-1g85e4q88--1dt4ywffcrc53">
                <rico:name xml:lang="fr">Bataville (Moussey ; parc industriel)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="https://www.wikidata.org/wiki/Q1662100"/>
        <skos:closeMatch rdf:resource="http://data.ign.fr/id/codes/topo/typedezai/ZoneIndustrielle"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Ajout des données suivantes : définition, exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/paroisse">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">paroisse</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20humaine"/>
        <skos:narrower rdf:resource="placeType/paroisse%20de%20Paris%20avant%201789"/>
        <skos:definition xml:lang="fr">La paroisse est le territoire de la subdivision de base, dans le christianisme, d’un diocèse de l’Église. La
            paroisse occupe un rôle essentiel dans la vie religieuse, elle est le lieu de culte, de célébration pour les croyants (source :
            Wikipédia).</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_024-d3nyvp4aef--lj9z4juc8apm">
                <rico:name xml:lang="fr">La Madeleine (Paris, France ; paroisse)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="https://www.wikidata.org/wiki/Q102496"/>
        <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11941179g"/>
        <skos:closeMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-96"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, exemple(s),
                    relation(s) sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/paroisse%20de%20Paris%20avant%201789">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">paroisse de Paris avant 1789</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/paroisse"/>
        <skos:definition xml:lang="fr">Les paroisses de Paris, à la fin de l’Ancien Régime, couvrent la zone urbaine du territoire du diocèse de Paris
            selon les déclarations de patrimoine établies par leurs curés en 1790 et les relevés des prestations de serment de leurs prêtres à la
            Constitution civile du clergé les 9 et 16 janvier 1791. Cette organisation est sensiblement modifiée au début de 1791. (Source :
            Wikipédia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_024-d3nyvosba5--16qzzcu3058e5">
                <rico:name xml:lang="fr">Saint-André-des-Arts (Paris, France ; paroisse)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/parvis">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">parvis</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/place"/>
        <skos:definition xml:lang="fr">« Un parvis est l’espace ouvert devant l’entrée d’une église dont le périmètre est délimité par une clôture ».
            (source: Wikipédia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_025-d3nzcry5js-1ev7geaq4hery">
                <rico:name xml:lang="fr">parvis de la Raison (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q283977"/>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-55"/>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/page/Parvis"/>
        <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb123491994"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/passage">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">passage</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/voie"/>
        <skos:definition xml:lang="fr">« Un passage est en construction-architecture, urbanisme et voirie, une voie qui sert de passage entre 2 rues
            ou entre deux bâtiments ». (source : Wikipédia).</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_025-d3nz8dagul-1ve20yu7gwa5g">
                <rico:name xml:lang="fr">passage Abel Leblanc (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q13634881"/>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-69"/>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/page/Passage_(voie)"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/passerelle">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">passerelle</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/pont"/>
        <skos:definition xml:lang="fr">« Une passerelle est, dans le domaine de l’architecture, un pont ou un passage aérien, à l’usage exclusif des
            piétons voire des cyclistes, pouvant par exemple relier deux bâtiments entre eux, enjamber un cours d’eau ou une voie navigable, un axe de
            circulation routière ou ferroviaire, etc ». (source: Wikipédia).</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_025-d3nz9n2kb4-18f8webqcwbdx">
                <rico:name xml:lang="fr">passerelle de Constantine (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q1068842"/>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-1098"/>
        <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb13177898n"/>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/page/Passerelle_(architecture)"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/pavillon">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">pavillon</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">Un pavillon est un bâtiment ou corps de bâtiment caractérisé par un plan sensiblement carré. Un pavillon peut
            être isolé, hors-œuvre, demi-hors-œuvre, dans-œuvre, sur l’angle, dans l’angle. (Source : Les vocabulaires du Ministère de la Culture et
            de la Communication)</skos:definition>
        <skos:scopeNote xml:lang="fr">Le pavillon est une forme architecturale, il ne présente pas de fonction particulière. Pour les édifices connus
            sous le nom de pavillon, réserver ce terme à la désignation complète de l’édifice.</skos:scopeNote>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-1328"/>
        <skos:exactMatch rdf:resource="http://vocab.getty.edu/aat/300002660"/>
        <skos:closeMatch rdf:resource="http://fr.dbpedia.org/resource/Pavillon_%28architecture%29"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/pays">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">pays</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20humaine"/>
        <skos:definition xml:lang="fr">« Un pays est un territoire constituant une entité géographique et humaine qui peut être souveraine, autonome
            en association avec une autre entité souveraine pour sa part, ou bien indépendante de fait mais non reconnue de droit (par le droit
            international et l’ONU. » (Source : Wikipédia).</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_005-d3ntxku8g8--8c7e9zxf15do">
                <rico:name xml:lang="fr">Italie</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="https://www.wikidata.org/wiki/Q6256"/>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T1-1372"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, exemple(s),
                    relation(s) sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/p%C3%A9pini%C3%A8re">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">pépinière</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">"En agriculture, sylviculture, arboriculture ou horticulture, une pépinière est un champ ou une parcelle de
            terre réservée à la multiplication des plantes ligneuses principalement (arbres, arbustes) mais aussi de plantes vivaces, et à leur
            culture jusqu’à ce qu’elles atteignent le stade où elles peuvent être transplantées ou commercialisées." (Source :
            Wikipédia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3m0cugrzh6-r3zowig8uyxo">
                <rico:name xml:lang="fr">Roi, pépinière du (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/p%C3%A9ristyle">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">péristyle</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">« Un péristyle est une galerie de colonnes faisant le tour extérieur (entièrement ou partiellement, sous la
            forme d’un porche) ou intérieur d’un édifice ». (source: Wikipédia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_025-d3nz8s8vj1-in2j4erankss">
                <rico:name xml:lang="fr">péristyle de Beaujolais (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q725453"/>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-1255"/>
        <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb133252217"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/petite%20%C3%A9curie">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">petite écurie</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">Sous l’Ancien Régime, une petite écurie est un lieu d’assurer le service ordinaire des montures et des voitures
            royales (chevaux d’attelage, carrosses, véhicules de parade) et accueillait également une école de pages, réservée à la noblesse ancienne.
            (Source : Wikipédia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3nzunr4o7--3ghw1db46a95">
                <rico:name xml:lang="fr">Roi, petites écuries du (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/phare">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">phare</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">Un phare est un « ouvrage, généralement en forme de tour, construit sur un point de la côte, à l’extrémité
            d’une jetée ou sur une île, et portant un signal lumineux de forte intensité servant à guider les navires.». (Source : Thésaurus de la
            désignation des œuvres architecturales et des espaces aménagés)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_005-d-6l8o47280--dx1zhzxfh9om">
                <rico:name xml:lang="fr">Phare des Baleines (Saint-Clément-des-Baleines ; phare)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="https://www.wikidata.org/wiki/Q39715"/>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-1039"/>
        <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb119330900"/>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/page/Phare"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Ajout des données suivantes : définition, exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/pic">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">pic</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
        <skos:definition xml:lang="fr">Un pic est un sommet montagneux assez pointu (source : Wikipédia).</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_005-d-1g86cbsqw--1kutj8qyj7hcl">
                <rico:name xml:lang="fr">Grand pic de Belledonne (Isère ; pic)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://data.ign.fr/id/codes/topo/typederelief/Pic"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition,
                    exemple(s)</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/pilier">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">pilier</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">Un pilier est un élément architectural vertical, de plan généralement massif (carré, cylindrique, polygonal),
            servant de support à une construction. Par extension, le terme désignait les arcades et galeries marchandes établies autour du marché.
            (Source : Wikipédia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3m0cugoiot--148vdz9oo8tir">
                <rico:name xml:lang="fr">Tonnellerie, piliers de la (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/pilori">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">pilori</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:definition xml:lang="fr">Un pilori est un poteau ou un dispositif vertical auquel un condamné est attaché temporairement, à l’aide de
            cordes ou d’un carcan, pour être vu et raillé par la foule. Les formes de ce support d’exposition varient, depuis le poteau en bois
            initialement élevé sur la place du marché ou le pan de mur, jusqu’à l’intégration progressive du carcan puis la transformation du poteau
            en pilori charpenté, en pilier de pierre ou en tour maçonnée. Les piloris présentent, malgré leur diversité, une caractéristique commune,
            celle de leur implantation dans un lieu public (place, carrefour, pont, porte de la ville) ancré dans le paysage urbain, choisi pour
            maximiser la publicité de ce supplice. Par extension, le terme en est venu à désigner non plus seulement l’instrument, mais aussi
            l’endroit lui-même, devenu un lieu identifié dans la ville.(Source : Wikipédia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3nzujck84-gbxmftxf2o7n">
                <rico:name xml:lang="fr">Halles, pilori des (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-251"/>
        <skos:exactMatch rdf:resource="http://data.bnf.fr/ark:/12148/cb12173120p"/>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/resource/Pilori"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Concept ajouté.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/place">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">place</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/am%C3%A9nagement%20ou%20construction"/>
        <skos:narrower rdf:resource="placeType/esplanade"/>
        <skos:narrower rdf:resource="placeType/parvis"/>
        <skos:definition xml:lang="fr">« Une place est un espace public non bâti, desservi par des voies de communication ; elle peut être affectée
            aux piétons ou aux véhicules ». (source: Wikipédia).</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_025-d3nz8e4gsw--1c8m8o4k6ocz3">
                <rico:name xml:lang="fr">place Adolphe Chérioux (Paris, France)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q174782"/>
        <skos:exactMatch rdf:resource="http://data.culture.fr/thesaurus/page/ark:/67717/T96-51"/>
        <skos:exactMatch rdf:resource="http://fr.dbpedia.org/page/Place"/>
        <skos:exactMatch rdf:resource="https://data.bnf.fr/ark:/12148/cb11954989x"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Ajout des données suivantes : exemple(s), relation(s) sémantique(s) vers des concepts d’autres
                    vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/plage">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">plage</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
        <skos:definition xml:lang="fr">« Une plage est une berge ou un rivage en pente douce ou très douce correspondant à une étendue de sable, de
            gravier ou de galets qui se poursuit sous le niveau de l’eau (définition qui prend en compte les plages maritimes le long des mers et des
            océans, et les plages continentales le long des cours d’eau ou en bordures de plan d’eau) ». (source: Wikipédia)</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_005-d-5hh2vt4x5--1hnq9xzkcmqwf">
                <rico:name xml:lang="fr">Bréhec, plage de (Plouha ; plage)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:exactMatch rdf:resource="https://www.wikidata.org/wiki/Q40080"/>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition, exemple(s),
                    relation(s) sémantique(s) vers des concepts d’autres vocabulaires.</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/plateau">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">plateau</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
        <skos:definition xml:lang="fr">Un plateau est une zone géographique où les cours d’eau sont encaissés, par opposition aux plaines où les cours
            d’eau coulent à fleur de sol. Le relief y est peu marqué, ce qui différencie un plateau d’une montagne (source :
            Wikipédia).</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_005-d-9hudi4z2v-1o9i0wl4y057j">
                <rico:name xml:lang="fr">Gergovie, plateau de (Puy-de-Dôme ; plateau)</rico:name>
            </rico:Place>
        </skos:example>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition,
                    exemple(s)</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/pointe">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">pointe</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/%C3%A9l%C3%A9ment%20de%20g%C3%A9ographie%20physique"/>
        <skos:definition xml:lang="fr">« Un cap ou une pointe est une avancée des terres dans une étendue d’eau et constituant une proéminence du
            littoral ». (source: Wikipédia)</skos:definition>
        <skos:changeNote>
            <rdf:Description>
                <rdf:value xml:lang="fr">Correction de la relation vers le concept générique. Ajout des données suivantes : définition</rdf:value>
                <dc:date>2026-02-23</dc:date>
            </rdf:Description>
        </skos:changeNote>
    </skos:Concept>
    <skos:Concept rdf:about="placeType/pompe%20%C3%A0%20eau">
        <rdf:type rdf:resource="https://www.ica.org/standards/RiC/ontology#PlaceType"/>
        <skos:inScheme rdf:resource="placeTypes"/>
        <skos:prefLabel xml:lang="fr">pompe à eau</skos:prefLabel>
        <iso-thes:status xml:lang="fr">candidat</iso-thes:status>
        <skos:broader rdf:resource="placeType/ouvrage%20li%C3%A9%20%C3%A0%20l%E2%80%99alimentation%20en%20eau"/>
        <skos:definition xml:lang="fr">Une pompe à eau est un édifice construit afin de prélever l’eau pour alimenter des
            résidences.</skos:definition>
        <skos:example>
            <rico:Place rdf:about="https://rdf.archives-nationales.culture.gouv.fr/place/FRAN_RI_026-d3nzupif4x--xbjsjbtds6cd">
